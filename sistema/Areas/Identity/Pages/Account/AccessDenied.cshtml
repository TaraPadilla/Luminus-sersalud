@page
@model AccessDeniedModel
@{
    ViewData["Title"] = "Acceso denegado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center p-5">
                    <h1 class="h3 mb-3">Acceso denegado</h1>
                    <p class="text-muted mb-4">
                        No tiene permisos para acceder a este recurso.
                    </p>
                    <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Volver al inicio</a>
                    <a class="btn btn-outline-secondary ml-2" asp-area="Identity" asp-page="/Account/Login">Iniciar sesión</a>
                </div>
            </div>
        </div>
    </div>
</div>
