@page
@model LoginModel
@inject Microsoft.Extensions.Configuration.IConfiguration Config

@{
    ViewData["Title"] = "Log in";
    Layout = "_LoginLayout";
    var clienteLogin = Config["Cliente"] ?? "";
    bool esSerSaludLogin = farmamest.Utilidades.SerSaludUiHelper.EsSerSalud(clienteLogin);
    var nombreEmpresaLogin = Config["EstablecimientoNombreEmpresa"] ?? (esSerSaludLogin ? "SerSalud" : "AVM Enterprises S.A.");
    var logoUrl = Config["ImagenLogoBase64"];
    if (string.IsNullOrWhiteSpace(logoUrl))
    {
        var logoFile = clienteLogin switch
        {
            "HNPB" => "logoHPB",
            _ when farmamest.Utilidades.SerSaludUiHelper.EsSerSalud(clienteLogin) => "logoSS",
            _ when !string.IsNullOrWhiteSpace(clienteLogin) => $"logo{clienteLogin}",
            _ => null
        };
        logoUrl = logoFile != null
            ? $"/assets/images/logos/{logoFile}.png"
            : "/assets/images/farm.png";
    }
}

<style>
    /* Fondo general del login (claro y sutil) */
    .login-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        /* centra card + footer como bloque */
        background: linear-gradient(135deg, #e7edf7 0%, #f5f7fb 55%, #e9eef6 100%);
    }

    .login-wrapper {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 2.5rem 1rem 1rem;
        /* bottom menor para acercar al footer */
    }

    /* Tarjeta de login */
    .card-signin {
        border: none;
        border-radius: 1.25rem;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.25);
        background: #ffffff;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .card-signin:hover {
        transform: translateY(-3px);
        box-shadow: 0 22px 55px rgba(15, 23, 42, 0.3);
    }

    .card-signin .card-body {
        padding: 2.3rem 2.4rem;
    }

    @@media (max-width: 576px) {
        .card-signin .card-body {
            padding: 2rem 1.6rem;
        }
    }

    /* Logo */
    .login-logo {
        margin-bottom: 0.75rem;
    }

    /* Título principal más grande / protagonista */
    .login-title {
        font-size: 1.5rem;
        font-weight: 700;
        text-align: center;
        color: #111827;
        margin-bottom: 0.35rem;
    }

    .login-subtitle {
        font-size: 0.95rem;
        color: #6b7280;
        margin-bottom: 1.8rem;
        text-align: center;
    }

    /* Labels e inputs formales */
    .login-label {
        font-size: 0.9rem;
        font-weight: 600;
        color: #374151;
        margin-bottom: 0.35rem;
    }

    .login-input {
        border-radius: 0.7rem;
        padding: 0.75rem 0.9rem;
        border: 1px solid #d1d5db;
        background-color: #f9fafb;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
    }

    .login-input:focus {
        background-color: #ffffff;
        border-color: #2563eb;
        box-shadow: 0 0 0 0.16rem rgba(37, 99, 235, 0.25);
    }

    /* Grupo del input de contraseña + ojo (un solo control visual) */
    .login-input-group {
        position: relative;
    }

    .login-input-group .form-control {
        border-radius: 0.7rem 0 0 0.7rem;
        border-right: none;
    }

    .login-input-group .input-group-text {
        border-radius: 0 0.7rem 0.7rem 0;
        border: 1px solid #d1d5db;
        border-left: none;
        background-color: #f9fafb;
        color: #6b7280;
        transition: background-color 0.18s ease, color 0.18s ease, border-color 0.18s ease;
    }

    .login-input-group .input-group-text:hover {
        background-color: #e5edff;
        color: #2563eb;
        cursor: pointer;
    }

    /* Sombra/borde para todo el grupo cuando algo está en focus */
    .login-input-group:focus-within .form-control {
        background-color: #ffffff;
        border-color: #2563eb;
        box-shadow: 0 0 0 0.16rem rgba(37, 99, 235, 0.25);
    }

    .login-input-group:focus-within .input-group-text {
        background-color: #ffffff;
        border-color: #2563eb;
    }

    /* Alinear visualmente el borde derecho del input con el ojo */
    .login-input-group .form-control:focus {
        box-shadow: none;
    }

    /* Checkbox */
    .form-check-label {
        font-size: 0.9rem;
        color: #374151;
    }

    /* Botones a todo el ancho del card, mismo tamaño base */
    .btn-login-primary,
    .btn-login-secondary {
        width: 100%;
        border-radius: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #ffffff !important;
        border: none;
        padding: 0.8rem 1rem;
        /* altura base igual en ambos */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s ease, box-shadow 0.2s ease, transform 0.15s ease;
    }

    .btn-login-primary {
        background-color: #0f172a;
    }

    .btn-login-primary:hover {
        background-color: #111827;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.55);
        transform: translateY(-1px);
    }

    /* Botón de huella con padding un poco menor para no crecer de más */
    .btn-login-secondary {
        background-color: #2563eb;
        padding: 0.65rem 1rem;
    }

    .btn-login-secondary:hover {
        background-color: #1d4ed8;
        box-shadow: 0 10px 30px rgba(37, 99, 235, 0.5);
        transform: translateY(-1px);
    }

    /* Huella más grande y visible pero sin aumentar la altura del botón */
    .btn-login-secondary i {
        margin-right: 0.5rem;
        font-size: 1.4rem;
        line-height: 1;
        vertical-align: middle;
    }

    /* Mensajes de validación */
    #mensajeLogin {
        font-size: 0.9rem;
    }

    /* Footer dentro de login-page, cerca del card y sin scroll extra */
    .login-footer-global {
        margin-top: 0.5rem;
        background-color: transparent;
        padding: 0.25rem 1.5rem 0.75rem;
        text-align: center;
        font-size: 0.8rem;
        color: #4b5563;
    }
</style>

<div class="login-page">
    <div class="login-wrapper">
        <div class="container">
            <div class="row justify-content-center">
                <!-- Card centrado y ancho cómodo -->
                <div class="col-12 col-md-8 col-lg-6 col-xl-5">
                    <div class="card card-signin my-3">
                        <div class="card-body">
                            <h5 class="card-title text-center login-logo">
                                <img src="@logoUrl" width="230" class="img-fluid" alt="Logo" />
                            </h5>

                            <h2 class="login-title">Iniciar Sesión</h2>
                            <p class="login-subtitle">
                                Bienvenido. Ingresa tus credenciales para continuar.
                            </p>

                            <form id="account" class="form-signin" method="post">
                                <div asp-validation-summary="All" class="text-danger mb-3"></div>

                                <!-- Usuario -->
                                <div class="mb-3">
                                    <label for="inputUserame" class="login-label">Usuario</label>
                                    <input type="text" id="inputUserame" class="form-control login-input"
                                           asp-for="Input.Email" placeholder="Usuario" required autofocus />
                                </div>

                                <!-- Contraseña con input-group (un solo control visual) -->
                                <div class="mb-3">
                                    <label for="inputPassword" class="login-label">Contraseña</label>
                                    <div class="input-group login-input-group">
                                        <input type="password" id="inputPassword" class="form-control login-input"
                                               placeholder="Contraseña" asp-for="Input.Password" required />
                                        <span class="input-group-text bi bi-eye-slash toggle-password"
                                              toggle="#inputPassword"></span>
                                    </div>
                                </div>

                                <!-- Recordarme -->
                                <div class="mb-3 d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe"
                                               id="rememberMe" />
                                        <label class="form-check-label" for="rememberMe">
                                            Recuérdame
                                        </label>
                                    </div>
                                </div>

                                <!-- Botón iniciar sesión -->
                                <div class="mb-3">
                                    <button class="btn btn-lg btn-login-primary" type="submit">
                                        INICIAR SESION
                                    </button>
                                </div>

                                <!-- Botón iniciar sesión con huella -->
                                <hr class="my-3" />

                                <div class="mb-2">
                                    <button id="btnLoginHuella" type="button" class="btn btn-lg btn-login-secondary">
                                        <i class="bi bi-fingerprint"></i> INICIAR SESIÓN CON HUELLA
                                    </button>
                                </div>

                                <div id="mensajeLogin" class="mt-3 text-center fw-semibold text-danger"></div>
                            </form>
                        </div>
                    </div>
                </div> <!-- /col -->
            </div>
        </div>
    </div>

    <footer class="login-footer-global">
        @if (!esSerSaludLogin)
        {
        <p><strong>Integrado con Al Alyssa</strong></p>
        }
        <p>&copy; @DateTime.Now.Year @nombreEmpresaLogin. Todos los derechos reservados.</p>
    </footer>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        (function () {
            const btn = document.getElementById("btnLoginHuella");
            const mensaje = document.getElementById("mensajeLogin");
            const emailInput = document.getElementById("inputUserame");

            if (!btn || !mensaje || !emailInput) return;

            function base64ToUint8Array(base64) {
                const normalized = (base64 || "").replace(/-/g, "+").replace(/_/g, "/");
                const padded = normalized + "=".repeat((4 - (normalized.length % 4)) % 4);
                const raw = atob(padded);
                const arr = new Uint8Array(raw.length);
                for (let i = 0; i < raw.length; i++) arr[i] = raw.charCodeAt(i);
                return arr;
            }

            function arrayBufferToBase64(buffer) {
                const bytes = new Uint8Array(buffer);
                let binary = "";
                for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
                return btoa(binary);
            }

            async function readApiError(response) {
                try {
                    const data = await response.json();
                    return data.errorMessage || data.message || JSON.stringify(data);
                } catch {
                    try { return await response.text(); } catch { return "Error desconocido."; }
                }
            }

            btn.addEventListener("click", async function () {
                mensaje.innerText = "";
                mensaje.classList.remove("text-success");
                mensaje.classList.add("text-danger");

                const email = (emailInput.value || "").trim();
                if (!email) {
                    mensaje.innerText = "Debe ingresar el usuario/correo para iniciar sesión con huella.";
                    emailInput.focus();
                    return;
                }

                if (!window.PublicKeyCredential) {
                    mensaje.innerText = "Este navegador no soporta autenticación con huella (WebAuthn).";
                    return;
                }

                if (!window.isSecureContext) {
                    mensaje.innerText = "La huella requiere HTTPS o localhost como origen seguro.";
                    return;
                }

                btn.disabled = true;

                try {
                    const beginResponse = await fetch(`/api/WebAuthn/BeginLogin?email=${encodeURIComponent(email)}`, {
                        method: "POST",
                        credentials: "include"
                    });

                    if (!beginResponse.ok) {
                        mensaje.innerText = await readApiError(beginResponse);
                        return;
                    }

                    const optionsFromServer = await beginResponse.json();
                    const allowCredentials = Array.isArray(optionsFromServer.allowCredentials)
                        ? optionsFromServer.allowCredentials
                        : [];

                    if (allowCredentials.length === 0) {
                        mensaje.innerText = "Este usuario no tiene huella registrada. Inicie sesión con contraseña y registre su huella.";
                        return;
                    }

                    const publicKeyOptions = {
                        challenge: base64ToUint8Array(optionsFromServer.challenge),
                        timeout: optionsFromServer.timeout,
                        rpId: optionsFromServer.rpId,
                        userVerification: optionsFromServer.userVerification || "required",
                        allowCredentials: allowCredentials.map(function (cred) {
                            return {
                                type: "public-key",
                                id: base64ToUint8Array(cred.id),
                                transports: cred.transports
                            };
                        })
                    };

                    let assertion;
                    try {
                        assertion = await navigator.credentials.get({ publicKey: publicKeyOptions });
                    } catch (webAuthnError) {
                        if (webAuthnError && webAuthnError.name === "NotAllowedError") {
                            mensaje.innerText = "Autenticación cancelada o no completada.";
                            return;
                        }
                        throw webAuthnError;
                    }

                    const assertionResponse = {
                        id: assertion.id,
                        rawId: arrayBufferToBase64(assertion.rawId),
                        type: assertion.type,
                        response: {
                            authenticatorData: arrayBufferToBase64(assertion.response.authenticatorData),
                            clientDataJSON: arrayBufferToBase64(assertion.response.clientDataJSON),
                            signature: arrayBufferToBase64(assertion.response.signature),
                            userHandle: assertion.response.userHandle
                                ? arrayBufferToBase64(assertion.response.userHandle)
                                : null
                        }
                    };

                    const completeResponse = await fetch("/api/WebAuthn/CompleteLogin", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        credentials: "include",
                        body: JSON.stringify(assertionResponse)
                    });

                    if (!completeResponse.ok) {
                        mensaje.innerText = await readApiError(completeResponse);
                        return;
                    }

                    const result = await completeResponse.json();
                    if (result.status === "ok") {
                        window.location.href = "/Home/Index";
                        return;
                    }

                    mensaje.innerText = result.message || "Error desconocido durante autenticación.";
                } catch (error) {
                    console.error("Error de autenticación:", error);
                    mensaje.innerText = (error && error.message) ? error.message : "Error desconocido durante autenticación.";
                } finally {
                    btn.disabled = false;
                }
            });
        })();
    </script>

    <script>
        document.querySelectorAll(".toggle-password").forEach(function (el) {
            el.addEventListener("click", function () {
                const input = document.querySelector(this.getAttribute("toggle"));
                const type = input.getAttribute("type") === "password" ? "text" : "password";
                input.setAttribute("type", type);
                this.classList.toggle("bi-eye");
                this.classList.toggle("bi-eye-slash");
            });
        });
    </script>
}
