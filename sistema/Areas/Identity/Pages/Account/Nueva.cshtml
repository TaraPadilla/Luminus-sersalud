@page
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Register";
    string sufijoLayout = Configuration["Cliente"];
    if (string.IsNullOrWhiteSpace(sufijoLayout))
    {
        Layout = "/Views/Shared/_LayoutSS.cshtml";
    }
    else
    {
        Layout = $"/Views/Shared/_Layout{sufijoLayout}.cshtml";
    }
}
 @await Html.PartialAsync("Register")