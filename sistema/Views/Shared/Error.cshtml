@model ErrorViewModel
@{
    ViewData["Title"] = Model.IsDatabaseError ? "Base de datos no disponible" : "Error";
}

<h1 class="text-danger">@(Model.IsDatabaseError ? "Base de datos no disponible" : "Error")</h1>

@if (Model.ShowMessage)
{
    <p class="text-muted">@Model.Message</p>
}
else if (Model.IsDatabaseError)
{
    <p class="text-muted">
        No se pudo conectar a PostgreSQL. Verifique red, firewall y la cadena de conexión.
    </p>
}
else
{
    <h2 class="text-danger">An error occurred while processing your request.</h2>
}

@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

@if (Model.IsDatabaseError)
{
    <p><a href="javascript:history.back()" class="btn btn-secondary">Volver</a></p>
}
