@* Views/Shared/_ReportStyles.cshtml *@
<style>
  /* Tipografía base */
  body {
    font-family: Arial, Helvetica, sans-serif;
    font-size: 13px;
    color: #1f2937;
    margin: 0;
  }

  h1,
  h2,
  h3,
  h4 {
    color: #0d0e36;
    margin: 0 0 8px 0;
  }

  p {
    margin: 0 0 6px 0;
  }

  hr {
    border: 0;
    border-top: 1px solid #e6e8ef;
    margin: 10px 0;
  }

  /* Tablas básicas (1, 2 o 3 columnas como máximo) */
  table {
    width: 100%;
    border-collapse: collapse;
    margin: 8px 0 12px;
    page-break-inside: auto;
    font-size: 12px;
  }

  thead th {
    background-color: #eef2ff;
    color: #0d0e36;
    font-weight: bold;
    text-align: left;
    border-bottom: 1px solid #e6e8ef;
    padding: 6px 8px;
  }

  tbody th,
  tbody td {
    padding: 6px 8px;
    vertical-align: top;
    border-bottom: 1px solid #e6e8ef;
  }

  tr:last-child td,
  tr:last-child th {
    border-bottom: none;
  }

  /* Paginación para wkhtmltopdf */
  @@page {
    size: Letter;
    margin: 18mm 12mm;
  }

  thead {
    display: table-header-group;
  }

  tfoot {
    display: table-footer-group;
  }

  tr,
  td,
  th {
    page-break-inside: avoid;
  }
</style>