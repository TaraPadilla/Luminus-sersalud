@model IEnumerable<Database.Shared.Models.Ambulancia>
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@{
    ViewData["Title"] = "Lista de Ambulancias";
    ViewData["ImagenLogo"] = Config["ImagenLogoBase64"];
    var tipo = ViewContext.ActionDescriptor.RouteValues["action"] == "ListaIgss" ? "IGSS" : "Privadas";
}

<div class="main-card mb-3 card">
    <div class="card-body text-center">
        <h4 class="mb-4 text-primary"><b>Listado de Ambulancias @tipo</b></h4>

        <table class="table table-striped table-hover text-center">
            <thead class="thead-dark">
                <tr>
                    <th style="width:10%;">ID</th>
                    <th style="width:70%;">Paciente</th>
                    <th style="width:20%;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.NombrePaciente</td>
                        <td>
                            <a asp-action="Detalle" asp-controller="Ambulancias" asp-route-id="@item.Id" class="btn btn-sm btn-info mr-2">
                                <i class="fas fa-eye"></i> Ver más
                            </a>
                            <a asp-action="AmbulanciaPDF" asp-controller="CrearPDF" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                <i class="fas fa-file-pdf"></i> PDF
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
