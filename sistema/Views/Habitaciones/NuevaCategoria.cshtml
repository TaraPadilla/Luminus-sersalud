@{
    ViewData["Title"] = "Categoria - Nueva";
}

@await Html.PartialAsync("_MensajeExito")

<div id="habitacion-categoria-ko-root">
<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12 text-center">
                <span class="h4"><b>Nueva categor&iacute;a</b></span>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_CategoriaForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <button type="button" class="btn btn-primary" data-habitacion-cat-accion="guardar-nuevo">
                    Guardar
                </button>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts
{
<!--JS Vista (depende de knockout)-->
<script type="text/javascript" src="~/ViewModelKo/HabitacionesCategoriaVM.js"></script>
}