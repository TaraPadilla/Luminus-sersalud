            </div>
            <div id="tab-antecedentes">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <div class="form-row">
                            @if (User.IsInRole("CirugiaPlastica"))
                            {
                                <div class="col-md-12">
                                    <h5><b>Datos familiares</b></h5>
                                    <hr>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-12">
                                    <h5><b>Antecedentes familiares</b></h5>
                                    <hr>
                                </div>
                            }

                            <div class="col-md-12">
                                <div class="table-responsive">
                                    <table id="tabla-antecedentes-familiares">
                                        <thead>
                                            <tr>
                                                <th class="text-center">Antecedente</th>
                                                <th class="text-center">Madre</th>
                                                <th class="text-center">Abuela</th>
                                                <th class="text-center">Abuelo</th>
                                                <th class="text-center">Otros</th>
                                                <th class="text-center">Padre</th>
                                                <th class="text-center">Abuela</th>
                                                <th class="text-center">Abuelo</th>
                                                <th class="text-center">Hermanos</th>
                                                <th class="text-center">Otros</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <!--ko foreach: antecedentesFamiliares-->
                                            <tr>
                                                <td data-bind="text: TipoPatologia"></td>
                                                <td><input type="checkbox" class="form-control" data-bind="checked: Madre" /></td>
                                                <td><input type="checkbox" class="form-control" data-bind="checked: AbuelaMaterna" /></td>
                                                <td><input type="checkbox" class="form-control" data-bind="checked: AbueloMaterno" /></td>
                                                <td><input type="checkbox" class="form-control" data-bind="checked: OtrosMaterno" /></td>
                                                <td><input type="checkbox" class="form-control" data-bind="checked: Padre" /></td>
