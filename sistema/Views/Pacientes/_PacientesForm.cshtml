<script>
$(document).ready(function() {
    function calcularEdad() {
        var fechaNacimiento = $('#FechaNacimiento').val();
        if (fechaNacimiento) {
            var hoy = new Date();
            var fechaNacimientoDate = new Date(fechaNacimiento);
            var edad = hoy.getFullYear() - fechaNacimientoDate.getFullYear();
            var m = hoy.getMonth() - fechaNacimientoDate.getMonth();
            if (m < 0 || (m === 0 && hoy.getDate() < fechaNacimientoDate.getDate())) {
                edad--;
            }
            return edad;
        }
        return 0;
    }

    function mostrarOcultarCampos() {
        var edad = calcularEdad();
        if (edad < 13) {
            $('.campos-encargado').show();
        } else {
            $('.campos-encargado').hide();
        }
    }

    $('#FechaNacimiento').change(function() {
        mostrarOcultarCampos();
        $('#Edad').val(calcularEdad());
    });

    mostrarOcultarCampos(); // Llamar al cargar para manejar la carga de datos existentes
});
</script>


<script>




    function abrirModal(json) {

        $("#FormModal").modal("show");
    }

    function agregarNuevaAlergia() {
        // Obtener el valor del input
        var nuevoNombre = document.getElementById('nombreNuevaAlergia').value;

        // Crear una nueva fila para la tabla
        var nuevaFila = document.createElement('tr');

        // Crear las celdas de la fila
        var celdaNombre = document.createElement('td');
        var celdaSelect = document.createElement('td');
        var celdaVacia = document.createElement('td');

        var nombreEnNegrita = document.createElement('b');
        nombreEnNegrita.textContent = nuevoNombre;

        // Agregar contenido a las celdas
        celdaNombre.appendChild(nombreEnNegrita);
        celdaSelect.innerHTML = `
                        <select class="form-control">
                            <option value="">Seleccione</option>
                            <option value="si">Sí</option>
                            <option value="no">No</option>
                            <option value="ns">N/S</option>
                        </select>
                    `;

        // Agregar las celdas a la fila
        nuevaFila.appendChild(celdaNombre);
        nuevaFila.appendChild(celdaSelect);
        nuevaFila.appendChild(celdaVacia);

        // Obtener la referencia al último elemento (última fila) de la tabla
        var ultimaFila = document.getElementById('tabla-alergias').getElementsByTagName('tbody')[0].lastChild;

        // Insertar la nueva fila antes del último elemento (última fila) de la tabla
        document.getElementById('tabla-alergias').getElementsByTagName('tbody')[0].insertBefore(nuevaFila, ultimaFila);

        // Limpiar el input después de agregar la nueva alergia
        document.getElementById('nombreNuevaAlergia').value = "";
    };





</script>

