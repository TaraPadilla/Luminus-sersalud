                <a data-toggle="tab" href="#tab-eg2-8"
                   class="btn-pill btn-wide mr-1 ml-1 btn btn-outline-alternate btn-sm d-none">Declaración de consentimiento</a>
                <a data-toggle="tab" href="#tab-eg2-9"
                   class="btn-pill btn-wide mr-1 ml-1 btn btn-outline-alternate btn-sm d-none">Datos de pago</a>
                <a data-toggle="tab" href="#tab-eg2-6"
                   class="btn-pill btn-wide mr-1 ml-1 btn btn-outline-alternate btn-sm d-none">Neurológicos</a>
                <a data-toggle="tab" href="#tab-historial-membresia"
                   class="btn-pill btn-wide mr-1 ml-1 btn btn-outline-alternate btn-sm d-none">Historial de membresia</a>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="tab-content">
            <div class="tab-pane active" id="tab-eg2-0" role="tabpanel">
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Datos personales</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-4">
                                <b>Fecha de registro</b><br />
                                @{
                                    var fechaRegistro = Model.FechaRegistro == null ? "" : Convert.ToDateTime(Model.FechaRegistro).ToString("yyyy-MM-dd");
                                }
                                @fechaRegistro
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Nombre completo del paciente</b><br />
                                    @Model.Nombre
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Alias del paciente</b><br />
                                    @Model.Alias
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Sexo</b><br />
                                    @Model.sexoText
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Fecha de nacimiento</b><br />
                                    @fechaNacimiento
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Edad</b><br />
                                    @Model.Edad
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <b>Tipo de sangre</b><br />
                                    @Model.TipoDeSangre
                                </div>
                            </div>
                            <div class="col-md-4">
                                <b>Teléfono</b><br />
                                @Model.Telefono
                            </div>
                            <div class="col-md-4">
                                <b>Celular</b><br />
                                @Model.Celular
                            </div>
                            <div class="col-md-4">
                                <b>Email</b><br />
                                @Model.Email
                            </div>
                            <div class="col-md-4">
                                <b>Contraseña</b><br />
                                @Model.Contrasennia
                            </div>
                            <div class="col-md-4">
                                <b>NIT</b><br />
                                @Model.Nit
                            </div>
                            <div class="col-md-4">
                                <b>DPI</b><br />
                                @Model.Dpi
                            </div>
                            <div class="col-md-4">
                                <b>Dirección</b><br />
                                @Model.Direccion
                            </div>
                            <div class="col-md-4">
                                <b>Número de afiliación</b><br />
                                @Model.no_IGGS
                            </div>
                            <div class="col-md-4">
                                <b>¿Está afiliado?</b><br />
                                @{
                                    var estaAfiliado = "Sí";
                                    if (!(bool)Model.esta_Afiliado)
                                    {
                                        estaAfiliado = "No";
                                    }
                                }
                                @estaAfiliado
                            </div>
                            <div class="col-md-4">
                                <b>Seguro EPSS</b><br />
                                @seguroEpss
                            </div>
                            <div class="col-md-4">
                                <b>Código EPSS</b><br />
                                @Model.CodigoEPS
                            </div>
                            <div class="col-md-4">
                                <b>Religion</b><br />
                                @religion
                            </div>
                            <div class="col-md-4">
                                <b>Ocupación</b><br />
                                @ocupacion
                            </div>
                            <div class="col-md-4">
                                <b>Estado civil</b><br />
                                @estadoCivil
                            </div>
                            <div class="col-md-4">
                                <b>Contacto de emergencia</b><br />
                                @contactoEmergencia
                            </div>
                            <div class="col-md-4">
                                <b>Número de contacto de emergencia</b><br />
                                @numeroContactoEmergencia
                            </div>
                            <div class="col-md-4">
                                <b>Nombre del contacto de emergencia</b><br />
                                @nombreContactoEmergencia
                            </div>
                            <div class="col-md-4">
                                <b>Nacionalidad</b><br />
                                @nacionalidad
                            </div>
                            <div class="col-md-4">
                                <b>País de residencia</b><br />
                                @paisResidencia
                            </div>
                            <div class="col-md-4">
                                <b>Departamento de residencia</b><br />
                                @departamentoResidencia
                            </div>
                            <div class="col-md-4">
                                <b>Municipio de residencia</b><br />
                                @municipioResidencia
                            </div>

                            <div class="col-md-4">
                                <b>Tipo de paciente</b><br />
                                @{
                                    var tipoPaciente = Model.TipoPaciente == null ? "-" : Model.TipoPaciente.NombreTipo;
                                }
                                @tipoPaciente
                            </div>
                            <div class="col-md-4">
                                <b>Modalidad de atención</b><br />
                                @{
                                    var modalidadAtencion = "Presencial";
                                    if (Model.ModalidadAtencion == "virtual")
                                    {
                                        modalidadAtencion = "Virtual";
                                    }
                                }
                                @modalidadAtencion
                            </div>
                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Fotografía del paciente</b></h5>
                                <hr>
                            </div>
                            @if (Model.UrlFotografiaPaciente == null
                            || Model.UrlFotografiaPaciente.Trim() == "")
                            {
                                <div class="col-md-11">
                                    <input type="file" class="form-control" id="fotografia-paciente" />
                                    <input type="hidden" id="base-64-fotografia">
                                </div>
                                <div class="col-md-1">
                                    <button class="btn btn-primary" data-bind="click:subirFotografiaPaciente">Subir</button>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-12">
                                    <img src="@Model.UrlFotografiaPaciente" width="300" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Beneficiarios EPSS</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-12">
                                <br>
                                <div class="table-responsive">
                                    <table class="table">
                                        @if (Model.PersonasSeguro == null || Model.PersonasSeguro.Count == 0)
                                        {
                                            <thead>
                                                <tr>
                                                    <th>No hay beneficiarios registrados</th>
                                                </tr>
                                            </thead>
                                        }
                                        else
                                        {
                                            <thead>
                                                <tr>
                                                    <th>Tipo</th>
                                                    <th>Nit</th>
                                                    <th>Nombres</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var beneficiario in Model.PersonasSeguro)
                                                {
                                                    <tr>
                                                        <td>@beneficiario.Tipo</td>
                                                        <td>@beneficiario.Nit</td>
                                                        <td>@beneficiario.Name</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        }
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Datos de IGSS</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-3">
                                <b>Tipo de afiliación</b><br />
                                @igssTipoAfiliacion
                            </div>
                            <div class="col-md-3">
                                <b>Número de afiliación</b><br />
                                @igssNumeroAfiliacion
                            </div>
                            <div class="col-md-3">
                                <b>Cantidad de dependientes</b><br />
                                @igssCantidadDependientes
                            </div>
                            <div class="col-md-3">
                                <b>Parentesco de dependientes</b><br />
                                @igssParentescoDependientes
                            </div>
                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Información de nacimiento</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-3">
                                <b>PAN (Peso al nacer)</b><br />
                                @pesoAlNacer
                            </div>
                            <div class="col-md-3">
                                <b>Talla (estatura del niño)</b><br />
                                @talla
                            </div>
                            <div class="col-md-3">
                                <b>Circunferencia cefálica (CC)</b><br />
                                @circunferenciaCefalica
                            </div>
                            <div class="col-md-3">
                                <b>Tipo de parto</b><br />
                                @tipoParto
                            </div>
                        </div>
                    </div>
                </div>

                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Archivos</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-4">
                                <input placeholder="Nombre de archivo" type="text"
                                       class="form-control" data-bind="value:nombreNuevoArchivo" />
                            </div>
                            <div class="col-md-7">
                                <input type="file" class="form-control" id="nuevo-archivo" />
                                <input type="hidden" id="base-64-nuevo-archivo" />
                            </div>
                            <div class="col-md-1">
                                <button class="btn btn-primary" data-bind="click:subirArchivoPaciente">Subir</button>
                            </div>
                            <div class="col-md-12">
                                <table class="table table-hover">
                                    @if (Model.PacienteArchivos == null || Model.PacienteArchivos.Count == 0)
                                    {
                                        <thead>
                                            <tr>
                                                <th>No hay archivos subidos</th>
                                            </tr>
                                        </thead>
                                    }
                                    else
                                    {
                                        <thead>
                                            <tr>
                                                <th>Nombre</th>
                                                <th>Ruta</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        foreach (var archivo in Model.PacienteArchivos)
                                        {
                                            <tbody>
                                                <tr>
                                                    <td>@archivo.NombreArchivo</td>
                                                    <td>@archivo.UrlArchivo</td>
                                                    <td>
                                                        <a download href="@archivo.UrlArchivo" target="_blank"
                                                   class="btn btn-primary text-light">Descargar</a>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        }
                                    }
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card col-md-12">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Firma</b></h5>
                                <hr>
                            </div>
                            @if (Model.UrlFirmaRegistro == null || Model.UrlFirmaRegistro.Trim() == "")
                            {
                                <div class="col-md-11">
                                    No hay firma de registro
                                </div>
                                <div class="col-md-1">
                                    <button class="btn btn-primary" data-bind="click:abrirModalAgregarFirmaRegistro">Agregar firma</button>
                                </div>
                            }
                            else
                            {
                                <div class="col-md-12">
                                    <img src="@Model.UrlFirmaRegistro" width="300" />
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
            <div class="tab-pane" id="tab-eg2-1" role="tabpanel">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Antecedentes familiares</b></h5>
                                <hr>
                            </div>
                            <div class="col-md-12">
                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th class="text-center">Antecedente</th>
                                                <th class="text-center">Madre</th>
                                                <th class="text-center">Abuela</th>
                                                <th class="text-center">Abuelo</th>
                                                <th class="text-center">Otros</th>
                                                <th class="text-center">Padre</th>
                                                <th class="text-center">Abuela</th>
                                                <th class="text-center">Abuelo</th>
                                                <th class="text-center">Hermanos</th>
                                                <th class="text-center">Otros</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var antecedenteFamiliar in Model.PatologiasPaciente)
                                            {
                                                <tr>
                                                    <td>@antecedenteFamiliar.TipoPatologia.Tipo</td>
                                                    <td>
                                                        @if (antecedenteFamiliar.Madre)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.AbuelaMaterna)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.AbueloMaterno)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.OtrosMaterno)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.Padre)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.AbuelaPaterna)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.AbueloPaterno)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.Hermanos)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
                                                        {
                                                            <label class="badge badge-danger">No</label>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (antecedenteFamiliar.OtrosPaterno)
                                                        {
                                                            <label class="badge badge-success">Si</label>
                                                        }
                                                        else
