                                            <img src="@Model.UrlFirmaPoliticas" width="300" />
                                        </div>
                                        <div class="col-md-1">
                                            <button class="btn btn-primary" data-bind="click:abrirModalAgregarFirmaPoliticasPago">Cambiar firma</button>
                                        </div>
