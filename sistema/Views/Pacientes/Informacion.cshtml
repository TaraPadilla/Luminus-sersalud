                        <div class="main-card mb-3 card col-md-12">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Firma</b></h5>
                                        <hr>
                                    </div>
                                    @if (Model.UrlFirmaConsentimiento == null || Model.UrlFirmaConsentimiento.Trim() == "")
                                    {
                                        <div class="col-md-11">
                                            No hay firma registrada
                                        </div>
                                        <div class="col-md-1">
                                            <button class="btn btn-primary"
                                                    data-bind="click:abrirModalAgregarFirmaDeclaracionConsentimiento">
                                                Agregar firma
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-md-12">
                                            <img src="@Model.UrlFirmaConsentimiento" width="300" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-pane" id="tab-eg2-9" role="tabpanel">
                    <div class="form-row">
                        <div class="col-md-12">
                            <h5><b>Tarjeta de crédito</b></h5>
                            <hr />
                        </div>
                        <div class="col-md-12">
                            <b>Número de tarjeta</b><br />
                            @Html.TextBoxFor(p => p.NumeroTarjetaCredito, new { @class = "form-control", @readonly = "true", @type = "password" })
                        </div>
                        <div class="main-card mb-3 card col-md-12">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Firma</b></h5>
                                        <hr>
                                    </div>
                                    @if (Model.UrlFirmaTarjetaCredito == null || Model.UrlFirmaTarjetaCredito.Trim() == "")
                                    {
                                        <div class="col-md-11">
                                            No hay firma registrada
                                        </div>
                                        <div class="col-md-1">
                                            <button class="btn btn-primary"
                                                    data-bind="click:abrirModalAgregarFirmaTarjetaCredito">
                                                Agregar firma
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-md-12">
                                            <img src="@Model.UrlFirmaTarjetaCredito" width="300" />
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="tab-pane" id="tab-historial-membresia" role="tabpanel">
                    <div class="form-row">
                        <div class="col-md-12 table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Accion</th>
                                        <th>Fecha de recontacto</th>
                                        <th>Observaciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.PacienteHistorial != null && Model.PacienteHistorial.Count() > 0)
                                    {
                                        foreach (var historico in Model.PacienteHistorial)
                                        {
                                            string fechaRecontacto = "-";
                                            if (historico.FechaContacto != null)
                                            {
                                                fechaRecontacto = ((DateTime)historico.FechaContacto)
                                                .ToShortDateString();
                                            }
                                            <tr>
                                                <td>@historico.Fecha</td>
                                                <td>
                                                    @(historico.AccionPaciente!=null
                                        ?historico.AccionPaciente.NombreAccion
                                        :"-")
                                                </td>
                                                <td>
                                                    @fechaRecontacto
                                                </td>
                                                <td>
                                                    @historico.MotivoRetiro
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td>
                                                <i>No hay registros</i>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
    </div>
</div>

