@using Database.Shared.Enumeraciones
@model Database.Shared.Models.Paciente
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    // Leer el valor del appsettings.json. 
    string sufijoLayout = Configuration["Cliente"]; 
    
    // Concatenar para formar el nombre del Layout (ejemplo: "_Layout" + "SS")
    // Si la clave trae el nombre completo (ej. "_LayoutSS"), simplemente asignalo directo.
    Layout = $"_Layout{sufijoLayout}";
    ViewData["Title"] = "Información del paciente";
    var fechaNacimiento = Model.FechaNacimiento == null ? ""
    : Convert.ToDateTime(Model.FechaNacimiento).ToShortDateString();
    var ocupacion = Model.Ocupacion ?? "-";
    var religion = Model.Religion ?? "-";
    var estadoCivil = Model.EstadoCivil ?? "-";
    var contactoEmergencia = Model.ContactoEmergencia ?? "-";
    var numeroContactoEmergencia = Model.NumeroContactoEmergencia ?? "-";
    var nombreContactoEmergencia = Model.NombreContactoEmergencia ?? "-";
    var nacionalidad = Model.Nacionalidad ?? "-";
    var paisResidencia = Model.PaisResidencia ?? "-";
    var departamentoResidencia = Model.DepartamentoResidencia ?? "-";
    var municipioResidencia = Model.MunicipioResidencia ?? "-";

    var seguroEpss = Model.SeguroEpss == null ? "-" : (Model.SeguroEpss.Nombre ?? "-");

    //Información de nacimiento
    var pesoAlNacer = Model.PesoAlNacer ?? "-";
    var talla = Model.Talla ?? "-";
    var circunferenciaCefalica = Model.CircunferenciaCefalica ?? "-";
    var tipoParto = "-";
    if (Model.TipoParto != null)
    {
        if (Model.TipoParto == "normal")
        {
            tipoParto = "Normal";
        }
        else
        {
            tipoParto = "Cesarea";
        }
    }

    //Datos de IGSS
    var igssTipoAfiliacion = Model.IgssTipoAfiliacion ?? "-";
    var igssNumeroAfiliacion = Model.IgssNumeroAfiliacion ?? "-";
    var igssCantidadDependientes = Model.IgssCantidadDependientes ?? 0;
    var igssParentescoDependientes = Model.IgssParentescoDependientes ?? "-";

    //Antecedentes
    var antMedicos = Model.AntecedentesMedicos ?? "-";
    var antQuirurgicos = Model.AntecedentesQuirurgicos ?? "-";
    var antTraumaticos = Model.AntecedentesTraumaticos ?? "-";
    var antAlergias = Model.AntecedentesAlergias ?? "-";
    var antFarmacoDependencias = Model.AntecedentesVicios ?? "-";
    var antMedicamentos = Model.AntecedentesMedicamentos ?? "-";

    //Antecedentes personales
    var antPersonalesObservaciones = Model.AntecedentesPersonalesObservaciones ?? "-";
    var antPersonalesOtros = Model.AntecedentesPersonalesOtros ?? "-";

}
@Html.HiddenFor(m=>m.Id)

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <span class="h4"><b>Información de paciente</b></span><br />
            <span class="h5">@Model.Nombre</span><br />
           @*  @if (Model.EstadoPacienteId == null || Model.EstadoPacienteId == (int)EstadoPacienteEnum.Inactivo)
            {
                <span class="text-danger alert-danger p-1 rounded"><b>Inactivo</b></span>
            }
            else
            {
                <span class="text-success alert-success p-1 rounded"><b>Activo</b></span>
            } *@
            <hr />
        </div>
        <div class="col-md-12">
            <a asp-action="Lista" asp-controller="Pacientes"
               class="enlace-redirigir btn btn-warning text-ligth">
                Lista de pacientes
            </a>
            <a asp-action="Modificar" asp-controller="Pacientes"
               asp-route-id="@Model.Id" class="enlace-redirigir btn btn-primary text-ligth">
                Editar paciente
            </a>
            @* @if (Model.EstadoPacienteId != null &&
            Model.EstadoPacienteId == (int)EstadoPacienteEnum.Activo)
            {
                <a asp-action="CambiarFase" asp-controller="Pacientes"
               asp-route-id="@Model.Id" class="enlace-redirigir btn btn-primary text-ligth">
                    Cambiar fase de tratamiento
                </a>
            } *@
            @if (Model.EstadoPacienteId == (int)EstadoPacienteEnum.Activo)
            {
                <a asp-action="RegistrarRetiro" asp-controller="Pacientes"
               asp-route-pacienteId="@Model.Id" class="enlace-redirigir btn btn-primary text-ligth">
                    Registrar retiro
                </a>
            }
            @if (Model.EstadoPacienteId == (int)EstadoPacienteEnum.Inactivo)
            {
                <a asp-action="RetomarServicio" asp-controller="Pacientes"
               asp-route-pacienteId="@Model.Id" class="enlace-redirigir btn btn-primary text-ligth">
                    Retomar servicio
                </a>
            }
            <a asp-action="PacientesExpedientePDF" asp-controller="CrearPDF"
               asp-route-pacienteId="@Model.Id" class="enlace-redirigir btn btn-danger text-ligth">
                Descargar expediente
            </a>
            <a asp-action="CarneVacunacionJovenes" asp-controller="CrearPDF"
               asp-route-idPaciente="@Model.Id" class="enlace-redirigir btn btn-danger text-ligth">
                Descargar carné de vacunación
            </a>
        </div>
    </div>
</div>


<div class="main-card mb-3 card">
    <div class="card-header">
        <div class="btn-actions-pane-right">
            <div class="nav">
                <a data-toggle="tab" href="#tab-eg2-0"
                   class="btn-pill btn-wide mr-1 ml-1 active btn btn-outline-alternate btn-sm">Datos personales</a>
                <a data-toggle="tab" href="#tab-eg2-1"
                   class="btn-pill btn-wide mr-1 ml-1 btn btn-outline-alternate btn-sm">Antecedentes</a>
                <a data-toggle="tab" href="#tab-eg2-2"
