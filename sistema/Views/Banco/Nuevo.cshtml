@{
    ViewData["Title"] = "Nueva Banco";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>Nuevo Banco</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BancoForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div>
            <button class="btn btn-danger" data-bind="click: cancelarRegistroBanco">
                Cancelar
            </button>
            <button class="btn btn-primary" data-bind="click:registrarBanco">
                Guardar banco
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="~/ViewModelKo/BancoVM.js"></script>
}