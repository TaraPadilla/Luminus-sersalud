@{
    ViewData["Title"] = "Modificar banco";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>Modificar Banco</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_BancoForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div>
            <button class="btn btn-danger" data-bind="click: cancelarRegistroBanco">
                Cancelar
            </button>
            <button class="btn btn-primary" data-bind="click:modificarBanco">
                Guardar Banco
            </button>
        </div>
    </div>
</div>


@section Scripts{
    <script src="~/ViewModelKo/BancoVM.js"></script>
}