@model sistema.Models.DevolucionViewModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config

@Html.HiddenFor(a => a.RequisicionId)
@Html.HiddenFor(a => a.EstadoRequisicion)

@{
    var nombreEmpresaDefault = Config["EstablecimientoNombreEmpresa"];
}

@await Html.PartialAsync("_MensajeExito")

<style>
    #barcodeContainer {
        background-color: #ffffff !important;
        border: 2px solid #333;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
        min-height: 150px;
    }

    #barcodeModalElement {
        width: 100% !important;
        height: auto !important;
        display: block !important;
    }

    #modalBarcode .modal-content {
        box-shadow: none !important;
        border: none !important;
    }

    #modalBarcode .modal-dialog {
        box-shadow: none !important;
    }
</style>

<div class="container-fluid px-0">
    <div class="card shadow-sm mb-3">
        <div class="card-body">

            <!-- Header / Toolbar -->
            <div class="d-flex align-items-center justify-content-between flex-wrap">
                <div class="d-flex align-items-center">
                    <h4 class="mb-0 font-weight-bold">Nueva Devolución</h4>
                </div>
            </div>

            <hr class="my-3" />

            <!-- Datos generales -->
            <div class="mb-4">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0 text-uppercase font-weight-bold text-secondary">Datos generales</h6>
                </div>

                <div class="bg-light border rounded p-3">
                    <div class="form-row">

                        <!-- ENCABEZADO -->
                        <div class="col-12 mb-3">
                            <div class="bg-white border rounded p-3">
                                <div class="d-flex align-items-center justify-content-between flex-wrap mb-2">
                                    <div>
                                        <div class="font-weight-bold">Encabezado de Devolución</div>
                                    </div>
                                    <span class="badge badge-pill badge-info mt-2 mt-sm-0">Formulario</span>
                                </div>

                                <div class="form-row">
                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Dirección</label>
                                        <input asp-for="Direccion" class="form-control form-control-sm" maxlength="35"
                                               value="@nombreEmpresaDefault" placeholder="Nombre del hospital" readonly />
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Departamento</label>
                                        <input asp-for="Departamento" class="form-control form-control-sm"
                                               maxlength="60" placeholder="Automático según usuario"
                                               data-bind="value: departamento" readonly />
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Unidad / Sección</label>
                                        <input asp-for="UnidadSeccion" class="form-control form-control-sm"
                                               maxlength="60" placeholder="Automático según usuario"
                                               data-bind="value: unidad" readonly />
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Otros</label>
                                        <input asp-for="Otros" class="form-control form-control-sm" maxlength="60"
                                               placeholder="Información adicional o complementaria" />
                                    </div>

                                    <div class="col-12">
                                        <hr class="my-2" />
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Número de Devolución</label>
                                        <input asp-for="NumeroDevolucion" type="number"
                                               class="form-control form-control-sm" maxlength="6"
                                               placeholder="Automático según el sistema"
                                               data-bind="value: proximoDevolucion" readonly />
                                        <small class="text-muted">Numérico (6)</small>
                                    </div>

                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Número de Oficio</label>
                                        <input id="NumeroOficio" name="NumeroOficio" type="text"
                                               class="form-control form-control-sm"
                                               placeholder="Automático según el sistema"
                                               readonly />
                                        <small class="text-muted">Formato: 001-2026</small>
                                    </div>

                                    <div class="col-md-9 mb-3">
                                        <label class="mb-1 font-weight-bold">Fecha de la devolución</label>
                                        <input asp-for="FechaSolicitud" type="datetime-local"
                                               class="form-control form-control-sm"
                                               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" readonly />
                                        <small class="text-muted">Formato: dd/mm/aaaa</small>
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-3 mb-3">
                                        <label class="mb-1 font-weight-bold">Nombre del Solicitante</label>
                                        <input asp-for="NombreSolicitante" class="form-control form-control-sm"
                                               maxlength="60" placeholder="Nombre completo de quien devuelve"
                                               value="@User.Identity.Name" readonly />
                                    </div>

                                    <div class="form-group col-md-9">
                                        <label class="font-weight-bold">Firma del Solicitante:</label>

                                        <div data-bind="visible: firmaUrl" class="mb-3">
                                            <div class="border rounded p-2 d-flex align-items-center justify-content-center"
                                                 style="height: 150px; background-color: #f8f9fa; position: relative;">
                                                <img data-bind="attr: { src: firmaUrl }"
                                                     style="max-width: 100%; max-height: 100%; object-fit: contain;" />
                                                <button class="btn btn-sm btn-danger"
                                                        style="position: absolute; top: 5px; right: 5px;"
                                                        data-bind="click: function() { firmaUrl('') }">
                                                    <i class="fa fa-times"></i> Cambiar
                                                </button>
                                            </div>
                                        </div>

                                        <div data-bind="visible: !firmaUrl()" class="accordion" id="accordionFirma">
                                            <div class="card border">
                                                <div class="card-header bg-white p-0">
                                                    <div class="d-flex ml-3">
                                                        <button class="btn btn-light flex-grow-1 rounded-0 border-right"
                                                                type="button" data-toggle="collapse"
                                                                data-target="#colSubir">
                                                            <i class="fa fa-upload mr-2"></i>Subir Imagen
                                                        </button>
                                                        <button class="btn btn-light flex-grow-1 rounded-0"
                                                                type="button" data-toggle="collapse"
                                                                data-target="#colDibujar" onclick="initCanvas()">
                                                            <i class="fa fa-pencil-alt mr-2"></i>Firma Digital
                                                        </button>
                                                    </div>
                                                </div>

                                                <div id="colSubir" class="collapse" data-parent="#accordionFirma">
                                                    <div class="card-body">
                                                        <div class="custom-file">
                                                            <input type="file" class="custom-file-input" id="inputFirma"
                                                                   accept="image/*"
                                                                   data-bind="event: { change: previsualizarFirma }">
                                                            <label class="custom-file-label">Seleccionar archivo...</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <div id="colDibujar" class="collapse" data-parent="#accordionFirma">
                                                    <div class="card-body text-center p-1">
                                                        <canvas id="canvasFirma" width="500" height="250"
                                                                style="border: 2px dashed #ccc; cursor: crosshair; background: #fff; max-width: 100%; touch-action: none;"></canvas>
                                                        <div class="mt-3">
                                                            <button type="button" class="btn btn-secondary" onclick="limpiarCanvas('canvasFirma')">
                                                                <i class="fa fa-eraser"></i> Limpiar
                                                            </button>
                                                            <button type="button" class="btn btn-primary"
                                                                    data-bind="click: guardarFirmaDigital">
                                                                <i class="fa fa-check"></i> Usar esta firma
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Proveedor -->
                                <div class="form-row">
                                    <div class="col-md-4 mb-3">
                                        <label class="mb-1 font-weight-bold">
                                            Proveedor
                                        </label>
                                        <select class="form-control form-control-sm"
                                                data-bind="options: proveedores,
                                                           optionsText: 'Nombre',
                                                           optionsValue: 'Id',
                                                           value: proveedorSeleccionado,
                                                           optionsCaption: 'Seleccione un proveedor...',
                                                          ">
                                        </select>
                                    </div>

                                    <div class="col-md-4 mb-3">
                                        <label class="mb-1 font-weight-bold">Teléfono del proveedor</label>
                                        <input type="text" class="form-control form-control-sm"
                                               
                                               data-bind="value: proveedorTelefono" readonly />
                                    </div>

                                    <div class="col-md-4 mb-3">
                                        <label class="mb-1 font-weight-bold">Dirección del proveedor</label>
                                        <input type="text" class="form-control form-control-sm"
                                               
                                               data-bind="value: proveedorDireccion" readonly />
                                    </div>
                                </div>

                                <!-- Bodega origen -->
                                <div class="form-row">
                                    <div class="col-md-6 mb-3">
                                        <label class="mb-1 font-weight-bold">Ubicación de origen (bodega que devuelve)</label>
                                        @if (Model.RequisicionId == null)
                                        {
                                            <select class="form-control form-control-sm" asp-for="BodegaOrigenId"
                                                    asp-items="Model.ListaBodegasOrigen">
                                                <option value="">Seleccione...</option>
                                            </select>
                                        }
                                    </div>

                                    <div class="col-md-12">
                                        <label class="mb-1 font-weight-bold">Observaciones</label>
                                        @Html.TextAreaFor(a => a.Observaciones, new { @class = "form-control", @rows = "3" })
                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- PRODUCTOS -->
                        <div class="col-12 mb-3">
                            <div class="mb-2">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <h6 class="mb-0 text-uppercase font-weight-bold text-secondary">Productos a devolver</h6>
                                </div>

                                <div class="row">
                                    <!-- Disponibles en bodega -->
                                    <div class="col-12 mb-4">
                                        <div class="border rounded bg-white">
                                            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom flex-wrap">
                                                <div class="mr-2">
                                                    <div class="font-weight-bold">Productos disponibles en bodega</div>
                                                    <small class="text-muted">Listado según la ubicación de origen</small>
                                                </div>
                                            </div>

                                            <div class="table-responsive p-3">
                                                <table class='table table-hover table-sm mb-0' id="tabla-traslado">
                                                    <thead class="thead-light">
                                                        <tr>
                                                            <th>Código / Producto</th>
                                                            <th>Unidad</th>
                                                            <th class="text-nowrap">Stock</th>
                                                            <th class="text-nowrap">Código de barras</th>
                                                            <th class="text-right"></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <!--ko foreach: productosDisponibles-->
                                                        <tr>
                                                            <td data-bind="text: ProductoNombre"></td>
                                                            <td data-bind="text: UnidadMedidaVentaNombre"></td>
                                                            <td data-bind="text: CantidadExistente"></td>
                                                            <td>
                                                                <button class="btn btn-sm btn-outline-info"
                                                                        data-bind="click: $root.dibujarCodigoEnModal">
                                                                    <i class="fas fa-barcode"></i> Generar
                                                                </button>
                                                            </td>
                                                            <td class="text-right">
                                                                <button class="btn btn-primary btn-sm"
                                                                        data-bind="click: $root.anniadirProductoSolicitud">
                                                                    <i class="fas fa-plus"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                        <!--/ko-->
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Productos a devolver (seleccionados) -->
                                    <div class="col-12 mb-4">
                                        <div class="border rounded bg-white">

                                            <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom flex-wrap">
                                                <div class="mr-2">
                                                    <div class="font-weight-bold">Productos a devolver</div>
                                                    <small class="text-muted">Indique la cantidad a devolver por producto</small>
                                                </div>
                                            </div>

                                            <!-- Filtro -->
                                            <div class="p-3 border-bottom bg-light">
                                                <div class="form-row align-items-center">
                                                    <div class="col-md-8 mb-2 mb-md-0">
                                                        <input type="text" class="form-control form-control-sm"
                                                               placeholder="Buscar producto..."
                                                               data-bind="value: searchQuery, valueUpdate: 'input'">
                                                    </div>
                                                    <div class="col-md-4 text-md-right">
                                                        <small class="text-muted"
                                                               data-bind="text: (filteredProductosSolicitados().length || 0) + ' producto(s)'"></small>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Tabla -->
                                            <div class="table-responsive">
                                                <table class='table table-hover table-sm mb-0' id="tabla-trasladados">
                                                    <thead class="thead-light">
                                                        <tr>
                                                            <th style="display: none;">Fecha</th>
                                                            <th style="width: 110px;">Id</th>
                                                            <th>Producto</th>
                                                            <th>Unidad</th>
                                                            <th class="text-nowrap">Stock</th>
                                                            <th class="text-nowrap">Código de barras</th>
                                                            <th class="text-nowrap" style="width: 150px;">Cantidad a devolver</th>
                                                            <th class="text-right" style="width: 120px;">Acciones</th>
                                                        </tr>
                                                    </thead>

                                                    <tbody data-bind="foreach: paginatedProductosSolicitados">
                                                        <tr>
                                                            <td style="display: none;" data-bind="text: FechaTraslado"></td>

                                                            <td data-bind="text: (typeof ProductoId !== 'undefined' ? ProductoId : '')"></td>
                                                            <td data-bind="text: ProductoNombre"></td>
                                                            <td data-bind="text: UnidadMedidaVentaNombre"></td>
                                                            <td data-bind="text: (typeof CantidadExistente !== 'undefined' ? CantidadExistente : '')"></td>

                                                            <td>
                                                                <button class="btn btn-sm btn-outline-info"
                                                                        data-bind="click: $root.dibujarCodigoEnModal">
                                                                    <i class="fas fa-barcode"></i> Generar
                                                                </button>
                                                            </td>

                                                            <td>
                                                                <input class="form-control form-control-sm"
                                                                       type="number" min="1"
                                                                       data-bind="value: CantidadTrasladada,
                                                                                  valueUpdate: 'input',
                                                                                  css: { 'is-invalid': errorStock }" />
                                                                <div class="text-danger" style="font-size: 0.75rem; font-weight: bold;"
                                                                     data-bind="visible: errorStock">
                                                                    <i class="fas fa-exclamation-triangle"></i> Máximo: <span data-bind="text: CantidadExistente"></span>
                                                                </div>
                                                            </td>

                                                            <td class="text-right">
                                                                <div class="btn-group" role="group">
                                                                    <button class="btn btn-danger btn-sm" title="Quitar producto"
                                                                            data-bind="click: $root.quitarProductoSolicitud">
                                                                        <i class="fas fa-trash"></i>
                                                                    </button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            <!-- Paginación -->
                                            <div class="px-3 py-2 border-top bg-white">
                                                <div class="d-flex justify-content-between align-items-center flex-wrap">
                                                    <button class="btn btn-outline-secondary btn-sm mb-2"
                                                            data-bind="click: prevPage, enable: currentPage() > 1">
                                                        Anterior
                                                    </button>
                                                    <small class="text-muted mb-2"
                                                           data-bind="text: 'Página ' + currentPage() + ' de ' + totalPages()"></small>
                                                    <button class="btn btn-outline-secondary btn-sm mb-2"
                                                            data-bind="click: nextPage, enable: currentPage() < totalPages()">
                                                        Siguiente
                                                    </button>
                                                </div>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Acciones -->
                        <div class="col-12">
                            <div class="pt-3 border-top bg-white">
                                <div class="d-flex justify-content-end flex-wrap">
                                    <button class="btn btn-outline-danger mr-2 mb-2"
                                            data-bind="click: cancelarRegistroTraslado">
                                        Cancelar
                                    </button>
                                    <button class="btn btn-primary mb-2"
                                            data-bind="click: guardarDevolucion,
                                                       disable: productosSolicitados().some(p => p.errorStock && p.errorStock())">
                                        Registrar Devolución
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- Modal Barcode -->
<div class="modal fade" id="modalBarcode" tabindex="-1" role="dialog" aria-hidden="true" style="z-index: 9999;">
    <div class="modal-dialog modal-dialog-centered" role="document" style="box-shadow: none !important;">
        <div class="modal-content"
             style="box-shadow: none !important; border: none !important; background: transparent;">
            <div class="modal-header bg-dark text-white" style="border-radius: 8px 8px 0 0;">
                <h5 class="modal-title">Código de barras</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body text-center p-4"
                 style="background-color: white !important; border-radius: 0 0 8px 8px;">
                <div id="barcodeContainer" class="p-3"
                     style="width: 100%; height: 150px; background: #fff !important; display: flex; align-items: center; justify-content: center;">
                    <svg id="barcodeModalElement" style="max-width: 100%; height: 100%;"></svg>
                </div>
                <div class="mt-3">
                    <h6 id="barcodeTextLabel" class="font-weight-bold text-dark mb-0"></h6>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <script type="text/javascript" src="~/ViewModelKo/DevolucionVM.js"></script>
}
