@using sistema.Models
@model Database.Shared.Models.DevolucionNacional

<div class="container-fluid py-2">

    <div class="d-flex align-items-center mb-4 border-bottom pb-3">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mr-3"
             style="width: 45px; height: 45px;">
            <i class="fa fa-file-signature fa-lg"></i>
        </div>
        <div>
            <h5 class="mb-0 text-dark font-weight-bold">Autorización de Devolución</h5>
            <small class="text-muted">N° @Model.NumeroDevolucion — @(Model.SolicitanteNombre ?? "")</small>
        </div>
    </div>

    <input type="hidden" id="idDevolucionAutorizar" value="@Model.Id" />

    <div class="row justify-content-center">
        <div class="col-md-11">

            <!-- Previsualización de firma seleccionada -->
            <div id="contenedorPrevisualizacionDevol" class="mb-4 d-none">
                <label class="text-muted small font-weight-bold text-uppercase mb-2 d-block">Firma Seleccionada</label>
                <div class="card shadow-sm border-success">
                    <div class="card-body p-2 bg-light d-flex align-items-center justify-content-center"
                         style="height: 180px; position: relative;">
                        <img id="imgFirmaPrevDevol" src="" style="max-width: 90%; max-height: 90%; object-fit: contain;" />
                        <button class="btn btn-sm btn-danger shadow"
                                style="position: absolute; top: 10px; right: 10px;"
                                onclick="resetearFirmaDevol()">
                            <i class="fa fa-sync-alt"></i> Cambiar Método
                        </button>
                    </div>
                </div>
            </div>

            <!-- Selector de método de firma -->
            <div id="selectorFirmaDevol">
                <label class="text-muted small font-weight-bold text-uppercase mb-3 d-block text-center">
                    Seleccione un método de firma
                </label>

                <div class="nav nav-pills nav-fill mb-3" role="tablist">
                    <a class="nav-item nav-link border mr-2 py-3"
                       data-toggle="collapse" href="#colSubirDevol" role="tab">
                        <i class="fa fa-upload d-block mb-1 fa-lg"></i> Subir Imagen
                    </a>
                    <a class="nav-item nav-link border mr-2 py-3"
                       data-toggle="collapse" href="#colDibujarDevol" role="tab"
                       onclick="initCanvasDevol()">
                        <i class="fa fa-pencil-alt d-block mb-1 fa-lg"></i> Firma Digital
                    </a>
                    <a class="nav-item nav-link border py-3" href="javascript:void(0)" role="tab">
                        <i class="fa fa-fingerprint d-block mb-1 fa-lg"></i> Huella
                    </a>
                </div>

                <div class="accordion" id="accordionMetodosDevol">

                    <div id="colSubirDevol" class="collapse" data-parent="#accordionMetodosDevol">
                        <div class="card border-top-0 rounded-bottom shadow-sm">
                            <div class="card-body bg-light">
                                <div class="custom-file shadow-sm">
                                    <input type="file" class="custom-file-input" id="inputFirmaDevol"
                                           accept="image/*" onchange="previsualizarArchivoDevol(this)">
                                    <label class="custom-file-label" for="inputFirmaDevol">
                                        Elegir archivo PNG/JPG...
                                    </label>
                                </div>
                                <small class="d-block mt-2 text-center text-uppercase text-muted"
                                       style="letter-spacing: 0.5px; font-size: 0.7rem;">
                                    Formato óptimo:
                                    <span class="badge badge-light border">Fondo Blanco</span> o
                                    <span class="badge badge-light border">Transparente</span>
                                </small>
                            </div>
                        </div>
                    </div>

                    <div id="colDibujarDevol" class="collapse" data-parent="#accordionMetodosDevol">
                        <div class="card border-top-0 rounded-bottom shadow-sm">
                            <div class="card-body p-1 text-center bg-light">
                                <canvas id="canvasFirmaDevol" width="600" height="250"
                                        style="border: 1px dashed #adb5bd; cursor: crosshair; background: #fff;
                                               max-width: 100%; touch-action: none; border-radius: 4px;">
                                </canvas>
                                <div class="p-3">
                                    <button type="button" class="btn btn-outline-secondary btn-sm px-4"
                                            onclick="limpiarCanvasDevol()">
                                        <i class="fa fa-eraser mr-1"></i> Borrar Todo
                                    </button>
                                    <button type="button" class="btn btn-primary btn-sm px-4 ml-2 shadow"
                                            onclick="usarFirmaCanvasDevol()">
                                        <i class="fa fa-check mr-1"></i> Confirmar Trazo
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="mt-5 border-top pt-4 text-right">
                <button type="button" class="btn btn-secondary mr-2" data-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success btn-lg px-5 shadow"
                        id="btnFinalizarAutorizacionDevol"
                        onclick="AutorizarDevolucion()" disabled>
                    <i class="fa fa-check-double mr-2"></i> Finalizar y Autorizar
                </button>
            </div>

        </div>
    </div>

</div>
