@using Database.Shared.Paginacion;
@model sistema.Models.CalendarioLinealViewModel

@{
    ViewData["Title"] = "Calendario";
}

@await Html.PartialAsync("_MensajeExito")

    <div class="main-card mb-3 card">
        <div class="card-body form-row ">
        <form asp-controller="" asp-action="" method="post">
            <div class="text-center col-md-12">
                <h4 ><b>Estado de resultados</b></h4>
                <hr />

            </div>

            <div class="col-md-12 form-row offset-md-3 mt-4 mb-3">
                <div class="col-md-4">
                    <label>Fecha Inicial:</label>
                    <input type="date" class="form-control" id="fechaInicial" name="fechaInicial" >
                </div>

                <div class="col-md-4">
                    <label>Fecha Final:</label>
                    <input type="date" class="form-control" id="fechaFinal" name="fechaFinal">
                </div>

                
                <div class="col-md-4">
                        <label>Año</label>
                        <select class="form-control">
                            <option>Todos</option>
                        </select>
                </div>
            </div>
            <div class="col-md-12">

                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('mes')">
                    <i class="fas fa-list"></i>  &nbsp; Mes actual
                </button>
                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('rango')">
                    <i class="fas fa-list"></i>  &nbsp; Rango de fechas
                </button>

                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('anual')">
                    <i class="fas fa-list"></i>  &nbsp; Anual
                </button>
                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('facturado')">
                    <i class="fas fa-list"></i>  &nbsp; Facturado
                </button>
                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('no-facturado')">
                    <i class="fas fa-list"></i>  &nbsp; No facturado
                </button>

                <button type="button" class="btn btn-danger" onclick="aplicarFiltroEstadoResultados('general')">
                    <i class="fas fa-list"></i>  &nbsp; General
                </button>
            </div>
           

          </form>
        </div>
    </div>

