@section Scripts
{
<script src="~/ViewModelKo/CitaCalendarioLinealVM.js"></script>
<script>
    function formatearFechaLocal(fecha) {
        const y = fecha.getFullYear();
        const m = String(fecha.getMonth() + 1).padStart(2, '0');
        const d = String(fecha.getDate()).padStart(2, '0');
        return y + '-' + m + '-' + d;
    }

    function aplicarFiltroEstadoResultados(tipo) {
        const hoy = new Date();
        const inicio = document.getElementById('fechaInicial');
        const fin = document.getElementById('fechaFinal');

        if (tipo === 'mes') {
            const primerDia = new Date(hoy.getFullYear(), hoy.getMonth(), 1);
            const ultimoDia = new Date(hoy.getFullYear(), hoy.getMonth() + 1, 0);
            inicio.value = formatearFechaLocal(primerDia);
            fin.value = formatearFechaLocal(ultimoDia);
        } else if (tipo === 'anual') {
            inicio.value = hoy.getFullYear() + '-01-01';
            fin.value = hoy.getFullYear() + '-12-31';
        } else if (tipo === 'rango') {
            if (!inicio.value || !fin.value) {
                alert('Seleccione la fecha inicial y final.');
                return;
            }
        }

        document.querySelectorAll('.tab-pane').forEach(function (panel) {
            panel.classList.add('show', 'active');
        });

        if (typeof mensajeEmergente === 'function') {
            mensajeEmergente('Filtro aplicado: ' + tipo.replace('-', ' '));
        }
    }
</script>
}

