                margin: auto;
            }
        }

        .ui-state-active > a {
            font-weight: bolder;
            transform: scale(1.1);
            z-index: 1000;
            /* Sombra: desplazamiento X, Y, Difuminado, Extensión, Color */
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.25) !important;
            transition: box-shadow 0.2s ease, transform 0.2s ease;
        }

        .ui-state-active {
            background-color: #17a2b8 !important;
        }

/* --- BASE MEJORADA --- */
#tabs > ul {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap; /* CRUCIAL: evita que se salgan del contenedor */
    gap: 15px; /* Reducido un poco para ganar espacio */
    border: none !important;
    background: transparent !important;
    margin-bottom: 32px;
    padding: 0;
    width: 100%; /* Asegura que respete el contenedor */
}

#tabs > ul > li {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 0 1 auto; /* Permite que los elementos se ajusten */
}

#tabs > ul > li > a {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 160px; /* Reducido ligeramente de 180px */
    padding: 0 15px; /* Padding interno para que el texto no toque los bordes */
    height: 70px;
    font-size: 1.1em;
    font-weight: bold;
    border-radius: 16px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.2s ease;
    color: #fff !important;
    background: #3b82f6;
    text-align: center;
}

/* --- OPTIMIZACIÓN PARA PANTALLAS GRANDES Y MEDIANAS --- */
@@media (min-width: 1200px) {
    #tabs > ul {
        gap: 20px;
    }
    /* Si quieres que siempre queden en una línea en pantallas gigantes */
    #tabs > ul > li > a {
        min-width: 180px; 
    }
}

/* --- DRILLDOWNS: AJUSTES ESPECÍFICOS --- */

/* 1. Laptop Mediana / Tablet Horizontal (Evita desbordamiento) */
@@media (max-width: 1199px) {
    #tabs > ul > li > a {
        min-width: 140px;
        height: 60px;
        font-size: 1em;
    }
    #tabs > ul {
        gap: 10px;
    }
}

/* 2. Tablets (2 o 3 columnas según ancho) */
@@media (max-width: 768px) {
    #tabs > ul > li {
        flex: 1 1 calc(45% - 10px); /* Fuerza el acomodo en rejilla */
    }
    #tabs > ul > li > a {
        min-width: 100%;
        height: 55px;
    }
}

/* 3. Móviles (1 columna completa) */
@@media (max-width: 480px) {
    #tabs > ul > li {
        flex: 1 1 100%;
    }
    #tabs > ul > li > a {
        height: 50px;
        font-size: 0.95em;
    }
}

#tabs > ul > li:nth-child(1) > a { background: #3b82f6; } /* General - azul */
#tabs > ul > li:nth-child(2) > a { background: #fbbf24; } /* Hospital - amarillo */
#tabs > ul > li:nth-child(3) > a { background: #ef4444; } /* Laboratorio - rojo */
#tabs > ul > li:nth-child(4) > a { background: #22c55e; } /* Clínica - verde */
#tabs > ul > li:nth-child(5) > a { background: #2563eb; } /* Farmacia - azul fuerte */
#tabs > ul > li:nth-child(6) > a { background: #ef4444; } /* Compras - rojo */


#tabs > ul {
    border: none !important;
    background: transparent !important;
    padding: 0 !important;
}

#tabs > ul > li {
    border: none !important;
    background: transparent !important; /* Esto quita el fondo gris de jQuery UI */
    box-shadow: none !important; /* Por si acaso tiene sombra heredada */
    margin-bottom: 5px; /* Espacio para que el efecto scale no se corte */
}

#tabs > ul > li > a {
    outline: none !important; /* Quita el recuadro de enfoque al hacer clic */
    text-decoration: none !important;
}
    </style>
}

