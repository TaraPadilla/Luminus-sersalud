@using System.Linq
@model List<Database.Shared.Models.Clientes>

@{
    Layout = "_HojaMembreteLayout";
    ViewData["Title"] = "Clientes";

    // Flags de visibilidad del membrete
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = true;
    ViewData["MostrarEmergencias"] = true;

    DateTime fecha = DateTime.Now;
}

<style>
    .report-container {
        margin-top: 10px;
        font-size: 12px;
    }

    .report-title {
        text-align: center;
        font-weight: bold;
        font-size: 16px;
        color: #0d0e36;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .report-subtitle {
        text-align: center;
        font-size: 12px;
        margin-bottom: 10px;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    .report-table-title-row th {
        background-color: #f3f4ff;
        border-left: 3px solid #0d0e36;
        color: #0d0e36;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: bold;
        font-size: 12px;
        text-align: left;
        padding: 6px 8px;
    }

    .report-table-header-row th {
        background-color: #eef2ff;
        color: #0d0e36;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 11px;
        text-align: left;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table td {
        font-size: 12px;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table tr:last-child td {
        border-bottom: none;
    }
</style>

<div class="report-container">
    <!-- Encabezado -->
    <div class="report-title">
        REPORTE - @ViewData["Title"]
    </div>
    <div class="report-subtitle">
        <b>Fecha y hora de emisión:</b> @fecha
    </div>

    <!-- Tabla de clientes -->
    <table class="report-table">
        <thead>
            <tr class="report-table-title-row">
                <th colspan="5">Listado de clientes</th>
            </tr>
            <tr class="report-table-header-row">
                <th>Nombre</th>
                <th>Dirección</th>
                <th>Teléfono</th>
                <th>NIT</th>
                @* <th>Alias</th> *@
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Nombre</td>
                        <td>@item.Direccion</td>
                        <td>@item.Telefono</td>
                        <td>@item.Nit</td>
                        @* <td>@item.Alias</td> *@
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5">No hay clientes registrados.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
