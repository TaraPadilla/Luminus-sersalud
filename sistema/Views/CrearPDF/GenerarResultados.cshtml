                                              <td style="border:0;">@valorSplit</td>
                                            }
                                          }
                                        </tr>
                                      }
                                    </tbody>
                                  </table>
                                }
                              </td>
                            }
                          </tr>
                        }
                      }
                    </tbody>
                  </table>
