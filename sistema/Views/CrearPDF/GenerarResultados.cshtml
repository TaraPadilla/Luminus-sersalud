                                {
                                  <table class="table" style="border:0;">
                                    <tbody>
                                      @foreach (var valor in valoresReferencia)
                                      {
                                        var valoresSplitDosPuntos = valor.Replace("\"", "").Split(':').ToList();
                                        <tr>
                                          @if (valoresSplitDosPuntos != null)
                                          {
                                            foreach (var valorSplit in valoresSplitDosPuntos)
