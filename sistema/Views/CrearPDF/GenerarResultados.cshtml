@using Database.Shared.Models
@using sistema.Models
@model ExamenResultadosVM

@{
  Layout = "_HojaMembreteLayout";
  ViewData["Title"] = "Resultados de laboratorio";

  // Flags de visibilidad del membrete
  ViewData["MostrarLogo"] = true;
  ViewData["MostrarNombreEmpresa"] = true;
  ViewData["MostrarDireccion"] = true;
  ViewData["MostrarTelefono"] = true;
  ViewData["MostrarCorreoElectronico"] = true;
  ViewData["MostrarServicios"] = true;
  ViewData["MostrarEmergencias"] = true;

  DateTime fecha = DateTime.Now;

  string no = "--";
  int edad = 0;
  var numeroOrden = Model.NumeroOrden ?? "-";
  List<DetalleExamen> nuevaColeccion = new List<DetalleExamen>();

  if (Model.Paciente?.FechaNacimiento != null)
  {
    edad = fecha.Year - Model.Paciente.FechaNacimiento.Value.Year;
    if (fecha.Month < Model.Paciente.FechaNacimiento.Value.Month
    || (fecha.Month == Model.Paciente.FechaNacimiento.Value.Month && fecha.Day < Model.Paciente.FechaNacimiento.Value.Day))
    {
      edad--;
    }
  }
}

<style>
  :root {
    --azul: #3498db;
    --azul-osc: #2980b9;
    --azul-claro: #f0f7ff;
    --borde: #e6edf5;
    --texto: #2c3e50;
    --muted: #6b7683;
    --gris: #f8fafc;
  }

  /* Documento base */
  .doc {
    font-family: "Segoe UI", Arial, sans-serif;
    color: #333;
    font-size: 10pt;
    line-height: 1.25;
    letter-spacing: -0.15px;
    display: block !important;
  }

  .doc-title {
    font-size: 14pt;
    font-weight: 800;
    color: var(--texto);
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 4px 0;
  }

  .doc-underline {
    height: 2px;
    background: linear-gradient(90deg, transparent 0%, var(--azul) 18%, var(--azul) 82%, transparent 100%);
    margin: 4px 0 8px 0;
    border: 0;
  }

  /* Títulos de sección */
  table.section-title {
    width: 100%;
    border-collapse: collapse;
    margin: 8px 0 4px 0;
    background: var(--azul-claro);
    border: 1px solid var(--borde);
    border-left: 4px solid var(--azul);
    border-radius: 8px;
    /* CAMBIO: Evitar que el título quede solo al final de una página */
    page-break-after: avoid !important;
    break-after: avoid !important;
  }

  table.section-title td {
    padding: 5px 10px;
    font-weight: 800;
    color: var(--azul-osc);
    font-size: 9pt;
    text-transform: uppercase;
  }

  /* TABLAS - Permitir flujo continuo */
  table.table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--borde);
    margin-bottom: 8px;
    background: #fff;
    /* CAMBIO CLAVE: Permitir que la tabla se rompa entre páginas */
    page-break-inside: auto !important;
    break-inside: auto !important;
    height: auto !important;
  }

  table.table thead th {
    text-align: left;
    background: var(--gris);
    color: #4f5b66;
    font-size: 8.4pt;
    padding: 6px 8px;
    border-bottom: 1px solid var(--borde);
    text-transform: uppercase;
  }

  table.table tbody td {
    padding: 4px 8px;
    /* Compacto pero respirable */
    border-bottom: 1px solid #f2f4f7;
    vertical-align: middle;
    font-size: 9.2pt;
    /* Texto de datos claro */
  }

  /* BLOQUES CONTENEDORES */
  .block,
  table.block {
    width: 100%;
    margin-bottom: 5px !important;
    /* CAMBIO: Eliminamos el avoid para que los datos del paciente no empujen el resto */
    page-break-inside: auto !important;
    page-break-after: auto !important;
  }

.bloque-examen-urologia {
    position: relative;
    display: block !important;
    margin-top: 5px !important; 
    /* Permitir que la tabla empiece en una página y siga en otra */
    page-break-inside: auto !important;
    break-inside: auto !important;
    clear: both;
}

  table.table tr {
    page-break-inside: avoid !important;
  }

  .value {
    font-weight: 700;
    color: #111;
  }

  .label {
    color: #55616d;
    font-size: 8.5pt;
    font-weight: 600;
  }

  /* Filas tipo key-value */
  tr.kv-row td {
    padding-top: 7px;
    padding-bottom: 7px;
  }

  /* Column layout helper (por si tu renderer respeta colgroup) */
  table.threecol th,
  table.threecol td {
    width: 33.33%;
  }

  /* Emisión: tu tabla “sin borde” */
  table.table[style*="border:0"] td {
    color: var(--muted);
    font-size: 9pt;
  }

  /* Página / cortes */
  .page {
    position: relative;
    page-break-after: auto;
  }

  /* Footer wrapper: evita quedarlo “huérfano” lo más posible */
  .report-footer {
    page-break-inside: avoid;
    margin-top: 14px;
  }
</style>

