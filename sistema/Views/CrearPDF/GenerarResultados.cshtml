                        var valoresReferencia = new List<string>();
                        if (r.DatosExamenesLabClinico.ValorReferencia != null
                        && detalle.ExamenLabClinico.NombreExamen != "Covid-19, Influenza A+B, RSV, Adenovirus")
                        {
                          valoresReferencia = r.DatosExamenesLabClinico.ValorReferencia.Split(",").ToList();
                        }

                        if (!string.IsNullOrEmpty(r.ValorResultado))
                        {
                          var resultadoTexto = string.IsNullOrEmpty(r.ValorResultado) ? " --- " : r.ValorResultado;
                          <tr class="kv-row">
                            <td>@r.DatosExamenesLabClinico.Campos</td>
                            <td>@resultadoTexto</td>
