@using Database.Shared.Models
@using System.Globalization
@using sistema.Models
@model PrescripcionPdfViewModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@{
    Layout = "_HojaLayout";
    ViewData["Title"] = "Prescripcion medica";
    ViewData["ImagenLogo"] = Config["ImagenLogoBase64"];
    ViewData["Direccion"] = Config["EstablecimientoDireccion"];
    ViewData["Telefono"] = Config["EstablecimientoTelefono"];
    ViewData["CorreoElectronico"] = Config["EstablecimientoCorreoElectronico"];
    ViewData["ImagenFirma"] = Config["EstablecimientoImagenFirma"];
    DateTime fecha = DateTime.Now;
    CultureInfo culture = new CultureInfo("es-GT");
}

<style>
    .seccion-expediente {
        background-color: black;
        color: white;
        padding: 10px;
    }

    .lgon {
        width: 300px;
        height: 100px;
        background-image: url("logo");
    }

    thead {
        background-color: black;
        color: white;
    }

    .color {
        background-color: red;
        width: 100%;
        height: 5px;
    }

    .textoTipo {
        font-family: Georgia, serif;
    }

    .fondo {
        background-color: #1D50BD;
    }

    .custom-table td,
    .custom-table th {
        padding: 1px;
        /* Ajusta este valor según sea necesario */
    }

    footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 10px;
        /* Puedes ajustar la altura según tus necesidades */
        padding: 15px;
        height: 14%;
        /* Ajusta la altura según tus necesidades */
    }

    table {
        border-collapse: collapse;
        width: 100%;
    }

    th,
    td {
        border: 1px solid black;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #f2f2f2;
    }
</style>

<div id="contenido" style="width: 220mm; height: 340mm; margin: 0 auto; font-size: 13PX;">
    <div class="header center"
        style="width: 100%; background-color: #1D50BD; color: white; padding: 5px; font-family: Georgia, serif ">
        <strong><b><span style="font-size: 18PX;  ">EXAMNES A REALIZAR </span></b></strong>
        <br>

        <br>
        <strong>5 calle 3-064, San Antonio Suchitepéquez</strong>
        <br>
    </div>
    <br>
    <div class="form-row" style="font-family: Georgia, serif">
        <center>
            <img width="150" src="@ViewData["ImagenLogo"]" />
        </center>

        <center>
            <h4><b>Centro Medico Shefa</b></h4>
        </center>
        <center>
            5 calle 3-064, San Antonio Suchitepéquez<br />
        </center>
        <div class="col-md-12">
            <center>
                <h5><b>EXAMENES A REALIZAR</b></h5>
            </center>
            <hr />
        </div>
    </div>

    <div class="form-row" style="font-family: Georgia, serif">
        <div class="col-md-12">
            <center><b>Fecha y hora de emisión:</b> @fecha</center>
            <hr />
        </div>
    </div>
    <div class="form-row textoTipo">
        <div class="col-md-12">
            <b>DATOS DEL PACIENTE</b>
        </div>
        <div class="col-md-12">
            <table class="col-md-12">
                <tr>
                    <td>
                        <b>Nombre</b><br />
                        @Model.PacienteNombre
                    </td>
                    <td>
                        <b>Edad</b><br />
                        @Model.PacienteEdad
                    </td>
                </tr>
            </table>
            <hr />
        </div>
    </div>

    <div class="form-row textoTipo">
        <div class="col-md-12 seccion-expediente"
            style="width: 100%; background-color: #638ADD; color: white; padding: 5px; ">
            <b>EXAMENES</b>
        </div>
        <table class="table">
            <thead class="" style="width: 100%; padding: 5px; border:solid ">
                <tr>
                    @*<th><b>Item</b></th>*@
                    <th><b>Codigo Examen</b></th>
                    <th><b>Examen a Realizar</b></th>
                    <th><b>Cantidad</b></th>

                </tr>
            </thead>
            <tbody>
                @if (Model.DetallesPrescripcion != null && Model.DetallesPrescripcion.Count() > 0)
                {
                    @foreach (var medicamento in Model.DetallesPrescripcion)
                    {
                        if (medicamento.Item >= 1000)
                        {
                            <tr>
                                @*<td>@medicamento.Item</td>*@
                                <td>@medicamento.Observaciones</td>
                                <td>@medicamento.Medicamento</td>
                                <td>@medicamento.Cantidad</td>

                            </tr>
                        }
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10">No hay medicamentos registrados</td>
                    </tr>
                }
            </tbody>

        </table>



    </div>

    <footer>
        <center>
            <img width="120"
                src="data:image/jpeg;base64," />



        </center>

        <div class="form-row">
            <div class="col-md-12 text-right">
                <b>"Porque sera como medicina a tu cuerpo y refrigerio para tus huesos" </b>
            </div>
        </div>

        <div class="footer center" style="width: 100%; background-color: #1D50BD; color: white; padding: 5px;">
            <strong><b>Horarios de atencion:</b></strong><br>
            <strong>Lunes a Viernes de 7:00 a 4:00 hrs.Teléfonos: 5842-3025</strong><br>
            <strong>Sabado 7:00 a 12:00 hrs Citas y consultas: 58423025/58584360 </strong>

        </div>
    </footer>

</div>