@model Database.Shared.Models.Cotizacion

@{
    Layout = "_HojaMembreteLayout";
    ViewData["Title"] = "Cotización";

    // Flags de visibilidad del membrete
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = true;
    ViewData["MostrarEmergencias"] = true;

    DateTime fechaEmision = DateTime.Now;

    decimal suma = 0.00m;
    decimal sumades = 0.00m;
    decimal sumasub = 0.00m;
}

<style>
    .report-container {
        margin-top: 10px;
        font-size: 12px;
    }

    .report-title {
        text-align: center;
        font-weight: bold;
        font-size: 16px;
        color: #0d0e36;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .report-subtitle {
        text-align: center;
        font-size: 12px;
        margin-bottom: 10px;
    }

    .report-meta-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 10px;
    }

    .report-meta-table td {
        font-size: 12px;
        padding: 4px 6px;
        vertical-align: top;
    }

    .report-meta-label {
        font-weight: bold;
        width: 18%;
        white-space: nowrap;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    .report-table-title-row th {
        background-color: #f3f4ff;
        border-left: 3px solid #0d0e36;
        color: #0d0e36;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: bold;
        font-size: 12px;
        text-align: left;
        padding: 6px 8px;
    }

    .report-table-header-row th {
        background-color: #eef2ff;
        color: #0d0e36;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 11px;
        text-align: left;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table tbody td {
        font-size: 12px;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table tbody tr:last-child td {
        border-bottom: none;
    }

    .report-table tfoot td {
        font-weight: bold;
        padding: 6px 8px;
        border-top: 1px solid #e1e4ea;
        background-color: #f9fafb;
    }
</style>

<div class="report-container">
    <!-- Encabezado -->
    <div class="report-title">
        REPORTE - @ViewData["Title"]
    </div>
    <div class="report-subtitle">
        <b>Fecha y hora de emisión:</b> @fechaEmision.ToString("dd/MM/yyyy HH:mm")
    </div>

    <!-- Datos generales de la cotización -->
    <table class="report-meta-table">
        <tbody>
            <tr>
                <td class="report-meta-label">No. Cotización:</td>
                <td>@Model.Id</td>
                <td class="report-meta-label">Fecha cotización:</td>
                <td>@Model.FechaCotizacion</td>
            </tr>
            <tr>
                <td class="report-meta-label">Válida hasta:</td>
                <td>@Model.FechaValida</td>
                <td class="report-meta-label">Cliente:</td>
                <td>@(string.IsNullOrWhiteSpace(Model.Cliente) ? "-" : Model.Cliente)</td>
            </tr>
            <tr>
                <td class="report-meta-label">NIT:</td>
                <td>@(string.IsNullOrWhiteSpace(Model.Nit) ? "-" : Model.Nit)</td>
                <td class="report-meta-label">Dirección:</td>
                <td>@(string.IsNullOrWhiteSpace(Model.Direccion) ? "-" : Model.Direccion)</td>
            </tr>
        </tbody>
    </table>

    <!-- Detalle de la cotización -->
    <table class="report-table">
        <thead>
            <tr class="report-table-title-row">
                <th colspan="6">Detalle de la cotización</th>
            </tr>
            <tr class="report-table-header-row">
                <th>Nombre producto / servicio</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Descuento</th>
                <th>Subtotal</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.DetalleCotizacion != null && Model.DetalleCotizacion.Any())
            {
                foreach (var item in Model.DetalleCotizacion)
                {
                    suma    += item.Total;
                    sumades += item.Descuento;
                    sumasub += item.Subtotal;

                    <tr>
                        <td>
                            @if (item.ProductoId == null)
                            {
                                @item.Servicio.NombreServicio
                            }
                            else
                            {
                                @item.Producto.NombreProducto
                            }
                        </td>
                        <td>@item.Cantidad</td>
                        <td>Q @item.Precio</td>
                        <td>Q @item.Descuento</td>
                        <td>Q @item.Subtotal</td>
                        <td>Q @item.Total</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">No hay líneas en la cotización.</td>
                </tr>
            }
        </tbody>
        @if (Model?.DetalleCotizacion != null && Model.DetalleCotizacion.Any())
        {
            <tfoot>
                <tr>
                    <td colspan="4"></td>
                    <td>Subtotal:</td>
                    <td>Q @sumasub</td>
                </tr>
                <tr>
                    <td colspan="4"></td>
                    <td>Descuento:</td>
                    <td>Q @sumades</td>
                </tr>
                <tr>
                    <td colspan="4"></td>
                    <td>Total:</td>
                    <td>Q @suma</td>
                </tr>
            </tfoot>
        }
    </table>
</div>
