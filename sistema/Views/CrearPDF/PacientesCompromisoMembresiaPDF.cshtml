@model Database.Shared.Models.Paciente

@{
    Layout = "_HojaMembreteLayout";
    ViewData["Title"] = "Membresía para pacientes en mantenimiento";

    // Configuración estándar de membrete
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = true;
    ViewData["MostrarEmergencias"] = true;

    DateTime fecha = DateTime.Now;
    var año = fecha.Year;
    var dia = fecha.Day;
    var mes = "";

    switch (fecha.Month)
    {
        case 1: mes = "Enero"; break;
        case 2: mes = "Febrero"; break;
        case 3: mes = "Marzo"; break;
        case 4: mes = "Abril"; break;
        case 5: mes = "Mayo"; break;
        case 6: mes = "Junio"; break;
        case 7: mes = "Julio"; break;
        case 8: mes = "Agosto"; break;
        case 9: mes = "Septiembre"; break;
        case 10: mes = "Octubre"; break;
        case 11: mes = "Noviembre"; break;
        case 12: mes = "Diciembre"; break;
    }
}

<div class="doc">
    <!-- Título principal usando ViewData["Title"] -->
    <div class="doc-title">REPORTE - @ViewData["Title"]</div>
    <div class="doc-underline"></div>

    <!-- Fecha de emisión -->
    <table class="table" style="border:0;">
        <tbody>
            <tr>
                <td style="text-align:center; border:0; font-weight:700;">
                    Fecha y hora de emisión: @fecha.ToString("dd/MM/yyyy HH:mm")
                </td>
            </tr>
        </tbody>
    </table>

    <div class="form-row">
        <div class="col-md-12">
            <br />
            Nosotros, te ofrece un modelo de tratamiento para que puedas disfrutar de
            los servicios básicos y necesarios para lograr tu cuidado día a día y lograr un mantenimiento a largo plazo.
            <br /><br />

            <b>PRE-REQUISITOS</b><br />
            <ul>
                <li>Estar actualmente dentro del rango de tu peso saludable.</li>
                <li>
                    Haber estado durante un año en mantenimiento, manteniéndote en tu rango de peso saludable y
                    haber asistido regularmente a tus citas mensuales de control nutricional.
                </li>
            </ul>

            <b>BENEFICIOS</b><br />
            <ul>
                <li>Tendrás un 50% de descuento en el costo mensual de tu tratamiento, siendo este un total de Q800.</li>
                <li>Contarás con citas presenciales 1 vez al mes, para tu control nutricional y tu seguimiento terapéutico.</li>
                <li>Tendrás acceso a las sesiones en vivo diarias transmitidas en GoTomeeting.</li>
                <li>Tendrás acceso al portal, dónde podrás escuchar los audios y llevar tu registro diario de peso.</li>
            </ul>

            <b>POS-REQUISITOS</b><br />
            <ul>
                <li>Mantenerte en el rango de tu peso saludable, verificable en tus citas presenciales nutricionales.</li>
                <li>Realizar tu pago mensualmente.</li>
                <li>
                    En caso que necesites regresar a la fase de adelgazamiento, inmediatamente entraras
                    en ese formato del tratamiento y tendrás nuevamente la opción de utilizar
                    tu membresía PLUSVIDA al haber nuevamente permanecido en tu rango de peso saludable por 3 meses.
                </li>
            </ul>

            <br /><br />
            Si estás de acuerdo con lo anterior mencionado, te damos la bienvenida a nuestro grupo
            selecto de pacientes en mantenimiento, que desarrollaron la consciencia
            de cuidarse de por vida y encontraron aquí el medio para lograrlo.
            <br /><br />
            Yo, @Model.Nombre, me comprometo a cumplir y aceptar los requisitos descritos en el presente documento.
            <br /><br />
            Me comprometo a cumplir y aceptar los requisitos descritos en el presente documento.
            <br /><br />
            Guatemala, @dia de @mes del año @año
            <br /><br />
        </div>
    </div>

    <div class="form-row">
        <div class="col-md-12">
            <h6>Firma del paciente</h6>
            <hr />
        </div>
        <div class="col-md-12">
            <img src="#" alt="Firma del paciente" />
        </div>
    </div>
</div>
