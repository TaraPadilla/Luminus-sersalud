@using farmamest.Models
@model NotaMedica2ViewModel

@{
    var embebido = ViewData["EmbebidoEnExpediente"] as bool? ?? false;
    Layout = embebido ? null : "_HojaMembreteLayout";
    ViewData["Title"] = "Hospitalización - Nota médica";
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = false;
    ViewData["MostrarEmergencias"] = false;

    DateTime fecha = DateTime.Now;
    var medicoTratante = Model.EmpleadoText ?? Model.Profesional ?? "-";
    var nombreFirmante = Model.NombreFirmante ?? Model.RegistradoPor ?? "-";
    var mostrarCapturadoPor = !string.IsNullOrWhiteSpace(Model.RegistradoPor)
        && !string.Equals(Model.RegistradoPor, medicoTratante, StringComparison.OrdinalIgnoreCase);
}

<style>
.notes p { margin: 0 0 4px 0; }
.notes strong { font-weight: bold; }
.notes em { font-style: italic; }
.notes u { text-decoration: underline; }
.notes s { text-decoration: line-through; }
.notes ol { margin: 4px 0; padding-left: 20px; list-style-type: decimal; }
.notes ul { margin: 4px 0; padding-left: 20px; list-style-type: disc; }
.notes li { margin-bottom: 2px; }
.notes h1 { font-size: 1.4em; font-weight: bold; margin: 6px 0; }
.notes h2 { font-size: 1.2em; font-weight: bold; margin: 5px 0; }
.notes h3 { font-size: 1.1em; font-weight: bold; margin: 4px 0; }
.notes blockquote { border-left: 3px solid #ccc; margin: 4px 0 4px 10px; padding-left: 8px; color: #555; }
</style>

<div class="doc">

    <!-- Título principal -->
    <div class="doc-title">REPORTE - @ViewData["Title"]</div>
    <div class="doc-underline"></div>

    <!-- Fecha de emisión -->
    <table class="table" style="border:0;">
        <tbody>
            <tr>
                <td style="text-align:center; font-weight:700; border:0;">
                    Fecha y hora de emisión: @fecha.ToString("dd/MM/yyyy hh:mm tt")
                </td>
            </tr>
        </tbody>
    </table>

    <!-- DATOS DEL PACIENTE -->
    <table class="section-title">
        <tr>
            <td class="bar"></td>
            <td>Datos del paciente</td>
        </tr>
    </table>

    <table class="block">
        <tr>
            <td style="padding:0;">
                <table class="table threecol">
                    <colgroup>
                        <col />
                        <col />
                        <col />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Nombre</th>
                            <th>Sexo</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="kv-row">
                            <td><span class="value">@Model.PacienteNombre</span></td>
                            <td><span class="value">@Model.PacienteSexoText</span></td>
                            <td><span class="value"></span></td>
                        </tr>
                    </tbody>
                </table>
            </td>
        </tr>
    </table>

    <!-- DIAGNÓSTICO -->
    <table class="section-title">
        <tr>
            <td class="bar"></td>
            <td>Diagnóstico</td>
        </tr>
    </table>

    <table class="block">
        <tr>
            <td style="padding:0;">
                <table class="table">
                    <colgroup>
                        <col class="label-col" />
                        <col />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Campo</th>
                            <th>Detalle</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="kv-row">
                            <td><span class="label">Diagnóstico</span></td>
                            <td class="notes">
                                @Html.Raw(Model.Diagnostico)
                            </td>
                        </tr>
                        <tr class="kv-row">
                            <td><span class="label">Médico tratante</span></td>
                            <td><span class="value">@medicoTratante</span></td>
                        </tr>
                        @if (mostrarCapturadoPor)
                        {
                            <tr class="kv-row">
                                <td><span class="label">Capturado por</span></td>
                                <td><span class="value">@Model.RegistradoPor</span></td>
                            </tr>
                        }
                        @if (Model.Autorizado && !string.IsNullOrWhiteSpace(Model.AutorizadoPor))
                        {
                            <tr class="kv-row">
                                <td><span class="label">Autorizado por</span></td>
                                <td><span class="value">@Model.AutorizadoPor</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </td>
        </tr>
    </table>

    @if (!string.IsNullOrEmpty(Model.FirmaBase64))
    {
        <table class="section-title">
            <tr>
                <td class="bar"></td>
                <td>@(Model.Autorizado && !string.IsNullOrWhiteSpace(Model.AutorizadoPor) ? "Firma de quien autorizó" : "Firma del profesional")</td>
            </tr>
        </table>
        <table class="block">
            <tr>
                <td style="padding:8px; text-align:center;">
                    <div>@nombreFirmante</div>
                    @if (Model.Autorizado && !string.IsNullOrWhiteSpace(Model.AutorizadoPor))
                    {
                        <div style="color:#64748b;">Validaci&oacute;n con huella digital</div>
                    }
                    <div style="color:#64748b;">M&eacute;dico tratante: @medicoTratante</div>
                    <div style="color:#64748b;">Colegiado: @Model.ColegioEmpleado</div>
                    <img src="@Model.FirmaBase64" style="max-height:100px; max-width:300px; border:1px solid #ccc; padding:4px; margin-top:8px;" />
                </td>
            </tr>
        </table>
    }
    else if (Model.Autorizado && !string.IsNullOrWhiteSpace(Model.AutorizadoPor))
    {
        <table class="section-title">
            <tr>
                <td class="bar"></td>
                <td>Autorización</td>
            </tr>
        </table>
        <table class="block">
            <tr>
                <td style="padding:8px; text-align:center;">
                    <div>Autorizado por: @Model.AutorizadoPor</div>
                    <div style="color:#64748b;">Médico tratante: @medicoTratante</div>
                </td>
            </tr>
        </table>
    }
    else
    {
        <table class="section-title">
            <tr>
                <td class="bar"></td>
                <td>Profesional responsable</td>
            </tr>
        </table>
        <table class="block">
            <tr>
                <td style="padding:8px; text-align:center;">
                    <div><strong>Médico tratante:</strong> @medicoTratante</div>
                    <div style="color:#64748b;"><strong>Colegiado:</strong> @(Model.ColegioEmpleado ?? "-")</div>
                    @if (mostrarCapturadoPor)
                    {
                        <div style="color:#64748b; margin-top:4px; font-size:11px;">Capturado por: @Model.RegistradoPor</div>
                    }
                    <div style="color:#b45309; margin-top:8px; font-style:italic;">
                        @(Model.Autorizado ? "Firma digital no disponible en archivo del profesional." : "Pendiente de autorización y firma.")
                    </div>
                </td>
            </tr>
        </table>
    }

</div>
