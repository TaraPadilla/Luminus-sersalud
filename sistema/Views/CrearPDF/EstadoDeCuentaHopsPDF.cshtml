    <!-- ========== PRODUCTOS / SERVICIOS ========== -->
    @foreach (var grupo in Model.Productos.GroupBy(p => p.Tipo).Where(g => g.Key != "Paquete"))
    {
        <div class="section-heading">@grupo.Key</div>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Item</th>
                    <th>Cantidad</th>
                    <th>Precio unitario</th>
                    <th>% Desc</th>
                    <th>Cargo</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var producto in grupo)
                {
                    <tr>
                        <td>@producto.Fecha</td>
                        <td>@producto.Item</td>
                        <td>@producto.Cantidad</td>
                        <td>@(producto.PrecioUnitario == 0 ? "" : producto.PrecioUnitario.ToString("N2"))</td>
                        <td>@(producto.DescPct == 0 ? "" : producto.DescPct.ToString("N2") + "%")</td>
                        <td>@(producto.Cargo == 0 ? "" : producto.Cargo.ToString("N2"))</td>
                        <td>@(producto.Subtotal == 0 ? "" : producto.Subtotal.ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- ========== GLOBAL DISCOUNT ROW ========== -->
    @if (Model.DescuentoGlobal > 0)
    {
        <div class="section-heading">Ajustes</div>
        <table class="report-table">
            <tbody>
                <tr>
                    <th>Descuento global</th>
                    <td>@Model.DescuentoGlobal.ToString("N2")</td>
                </tr>
            </tbody>
        </table>
    }

    <!-- ========== PAQUETES ========== -->
    @if (Model.Paquetes != null && Model.Paquetes.Any())
    {
        <div class="section-heading">PAQUETES</div>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    <th>Item</th>
                    <th>Cantidad</th>
                    <th>Precio unitario</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Paquetes)
                {
                    <tr>
                        <td>@p.Fecha</td>
                        <td>@p.Nombre</td>
                        <td>@p.Cantidad</td>
                        <td>@p.PrecioUnitario</td>
                        <td>@p.Subtotal</td>
                    </tr>
                }
            </tbody>
        </table>
    }

   
    <!-- ========== GASTOS ADMINISTRATIVOS ========== -->
    @if (Model.GastosAdministrativos != null && Model.GastosAdministrativos.Any())
    {
        <div class="section-heading">GASTOS ADMINISTRATIVOS</div>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Fecha</th>
                    @* <th>Porcentaje aplicado</th> *@
                    <th>Monto</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model.GastosAdministrativos)
                {
                    <tr>
                        <td>@g.Fecha.ToString("dd/MM/yyyy")</td>
                        @* <td>@g.PorcentajeAplicado.ToString("0.00")%</td> *@
                        <td>@g.Monto.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    }

   
    <!-- Honorarios -->
    @if (honorariosValidos.Any())
    {
        <div class="section-heading">Honorarios</div>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Médico</th>
                    <th>Monto</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var honorario in honorariosValidos)
                {
                    <tr>
                        <td>@honorario.Medico</td>
                        <td>@honorario.Monto</td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <!-- Pagos -->
    <div class="section-heading">Pagos</div>
    <table class="report-table">
        <tbody>
            <tr>
                <th>Total cuenta</th>
                <td>
                    @if (Model.Pagos.TotalCuenta == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.TotalCuenta
                    }
                </td>
            </tr>
            <tr>
                <th>Total aseguradora</th>
                <td>
                    @if (Model.Pagos.TotalAseguradora == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.TotalAseguradora
                    }
                </td>
            </tr>
            <tr>
                <th>Total no elegibles</th>
                <td>
                    @if (Model.Pagos.TotalNoElegibles == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.TotalNoElegibles
                    }
                </td>
            </tr>
            <tr>
                <th>Deducibles</th>
                <td>
                    @if (Model.Pagos.Deducibles == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.Deducibles
                    }
                </td>
            </tr>
            <tr>
                <th>Coaseguro</th>
                <td>
                    @if (Model.Pagos.Coaseguro == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.Coaseguro
                    }
                </td>
            </tr>
            <tr>
                <th>Copago</th>
                <td>
                    @if (Model.Pagos.Copago == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.Copago
                    }
                </td>
            </tr>
            <tr>
                <th>IVA</th>
                <td>
                    @if (Model.Pagos.IVA == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.IVA
                    }
                </td>
            </tr>
            <tr>
                <th>Pago paciente</th>
                <td>
                    @if (Model.Pagos.PagoPaciente == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.PagoPaciente
                    }
                </td>
            </tr>
            <tr>
                <th>Pago seguro</th>
                <td>
                    @if (Model.Pagos.PagoSeguro == 0)
                    {
                        @: <!-- Campo vacío -->
                    }
                    else
                    {
                        @Model.Pagos.PagoSeguro
                    }
                </td>
            </tr>
        </tbody>
    </table>
</div>
