@model farmamest.Models.EstadoCuentaViewModel

@{
    Layout = "_HojaMembreteLayout";
    ViewData["Title"] = "Estado de Cuenta Hospitalario";

    // Flags de visibilidad del membrete
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = true;
    ViewData["MostrarEmergencias"] = true;

    DateTime fecha = DateTime.Now;

    var honorariosValidos = Model.Honorarios
        .Where(h => h.Medico != "Seleccione un médico" || h.Monto != 0.0m)
        .ToList();
}

<style>
    .report-container {
        margin-top: 10px;
        font-size: 12px;
    }

    .report-title {
        text-align: center;
        font-weight: bold;
        font-size: 16px;
        color: #0d0e36;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .report-subtitle {
        text-align: center;
        font-size: 12px;
        margin-bottom: 12px;
    }

    .section-heading {
        font-size: 13px;
        font-weight: bold;
        color: #0d0e36;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 10px 0 6px;
        padding-left: 8px;
        border-left: 3px solid #0d0e36;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 12px;
    }

    .report-table th {
        background-color: #eef2ff;
        color: #0d0e36;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 11px;
        text-align: left;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table td {
        font-size: 12px;
        padding: 6px 8px;
        border-bottom: 1px solid #e1e4ea;
    }

    .report-table tbody tr:last-child td {
        border-bottom: none;
    }
</style>

<div class="report-container">
    <!-- Título principal -->
    <div class="report-title">
        REPORTE - @ViewData["Title"]
    </div>

    <!-- Fecha y hora de emisión -->
    <div class="report-subtitle">
        <b>Fecha y hora de emisión:</b> @fecha.ToString("dd/MM/yyyy HH:mm")
    </div>

    <!-- Paciente -->
    <div class="section-heading">Paciente</div>
    <table class="report-table">
        <tbody>
            <tr>
                <th>Nombre</th>
                <td>@Model.Paciente.Nombre</td>
            </tr>
            <tr>
                <th>Teléfono</th>
                <td>@Model.Paciente.Telefono</td>
            </tr>
            <tr>
                <th>Celular</th>
                <td>@Model.Paciente.Celular</td>
            </tr>
            <tr>
                <th>Dirección</th>
                <td>@Model.Paciente.Direccion</td>
            </tr>
            <tr>
                <th>Edad</th>
                <td>@Model.Paciente.Edad</td>
            </tr>
            <tr>
                <th>Sexo</th>
                <td>@Model.Paciente.Sexo</td>
            </tr>
            <tr>
                <th>NIT</th>
                <td>@Model.Paciente.Nit</td>
            </tr>
            <tr>
                <th>DPI</th>
                <td>@Model.Paciente.Dpi</td>
            </tr>
        </tbody>
    </table>

    <!-- Responsable -->
    <div class="section-heading">Responsable</div>
    <table class="report-table">
        <tbody>
            <tr>
                <th>Nombre</th>
                <td>@Model.Responsable.Nombre</td>
            </tr>
            <tr>
                <th>NIT</th>
                <td>@Model.Responsable.Nit</td>
            </tr>
            <tr>
                <th>Dirección</th>
                <td>@Model.Responsable.Direccion</td>
            </tr>
            <tr>
                <th>Correo</th>
                <td>@Model.Responsable.Correo</td>
            </tr>
        </tbody>
    </table>

    <!-- Habitación -->
    <div class="section-heading">Habitación</div>
    <table class="report-table">
        <tbody>
            <tr>
                <th>Número</th>
                <td>@Model.Habitacion.Numero</td>
            </tr>
            <tr>
                <th>Categoría</th>
                <td>@Model.Habitacion.Categoria</td>
            </tr>
            <tr>
                <th>Tarifa</th>
                <td>@Model.Habitacion.Tarifa</td>
            </tr>
        </tbody>
    </table>

    <!-- Productos -->
    @* @foreach (var grupo in Model.Productos.GroupBy(p => p.Tipo))
