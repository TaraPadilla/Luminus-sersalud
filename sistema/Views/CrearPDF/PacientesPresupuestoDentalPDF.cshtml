@using Database.Shared.Models
@model PresupuestoDental

@{
    Layout = "_HojaLayout";
    // Configuración estándar de membrete
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = true;
    ViewData["MostrarEmergencias"] = true;
    DateTime fecha = DateTime.Now;
    decimal totalPresupuesto = 0;
}

<style>
    .seccion-expediente {
        background-color: #f5f5f5;
        padding: 10px;
    }
</style>


<div class="form-row">
    <div class="col-md-12">
        <center>
            <h5><b>PRESUPUESTO DENTAL</b></h5>
        </center>
        <hr />
    </div>
</div>
<div class="form-row">
    <div class="col-md-12">
        <center><b>Fecha y hora de emisión:</b> @fecha</center>
        <hr />
    </div>
</div>

<div class="form-row">
    <div class="col-md-12 seccion-expediente">
        <b>SERVICIOS COTIZADOS</b>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th><b>Codigo</b></th>
                <th><b>Nombre del servicio</b></th>
                <th><b>Diente</b></th>
                <th><b>Precio</b></th>
                <th><b>Valor</b></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.PresupuestosDentalesDetalles != null &&
                        Model.PresupuestosDentalesDetalles.Count() > 0)
            {
                @foreach (var detalle in Model.PresupuestosDentalesDetalles)
                {
                    totalPresupuesto += Convert.ToDecimal(detalle.Valor);
                    <tr>
                        <td>@detalle.Codigo</td>
                        <td>@detalle.NombreServicio</td>
                        <td>@detalle.Diente</td>
                        <td>@detalle.Precio</td>
                        <td>@detalle.Valor</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10">No hay servicios registrados</td>
                </tr>
            }
            <tr class="seccion-expediente">
                <td colspan="3"></td>
                <td style="text-align:right"><b>TOTAL</b></td>
                <td><b>@totalPresupuesto</b></td>
            </tr>
        </tbody>
    </table>
</div>

<div class="form-row">
    <div class="col-md-12 seccion-expediente">
        <b>MEDIOS DE PAGO</b>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>
                    <center><b>PSE</b></center>
                </th>
                <th>
                    <center><b>Efectivo</b></center>
                </th>
                <th>
                    <center><b>Transferencia</b></center>
                </th>
                <th>
                    <center><b>VisaNet</b></center>
                </th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <center>
                        <img width="130"
                            src="data:image/jpeg;base64," />
                    </center>
                </td>
                <td>
                    <center>
                        <img width="130"
                            src="data:image/png;base64," />
                    </center>
                </td>
                <td>
                    <center>
                        <img width="130"
                            src="data:image/png;base64," />
                    </center>
                </td>
                <td>
                    <center>
                        <img width="130"
                            src="data:image/png;base64," />
                    </center>
                </td>
            </tr>
        </tbody>
    </table>
</div>