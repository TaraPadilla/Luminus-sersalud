    <!-- OBSTETRICIA - ECOGRAFIA ENDOCAVITARIA -->
    <table class="report-table keep-with-next">
        <thead>
            <tr class="report-table-title-row">
                <th colspan="3">OBSTETRICIA - ECOGRAFIA ENDOCAVITARIA</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <b>Útero</b><br />
                    @Model.EcografiaEndocavitariaUtero
                </td>
                <td>
                    <b>Longitudinal</b><br />
                    @Model.EcografiaEndocavitariaLongitudinal
                </td>
                <td>
                    <b>Transverso</b><br />
                    @Model.EcografiaEndocavitariaTransverso
                </td>
            </tr>
            <tr>
                <td>
                    <b>Endometrio</b><br />
                    @Model.EcografiaEndocavitariaEndometrio
                </td>
                <td>
                    <b>Ovario derecho</b><br />
                    @Model.EcografiaEndocavitariaOvarioDerecho
                </td>
                <td>
                    <b>Ovario izquierdo</b><br />
                    @Model.EcografiaEndocavitariaOvarioIzquierdo
                </td>
