@model farmamest.Models.ConsentimientoHospiVM
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config

@{
    var embebido = ViewData["EmbebidoEnExpediente"] as bool? ?? false;
    Layout = embebido ? null : "_HojaMembreteLayout";
    ViewData["MostrarServicios"] = false;
    ViewData["MostrarEmergencias"] = false;
    var imagenLogoBase64 = Config["ImagenLogoBase64"];
    ViewData["Direccion"]          = Config["EstablecimientoDireccion"];
    ViewData["Telefono"]           = Config["EstablecimientoTelefono"];
    ViewData["CorreoElectronico"]  = Config["EstablecimientoCorreoElectronico"];
    ViewData["ImagenFirma"]        = Config["EstablecimientoImagenFirma"];
    DateTime fecha = DateTime.Now;
    var empresa = Config["EstablecimientoNombreEmpresa"] ?? "Nombre de la Empresa";
}


<div style="text-align: center; margin-bottom: 50px; margin-top: 30px;">
    <h2><strong>Asignación de Médico Anestesiólogo</strong></h2>
</div>

<div style="font-size: 16px; margin-left: 20px; margin-right: 20px;">
    
    <p style="margin-bottom: 30px;">
       Yo, @(Model.NombreMedicoTratante ?? "Nombre del Médico"), Colegiado No. @(Model.ColegiadoMedico ?? "Número de Colegiado"),
    </p>

      <p style="margin-bottom: 30px;">
        He asignado a:<br><br>
        @{
            var nombreAnest = Model.NombreAnestesista;
            var colAnest = Model.ColegiadoAnestesista;
            if (string.IsNullOrWhiteSpace(nombreAnest)
                || nombreAnest == "Nombre del Anestesista"
                || nombreAnest == "Anestesiólogo asignado"
                || nombreAnest == "-")
            {
                nombreAnest = "___________________________";
            }
            if (string.IsNullOrWhiteSpace(colAnest)
                || colAnest == "Número de Colegiado"
                || colAnest == "-")
            {
                colAnest = "___________";
            }
        }
        @nombreAnest, Colegiado No. @colAnest,
    </p>

    <p style="margin-bottom: 30px; line-height: 1.8;">
        Para prestar los servicios de anestesia durante la intervención quirúrgica que se llevará a<br><br>
        cabo en @empresa en la fecha siguiente: &nbsp;&nbsp;&nbsp;@Model.FechaAdmision<br><br>
        Para el paciente:
        &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@(Model.NombreCompleto ?? "Nombre del Paciente")
    </p>
    </p>

    <p style="margin-top: 40px; margin-bottom: 60px;">
        Entiendo que dicha asignación se otorga bajo mi total responsabilidad.
    </p>

    <div style="margin-top: 40px;">
        <p><strong>Firma médico tratante:</strong></p>
        @if (!string.IsNullOrEmpty(Model.UrlFirmaMedico))
        {
            <div style="text-align: center; margin-top: 20px;">
                <img src="@Model.UrlFirmaMedico" alt="Firma del Médico" style="max-height:100px;" />
                <div style="width: 350px; border-bottom: 2px solid black; margin: 12px auto 0;"></div>
                <p>@(Model.NombreMedicoTratante ?? "")</p>
                @if (!string.IsNullOrWhiteSpace(Model.ColegiadoMedico))
                {
                    <p style="color:#64748b;">Colegiado: @Model.ColegiadoMedico</p>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(Model.NombreMedicoTratante) && Model.NombreMedicoTratante != "Nombre del Médico")
        {
            <div style="text-align: center; margin-top: 20px;">
                <div style="width: 350px; border-bottom: 2px solid black; margin: 12px auto 0;"></div>
                <p>@(Model.NombreMedicoTratante)</p>
                @if (!string.IsNullOrWhiteSpace(Model.ColegiadoMedico) && Model.ColegiadoMedico != "Número de Colegiado")
                {
                    <p style="color:#64748b;">Colegiado: @Model.ColegiadoMedico</p>
                }
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.UrlFirmaAnestesista))
        {
            <p style="margin-top: 30px;"><strong>Firma anestesiólogo asignado:</strong></p>
            <div style="text-align: center; margin-top: 20px;">
                <img src="@Model.UrlFirmaAnestesista" alt="Firma anestesiólogo" style="max-height:100px;" />
                <div style="width: 350px; border-bottom: 2px solid black; margin: 12px auto 0;"></div>
                <p>@(Model.NombreAnestesista ?? "")</p>
                @if (!string.IsNullOrWhiteSpace(Model.ColegiadoAnestesista))
                {
                    <p style="color:#64748b;">Colegiado: @Model.ColegiadoAnestesista</p>
                }
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(Model.NombreAnestesista) && Model.NombreAnestesista != "Nombre del Anestesista")
        {
            <p style="margin-top: 30px;"><strong>Anestesiólogo asignado:</strong></p>
            <div style="text-align: center; margin-top: 12px;">
                <p>@(Model.NombreAnestesista)</p>
                @if (!string.IsNullOrWhiteSpace(Model.ColegiadoAnestesista) && Model.ColegiadoAnestesista != "Número de Colegiado")
                {
                    <p style="color:#64748b;">Colegiado: @Model.ColegiadoAnestesista</p>
                }
            </div>
        }
    </div>

</div>