@model OrdenesMedicasListaPdfViewModel

@{
    Layout = "_HojaMembreteLayout";
    ViewData["Title"] = "Hospitalización - Órdenes médicas";
    ViewData["MostrarLogo"] = true;
    ViewData["MostrarNombreEmpresa"] = true;
    ViewData["MostrarDireccion"] = true;
    ViewData["MostrarTelefono"] = true;
    ViewData["MostrarCorreoElectronico"] = true;
    ViewData["MostrarServicios"] = false;
    ViewData["MostrarEmergencias"] = true;
}

<style>
.notes p { margin: 0 0 4px 0; }
.notes ul, .notes ol { margin: 4px 0; padding-left: 20px; }
</style>

<div class="doc">
    <div class="doc-title">REPORTE - @ViewData["Title"]</div>
    <div class="doc-underline"></div>

    <table class="section-title"><tr><td class="bar"></td><td>Datos del paciente</td></tr></table>
    <table class="block">
        <tr><td style="padding:8px;">
            <strong>Nombre:</strong> @Model.PacienteNombre &nbsp;|&nbsp;
            <strong>Sexo:</strong> @Model.PacienteSexoText &nbsp;|&nbsp;
            <strong>Edad:</strong> @Model.PacienteEdad
        </td></tr>
        <tr><td style="padding:8px;">
            <strong>Médico tratante:</strong> @Model.EmpleadoText &nbsp;|&nbsp;
            <strong>Colegiado:</strong> @Model.ColegioEmpleado
        </td></tr>
    </table>

    @foreach (var orden in Model.Ordenes ?? new List<OrdenMedicaViewModel>())
    {
        <table class="section-title" style="margin-top:14px;">
            <tr><td class="bar"></td><td>Orden @(orden.Autorizado ? "pre-operatoria autorizada" : "post-operatoria") — @orden.FechaHora</td></tr>
        </table>
        <table class="block">
            <tr><td style="padding:8px;">
                <div><strong>Registrado por:</strong> @orden.Profesional</div>
                @if (orden.Autorizado && !string.IsNullOrWhiteSpace(orden.AutorizadoPor))
                {
                    <div><strong>Autorizado por:</strong> @orden.AutorizadoPor</div>
                }
                <div><strong>Médico:</strong> @orden.EmpleadoText</div>
                <div class="notes" style="margin-top:8px;">@Html.Raw(orden.Descripcion)</div>
            </td></tr>
        </table>
        @if (!string.IsNullOrEmpty(orden.FirmaBase64))
        {
            <table class="block" style="margin-top:6px;">
                <tr><td style="padding:8px; text-align:center;">
                    <div style="font-size:11px; color:#64748b;">Firma del profesional</div>
                    <div>@(orden.NombreFirmante ?? orden.Profesional)</div>
                    @if (orden.Autorizado && !string.IsNullOrWhiteSpace(orden.AutorizadoPor))
                    {
                        <div style="color:#64748b;">Autorizado por (validaci&oacute;n): @orden.AutorizadoPor</div>
                    }
                    <div style="color:#64748b;">M&eacute;dico tratante: @orden.EmpleadoText</div>
                    <img src="@orden.FirmaBase64" style="max-height:80px; max-width:260px; border:1px solid #ccc; padding:4px;" />
                </td></tr>
            </table>
        }
        else if (orden.Autorizado && !string.IsNullOrWhiteSpace(orden.AutorizadoPor))
        {
            <table class="block" style="margin-top:6px;">
                <tr><td style="padding:8px; text-align:center;">
                    <div style="font-size:11px; color:#64748b;">Documento autorizado</div>
                    <div>@orden.AutorizadoPor</div>
                </td></tr>
            </table>
        }
    }
</div>
