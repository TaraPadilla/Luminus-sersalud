@model farmamest.Models.ConsentimientoHospiVM
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config

@{
  Layout = "_HojaMembreteLayout";
  ViewData["Title"] = "Consentimiento de Hospitalización";
  ViewData["ImagenLogo"] = Config["ImagenLogoBase64"];
  ViewData["Direccion"] = Config["EstablecimientoDireccion"];
  ViewData["Telefono"] = Config["EstablecimientoTelefono"];
  ViewData["CorreoElectronico"] = Config["EstablecimientoCorreoElectronico"];
  ViewData["ImagenFirma"] = Config["EstablecimientoImagenFirma"];
  DateTime fecha = DateTime.Now;

  string ValorOuNoEspecificado(string valor) =>
  string.IsNullOrWhiteSpace(valor) ? "No especificado" : valor;
}

<style>
  /* =========================
     IMPRESIÓN / PDF (CARTA)
     ========================= */
  @@page {
    size: Letter;
    /* 8.5in x 11in */
    margin: 18mm 14mm;
    /* tu margen, se respeta */
  }

  /* Evita escalados raros en algunos engines */
  html,
  body {
    height: auto;
  }

  body {
    margin: 0;
    padding: 0;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }

  /* Contenedor general */
  .doc {
    font-family: "Segoe UI", system-ui, -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
    color: #111827;
    font-size: 11.5px;
    line-height: 1.5;
  }

  /* =========================
     PÁGINA (una hoja carta)
     =========================
     Nota: 11in total alto carta.
     Como el margen lo define @@page, aquí solo controlamos el flujo
     y evitamos cortes raros dentro de una página.
  */
  .page {
    page-break-after: always;
    break-after: page;
    /* Mantén una "caja página" consistente */
    min-height: 11in;
    /* ayuda a que cada page sea una carta visualmente */
    box-sizing: border-box;
    padding: 0;
    /* no agregamos padding extra, el margen lo maneja @@page */
  }

  .page:last-child {
    page-break-after: auto;
    break-after: auto;
  }

  .page-inner {
    width: 100%;
    box-sizing: border-box;
  }

  /* =========================
     TIPOGRAFÍA / TÍTULOS
     ========================= */
  .heading-main {
    text-align: center;
    text-transform: uppercase;
    font-weight: 800;
    font-size: 17px;
    letter-spacing: 0.10em;
    margin: 0 0 12px 0;
    padding: 6px 0 4px 0;
    border-bottom: 1px solid #e5e7eb;
  }

  /* =========================
     META (arriba)
     ========================= */
  .meta-table {
    width: 100%;
    border-collapse: collapse;
    margin: 10px 0 16px 0;
  }

  .meta-table td {
    text-align: left;
    padding: 4px 2px;
    border: 0;
    font-weight: 500;
  }

  .meta-label {
    display: inline-block;
    font-weight: 700;
    min-width: 170px;
    color: #111827;
  }

  /* =========================
     TÍTULOS DE SECCIÓN
     ========================= */
  .section-title {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 10px 0;
  }

  .section-title td {
    vertical-align: middle;
    padding: 0;
    border: 0;
  }

  .section-bar {
    width: 4px;
    height: 100%;
    border-radius: 999px;
  }

  .section-bar.blue {
    background: #2563eb;
  }

  .section-bar.red {
    background: #b91c1c;
  }

  .section-title-text {
    font-weight: 800;
    text-transform: uppercase;
    font-size: 11.5px;
    padding: 7px 10px;
    margin-left: 8px;
    color: #111827;
    background: #f3f4f6;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }

  .section-title-text span.subtle {
    font-weight: 400;
    text-transform: none;
    font-size: 11px;
    color: #4b5563;
  }

  /* =========================
     BLOQUES (cards)
     ========================= */
  .block {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border-radius: 10px;
    border: 1px solid #e5e7eb;
    background: #ffffff;
    margin-bottom: 12px;
    overflow: hidden;
  }

  /* Evita cortes dentro de bloques importantes */
  .block.keep {
    page-break-inside: avoid;
    break-inside: avoid;
  }

  .block-header {
    background: #eef2ff;
    font-weight: 800;
    text-align: left;
  }

  .block-header th {
    padding: 8px 12px;
    font-size: 11.5px;
    border-bottom: 1px solid #e5e7eb;
  }

  /* =========================
     TABLAS GENERALES
     ========================= */
  .table {
    width: 100%;
    border-collapse: collapse;
  }

  .table th,
  .table td {
    border: 1px solid #e5e7eb;
    padding: 5px 8px;
    vertical-align: top;
  }

  .table th {
    background: #f9fafb;
    font-weight: 800;
    font-size: 11px;
    color: #111827;
  }

  /* =========================
     KV TABLE (campo/valor)
     ========================= */
  .kv-table {
    width: 100%;
    border-collapse: collapse;
  }

  .kv-table thead th {
    border-bottom: 1px solid #e5e7eb;
    background: #f9fafb;
    padding: 7px 10px;
    font-weight: 800;
    color: #111827;
  }

  .kv-table th,
  .kv-table td {
    border: 0;
    padding: 6px 10px;
  }

  .kv-table th {
    width: 32%;
    white-space: nowrap;
    text-align: left;
    font-weight: 700;
    color: #374151;
    border-right: 1px solid #eef2f7;
  }

  .kv-table td {
    width: 68%;
    text-align: left;
  }

  /* Rayado suave consistente */
  .kv-row:nth-child(odd) td,
  .kv-row:nth-child(odd) th {
    background: #fafafa;
  }

  .kv-row:nth-child(even) td,
  .kv-row:nth-child(even) th {
    background: #ffffff;
  }

  .label {
    display: block;
    font-weight: 700;
    margin-bottom: 2px;
    color: #111827;
  }

  .value {
    display: block;
    font-weight: 400;
    color: #111827;
  }

  .muted {
    color: #6b7280;
  }

  /* =========================
     NOTAS / PÁRRAFOS
     ========================= */
  .notes {
    padding: 10px 12px;
    font-size: 11.5px;
  }

  .notes p {
    margin: 0 0 7px 0;
  }

  .notes p:last-child {
    margin-bottom: 0;
  }

  /* Utilidades */
  .mt-2 {
    margin-top: 8px;
  }

  .mt-3 {
    margin-top: 12px;
  }

  .mb-2 {
    margin-bottom: 8px;
  }

  .mb-3 {
    margin-bottom: 12px;
  }

  .text-center {
    text-align: center;
  }

  .text-right {
    text-align: right;
  }

  .text-justify {
    text-align: justify;
  }

  .fw-bold {
    font-weight: 800;
  }

  /* =========================
     REGLAMENTO
     ========================= */
  .reglamento-list {
    margin: 6px 0 0 0;
    padding-left: 20px;
  }

  .reglamento-list li {
    margin-bottom: 7px;
  }

  .reglamento-list li::marker {
    font-weight: 800;
  }

  /* =========================
     FIRMAS
     ========================= */
  .signature-table {
    width: 100%;
    border-collapse: collapse;
  }

  .signature-table th,
  .signature-table td {
    text-align: center;
    border: 0;
    padding: 6px 8px;
  }

  .signature-name {
    font-weight: 800;
    margin-top: 4px;
  }

  .signature-role {
    font-size: 10px;
    color: #4b5563;
  }

  .signature-space {
    height: 44px;
  }

  /* Para imágenes de firma: mejor render en PDF */
  img {
    image-rendering: auto;
  }

  /* Espaciador opcional */
  .page-separator {
    height: 12px;
  }
</style>

<div class="doc">
  <!-- ===========================
       PÁGINA 1
       =========================== -->
  <div class="page">
    <div class="page-inner">
      <!-- Encabezado principal -->
      <div class="heading-main">
        CONSENTIMIENTO DE HOSPITALIZACIÓN
      </div>

      <table class="meta-table">
        <tbody>
          <tr>
            <td>
              <span class="meta-label">Fecha y hora de emisión:</span>
              @fecha
            </td>
          </tr>
          <tr>
            <td>
              <span class="meta-label">Paciente número:</span>
              @ValorOuNoEspecificado(Model.NumeroPaciente)
            </td>
          </tr>
        </tbody>
      </table>

      <!-- Resumen superior: Datos rápidos del paciente -->
      <table class="block keep">
        <tbody>
          <tr class="block-header">
            <th colspan="2">DATOS DEL PACIENTE</th>
          </tr>
          <tr class="kv-row">
            <td style="width: 50%; padding: 8px 12px;">
              <span class="label">Nombre:</span>
              <span class="value">
                @ValorOuNoEspecificado(Model.NombreCompleto)
              </span>
            </td>
            <td style="width: 50%; padding: 8px 12px;">
              <span class="label">Número de habitación:</span>
              <span class="value">
                @ValorOuNoEspecificado(Model.NumeroHabitacion)
              </span>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- Registro de admisión -->
      <table class="section-title" style="margin-top: 50px;">
        <tr>
          <td class="section-bar blue"></td>
          <td class="section-title-text">
            REGISTRO DE ADMISIÓN A HOSPITALIZACIÓN
          </td>
        </tr>
      </table>

      <table class="block keep">
        <tbody>
          <tr class="kv-row">
            <td class="notes">
              <span class="value">
                <strong>Hora de ingreso:</strong>
                @ValorOuNoEspecificado(Model.HoraIngreso)<br />
                <strong># de Paciente:</strong>
                @ValorOuNoEspecificado(Model.NumeroPaciente)<br />
                <strong># de Habitación:</strong>
                @ValorOuNoEspecificado(Model.NumeroHabitacion)
              </span>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- I. DATOS DEL PACIENTE -->
      <table class="section-title" style="margin-top: 50px;">
        <tr>
          <td class="section-bar blue"></td>
          <td class="section-title-text">
            I. DATOS DEL PACIENTE
            <span class="subtle">
              : favor proporcionar el Documento Personal de Identificación
              para su registro (instrucción en el sistema: tener el espacio
              para digitalizar el documento de identificación y agregarlo al sistema)
            </span>
          </td>
        </tr>
      </table>

      <table class="block keep kv-table">
        <thead>
          <tr class="block-header">
            <th>Campo</th>
            <th>Información</th>
          </tr>
        </thead>
        <tbody>
          <tr class="kv-row">
            <th>Nombre</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.NombreCompleto)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Estado Civil</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.EstadoCivil)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Fecha de Nacimiento</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.FechaNacimiento)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Nacionalidad</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.Nacionalidad)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Profesión u oficio</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.Ocupacion)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Celular / Teléfono</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.Celular)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Tratamiento Médico</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.TratamientoMedico)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Tipo de Sangre</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.TipoSangre)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>DPI / Pasaporte</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.DPI)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>
              Dirección (indicar calle/avenida número de casa, zona,
              municipio y departamento)
            </th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.Direccion)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Correo Electrónico</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.Email)
              </span>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- III. RESPONSABLE DE LA CUENTA -->
      <table class="section-title" style="margin-top:300px">
        <tr>
          <td class="section-bar blue"></td>
          <td class="section-title-text">
            III. RESPONSABLE DE LA CUENTA
            <span class="subtle">
              &nbsp;(favor proporcionar el Documento Personal de Identificación
              para su registro)
            </span>
          </td>
        </tr>
      </table>

      <table class="block keep kv-table">
        <thead>
          <tr class="block-header">
            <th>Campo</th>
            <th>Información</th>
          </tr>
        </thead>
        <tbody>
          <tr class="kv-row">
            <th>Nombre</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.NombreResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Edad</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.EdadResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Nacionalidad</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.NacionalidadResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Profesión u oficio</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.OcupacionResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Celular / Teléfono</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.CelularResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>DPI / Pasaporte</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.DPIResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>
              Dirección (indicar calle/avenida número de casa, zona,
              municipio y departamento)
            </th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.DireccionResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Correo Electrónico</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.EmailResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Nit para facturación</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.NITResponsable)
              </span>
            </td>
          </tr>
          <tr class="kv-row">
            <th>Nombre para facturación</th>
            <td>
              <span class="value">
                @ValorOuNoEspecificado(Model.NombreFacturacion)
              </span>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- IV. CONTACTO DE EMERGENCIA -->
      <table class="section-title">
        <tr>
          <td class="section-bar blue"></td>
          <td class="section-title-text">
            IV. CONTACTO DE EMERGENCIA
          </td>
        </tr>
      </table>

      <!-- SECCIÓN CONTACTOS DE EMERGENCIA (MÚLTIPLES) -->
      @if (Model.ContactosEmergencia != null && Model.ContactosEmergencia.Any())
      {
        for (int i = 0; i < Model.ContactosEmergencia.Count; i++)
        {
          var contacto = Model.ContactosEmergencia[i];
          <div style="margin-bottom: 20px;">
            <div class="block-header"
                 style="background-color: #f2f2f2; padding: 8px; font-weight: bold; text-align: center;">
              Contacto de Emergencia @(i + 1)
            </div>
            <table class="block keep kv-table" style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
              <tbody>
                <tr class="kv-row">
                  <th style="border: 1px solid #ddd; padding: 8px;">Nombre</th>
                  <td style="border: 1px solid #ddd; padding: 8px;">
                    <span class="value">
                      @ValorOuNoEspecificado(contacto.Nombre)
                    </span>
                  </td>
                </tr>
                <tr class="kv-row">
                  <th style="border: 1px solid #ddd; padding: 8px;">Parentesco</th>
                  <td style="border: 1px solid #ddd; padding: 8px;">
                    <span class="value">
                      @ValorOuNoEspecificado(contacto.Parentesco)
                    </span>
                  </td>
                </tr>
                <tr class="kv-row">
                  <th style="border: 1px solid #ddd; padding: 8px;">Teléfono / Celular</th>
                  <td style="border: 1px solid #ddd; padding: 8px;">
                    <span class="value">
                      @ValorOuNoEspecificado(contacto.Telefono)
                    </span>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
        }
      }
      else
      {
        <div class="block keep kv-table" style="margin-bottom: 20px;">
          <div class="block-header"
               style="background-color: #f2f2f2; padding: 8px; font-weight: bold; text-align: center;">
            Contacto de Emergencia
          </div>
          <table class="kv-table" style="width: 100%; border-collapse: collapse;">
            <tbody>
              <tr class="kv-row">
                <th style="border: 1px solid #ddd; padding: 8px;">Nombre</th>
                <td style="border: 1px solid #ddd; padding: 8px;">
                  <span class="value">@ValorOuNoEspecificado(null)</span>
                </td>
              </tr>
              <tr class="kv-row">
                <th style="border: 1px solid #ddd; padding: 8px;">Parentesco</th>
                <td style="border: 1px solid #ddd; padding: 8px;">
                  <span class="value">@ValorOuNoEspecificado(null)</span>
                </td>
              </tr>
              <tr class="kv-row">
                <th style="border: 1px solid #ddd; padding: 8px;">Teléfono / Celular</th>
                <td style="border: 1px solid #ddd; padding: 8px;">
                  <span class="value">@ValorOuNoEspecificado(null)</span>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      }

      <!-- Nota y Política de depósito -->
      <table class="block keep">
        <tbody>
          <tr class="block-header">
            <th><strong>NOTA</strong></th>
          </tr>
          <tr>
            <td class="notes">
              <p>
                Al ingreso presentar el DPI o pasaporte del paciente y del
                responsable de la cuenta.
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <table class="block keep">
        <tbody>
          <tr class="block-header">
            <th><strong>POLÍTICA DE DEPÓSITO</strong></th>
          </tr>
          <tr>
            <td class="notes">
              <p>
                Hospital San Cristóbal solicitará un depósito inicial al momento
                del ingreso, cuyo monto dependerá del tipo de tratamiento y
                estimación de gastos médicos.
              </p>
              <p>
                En caso de hospitalizaciones prolongadas, se realizarán revisiones
                periódicas de la cuenta para actualizar los saldos y garantizar
                la continuidad de la atención.
              </p>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- ===========================
       PÁGINA 2: REGLAMENTO
       =========================== -->

      <!-- Reglamento de ingreso -->
      <table class="section-title">
        <tr>
          <td class="section-bar blue"></td>
          <td class="section-title-text">
            REGLAMENTO DE INGRESO
          </td>
        </tr>
      </table>

      <table class="block keep">
        <tbody>
          <tr>
            <td class="notes">
              <p class="text-justify">
                Para que su estancia en nuestras instalaciones sea lo más cómoda
                y segura posible, ponemos a su disposición nuestro equipo de
                profesionales, personas comprometidas con su salud y bienestar.
                A continuación, le presentamos las normas generales establecidas
                con el único objetivo de apoyar su proceso de recuperación.
              </p>

              <ul class="reglamento-list">
                <li class="text-justify">
                  <strong>Prohibición de ingreso y portación de armas:</strong>
                  El Hospital, en resguardo de la seguridad y bienestar de todos
                  los pacientes, visitantes y colaboradores, prohíbe estrictamente
                  el ingreso y/o portación de armas de fuego, armas blancas,
                  municiones o instrumentos que puedan representar un riesgo
                  físico o psicológico. En caso de detectarse la presencia de tales
                  objetos, el personal de seguridad estará facultado para denegar
                  el ingreso, solicitar el retiro inmediato o notificar a las
                  autoridades correspondientes.
                </li>
                <li class="text-justify">
                  Se permite el ingreso de un (1) acompañante mayor de edad por
                  paciente en el área de encamamiento.
                </li>
                <li class="text-justify">
                  El horario de visita es de 10:00 a 16:00 horas de lunes a domingo.
                </li>
                <li class="text-justify">
                  Está prohibido el ingreso de alimentos y bebidas al área de
                  encamamiento.
                </li>
                <li class="text-justify">
                  Está prohibido el ingreso de material de curación, equipo médico
                  y/o medicamentos.
                </li>
                <li class="text-justify">
                  Está prohibido fumar dentro de nuestras instalaciones.
                </li>
                <li class="text-justify">
                  Está prohibido el ingreso de mascotas.
                </li>
                <li class="text-justify">
                  Es obligatorio el uso de mascarilla.
                </li>
                <li class="text-justify">
                  Por protección de los niños y tranquilidad de nuestros pacientes,
                  está prohibida la entrada a menores de 12 años en áreas de
                  encamamiento.
                </li>
                <li class="text-justify">
                  Es responsabilidad del paciente y familiares el resguardo y
                  vigilancia de objetos de valor tales como joyas, dinero o
                  artículos electrónicos, eximiendo de responsabilidad a Hospital
                  San Cristóbal.
                </li>
                <li class="text-justify">
                  Todo menor de edad que se encuentre hospitalizado deberá estar
                  acompañado de un familiar mayor de edad de forma permanente.
                </li>
                <li class="text-justify">
                  Todo paciente mayor de sesenta y cinco (65) años de edad que se
                  encuentre hospitalizado y/o requiera asistencia especial deberá
                  contar con la compañía permanente de un familiar y/o responsable.
                  En caso de no ser posible, se asignará personal de enfermería
                  para atención continua, lo cual generará un recargo adicional en
                  la cuenta del paciente.
                </li>
              </ul>
            </td>
