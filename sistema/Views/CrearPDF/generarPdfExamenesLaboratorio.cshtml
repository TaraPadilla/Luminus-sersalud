                                                                <span class="valor-dato">@Model.Paciente.Nombre</span>
                                                            </td>
                                                            <td style="width: 20%;">
                                                                <span class="label-dato">Edad</span>
                                                                <span class="valor-dato">@Model.Paciente.Edad</span>
                                                            </td>
                                                            <td style="width: 40%;">
                                                                <span class="label-dato">Fecha Nacimiento</span>
                                                                <span class="valor-dato">@Model.Paciente.FechaNacimiento</span>
                                                            </td>
                                                        </tr>
                                                    </table>
                                                </div>

                                                <div class="header-secundario text-center mb-3">
                                                    <h5 style="margin:0;"><b>@Model.NombreExamen</b></h5>
                                                </div>

                                                <table class="tabla-moderna">
                                                    <thead>
                                                        <tr>
                                                            <th>Pregunta</th>
                                                            <th>Respuesta</th>
                                                            <th>Detalles</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var pregunta in Model.Preguntas)
                                                        {
                                                            <tr>
                                                                <td>¿@pregunta.Pregunta?</td>
                                                                <td>
                                                                    @if (pregunta.Respuesta == true)
                                                                    {
                                                                        <div>Si</div>
                                                                    }
                                                                    else
                                                                    {
                                                                        <div>No</div>
                                                                    }
                                                                </td>
                                                                <td>@pregunta.Detalles</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>

                                                <div class="header-secundario text-center mt-3">
                                                    <b>@Model.NombreExamen</b>
                                                </div>
                                                <table class="tabla-moderna">
                                                    <thead>
                                                        <tr>
                                                            @*<th><b>Item</b></th>*@
                                                            @*<th><b>Codigo Examen</b></th>*@
                                                            @*<th><b>Nombre</b></th>*@
                                                            <th><b>DECLARACIÓN DE CONSENTIMIENTO</b></th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @if (Model.NombreExamen != null)
                                                        {
                                                            <tr>
                                                                @*<td>@medicamento.Item</td>*@
                                                                @*<td>@Model.Id</td>*@
                                                                @*<td>@Model.NombreExamen</td>*@
                                                                <td>@Model.DeclaracionConsentimiento</td>
                                                            </tr>
                                                        }
                                                        else
                                                        {
                                                            <tr>
                                                                <td colspan="10" class="text-center">No hay Declaraciones registradas</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>

                                                <footer>
                                                    <div class="text-right footer-mensaje">
                                                        <b>"Porque será como medicina a tu cuerpo y refrigerio para tus huesos"</b>
                                                    </div>
                                                    <div class="footer-info text-center">
                                                        <strong><b>Horarios de atención:</b></strong><br>
                                                        <strong>Lunes a Viernes de 7:00 a 16:00 hrs. Teléfonos: 5842-3025</strong><br>
                                                        <strong>Sábado 7:00 a 12:00 hrs &nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Citas y consultas: 5842-3025 /
                                                            5858-4360</strong>
