@using Database.Shared.Models
@using System.Globalization
@using sistema.Models
@model ExamenLabClinicoViewModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration Config
@{
    Layout = "_HojaMembreteLayoutH";
    ViewData["ImagenLogo"] = Config["ImagenLogoBase64"];
    ViewData["Direccion"] = Config["EstablecimientoDireccion"];
    ViewData["Telefono"] = Config["EstablecimientoTelefono"];
    ViewData["CorreoElectronico"] = Config["EstablecimientoCorreoElectronico"];
    ViewData["ImagenFirma"] = Config["EstablecimientoImagenFirma"];
    DateTime fecha = DateTime.Now;
}

<style>
    /* Estilos Generales */
    .textoTipo {
        font-family: Georgia, serif;
        color: #333333;
    }

    .text-center {
        text-align: center;
    }

    .text-right {
        text-align: right;
    }

    .mt-3 {
        margin-top: 15px;
    }

    .mb-3 {
        margin-bottom: 15px;
    }

    /* Encabezados */
    .header-principal {
        width: 100%;
        background-color: #1D50BD;
        color: white;
        padding: 10px;
        font-family: Georgia, serif;
        font-size: 18px;
        text-transform: uppercase;
        border-radius: 4px 4px 0 0;
    }

    .header-secundario {
        width: 100%;
        background-color: #638ADD;
        color: white;
        padding: 8px;
        font-size: 14px;
    }

    /* Caja de Datos del Paciente */
    .caja-paciente {
        background-color: #f9fbfd;
        border: 1px solid #dce4ec;
        border-radius: 5px;
        padding: 10px;
        margin-bottom: 15px;
    }

    .caja-paciente-titulo {
        font-weight: bold;
        color: #1D50BD;
        border-bottom: 2px solid #1D50BD;
        padding-bottom: 5px;
        margin-bottom: 10px;
        font-size: 14px;
    }

    .tabla-paciente {
        width: 100%;
        border-collapse: collapse;
    }

    .tabla-paciente td {
        padding: 5px;
        vertical-align: top;
    }

    .label-dato {
        font-size: 11px;
        color: #638ADD;
        font-weight: bold;
        text-transform: uppercase;
        display: block;
    }

    .valor-dato {
        font-size: 14px;
        color: #000;
        font-weight: normal;
    }

    /* Tablas de Detalles/Indicaciones */
    .tabla-moderna {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
        border: 1px solid #dce4ec;
    }

    .tabla-moderna thead {
        background-color: #638ADD;
        color: white;
    }

    .tabla-moderna th {
        padding: 8px;
        text-align: left;
        font-weight: bold;
        border: 1px solid #5a7ec4;
    }

    .tabla-moderna td {
        padding: 8px;
        border: 1px solid #dce4ec;
        vertical-align: middle;
    }

    .tabla-moderna tr:nth-child(even) {
        background-color: #f9fbfd;
    }

    /* Footer */
    footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 15px;
        height: 14%;
        box-sizing: border-box;
    }

    .footer-mensaje {
        font-style: italic;
        color: #555;
        margin-bottom: 8px;
    }

    .footer-info {
        width: 100%;
        background-color: #1D50BD;
        color: white;
        padding: 10px;
        border-radius: 4px;
        line-height: 1.4;
    }
</style>

