@using sistema.Models
@model VentaUnificadaViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = farmamest.Utilidades.SerSaludUiHelper.ResolverLayout(Configuration);

    if (!string.IsNullOrWhiteSpace(Model.TipoVenta))
    {
        Model.ApplyTipoVenta();
    }

    ViewData["Title"] = Model.GetTituloPantalla();
    var tituloPantalla = Model.GetTituloPantalla();
}

<div class="main-card mb-3 card">
    <div class="card-body">
        <center>
            <h4>
                <b>
                    <span>@tituloPantalla</span>
                </b>
            </h4>
            @if (Model.IsClinica)
            {
                <span class="badge badge-primary mt-2">Venta clínica</span>
            }
            else if (Model.IsFarmacia)
            {
                <span class="badge badge-success mt-2">Venta farmacia</span>
            }
            else if (Model.IsLaboratorio)
            {
                <span class="badge badge-info mt-2">Venta laboratorio / exámenes</span>
            }
        </center>
    </div>
</div>

@await Html.PartialAsync("_VentaUnificadaForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                @if (Model.IsEmergencia)
                {
                    @* <button class="btn btn-success" data-bind="click:guardarEmergencia">
                        Guardar emergencia ))))
                    </button> *@

                     <button class="btn btn-success" data-bind="click:registrarVenta">
                        Registrar venta
                    </button>
                }
                else
                {
                    <button class="btn btn-success" data-bind="click:registrarVenta">
                        Registrar venta
                    </button>
                }

            </div>
        </div>
    </div>
</div>

@section Scripts{
<script src="~/ViewModelKo/VentaUnificadaVM.js"></script>
<script>
    $(document).ready(function () {
        // Simular cambio para forzar la carga de la información del cliente
        let clienteId = $("#ClienteId").val();
        if (clienteId) {
            $("#ClienteId").val(clienteId).trigger('change');
        }
    });
</script>

}

@section css{
<style>
    .seccion-header {
        background-color: #f5f5f5;
        padding: 15px;
        border-bottom: 2px solid darkgray;
    }

        .seccion-header:hover {
            background-color: darkgray;
            cursor: pointer;
        }
</style>
}
