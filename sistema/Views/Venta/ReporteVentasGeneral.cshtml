@{
    ViewData["Title"] = "Reporte General de Ventas";
}

<div class="container-fluid mt-4">

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex align-items-center">
            <i class="fa fa-file-pdf-o mr-2"></i>
            <strong>Reporte General de Ventas — Todos los Ambientes</strong>
        </div>

        <div class="card-body">

            <div class="row">

                <div class="col-md-3 form-group">
                    <label for="inputDesde"><i class="fa fa-calendar"></i> Fecha Desde</label>
                    <input type="date" id="inputDesde" class="form-control"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3 form-group">
                    <label for="inputHasta"><i class="fa fa-calendar"></i> Fecha Hasta</label>
                    <input type="date" id="inputHasta" class="form-control"
                           value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3 form-group">
                    <label for="inputAmbiente"><i class="fa fa-hospital-o"></i> Ambiente</label>
                    <select id="inputAmbiente" class="form-control">
                        <option value="0">— Todos —</option>
                        <option value="1">Farmacia</option>
                        <option value="2">Clínica</option>
                        <option value="3">Hospital</option>
                        <option value="4">Laboratorio</option>
                    </select>
                </div>

                <div class="col-md-3 form-group">
                    <label for="inputEmpleado"><i class="fa fa-user"></i> Empleado (opcional)</label>
                    <select id="inputEmpleado" class="form-control">
                        <option value="0">— Todos —</option>
                        @if (ViewBag.Empleados is Microsoft.AspNetCore.Mvc.Rendering.SelectList listaEmpleados)
                        {
                            foreach (var opcion in listaEmpleados)
                            {
                                <option value="@opcion.Value">@opcion.Text</option>
                            }
                        }
                    </select>
                </div>

            </div>

            <div class="row mt-2 align-items-center">

                <div class="col-md-8 form-group mb-0">
                    <label class="mb-1"><i class="fa fa-list-alt"></i> Detalle de ítems en el PDF</label>
                    <div class="d-flex flex-wrap align-items-center" style="gap:14px;">

                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="radio" name="modoDetalle" id="modoMonto" value="monto"
                                   checked onchange="sincronizarOpcionesReporte()" />
                            <label class="form-check-label" for="modoMonto">
                                <i class="fa fa-dollar"></i> Solo montos por categoría
                            </label>
                        </div>

                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="radio" name="modoDetalle" id="modoDescripcion"
                                   value="descripcion" onchange="sincronizarOpcionesReporte()" />
                            <label class="form-check-label" for="modoDescripcion">
                                <i class="fa fa-align-left"></i> Con descripción de ítems (servicios, exámenes, lab., paquetes, dietas)
                            </label>
                        </div>

                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="checkbox" id="chkConsolidadoItems" checked />
                            <label class="form-check-label" for="chkConsolidadoItems">
                                Incluir consolidado detallado de categorías (servicios, exámenes, lab., paquetes, dietas)
                            </label>
                        </div>

                        <div class="form-check form-check-inline m-0">
                            <input class="form-check-input" type="checkbox" id="chkConsolidadoMedicos" />
                            <label class="form-check-label" for="chkConsolidadoMedicos">
                                Incluir consolidado por médico y por especialidad
                            </label>
                        </div>

                    </div>
                </div>

                <div class="col-md-4 form-group mb-0 text-md-right">
                    <button type="button" id="btnGenerarPdf" class="btn btn-danger mr-2" onclick="generarReportePDF()">
                        <i class="fa fa-file-pdf-o"></i> Generar PDF
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="limpiarFiltros()">
                        <i class="fa fa-refresh"></i> Limpiar
                    </button>
                </div>

            </div>

            <div id="pdfLoadingAlert" class="alert alert-info mt-3 mb-0 d-none" role="status">
                <i class="fa fa-spinner fa-spin mr-2"></i>
                Generando PDF, por favor espere…
            </div>

        </div>
    </div>

</div>


<script>
    function sincronizarOpcionesReporte() {
        var modo = document.querySelector("input[name='modoDetalle']:checked").value;
        var chkItems = document.getElementById("chkConsolidadoItems");
        var chkMedicos = document.getElementById("chkConsolidadoMedicos");

        chkItems.checked = true;
        if (modo === "descripcion") {
            chkMedicos.checked = true;
        }
    }

    document.addEventListener("DOMContentLoaded", sincronizarOpcionesReporte);

    function setPdfLoading(activo) {
        var btn = document.getElementById("btnGenerarPdf");
        var alerta = document.getElementById("pdfLoadingAlert");
        btn.disabled = activo;
        if (activo) {
            alerta.classList.remove("d-none");
        } else {
            alerta.classList.add("d-none");
        }
    }

    function formatPdfError(text) {
        if (!text) return "No se pudo generar el PDF.";
        var plain = text.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
        if (/Npgsql|SSL handshake|SocketException|transient failure/i.test(plain)) {
            return "No se pudo conectar a la base de datos PostgreSQL. "
                + "En desarrollo use la base local; en producción verifique red y conexión al servidor.";
        }
        if (/wkhtmltopdf/i.test(plain)) {
            return "No se pudo generar el PDF: wkhtmltopdf no está disponible en el servidor.";
        }
        if (plain.length > 280) return plain.substring(0, 280) + "…";
        return plain;
    }

    function generarReportePDF() {
        var desde = document.getElementById("inputDesde").value;
        var hasta = document.getElementById("inputHasta").value;
        var ambienteId = document.getElementById("inputAmbiente").value;
        var empleadoId = document.getElementById("inputEmpleado").value;
        var modoDetalle = document.querySelector("input[name='modoDetalle']:checked").value;
        var incluirConsolidadoItems = document.getElementById("chkConsolidadoItems").checked;
        var incluirConsolidadoMedicos = document.getElementById("chkConsolidadoMedicos").checked;

        if (!desde || !hasta) {
            alert("Por favor selecciona el rango de fechas.");
            return;
        }
        if (new Date(desde) > new Date(hasta)) {
            alert("La fecha 'Desde' no puede ser mayor que la fecha 'Hasta'.");
            return;
        }

        var url = "/CrearPDF/ReporteVentasGeneralPDF"
            + "?desde=" + encodeURIComponent(desde)
            + "&hasta=" + encodeURIComponent(hasta)
            + "&ambienteId=" + ambienteId
            + "&empleadoId=" + empleadoId
            + "&modoDetalle=" + encodeURIComponent(modoDetalle)
            + "&incluirConsolidadoItems=" + incluirConsolidadoItems
            + "&incluirConsolidadoMedicos=" + incluirConsolidadoMedicos;

        setPdfLoading(true);

        fetch(url, { credentials: "same-origin" })
            .then(function (response) {
                var contentType = (response.headers.get("content-type") || "").toLowerCase();
                if (!response.ok) {
                    return response.text().then(function (text) {
                        throw new Error(text || ("Error " + response.status + " al generar el PDF."));
                    });
                }
                if (contentType.indexOf("application/pdf") === -1) {
                    return response.text().then(function (text) {
                        throw new Error(text || "El servidor no devolvió un PDF válido.");
                    });
                }
                return response.blob();
            })
            .then(function (blob) {
                var blobUrl = window.URL.createObjectURL(blob);
                var enlace = document.createElement("a");
                enlace.href = blobUrl;
                enlace.download = "ReporteVentasGeneral_" + desde + "_" + hasta + ".pdf";
                document.body.appendChild(enlace);
                enlace.click();
                document.body.removeChild(enlace);
                window.setTimeout(function () { window.URL.revokeObjectURL(blobUrl); }, 60000);
            })
            .catch(function (err) {
                alert(formatPdfError(err.message));
            })
            .finally(function () {
                setPdfLoading(false);
            });
    }

    function limpiarFiltros() {
        var hoy = new Date().toISOString().split("T")[0];
        document.getElementById("inputDesde").value = hoy;
        document.getElementById("inputHasta").value = hoy;
        document.getElementById("inputAmbiente").value = "0";
        document.getElementById("inputEmpleado").value = "0";
        document.querySelector("input[name='modoDetalle'][value='monto']").checked = true;
        document.getElementById("chkConsolidadoItems").checked = true;
        sincronizarOpcionesReporte();
    }
</script>
