@using sistema.Models
@model VentaUnificadaViewModel

@{
    if (!string.IsNullOrWhiteSpace(Model.TipoVenta))
    {
        Model.ApplyTipoVenta();
    }
}

@* @Html.HiddenFor(m => m.ClienteId) *@
@Html.HiddenFor(m => m.ConsultaId)
@Html.HiddenFor(m => m.EmergenciaId)
@Html.HiddenFor(m => m.AmbienteId)
@Html.HiddenFor(m => m.TipoVenta)
@Html.HiddenFor(m => m.IsClinica)
@Html.HiddenFor(m => m.IsFarmacia)
@Html.HiddenFor(m => m.IsLaboratorio)
@Html.HiddenFor(m => m.IsEmergencia)
@Html.HiddenFor(m => m.CodigoMedico)
@Html.HiddenFor(m => m.CitaTipoAtencion)
@Html.HiddenFor(m => m.ResponsableNit)
@Html.HiddenFor(m => m.ResponsableNombre)
@Html.HiddenFor(m => m.ResponsableDireccion)
@Html.HiddenFor(m => m.ResponsableCorreo)
@Html.HiddenFor(m => m.Origen)
@if (Context.Request.Query["isEmergencia"] == "true" || 
     Context.Request.Query["tipoVenta"] == "laboratorio" ||
     Context.Request.Query["isLaboratorio"] == "True" || 
     Context.Request.Query["tipoVenta"] == "clinica" ||
     Context.Request.Query["isClinica"] == "True")
{
    @Html.HiddenFor(m => m.ClienteId)
}
<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <div id="tabs-venta">
                    <ul>
                        <li><a href="#tab-encabezado">Encabezado</a></li>
                        <li><a href="#tab-detalles">Detalles</a></li>
                        <li><a href="#tab-datos-pago">Datos de pago</a></li>
                        @*  @if (Model.IsLaboratorio)
                        {
                        <li><a href="#tab-preguntas-concentimiento">Preguntas Concentimiento</a></li>
                        } *@
                    </ul>
                    <div id="tab-encabezado">
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-4">
                                        <label class="font-weight-bold">Número de comprobante</label>
                                        @Html.TextBoxFor(m => m.NumeroComprobante, new { @class = "form-control", @placeholder = "000000" })
                                    </div>
                                    <div class="col-md-4">
                                        <label class="font-weight-bold">Sucursal</label>
                                        <select class="form-control" disabled asp-for="SucursalId" asp-items="Model.ListaSucursales"></select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="font-weight-bold">Código del vendedor</label>
                                        @Html.TextBoxFor(m => m.CodigoVendedor, new { @class = "form-control", @readonly = "readonly" })
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">@(Model.IsFarmacia ? "Cliente" : "Paciente")</label>
                                        <select class="form-control select2bs4" style="width: 100%;" id="select-cliente" 
                                                @( !string.IsNullOrWhiteSpace(Model.ResponsableNombre) ? "disabled" : "" )>
                                            <option value="">Seleccione cliente...</option>
                                            @if (Model.ListaClientes != null)
                                            {
                                                foreach (var item in Model.ListaClientes)
                                                {
                                                    if (item.Selected)
                                                    {
                                                        <option value="@item.Value" selected="selected">@item.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@item.Value">@item.Text</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">NIT</label>
                                        @Html.TextBox(Model.ResponsableNit != null ? "ResponsableNit" : "Nit", 
                                            Model.ResponsableNit ?? Model.Nit, 
                                            new { @class = "form-control", id = "Nit", 
                                                @readonly = Model.ResponsableNit != null ? "readonly" : null })
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">Nombre Responsable</label>
                                        @Html.TextBoxFor(m => m.ResponsableNombre, new { @class = "form-control", @readonly = "readonly" })
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">Dirección</label>
                                        @Html.TextBox("Direccion", Model.ResponsableDireccion ?? Model.Direccion, 
                                            new { @class = "form-control", id = "Direccion", 
                                                @readonly = Model.ResponsableDireccion != null ? "readonly" : null })
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">Email</label>
                                        @Html.TextBox("Correo", Model.ResponsableCorreo ?? Model.Correo, 
                                            new { @class = "form-control", id = "Correo", 
                                                @readonly = Model.ResponsableCorreo != null ? "readonly" : null })
                                    </div>

                                    <div class="col-md-4 mt-2">
                                        <label class="font-weight-bold">Fecha de Nacimiento</label>
                                        @Html.TextBoxFor(m => m.PacienteFechaNacimiento, "{0:yyyy-MM-dd}", 
                                            new { @class = "form-control", @type = "date", id = "PacienteFechaNacimiento",
                                                @readonly = Model.PacienteFechaNacimiento != DateTime.MinValue ? "readonly" : null })
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
