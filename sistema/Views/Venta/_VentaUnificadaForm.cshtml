        <div class="col-md-12 mb-2">
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                El paciente ingresado no existe en el sistema. Complete los datos para registrarlo.
            </div>
        </div>
        <div class="col-md-6">
            <label><b>Nombre completo <span class="text-danger">*</span></b></label>
            <input type="text" class="form-control" id="nuevo-cliente-nombre" placeholder="Nombre completo" />
        </div>
        <div class="col-md-6">
            <label><b>NIT</b></label>
            <input type="text" class="form-control" id="nuevo-cliente-nit" placeholder="NIT" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Dirección</b></label>
            <input type="text" class="form-control" id="nuevo-cliente-direccion" placeholder="Dirección" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Teléfono</b></label>
            <input type="text" class="form-control" id="nuevo-cliente-telefono" placeholder="Teléfono" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Fecha de nacimiento</b></label>
            <input type="date" class="form-control" id="nuevo-cliente-fecha-nacimiento" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Género</b></label>
            <select class="form-control" id="nuevo-cliente-genero">
                <option value="">-- Seleccione --</option>
                <option value="M">Masculino</option>
                <option value="F">Femenino</option>
            </select>
        </div>
        <div class="col-md-12 mt-2" id="mdl-nuevo-cliente-error" style="display:none">
            <div class="alert alert-danger" id="mdl-nuevo-cliente-error-msg"></div>
        </div>
    </div>
</div>
<script>
    $(document).ready(function() {
        // En lugar de buscar el ID directamente, atamos el evento al 'document'
        // y le decimos que escuche específicamente los cambios en '#esHonorario'
        $(document).on('change', '#esHonorario', function() {
            
            if ($(this).is(':checked')) {
                $('#divPrecioSelect').hide(); // Ocultamos el select
                $('#divPrecioInput').show();  // Mostramos el campo libre
            } else {
                $('#divPrecioInput').hide();  // Ocultamos el campo libre
                $('#divPrecioSelect').show(); // Mostramos el select
            }
            
        });
    });
</script>