@using Database.Shared.Enumeraciones
@model sistema.Models.CajaBaseViewModel
@{
    var ambiente = "";
    switch (Model.AperturarAmbienteId)
    {
        case (int)AmbienteEnum.Clinica:
            ambiente = "Clinica";
            break;
        case (int)AmbienteEnum.Farmacia:
            ambiente = "Farmacia";
            break;
        case (int)AmbienteEnum.Hospital:
            ambiente = "Hospital";
            break;
        case (int)AmbienteEnum.Laboratorio:
            ambiente = "Laboratorio";
            break;
        case (int)AmbienteEnum.Global:
            ambiente = "Global";
            break;
    }
    var titulo = "Caja - " + ambiente;
    ViewData["Title"] = titulo;

    //Roles
    var usuarioAdministrador = User.IsInRole("Administrador");
    var usuarioDesarrollador = User.IsInRole("Desarrollador");
}

@await Html.PartialAsync("_MensajeExito")

<div class="form-row">
    <div class="col-md-6">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <div class="form-row">
                    <div class="col-md-6">
                        <label>Sucursal</label>
                        <select asp-for="AperturarSucursalId" asp-items="Model.ListaSucursales"
                                class="form-control" disabled>
                            @* @if (Model.AperturarAmbienteId == (int)AmbienteEnum.Global)
                            {
                                <option value="">TODAS</option>
                            } *@
                        </select>
                        @Html.ValidationMessageFor(a => a.AperturarSucursalId, "", new { @class = "text-danger"})
                    </div>
                    <div class="col-md-6">
                        <label>Ambiente</label>
                        <select asp-for="AperturarAmbienteId" class="form-control" disabled>
                            <option value="">Seleccione...</option>
                            <option value="@((int)AmbienteEnum.Farmacia)">Farmacia</option>
                            <option value="@((int)AmbienteEnum.Clinica)">Clinica</option>
                            <option value="@((int)AmbienteEnum.Hospital)">Hospital</option>
                            <option value="@((int)AmbienteEnum.Laboratorio)">Laboratorio</option>
                            <option value="@((int)AmbienteEnum.Global)">Global</option>
                        </select>
                        @Html.ValidationMessageFor(a => a.AperturarSucursalId, "", new { @class = "text-danger"})
                    </div>
                    <div class="col-md-6">
                        <label>Monto</label>
                        @Html.TextBoxFor(a => a.CajaMontoApertura, new {@class="form-control",
                        @placeholder="Monto a Aperturar"})
                        @Html.ValidationMessageFor(a => a.CajaMontoApertura, "", new { @class = "text-danger"})
                    </div>
                    <div class="col-md-6">
                        <label>Nombre</label>
                        @Html.TextBoxFor(a => a.CajaNombrePersonalizado, new {@class="form-control",
                        @placeholder="Nombre de caja"})
                        @Html.ValidationMessageFor(a => a.CajaNombrePersonalizado, "", new { @class = "text-danger"})
                    </div>
                    <div class="col-md-12">
                        <button class="btn btn-primary text-center" data-bind="click:aperturarCaja">
                            Abrir caja
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>


    @if (usuarioAdministrador || usuarioDesarrollador)
    {
        <div class="col-md-6">
            <form asp-controller="Caja" asp-action="Reporte" method="get" target="_blank">
                <input type="hidden" name="ambienteIdReporte" value="@Model.AperturarAmbienteId">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <div class="text-center">
                            <div class="position-relative form-group">
                                <label for="exampleEmail11" class="">Rango de fechas</label>
                                <div class="input-group">
                                    <input type="text" class="form-control float-right" id="reservationtime" name="fecha">
                                </div>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary text-center">Generar PDF</button>
                    </div>
                </div>
            </form>
        </div>
    }


</div>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <h5 class="font-weight-bold">Filtrar por sucursales</h5>
                <hr />
            </div>
            @if (Model.ListaSucursales != null)
            {
                foreach (var sucursal in Model.ListaSucursales)
                {
                    <div class="col-md-3">
                        <input type="checkbox" checked id="filtro-sucursal-@sucursal.Value"
                       data-bind="event:{change:aplicarFiltroSucursal}"
                       class="check-filtro-sucursal" />
                        <label for="filtro-sucursal-@sucursal.Value"> @sucursal.Text</label>
                    </div>
                }
            }
        </div>
    </div>
</div>



