                        }
                    </ul>
                    @if (Model.AperturarAmbienteId == (int)AmbienteEnum.Clinica)
                    {
                        <div id="tab-caja-clinica">
                            <div class="form-row">
                                <div class="col-md-12">
                                    <div class="table-responsive">
                                        <table class="mb-0 table table-hover ">
                                            <thead>
                                                <tr>
                                                    <th>Sucursal / Ambiente</th>
                                                    <th>Fecha de apertura</th>
                                                    <th>Resp. Apertura</th>
                                                    <th>Monto de apertura</th>
                                                    <th>Ingresos</th>
                                                    <th>Gastos</th>
                                                    <th>Fecha de cierre</th>
                                                    <th>Resp. Cierre</th>
                                                    <th>Total Cierre</th>
                                                    <th>Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in Model.ListaCajas)
                                                {
                                                    if (item.AmbienteId == (int)TipoBodegaEnum.Clinica)
                                                    {
                                                        @if (item.EstadoCaja == true)
                                                        {
                                                            var personaApertura = item.ResponsableApertura == null ? "" : item.ResponsableAperturaText;
                                                            var personaCierre = item.ResponsableCierre == null ? "" : item.ResponsableCierreText;

                                                            <tr class="bg-success reg-sucursal-@item.SucursalId">
                                                                <td>
                                                                    @(item.Sucursal!=null?item.Sucursal.NombreSucursal:"-") /<br />
                                                                    <span class="badge badge-primary">
                                                                        @(item.Ambiente!=null?item.Ambiente.NombreAmbiente:"-")
                                                                    </span>
                                                                </td>
                                                                <td>@item.FechaApertura</td>
                                                                <td>@personaApertura</td>
                                                                <td>@item.MontoApertura</td>
                                                                <td>@item.DetalleCajas.Sum(x => x.Ingreso)</td>
                                                                <td>@item.DetalleCajas.Sum(x => x.Gasto)</td>
                                                                <td>@item.FechaCierre</td>
                                                                <td>@personaCierre</td>
                                                                @{
                                                                    decimal suma1 = item.DetalleCajas.Sum(x => x.Ingreso - x.Gasto);
                                                                    decimal montoap = item.MontoApertura;

                                                                    decimal res = suma1 + montoap;
                                                                }
                                                                <td>@res</td>
                                                                <td>
                                                                    <a href="@Url.Action("VerDetalle","Caja", new {id = @item.Id})" class="btn btn-warning btn-sm">
                                                                        <i class="fas fa-eye"></i>
                                                                    </a>
                                                                </td>
                                                            </tr>
                                                        }
                                                        else
                                                        {
                                                            @if(usuarioAdministrador || usuarioDesarrollador)
                                                            {
                                                                var personaApertura = item.ResponsableApertura == null ? "" : item.ResponsableAperturaText;
                                                                var personaCierre = item.ResponsableCierre == null ? "" : item.ResponsableCierreText;

                                                                <tr class="reg-sucursal-@item.SucursalId">
                                                                    <td>
                                                                        @(item.Sucursal != null ? item.Sucursal.NombreSucursal : "-") /<br />
                                                                        <span class="badge badge-primary">
                                                                            @(item.Ambiente != null ? item.Ambiente.NombreAmbiente : "-")
                                                                        </span>
                                                                    </td>
                                                                    <td>@item.FechaApertura</td>
                                                                    <td>@personaApertura</td>
                                                                    <td>@item.MontoApertura</td>
                                                                    <td>@item.DetalleCajas.Sum(x => x.Ingreso)</td>
