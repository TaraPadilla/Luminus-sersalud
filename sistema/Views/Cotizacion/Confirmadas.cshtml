@using Database.Shared.Paginacion;
@model PaginacionList<Database.Shared.Models.Cotizacion>

@{
    ViewData["Title"] = "Cotizaciones - Confirmadas";
}


@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <center><h4><b>Cotizaciones - Confirmadas</b></h4></center>
    </div>
</div>

<form asp-action="Lista" method="get">
    <div class="col-md-12">
        <div class="input-group">
            <div class="input-group-prepend">
                <input type="submit" value="Buscar" class="btn btn-success"></input>
            </div>
            <input type="text" name="buscar" value="@ViewData["CurrentFilter"]" class="form-control"
                   placeholder="Buscar Venta...">
        </div>
    </div>
</form>

<br />
<div class="tab-pane tabs-animation fade show active" id="tab-content-0" role="tabpanel">
    <div class="main-card mb-3 card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="mb-0 table table-hover ">
                    <thead>
                        <tr>
                            <th>Fecha Cotizacion</th>
                            <th>Emergencia #</th>
                            <th>Cliente</th>
                            <th>Nit</th>
                            <th>Direccion</th>
                            <th>Valido Hasta</th>
                            <th>Total</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (item.FechaCotizacion != null)
                                    {
                                        DateTime f = (DateTime)item.FechaCotizacion;
                                        <label>@f.ToString("dd/MM/yyyy hh:mm tt")</label>
                                    }
                                </td>
                                <td>@item.Id</td>
                                <td>@item.Nombres</td>
                                <td>@item.Nit</td>
                                <td>@item.Direccion</td>
                                <td>
                                    @if (item.FechaValida != null)
                                    {
                                        DateTime d = (DateTime)item.FechaValida;
                                        <label>@d.ToString("dd/MM/yyyy hh:mm tt")</label>
                                    }
                                </td>
                                <td>Q @item.DetalleCotizacion.Sum(a => a.Total)</td>
                                <td>
                                    <a href="@Url.Action("Modificar","Cotizacion", new {id = @item.Id})"
                                   class="btn btn-primary">
                                        Ver detalles
                                    </a>
                                    <a href="@Url.Action("Delete","Cotizacion", new {id = @item.Id, view = "Confirmadas"})"
                                   class="btn btn-danger">
                                        Eliminar
                                    </a>
                                    @* <a href="@Url.Action("Eliminar","Venta", new {id = @item.Id})" class="btn
                                        btn-danger">
                                        Eliminar
                                        </a> *@
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<a asp-action="Confirmadas" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@(Model.PageIndex - 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-danger btn-sm @prevDisabled">
    Anterior
</a>

<a asp-action="Confirmadas" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@(Model.PageIndex + 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-danger btn-sm @nextDisabled" class="">
    Siguiente
</a>