@{
    ViewData["Title"] = "Nueva receta";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>Nueva Categoria</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_CuentasForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div>
            <button class="btn btn-danger" data-bind="click: cancelarRegistroCuenta">
                Cancelar
            </button>
            <button class="btn btn-primary" data-bind="click:registrarCuenta">
                Guardar Cuenta
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="~/ViewModelKo/CuentasVM.js"></script>
}