@{
    ViewData["Title"] = "Panel de Reportes";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="text-secondary border-bottom pb-2">
                <i class="fas fa-chart-line mr-2"></i>Centro de Reportes
            </h2>
            <p class="text-muted">Seleccione el reporte que desea generar y descargar.</p>
        </div>
    </div>

    <div class="row">
        
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center mt-3">
                    <i class="fas fa-file-excel fa-4x text-success mb-3"></i>
                    
                    <h5 class="card-title font-weight-bold">Informe Semanal</h5>
                    <h6 class="card-subtitle mb-2 text-muted">Renglón 292-261</h6>
                    <p class="card-text small mt-3">
                        Reporte de productos utilizados en el servicio de lavandería (Detergentes, Cloro, etc.).
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pb-4 text-center">
                    <a asp-action="ExportarExcelLavanderia" asp-controller="SuministrosReportes"
                           class="btn btn-outline-success px-4">
                        <i class="fas fa-download mr-1"></i> Descargar Excel
                    </a>
                </div>
            </div>
        </div>

        <<div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center mt-3">
                    <i class="fas fa-file-medical-alt fa-4x text-info mb-3"></i>
            
                    <h5 class="card-title font-weight-bold">Matriz de Datos del Hospital</h5>
                    <h6 class="card-subtitle mb-2 text-muted">Consolidado por Servicios</h6>
                    <p class="card-text small mt-3">
                        Reporte de consumos hospitalarios clasificados por grupos (Oficina, Limpieza, Químicos, etc.)
                        con suma total.
                    </p>
                </div>
                <div class="card-footer bg-white border-0 pb-4 text-center">
                    <a asp-action="ExportarMatrizHospital" asp-controller="SuministrosReportes" class="btn btn-outline-info px-4">
                        <i class="fas fa-download mr-1"></i> Descargar Excel
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>