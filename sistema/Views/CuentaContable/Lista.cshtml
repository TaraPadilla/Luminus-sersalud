@using Database.Shared.Models
@model List<CuentaContable>
@{
    ViewData["Title"] = "Cuentas contables";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <center><h4><b>Cuentas contables</b></h4></center>
                <hr />
                <a class="btn btn-danger" asp-action="Nuevo" asp-controller="CuentaContable">
                    Nueva Cuenta
                </a>
            </div>
        </div>
    </div>
</div>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tabla-cuenta-contable" class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Nombre de la cuenta</th>
                        <th>Especificaciones</th>
                        <th>Banco</th>
                        <th>Cuenta</th>
                        <th>Nomenclatura</th>
                        <th>Categoría</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var cuenta in Model)
                        {
                            var nomenclaturaText = cuenta.Nomenclatura != null && cuenta.Nomenclatura.Any()
                                ? string.Join(" - ", cuenta.Nomenclatura
                                    .Where(x => x.Nomenclatura != null)
                                    .Select(x => x.Nomenclatura.Nombre))
                                : "—";
                            <tr>
                                <td>@cuenta.NombreCuenta</td>
                                <td>@(cuenta.Especificaciones ?? "—")</td>
                                <td>@(cuenta.Banco?.Nombre ?? "—")</td>
                                <td>@(cuenta.Cuenta?.NumeroCuenta ?? "—")</td>
                                <td>@nomenclaturaText</td>
                                <td>@(cuenta.CategoriaCuenta?.Nombre ?? "—")</td>
                                <td>
                                    <button class="btn btn-warning" onclick="modificarCuenta(@cuenta.Id)">
                                        <i class="fa fa-edit"></i>
                                    </button>
                                    <button class="btn btn-danger" onclick="eliminarCuenta(@cuenta.Id)">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/ViewModelKo/CuentaContableListaVM.js"></script>
}
