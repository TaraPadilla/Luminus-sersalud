@using sistema.Models
@using Database.Shared.Models
@model EmpleadoBaseViewModel

<form id="formModificarEmpleado" asp-controller="Empleado" asp-action="Modificar" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Empleado.Id" />
    <input type="hidden" name="TipoEmpleadoFormulario" value="@Model.TipoEmpleadoFormulario" />
    <input type="hidden" asp-for="Empleado.UnidadOrgId" />
    <input type="hidden" asp-for="Empleado.SeccionOrgId" />

    <div class="tab-pane tabs-animation fade show active" id="tab-content-0" role="tabpanel">
        <div class="main-card mb-3 card shadow-sm border-0">
            <h5 class="card-header bg-white font-weight-bold text-dark">Modificar Empleado</h5>
            <div class="card-body">

                <h6 class="text-uppercase text-muted font-weight-bold border-bottom pb-2 mb-3">Nombre y Apellido</h6>
                <div class="form-row mb-4">
                    <div class="col-12 col-md-6">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Nombre<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Nombre, new { @class = "form-control", placeholder = "Nombre", data_bind = "value: Nombre" })
                            @Html.ValidationMessageFor(a => a.Empleado.Nombre, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-12 col-md-6">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Apellido<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Apellido, new { @class = "form-control", placeholder = "Apellido", data_bind = "value: Apellido" })
                            @Html.ValidationMessageFor(a => a.Empleado.Apellido, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <h6 class="text-uppercase text-muted font-weight-bold border-bottom pb-2 mb-3">Datos De Contacto</h6>
                <div class="form-row mb-4">
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Telefono<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Telefono, new { type = "text", @class = "form-control", placeholder = "Telefono", data_bind = "value: Telefono" })
                            @Html.ValidationMessageFor(a => a.Empleado.Telefono, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Telefono 2</label>
                            @Html.TextBoxFor(a => a.Empleado.Telefono_2, new { type = "text", @class = "form-control", placeholder = "Telefono 2", data_bind = "value: Telefono_2" })
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Email<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Email, new { type = "text", @class = "form-control", placeholder = "Email", data_bind = "value: Email" })
                            @Html.ValidationMessageFor(a => a.Empleado.Email, "", new { @class = "text-danger" })
                        </div>
                    </div>
                </div>

                <h6 class="text-uppercase text-muted font-weight-bold border-bottom pb-2 mb-3">Datos Personales y Laborales</h6>
                <div class="form-row">
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="position-relative form-group">
                            <label>Edad</label>
                            @Html.TextBoxFor(a => a.Empleado.Edad, new { type = "number", @class = "form-control", placeholder = "Edad", data_bind = "value: Edad" })
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Dpi<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Dpi, new { type = "text", @class = "form-control", placeholder = "Dpi", data_bind = "value: Dpi" })
                            @Html.ValidationMessageFor(a => a.Empleado.Dpi, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Nit<span class="text-danger"> * Obligatorio</span></label>
                            @Html.TextBoxFor(a => a.Empleado.Nit, new { type = "text", @class = "form-control", placeholder = "Nit", data_bind = "value: Nit" })
                            @Html.ValidationMessageFor(a => a.Empleado.Nit, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="position-relative form-group">
                            <label>Estado Civil</label>
                            <select class="form-control select2bs4" style="width: 100%;" asp-for="Empleado.EstadoCivil" data-bind="value: EstadoCivil">
                                <option value="">Seleccione una opción</option>
                                <option value="Soltero/a">Soltero/a</option>
                                <option value="Casado/a">Casado/a</option>
                                <option value="Viudo/a">Viudo/a</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-12">
                        <div class="position-relative form-group">
                            <label>Direccion</label>
                            @Html.TextBoxFor(a => a.Empleado.Direccion, new { @class = "form-control", placeholder = "Direccion", data_bind = "value: Direccion" })
                        </div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Tipo de contrato</label>
                            <select class="form-control select2bs4" style="width: 100%;" asp-for="Empleado.TipoContrato" data-bind="value: TipoContrato">
                                <option value="">Seleccione una opción</option>
                                <option value="Fijo">Fijo</option>
                                <option value="Eventual">Eventual</option>
                                <option value="Vacacionista">Vacacionista</option>
                                <option value="Indefinido">Indefinido</option>
                                <option value="Mixto">Mixto</option>
                                <option value="ServiciosProfesionalesEIndependientes">Servicios Profesionales e Independientes</option>
                                <option value="SinContrato">Sin Contrato</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Salario</label>
                            @Html.TextBoxFor(a => a.Empleado.Salario, new { @class = "form-control", placeholder = "Salario", data_bind = "value: Salario" })
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Telefono de la clinica</label>
                            @Html.TextBoxFor(a => a.Empleado.TelefonoClinica, new { type = "text", @class = "form-control", placeholder = "Telefono de la clinica", data_bind = "value: TelefonoClinica" })
                        </div>
                    </div>
                </div>

                <div class="form-row mb-4">
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Sucursal</label>
                            <select class="form-control" asp-items="Model.ListaSucursales" asp-for="Empleado.SucursalId" data-bind="value: SucursalId">
                                <option value="">Seleccione una sucursal</option>
                            </select>
                            @Html.ValidationMessageFor(a => a.Empleado.SucursalId, "", new { @class = "text-danger" })
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Tipo Empleado</label>
                            <select class="form-control" asp-for="Empleado.TipoEmpleado" data-bind="value: TipoEmpleado">
                                <option value="">Seleccione una opción</option>
                                <option value="Empleado">Empleado</option>
                                <option value="Administrador">Administrador</option>
                                <option value="Especialista">Especialista</option>
                                <option value="Licenciado">Licenciado</option>
                                <option value="Técnicos">Técnicos</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Jornada de Trabajo <span class="text-danger"> * Obligatorio</span></label>
                            <select class="form-control" asp-for="Empleado.JornadaTrabajo" data-bind="value: JornadaTrabajo">
                                <option value="">Seleccione una opción</option>
                                <option value="Diurna">Diurna</option>
                                <option value="Mixta">Mixta</option>
                                <option value="Nocturna">Nocturna</option>
                                <option value="No aplica">No está sujeto a jornada</option>
                            </select>
                        </div>
                    </div>
                </div>

                <h6 class="text-uppercase text-muted font-weight-bold border-bottom pb-2 mb-3">Ubicación Organizacional</h6>
                <div class="form-row mb-4">
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Departamento</label>
                            <select class="form-control"
                                    data-bind="value: DepartamentoId,
                                               options: DepartamentosOrg,
                                               optionsText: 'nombre',
                                               optionsValue: 'id',
                                               optionsCaption: 'Seleccione un departamento'">
                            </select>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Unidad</label>
                            <select class="form-control"
                                    data-bind="value: UnidadOrgId,
                                               options: UnidadesOrg,
                                               optionsText: 'nombre',
                                               optionsValue: 'id',
                                               optionsCaption: 'Seleccione una unidad',
                                               enable: DepartamentoId">
                            </select>
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Sección</label>
                            <select class="form-control"
                                    data-bind="value: SeccionOrgId,
                                               options: SeccionesOrg,
                                               optionsText: 'nombre',
                                               optionsValue: 'id',
                                               optionsCaption: 'Seleccione una sección',
                                               enable: UnidadOrgId">
                            </select>
                        </div>
                    </div>
                </div>

                <div class="form-row mb-4">
                    <div class="col-12 col-lg-6 mb-3 mb-lg-0">
                        <div class="position-relative form-group border rounded p-3 bg-light shadow-sm">
                            <label class="font-weight-bold text-primary">Inicio de Labores <span class="text-danger"> * Obligatorio</span></label>
                             <div class="form-row">
                                <div class="col-12">
                                    <label class="small text-muted font-weight-bold">Fecha Inicial</label>
                                   <input asp-for="Empleado.FechaInicioLabores"
                                   type="date"
                                   class="form-control mb-2"
                                   data-bind="value: FechaInicioLabores" />
                                    <span class="d-block mt-1 font-weight-bold text-info small">
                                        <i class="fa fa-calendar-check mr-1"></i> @Model.Empleado.FechaInicioLabores.ToString("dddd, dd 'de' MMMM 'de' yyyy")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-6">
                        <div class="position-relative form-group border rounded p-3 bg-light shadow-sm">
                            <label class="font-weight-bold text-primary">Vacaciones Programadas <span class="text-danger"> * Obligatorio</span></label>
                            <div class="form-row">
                                <div class="col-12 col-sm-6">
                                    <label class="small text-muted font-weight-bold">Fecha Inicial</label>
                                    <input asp-for="Empleado.VacacionesProgramadas"
                                           type="date"
                                           class="form-control"
                                           data-bind="value: VacacionesProgramadas" />
                                </div>
                                <div class="col-12 col-sm-6 mt-2 mt-sm-0">
                                    <label class="small text-muted font-weight-bold">Fecha Final</label>
                                    <input asp-for="Empleado.VacacionesProgramadasFinal"
                                           type="date"
                                           class="form-control"
                                           data-bind="value: VacacionesProgramadasFinal" />
                                </div>
                            </div>
                            <span class="d-block mt-2 font-weight-bold text-warning small">
                                <i class="fa fa-clock mr-1"></i> @Model.Empleado.VacacionesProgramadas.ToString("dd/MM/yyyy") - @Model.Empleado.VacacionesProgramadasFinal.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>
                </div>

               <h6 class="text-uppercase text-muted font-weight-bold border-bottom pb-2 mb-3">Configuración y Firma</h6>
                <div class="form-row mb-4">
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Fondo Calendario</label>
                            @Html.TextBoxFor(a => a.Empleado.ColorHexadecimalFondo, new { @class = "form-control p-1", type = "color", data_bind = "value: ColorHexadecimalFondo", style="height: 38px;" })
                        </div>
                    </div>
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Texto Calendario</label>
                            @Html.TextBoxFor(a => a.Empleado.ColorHexadecimalTexto, new { @class = "form-control p-1", type = "color", data_bind = "value: ColorHexadecimalTexto", style="height: 38px;" })
                        </div>
                    </div>
                    
                    <div class="col-12 col-md-4">
                        <div class="position-relative form-group">
                            <label>Firma del Empleado</label>
                            <input type="hidden" name="FirmaEmpleadoPath" value="@Model.Empleado.FirmaEmpleado" />
                            <div class="d-flex align-items-center">
                                <div class="mr-3 shadow-sm" style="width: 50px; height: 50px; border: 1px solid #ced4da; border-radius: 8px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #fff;">
                                    <img data-bind="attr: { src: FirmaPrevisualizacion }, visible: FirmaPrevisualizacion()" style="max-width: 100%; max-height: 100%;" />
                                    <i class="fas fa-signature text-muted" data-bind="visible: !FirmaPrevisualizacion()"></i>
                                </div>
                                @* <button type="button" class="btn btn-outline-primary shadow-sm" data-toggle="modal" data-target="#mdl-firma-empleado" data-bind="click: prepararModalFirma">
                                    <i class="fas fa-pen mr-1"></i> Configurar Firma
                                </button> *@
                                <button type="button" class="btn btn-outline-primary shadow-sm" 
                                    data-bind="click: prepararModalFirma">
                                    <i class="fas fa-pen mr-1"></i> Configurar Firma
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-row mb-3">
                    <div class="col-12">
                        <div class="position-relative form-group">
                            <label class="font-weight-bold">Observaciones</label>
                            @Html.TextAreaFor(a => a.Empleado.Observaciones, 4, 50, new { @class = "form-control", data_bind = "value: Observaciones", placeholder = "Escribe aquí cualquier observación adicional..." })
                        </div>
                    </div>
                </div>

                <hr class="mt-4 mb-4"/>
                
                <div class="d-flex justify-content-end">
                    <button type="button" class="btn btn-success btn-lg shadow-sm" data-bind="click: modificarEmpleado">
                        <i class="fa fa-save mr-2"></i> Guardar Cambios
                    </button>
                </div>

            </div>
        </div>
    </div>
</form>
