<!-- OVERLAY FIRMA - No usa Bootstrap modal, evita el problema del doble backdrop -->
<div id="mdl-firma-empleado" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; z-index:1055; align-items:center; justify-content:center;">
    <!-- Backdrop propio -->
    <div id="mdl-firma-backdrop" style="position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5);" onclick="window.cerrarModalFirmaEmpleado()"></div>
    <!-- Contenido -->
    <div style="position:relative; z-index:1; width:100%; max-width:800px; margin:auto; border-radius:14px; overflow:hidden; box-shadow:0 10px 40px rgba(0,0,0,0.3);">
        <div class="modal-content" style="border-radius:14px; overflow:hidden;">

            <div class="modal-header py-3" style="background:linear-gradient(135deg,#e3f2fd 0%,#bbdefb 100%);border-bottom:3px solid #1976d2;">
                <div class="d-flex align-items-center">
                    <div style="width:40px;height:40px;border-radius:10px;background:#bbdefb;display:flex;align-items:center;justify-content:center;margin-right:12px;">
                        <i class="fas fa-signature" style="color:#1976d2;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0 font-weight-bold text-dark">Firma del Empleado</h5>
                        <small class="text-muted">Dibuje o suba una imagen de su firma</small>
                    </div>
                </div>
                <button type="button" class="close ml-auto" onclick="window.cerrarModalFirmaEmpleado()">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="modal-body p-4" style="background:#f7f9fc;">
                <div id="selectorFirmaEmpleado">
                    <ul class="nav nav-pills mb-3 justify-content-center justify-content-sm-start" style="gap:8px;">
                        <li class="nav-item">
                            <a class="nav-link active" href="#" id="tabCanvasFirmaEmpleado" onclick="window._switchFirmaTabEmpleado('canvas'); return false;">
                                <i class="fas fa-pen mr-1"></i> Dibujar firma
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" id="tabArchivoFirmaEmpleado" onclick="window._switchFirmaTabEmpleado('archivo'); return false;">
                                <i class="fas fa-upload mr-1"></i> Subir imagen
                            </a>
                        </li>
                    </ul>

                    <div id="panelCanvasFirmaEmpleado">
                        <div class="text-center w-100" style="background:#fff; border:2px dashed #c5cedd; border-radius:10px; overflow:hidden;">
                            <canvas id="canvasFirmaEmpleado" style="width: 100%; height: 200px; cursor:crosshair; touch-action:none; display:block;"></canvas>
                        </div>
                        <div class="d-flex justify-content-between mt-3">
                            <button type="button" class="btn btn-outline-secondary shadow-sm" onclick="window.limpiarCanvasFirmaEmpleado()">
                                <i class="fas fa-eraser mr-1"></i> Limpiar
                            </button>
                            <button type="button" class="btn btn-outline-success shadow-sm" onclick="window.usarCanvasFirmaEmpleado()">
                                <i class="fas fa-check mr-1"></i> Usar esta firma
                            </button>
                        </div>
                    </div>

                    <div id="panelArchivoFirmaEmpleado" class="d-none">
                        <div class="p-4 border rounded text-center shadow-sm" style="background:#fff;">
                            <i class="fas fa-image fa-3x text-muted mb-3"></i>
                            <p class="text-muted mb-3 font-weight-bold">Seleccione una imagen de la firma</p>
                            <p class="small text-muted mb-3">(Formatos aceptados: PNG, JPG)</p>
                            <div class="custom-file text-left mx-auto" style="max-width: 350px;">
                                <input type="file" class="custom-file-input" id="inputArchivoFirma" accept="image/png, image/jpeg, image/jpg" onchange="window.previsualizarArchivoFirmaEmpleado(this)" />
                                <label class="custom-file-label" for="inputArchivoFirma" data-browse="Buscar">Elegir archivo...</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="contenedorPrevFirmaEmpleado" class="d-none mt-2 text-center w-100">
                    <p class="small font-weight-bold text-muted text-uppercase mb-2">Vista previa de la nueva firma</p>
                    <div class="d-flex justify-content-center w-100">
                        <img id="imgPrevFirmaEmpleado" alt="Firma Temporal" class="shadow-sm" style="max-height:160px; max-width:100%; border:1px solid #dee2e6; border-radius:8px; padding:6px; background:#fff; display:none; object-fit:contain;" onload="this.style.display='inline-block';" onerror="this.style.display='none';" />
                    </div>
                    <div class="mt-3">
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.resetearFirmaEmpleadoUI()">
                            <i class="fas fa-redo mr-1"></i> Cambiar firma
                        </button>
                    </div>
                </div>
            </div>

            <div class="modal-footer" style="background:#fff;border-top:1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary shadow-sm" onclick="window.cerrarModalFirmaEmpleado()">
                    <i class="fas fa-times mr-1"></i> Cancelar
                </button>
                @* <button type="button" class="btn btn-primary font-weight-bold shadow-sm" id="btnConfirmarFirmaEmpleado" disabled data-bind="click: confirmarFirmaModal">
                    <i class="fas fa-save mr-1"></i> Confirmar Firma
                </button> *@
                <button type="button" class="btn btn-primary font-weight-bold shadow-sm" id="btnConfirmarFirmaEmpleado" disabled data-bind="click: confirmarFirmaModal">
                    <i class="fas fa-save mr-1"></i> Confirmar Firma
                </button>
            </div>

        </div>
    </div>
</div>
