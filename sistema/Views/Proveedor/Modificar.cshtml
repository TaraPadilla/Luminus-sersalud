@{
    ViewData["Title"] = "Modificar Proveedor";
}
<div class="app-page-title">
    <div class="page-title-wrapper">

        <div class="page-title-heading">
            <div class="page-title-icon">
                <i class="pe-7s-graph text-success">
                </i>
            </div>
            <div>Proveedores
                <div class="page-title-subheading">Modifica un proveedor
                </div>
            </div>
        </div>
    </div>
</div>
 @await Html.PartialAsync("_MensajeExito")
<form asp-controller="Proveedor" asp-action="Modificar"  method="post">
@await Html.PartialAsync("_ProveedorForm")
</form>

<script>
    $(document).ready(function () {
        $('#SelectedTipoCompraId').change(function () {
            var selectedValue = $(this).val();
            if (selectedValue == "1") {
                $('#DiasCredito').prop('disabled', true);
            } else {
                $('#DiasCredito').prop('disabled', false);
            }
        });

        // Ejecutar al cargar la p·gina para establecer el estado inicial
        $('#SelectedTipoCompraId').trigger('change');
    });
</script>