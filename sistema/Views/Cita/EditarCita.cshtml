@using sistema.Models
@model CitaViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Editar cita";
    var cliente = Configuration["Cliente"];
    var puedeEditarHorario = User.IsInRole("CirugiaPlastica")
        || User.IsInRole("Admisiones")
        || User.IsInRole("Administrador")
        || User.IsInRole("Recepcion")
        || User.IsInRole("Recepcion Diurno")
        || User.IsInRole("Recepcion Nocturno")
        || cliente == "SS";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="row">
            <div class="col-md-12">
                <a asp-action="Lista" asp-controller="Cita" class="btn btn-danger">
                    <i class="fas fa-list"></i> &nbsp; Lista de citas
                </a>

                <a asp-action="CalendarioLineal" asp-controller="Cita" class="btn btn-danger"
                       asp-route-buscar="@Model.FechaHora.ToString("yyyy-MM-dd")">
                    <i class="fas fa-calendar-alt"></i> &nbsp; Regresar calendario
                    @Model.FechaHora.ToString("yyyy-MM-dd")
                </a>
            </div>
        </div>
    </div>
</div>

@if (puedeEditarHorario)
{
    <div class="main-card mb-3 card">
        <div class="card-body">
            <div class="border mb-4 rounded" style="overflow: hidden;">
                <div class="p-3" style="background-color: #fff9e6;">
                    <h4 class="fw-bold mb-0">Ajuste de Fecha y Hora <i class="fas fa-clock"></i></h4>
                </div>
                <div class="p-3">
                    <div class="row g-3">
                        <div class="col-md-4 mb-3">
                            <label class="form-label"><strong>Día</strong></label>
                            <input type="date" class="form-control" id="Dia"
                                   value="@Model.FechaHora.Date.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-md-5 mb-3">
                            <label class="form-label"><strong>Hora</strong></label>
                            <select class="form-control" id="Hora">
                                <option value="@Model.Hora">@Model.Hora</option>
                                @foreach (var hora in Model.Horas)
                                {
                                    if (hora != Model.Hora)
                                    {
                                        <option value="@hora">@hora</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@await Html.PartialAsync("_CitaForm")

@if (puedeEditarHorario)
{
    <div class="main-card mb-3 card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-12">
                    <button class="btn btn-primary" data-bind="click:editarCitaCP">
                        <i class="fas fa-save"></i> &nbsp; Editar cita
                    </button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="main-card mb-3 card">
        <div class="card-body">
            <div class="row">
                <div class="col-md-12">
                    <button class="btn btn-primary" data-bind="click:editarCita">
                        <i class="fas fa-save"></i> &nbsp; Editar cita
                    </button>
                </div>
            </div>
        </div>
    </div>
}


@section Scripts {
    <script src="~/ViewModelKo/CitaVM.js"></script>

    <script>
        // Bootstrap 4.3 tooltips
        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });

        // 1) Mandamos el modelo del servidor a JS
        window.__citaVmExternalInit = true;
        var serverModel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model));

        window.citaVm = new CitaVM(serverModel);
        ko.applyBindings(window.citaVm);
        window.citaVm.cargarEquipoQuirurgicoDesdeModel(serverModel);

        $(function () {
            window.citaVm.consultarPacientes();
            window.citaVm.consultarServiciosExistentes();
            window.citaVm.consultarExamenesExistentes();
            window.citaVm.consultarDepartamentosExistentes();
            var citaId = $("#CitaId").val();
            if (citaId && citaId.trim() !== "") {
                window.citaVm.consultarServiciosAgregadosCita();
                window.citaVm.consultarExamenesAgregadosCita();
            }
            if (citaId && citaId.trim() !== "" && $("#selectHabitacionEdicion").length) {
                window.citaVm.cargarHabitacionesEdicion(parseInt(citaId));
            }
        });
    </script>
}
