@model sistema.Models.CalendarioLinealViewModel
@using Database.Shared.Paginacion;

<div class="app-page-title">
    <div class="page-title-wrapper">

        <div class="page-title-heading">
            <div class="page-title-icon">
                <i class="pe-7s-graph text-success">
                </i>
            </div>
            <div>
                Reporte de Citas Agendadas
                <div class="page-title-subheading">
                    Citas
                </div>
            </div>

        </div>
    </div>
</div>


<ul class="body-tabs body-tabs-layout tabs-animated body-tabs-animated nav">

    <li class="nav-item">
        <a role="tab" class="nav-link" id="tab-2" data-toggle="tab" href="#tab-content-2">
            <span>Reporte Pdf</span>
        </a>
    </li>

</ul>

<div class="form-row">
    <div class="col-md-12">
        <div class="tab-pane tabs-animation fade show" id="tab-content-2" role="tabpanel">
            <div class="form">
                <div class="col-md-12">
                    <div class="main-card mb-3 card">
                        <div class="card-body">

                            <form asp-controller="CrearPdf" asp-action="CitasPorFechasPdf" method="post">
                                <div class="form-row">
                                    <div class="col-md-2">
                                        <label>Rango de fechas: </label>
                                        <div class="input-group">
                                            <input type="text" class="form-control float-right" id="reservationtime2" name="fecha">
                                        </div>
                                    </div>
                                    <div class="col-md-2">
                                        <label>Sucursal</label>
                                        <select class="form-control" asp-for="SucursalId" asp-items="Model.SucursalesSelectList">
                                            <option>Todas</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Medico</label>
                                        <select class="form-control" asp-for="EmpleadoId" asp-items="Model.EmpleadosSelectList">
                                            <option>Todos</option>
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Especialidad</label>
                                        <select class="form-control" asp-for="EspecialidadId" asp-items="Model.EspecialidadSelectListItem">
                                            <option>Todos</option>
                                        </select>
                                    </div>
                                </div>

                                <br />
                                <button type="submit" class="btn btn-primary">Ver Pdf</button>
                            </form>



                        </div>
                    </div>
                </div>
            </div>



        </div>








    </div>

</div>






@section Scripts
{

    <script type="text/javascript" src="~/js/moment.min.js"></script>
    <script type="text/javascript" src="~/js/daterangepicker.js"></script>
    <script type="text/javascript" src="~/js/tempusdominus-bootstrap-4.min.js"></script>

    <script>
        $(function () {
            //$('.select2').select2({
            //    tags: true
            //});

            //$('.select2bs4').select2({
            //  theme: 'bootstrap4',
            //  tags: true,
            //});

            $('#reservationtime').daterangepicker({
                timePicker: true,
                timePickerIncrement: 30,
                locale: {
                    format: 'DD/MM/YYYY HH:mm'
                }
            });
            $('#reservationtime2').daterangepicker({
                timePicker: true,
                timePickerIncrement: 30,
                locale: {
                    format: 'DD/MM/YYYY HH:mm'
                }
            });
        });



    </script>
}

@section css
{
    <link href="~/css/daterangepicker.css" rel="stylesheet">
}








