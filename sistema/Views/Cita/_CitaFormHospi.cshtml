function cargarHabitacionesPorCategoria(categoriaId, callback) {
    if (!categoriaId) {
        $('#HabitacionId').empty().append('<option selected>- Seleccione una habitación -</option>');
        return;
    }

    // Obtener valores de fecha y hora de los inputs
    var fechaInput = document.getElementById('fecha');
    var horaInput = document.getElementById('hora');
    
    if (!fechaInput || !horaInput) {
        console.error('No se encontraron los campos de fecha u hora');
        return;
    }

    var fecha = fechaInput.value; // formato yyyy-MM-dd
    var hora = horaInput.value;   // formato HH:mm

    if (!fecha || !hora) {
        console.warn('Fecha u hora vacías, se usará la fecha/hora actual como fallback');
        // Usar la fecha actual como fallback
        var ahora = new Date();
        fecha = ahora.toISOString().split('T')[0];
        hora = ahora.toTimeString().split(' ')[0].substring(0,5);
    }

    // Construir fecha de inicio válida (usando formato ISO)
    var fechaInicioStr = fecha + 'T' + hora + ':00';
    var fechaInicio = new Date(fechaInicioStr);
    
    // Validar que la fecha sea válida
    if (isNaN(fechaInicio.getTime())) {
        console.error('Fecha/hora inválida:', fechaInicioStr);
        $('#HabitacionId').empty().append('<option selected>- Error en fecha/hora -</option>');
        return;
    }

    // Calcular duración total (asegurarse de que los observables existan)
    var horas = (typeof citaHospiVm !== 'undefined' && citaHospiVm.totalDuracionHoras) 
                ? (citaHospiVm.totalDuracionHoras() || 0) : 0;
    var minutos = (typeof citaHospiVm !== 'undefined' && citaHospiVm.totalDuracionMinutos) 
                  ? (citaHospiVm.totalDuracionMinutos() || 0) : 0;
    var duracionMinutos = (horas * 60) + minutos;
    
    // Si no hay duración (p.ej. sin servicios), usar un mínimo de 60 minutos
    if (duracionMinutos <= 0) duracionMinutos = 60;

    // Calcular fecha fin
    var fechaFin = new Date(fechaInicio.getTime() + duracionMinutos * 60000);

    // Formatear para enviar al servidor (ISO)
    var fechaInicioISO = fechaInicio.toISOString();
    var fechaFinISO = fechaFin.toISOString();

    $.ajax({
        url: '/Cita/GetHabitacionesByCategoria',
        type: 'GET',
        data: {
            categoriaId: categoriaId,
            fechaInicio: fechaInicioISO,
            fechaFin: fechaFinISO,
            citaId: $('#CitaId').val() || null
        },
        success: function (data) {
            var select = $('#HabitacionId');
            select.empty();
            if (data && data.length > 0) {
                select.append('<option disabled>- Seleccione una habitación -</option>');
                $.each(data, function (i, hab) {
                    select.append($('<option>').val(hab.id).text(hab.nombreNumeroHabitacion));
                });
                // Seleccionar la primera opción válida
                var primera = select.find('option:not([disabled])').first();
                if (primera.length) {
                    select.val(primera.val());
                }
                if (typeof callback === 'function') callback();
            } else {
                select.append('<option selected>- Sin habitaciones disponibles -</option>');
            }
        },
        error: function (xhr, status, error) {
            console.error('Error al cargar habitaciones:', error);
            $('#HabitacionId').empty().append('<option selected>- Error al cargar -</option>');
        }
    });
}

        $('#CategoriaHabitacionId').change(function () {
            cargarHabitacionesPorCategoria($(this).val());
        });

        const acompananteSelector = document.getElementById("acompananteSelector");
        const acompananteSection = document.getElementById("acompananteSection");

        function toggleAcompananteSection() {
            if (acompananteSelector.value === "SI") {
                acompananteSection.style.display = "block";
            } else {
                acompananteSection.style.display = "none";
            }
        }

        toggleAcompananteSection();
        acompananteSelector.addEventListener("change", toggleAcompananteSection);
    });

    function calcularEdad(fechaInputId, edadInputId) {
        const fechaInput = document.getElementById(fechaInputId).value;
        const edadInput = document.getElementById(edadInputId);
        if (!fechaInput) {
            edadInput.value = "";
            return;
        }
        const hoy = new Date();
        const fechaNacimiento = new Date(fechaInput);
        let edad = hoy.getFullYear() - fechaNacimiento.getFullYear();
        const mes = hoy.getMonth() - fechaNacimiento.getMonth();
        if (mes < 0 || (mes === 0 && hoy.getDate() < fechaNacimiento.getDate())) {
            edad--;
        }
        edadInput.value = edad >= 0 ? edad : "";
    }

    function verificarEdad(edad) {
        if (isNaN(edad) || edad === null || edad === undefined) {
            return;
        }
        document.getElementById('datosPadre').style.display = edad < 18 ? 'block' : 'none';
        document.getElementById('datosMadre').style.display = edad < 18 ? 'block' : 'none';
    }

    let lastValue = '';
    setInterval(() => {
        const currentValue = document.getElementById('ABC').textContent;
        if (currentValue !== lastValue) {
            lastValue = currentValue;
            verificarEdad(currentValue);
        }
    }, 500);

    function formatearFechaHora(fecha, hora) {
        var fechaHora = new Date(fecha + 'T' + hora);
        var dia = fechaHora.getDate().toString().padStart(2, '0');
        var mes = (fechaHora.getMonth() + 1).toString().padStart(2, '0');
        var anio = fechaHora.getFullYear();
        var hora12 = fechaHora.getHours() % 12 || 12;
        var minutos = fechaHora.getMinutes().toString().padStart(2, '0');
        var ampm = fechaHora.getHours() >= 12 ? 'p. m.' : 'a. m.';
        return dia + '/' + mes + '/' + anio + ' ' + hora12 + ':' + minutos + ' ' + ampm;
    }

    function actualizarFechaHora() {
        var fecha = document.getElementById('fecha').value;
        var hora = document.getElementById('hora').value;
        if (fecha && hora) {
            var fechaHoraCombinada = formatearFechaHora(fecha, hora);
            document.getElementById('fechaHoraCombinadaText').textContent = fechaHoraCombinada;
            $("#FechaHora").val(fecha + 'T' + hora);
        }
    }

    document.getElementById('fecha').addEventListener('input', actualizarFechaHora);
    document.getElementById('hora').addEventListener('input', actualizarFechaHora);

</script>

@* El bloque del equipo quirúrgico se separa del script anterior para evitar *@
@* problemas de parsing con el bloque @if dentro de <script> *@
@if (esCalendario)
{
    <script>
        $(document).ready(function () {

            // Sincronizar campo cirujano con el médico asignado
            function sincronizarCirujano() {
                var texto = $("#EmpleadoId option:selected").text().trim();
                var val = $("#EmpleadoId").val();
                $("#cirujanoDiplay").val((val && val !== "" && texto !== "--- Sin Asignar ---") ? texto : "");
            }
            sincronizarCirujano();
            $("#EmpleadoId").on("change", sincronizarCirujano);

            // Cargar empleados del equipo quirúrgico por tipo
            $(".select-equipo-qx").each(function () {
                var $select = $(this);

                var especialidadNombre = ($select.data("especialidad-nombre") || "").toString().trim();
                var unidadNombre = ($select.data("unidad-nombre") || "").toString().trim();

                var params = {};
                if (especialidadNombre !== "") params.especialidadNombre = especialidadNombre;
                if (unidadNombre !== "") params.unidadNombre = unidadNombre;

                $.ajax({
                    url: "/Cita/GetEmpleadosPorTipo",
                    type: "GET",
                    data: params,
                    success: function (data) {
                        if ($select.hasClass("select2bs4") && $select.data("select2")) {
                            $select.select2("destroy");
                        }

                        $select.empty().append($('<option>').val("").text("Seleccione..."));

                        $.each(data, function (i, emp) {
                            // CORRECCIÓN: usar $('<option>').val() en lugar de concatenación
                            // de strings para que el value sea el ID real del empleado
                            var $opt = $('<option>').val(emp.id).text(emp.nombre);
                            $select.append($opt);
                        });

                        if ($select.hasClass("select2bs4")) {
                            $select.select2({
                                theme: "bootstrap4",
                                width: "100%",
                                minimumResultsForSearch: 0,
                                placeholder: "Buscar..."
                            });
                        }
                    },
                    error: function () {
                        console.error("Error al cargar empleados para #" + $select.attr("id"));
                    }
                });
            });

        });
    </script>
}
