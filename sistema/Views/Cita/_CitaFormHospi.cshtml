@using Database.Shared.Paginacion
@model sistema.Models.CitaViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var origenFormulario = (ViewData["OrigenFormulario"] as string) ?? "admision";
    var esCalendario = origenFormulario == "calendario";
    var esAdmision = origenFormulario == "admision";

    string clienteconf = Configuration["Cliente"]; 

}
@Html.HiddenFor(a => a.CitaId)
@Html.HiddenFor(a => a.PacienteId)
@Html.HiddenFor(a => a.EstadoCita)
@Html.HiddenFor(a => a.FechaHora)

@Html.HiddenFor(a => a.DepartamentoId)
@Html.HiddenFor(a => a.MunicipioId)


<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="mb-3 p-3 border rounded bg-light">
            <h4 class="mb-0"><b>Fecha y hora: <span id="fechaHoraCombinadaText">@Model.FechaHora.ToString("dd/MM/yyyy hh:mm tt")</span></b></h4>
        </div>

        @* SECCIÓN 1: DATOS DEL PACIENTE *@
        <div class="border mb-4 rounded" style="overflow: hidden;">
            <div class="p-3" style="background-color: #fff9e6;">
                <h4 class="fw-bold mb-0">1. Datos del Paciente <i class="fas fa-user-plus"></i></h4>
            </div>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label"><strong>Seleccione paciente:</strong></label>
                        <select class="form-control select2bs4" id="selectPaciente" style="width: 100%;">
                            <option value="">Seleccionar paciente</option>
                        </select>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label"><strong>Nombre del paciente</strong></label>
                        @Html.TextBoxFor(a => a.PacienteNombre, new { type = "text", @class = "form-control", @placeholder = "Nombre completo del paciente" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>No. DPI / Pasaporte</strong></label>
                        @Html.TextBoxFor(a => a.dpiPacienteSeleccionado, new { type = "text", @class = "form-control", @placeholder = "" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Fecha de nacimiento</strong></label>
                        @Html.TextBoxFor(a => a.FechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", id = "FechaNacimiento", @onchange = "getEdad();", @onkeyup = "getEdad();", value = Model.FechaNacimiento?.ToString("yyyy-MM-dd") })
                        <p style="display:none">Edad: <span data-bind="text: edadAniosPaciente" id="ABC"></span></p>
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label"><strong>Edad</strong></label>
                        @Html.TextBoxFor(a => a.PacienteEdad, new { type = "text", @class = "form-control", @placeholder = "Edad", @readonly = "true" })
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label"><strong>Sexo</strong></label>
                        <select class="form-control" asp-for="@Model.SexoId" style="width: 100%;">
                            <option value="">Seleccione...</option>
                            <option value="1">Masculino</option>
                            <option value="2">Femenino</option>
                            <option value="3">Otro</option>
                        </select>
                    </div>
                    <div class="col-md-2 mb-3">
                        <label class="form-label"><strong>Teléfono</strong></label>
                        @Html.TextBoxFor(a => a.Telefono, new { type = "text", @class = "form-control", @placeholder = "" })
                    </div>
                     <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Correo</strong></label>
                        @Html.TextBoxFor(a => a.Email, new { type = "text", @class = "form-control", @placeholder = "" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Dirección</strong></label>
                        @Html.TextBoxFor(a => a.Direccion, new { @class = "form-control", @placeholder = "" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Departamento</strong></label>
                        <select class="form-control select2bs4" style="width: 100%;" id="departamentoSeleccionado">
                            <option value="">Seleccione...</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Municipio</strong></label>
                        <select class="form-control select2bs4" style="width: 100%;" id="municipioSeleccionado">
                            <option value="">Seleccione...</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Etnia</strong></label>
                        <select id="etniaSelect" class="form-control select2bs4" style="width: 100%;" asp-for="EtniaPaciente">
                            <option value="Maya">Maya</option>
                            <option value="Garifuna">Garifuna</option>
                            <option value="Xinca">Xinca</option>
                            <option value="Mestizo / Ladino">Mestizo / Ladino</option>
                            <option value="Ninguno">Ninguno</option>
                            <option value="Ignorado">Ignorado</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Origen</strong></label>
                        <select id="origenPaciente" class="form-control select2bs4" style="width: 100%;" asp-for="OrigenPaciente">
                            <option value="Guatemalteco/a">Guatemalteco/a</option>
                            <option value="Extranjero">Extranjero</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Religión</strong></label>
                        <select id="religionPaciente" class="form-control select2bs4" style="width: 100%;" asp-for="ReligionPaciente">
                            <option value="Católico(a)">Católico(a)</option>
                            <option value="Evangélico(a)">Evangélico(a)</option>
                            <option value="Judío(a)">Judío(a)</option>
                            <option value="Mormón(a)">Mormón(a)</option>
                            <option value="Musulmán(a)">Musulmán(a)</option>
                            <option value="Testigo de Jehová">Testigo de Jehová</option>
                            <option value="Ateo(a)">Ateo(a)</option>
                            <option value="No Definido">No Definido</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        @* SECCIÓN 2: DATOS DE LA CITA *@
        <div class="border mb-4 rounded" style="overflow: hidden;">
            <div class="p-3" style="background-color: #fff9e6;">
                <h4 class="fw-bold mb-0">2. Datos de la Cita <i class="fas fa-calendar-alt"></i></h4>
            </div>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Fecha</strong></label>
                        @Html.TextBoxFor(a => a.FechaHora, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @id = "fecha" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Hora</strong></label>
                        @Html.TextBoxFor(a => a.FechaHora, "{0:HH:mm}", new { @class = "form-control", @type = "time", @id = "hora" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Médico asignado</strong></label>
                        <select class="form-control select2bs4" style="width: 100%;" asp-for="EmpleadoId" asp-items="@Model.DoctoresSelectListItem">
                            <option disabled selected>--- Sin Asignar ---</option>
                        </select>
                        <div id="msgConflictoEmpleado" class="text-danger small" style="display:none; margin-top:4px;"></div>
                    </div>
                    <div class="col-md-3 mb-3">
                         @if (esCalendario)
                        {
                            @* <select class="form-control" asp-for="@Model.NivelPrioridadCita" style="width: 100%;" hidden readonly>
                                <option value="BAJO">BAJO</option>
                                <option value="MEDIO">MEDIO</option>
                                <option value="ALTO" selected>ALTO</option>
                            </select>
                            </select> *@
                        }
                        else
                        {
                            @*<label class="form-label"><strong>Nivel de Atencion <span class="text-danger">*</span></strong></label>
                             <label class="form-label"><strong>Nivel de Atencion <span class="text-danger">*</span></strong></label>
                            <select class="form-control" asp-for="@Model.NivelPrioridadCita" style="width: 100%;">
                                <option value="BAJO">BAJO</option>
                                <option value="MEDIO">MEDIO</option>
                                <option value="ALTO">ALTO</option>
                            </select>
                            </select> *@
                        }
                    </div>
                    <div class="col-md-6 mb-3" id="CategoriaHabitacionSection">
                        <label class="form-label"><strong>Área asignada / Categoría Habitacion</strong></label>
                        @if (esCalendario)
                        {
                            <select class="form-control select2bs4" style="width: 100%;" asp-for="CategoriaHabitacionId" disabled>
                                <option value="13" selected>Sala de Operaciones</option>
                            </select>
                            <input type="hidden" name="CategoriaHabitacionId" value="13" />
                        }
                        else
                        {
                            var categoriasAdmision = Model.CategoriaHabitacionSelectListItem?.Where(x => x.Value != "13").ToList();
                            <select class="form-control select2bs4" style="width: 100%;" asp-for="CategoriaHabitacionId" asp-items="@categoriasAdmision">
                                <option selected>- Seleccione un área -</option>
                            </select>
                        }
                    </div>
                    <div class="col-md-6 mb-3" id="CategoriaHabitacionSection2">
                        <label class="form-label"><strong>Habitaciones</strong></label>
                        @if (esCalendario)
                        {
                            <select class="form-control select2bs4" style="width: 100%;" id="HabitacionId" name="HabitacionId">
                                <option value="">Cargando habitaciones...</option>
                            </select>
                        }
                        else
                        {
                            <select class="form-control select2bs4" style="width: 100%;" asp-for="HabitacionId" asp-items="@Model.HabitacionSelectListItem">
                                <option selected>- Seleccione una habitación -</option>
                            </select>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (esCalendario)
        {
            @* SECCIÓN 3: EQUIPO QUIRÚRGICO *@
            <div class="border mb-4 rounded" style="overflow: hidden;">
                <div class="p-3" style="background-color: #fff9e6;">
                    <h4 class="fw-bold mb-0">3. Equipo Quirúrgico <i class="fas fa-users-cog"></i></h4>
                </div>
                <div class="p-3">
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>CIRUJANO <small class="text-primary">(Médico asignado)</small></strong></label>
                            <input type="text" class="form-control" readonly placeholder="Se asigna con el médico seleccionado arriba" id="cirujanoDiplay" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>1ER. AYUDANTE <small class="text-primary">(Médico secundario)</small></strong></label>
                            <select class="form-control select2bs4 select-equipo-qx" style="width:100%;" id="PrimerAyudante" name="PrimerAyudante" data-especialidad-nombre="" data-unidad-nombre="">
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>ANESTESISTA</strong></label>
                            <select class="form-control select2bs4 select-equipo-qx" style="width:100%;" id="Anestesista" name="Anestesista" data-especialidad-nombre="Anestesista" data-unidad-nombre="">
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>2DO. AYUDANTE</strong></label>
                            <select class="form-control select2bs4 select-equipo-qx" style="width:100%;" id="SegundoAyudante" name="SegundoAyudante" data-especialidad-nombre="" data-unidad-nombre="">
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>INSTRUMENTISTA</strong></label>
                            <select class="form-control select2bs4 select-equipo-qx" style="width:100%;" id="Instrumentista" name="Instrumentista" data-especialidad-nombre="" data-unidad-nombre="Instrumentista">
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>CIRCULANTE</strong></label>
                            <select class="form-control select2bs4 select-equipo-qx" style="width:100%;" id="Circulante" name="Circulante" data-especialidad-nombre="" data-unidad-nombre="Circulante">
                                <option value="">Seleccione...</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        }

        @* SECCIÓN 4: RESPONSABLE DE PAGO Y TIPO DE ATENCIÓN *@
        <div class="border mb-4 rounded" style="overflow: hidden;">
            <div class="p-3" style="background-color: #fff9e6;">
                <h4 class="fw-bold mb-0">4. Responsable y Tipo de Atención <i class="fas fa-file-invoice-dollar"></i></h4>
            </div>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-md-12"><h6 class="fw-bold">Responsable de Pago</h6></div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label"><strong>NIT</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableNit, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label"><strong>Nombre</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableNombre, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label"><strong>Direccion</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableDireccion, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Correo</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableCorreo, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Telefono</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableTelefono, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Pasaporte</strong></label>
                        @Html.TextBoxFor(a => a.ResponsablePasaporte, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Nacionalidad</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableNacionalidad, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Ocupacion</strong></label>
                        @Html.TextBoxFor(a => a.ResponsableOcupacion, new { type = "text", @class = "form-control" })
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label"><strong>Tipo de atención</strong></label>
                        <select class="form-control" asp-for="CitaTipoAtencion" data_bind="value: citaTipoAtencion" id="CitaTipoAtencion">
                            <option value="PRIVADO">Privado</option>
                            <option value="IGSS">Igss</option>
                            <option value="SEGURO">Seguro</option>
                        </select>
                    </div>
                    <!--ko if:citaTipoAtencion() == 'IGSS'-->
                    <div class="col-md-9 mb-3">
                        <label class="form-label"><strong>No. Afiliacion IGSS</strong></label>
                        @Html.TextBoxFor(a => a.no_IGGS, new { type = "text", @class = "form-control", @placeholder = "" })
                    </div>
                    <!--/ko-->
                    <!--ko if:citaTipoAtencion() == 'SEGURO'-->
                    <div class="col-md-5 mb-3">
                        <label class="form-label"><strong>Seleccione Seguro:</strong></label>
                        <select class="form-control" style="width: 100%;" id="SeguroSeleccionado" data-bind="options: seguros, optionsText: 'Nombre', optionsValue: 'Nombre', value: seguroSeleccionado"></select>
                        @Html.TextBoxFor(a => a.CodigoCita, new { @class = "form-control", @placeholder = "Nombre del seguro" })
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label"><strong>Autorizacion</strong></label>
                        @Html.TextBoxFor(a => a.CodigoAutorizacion, new { @class = "form-control", @placeholder = "Autorizacion" })
                    </div>
                    <!--/ko-->
                </div>
            </div>
        </div>

        @* SECCIÓN 5: ACOMPAÑANTE Y FAMILIARES *@
        <div class="border mb-4 rounded" style="overflow: hidden;">
            <div class="d-flex justify-content-between align-items-center p-3" style="background-color: #fff9e6;">
                <h4 class="fw-bold mb-0">5. Acompañante y Familiares <i class="fas fa-users"></i></h4>
                <div>
                    <label class="form-label me-2 mb-0"><strong>¿Acompañante?</strong></label>
                    <select class="form-select form-select-sm" id="acompananteSelector" style="width: auto; display: inline-block;">
                        <option value="NO" selected>No</option>
                        <option value="SI">Sí</option>
                    </select>
                </div>
            </div>
            <div class="p-3">
                <div id="acompananteSection" style="display: none;">
                    <div class="row g-3">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Nombre del Acompañante</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteNombre, new { type = "text", @class = "form-control", @placeholder = "Nombre del Acompañante" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Relación del Acompañante</strong></label>
                            <select id="acompananteRelacion" class="form-control select2bs4" style="width: 100%;" asp-for="AcompananteRelacion">
                                <option value="Padre">Padre</option>
                                <option value="Madre">Madre</option>
                                <option value="Hermano(a)">Hermano(a)</option>
                                <option value="Primo(a)">Primo(a)</option>
                                <option value="Tio(a)">Tio(a)</option>
                                <option value="Amigo(a)">Amigo(a)</option>
                                <option value="Conocido(a)">Conocido(a)</option>
                               @if (clienteconf == "SS") 
                                {
                                    <option value="Esposo(a)">Esposo(a)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Fecha de Nacimiento</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteFechaNacimiento, "{0:yyyy-MM-dd}", new { @class = "form-control", @type = "date", @onchange = "calcularEdad('AcompananteFechaNacimiento', 'AcompananteEdad')", @onkeyup = "calcularEdad('AcompananteFechaNacimiento', 'AcompananteEdad')" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Edad</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteEdad, new { type = "text", @class = "form-control", @placeholder = "Edad", @readonly = "readonly", id = "AcompananteEdad" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>DPI del Acompañante</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteDPI, new { type = "text", @class = "form-control", @placeholder = "DPI del Acompañante" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Dirección del Acompañante</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteDireccion, new { type = "text", @class = "form-control", @placeholder = "Dirección del Acompañante" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Teléfono del Acompañante</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteTelefono, new { type = "text", @class = "form-control", @placeholder = "Teléfono del Acompañante" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Correo del Acompañante</strong></label>
                            @Html.TextBoxFor(a => a.AcompananteCorreo, new { type = "email", @class = "form-control", @placeholder = "Correo del Acompañante" })
                        </div>
                    </div>
                </div>

                <div id="datosPadre" style="display:none;">
                    <hr /><h6 class="fw-bold mt-3">Datos del Padre / Tutor</h6>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Nombre del Padre</strong></label>
                            @Html.TextBoxFor(a => a.NombrePadre, new { type = "text", @class = "form-control" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>DPI</strong></label>
                            @Html.TextBoxFor(a => a.DPIPadre, new { type = "text", @class = "form-control" })
                        </div>
                    </div>
                </div>
                <div id="datosMadre" style="display:none;">
                    <hr /> <h6 class="fw-bold mt-3">Datos de la Madre / Tutora</h6>
                    <div class="row g-3 mt-1">
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>Nombre de la Madre</strong></label>
                            @Html.TextBoxFor(a => a.NombreMadre, new { type = "text", @class = "form-control" })
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label"><strong>DPI</strong></label>
                            @Html.TextBoxFor(a => a.DPIMadre, new { type = "text", @class = "form-control" })
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* SECCIÓN 6: DATOS DE CONSULTA *@
        <div class="border mb-4 rounded" style="overflow: hidden;">
            <div class="p-3" style="background-color: #fff9e6;">
               @if (clienteconf != "SS") 
                {
                    <h4 class="fw-bold mb-0">6. Detalles de la Consulta <i class="fas fa-notes-medical"></i></h4>
                }
                else 
                {
                    <h4 class="fw-bold mb-0">6. Detalle de Procedimiento <i class="fas fa-notes-medical"></i></h4>
                }

            </div>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-md-4 mb-3">
                        <label class="form-label"><strong>Especialidad</strong></label>
                        <select class="form-control select2bs4" style="width: 100%;" asp-for="EspecialidadId" asp-items="@Model.EspecialidadSelectListItem">
                            <option disabled selected>--- SELECCIONE ---</option>
                        </select>
                    </div>
                    @* @if (esAdmision)
                    {
                        <div class="col-md-2 d-flex align-items-end mb-3">
                            <button class="btn btn-primary w-100" data-bind="click:generarTurno">Generar Turno***</button>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label"><strong>No. Turno</strong></label>
                            @Html.TextBoxFor(a => a.NumeroTurno, new { type = "text", @class = "form-control", @readonly = true })
                        </div>
                    } *@
