                                            @if (c.Finalizada != true && c.EstadoCita != "asistida")
                                            {
                                                <a class="btn btn-outline-secondary"
                                                   asp-controller="Cita" asp-action="NoAsistio"
                                                   asp-route-citaId="@c.Id" asp-route-fecha="@fechaHoraReal"
                                                   data-toggle="tooltip" data-placement="top" title="No asistió">
                                                    <i class="fas fa-user-times"></i>
                                                </a>

                                                @if (!esHospitalizacion)
                                                {
                                                    <a class="btn btn-outline-success"
                                                       asp-controller="Consultas" asp-action="IniciarYPagarConsulta"
                                                       asp-route-citaId="@c.Id"
                                                       data-toggle="tooltip" data-placement="top" title="Iniciar y pagar consulta">
                                                        <i class="fas fa-cash-register"></i>
                                                    </a>
                                                    <a class="btn btn-outline-success"
                                                       asp-controller="Consultas" asp-action="IniciarConsulta"
                                                       asp-route-citaId="@c.Id"
                                                       data-toggle="tooltip" data-placement="top" title="Iniciar consulta">
                                                        <i class="fas fa-play"></i>
                                                    </a>
                                                }
                                                else
                                                {
                                                    <a class="btn btn-outline-danger"
                                                       asp-controller="Hospitalizacion" asp-action="Hospitalizar"
                                                       asp-route-citaId="@c.Id"
                                                       data-toggle="tooltip" data-placement="top" title="Iniciar hospitalización">
                                                        <i class="fas fa-hospital-user"></i>
                                                    </a>
                                                }

                                                <a class="btn btn-outline-warning"
                                                   href="@Url.Action("EditarCita", "Cita", new { id = c.Id })"
                                                   data-toggle="tooltip" data-placement="top" title="Modificar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a class="btn btn-outline-warning"
                                                   href="@Url.Action("CancelarCita", "Cita", new { id = c.Id })"
                                                   data-toggle="tooltip" data-placement="top" title="Cancelar">
                                                    <i class="fas fa-ban"></i>
                                                </a>

                                                @if (!esHospitalizacion)
                                                {
                                                    <a class="btn btn-outline-warning"
                                                       asp-controller="Cita" asp-action="AgendarCita"
                                                       asp-route-fecha="@fechaHoraReal"
                                                       data-toggle="tooltip" data-placement="top" title="Clonar hora">
                                                        <i class="fas fa-clone"></i>
                                                    </a>
                                                }
                                            }
                                            @if (c.EstadoCita == "No asistida")
                                            {
                                                <a class="btn btn-outline-secondary"
                                                   asp-controller="Cita" asp-action="ReprogramarCita"
                                                   asp-route-citaId="@c.Id" asp-route-fecha="@fechaHoraReal"
                                                   data-toggle="tooltip" data-placement="top" title="Reprogramar">
                                                    <i class="fas fa-redo"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }

    </div>@* fin card-body *@
</div>@* fin card *@

@section Modales {
    <form asp-controller="Cita" asp-action="BloquearFecha" method="post">
        <div class="modal fade" id="modalMotivoBloqueo" tabindex="-1" role="dialog"
             aria-labelledby="modalMotivoBloqueoTitle" aria-hidden="true">
            <div class="modal-dialog modal-dialog-scrollable" role="document">
                <div class="modal-content border-0 shadow">
                    <div class="modal-header bg-light">
                        <h5 class="modal-title font-weight-bold text-uppercase" id="modalMotivoBloqueoTitle">Bloqueo de Fecha</h5>
                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="form-row">
                            <div class="col-12 mb-3">
                                <label class="small font-weight-bold text-muted text-uppercase">Fecha</label>
                                <div class="position-relative form-group">
                                    <input type="text" class="form-control shadow-none" asp-for="Fecha" value="">
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="small font-weight-bold text-muted text-uppercase">Motivo</label>
                                <div class="position-relative form-group">
                                    <input type="text" class="form-control shadow-none" asp-for="Motivo"
                                           placeholder="Especifique la razón...">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-sm btn-secondary font-weight-bold"
                                data-dismiss="modal">Cerrar</button>
                        <button type="submit" class="btn btn-sm btn-primary font-weight-bold">Guardar</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
}

