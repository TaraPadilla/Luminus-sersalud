@using Database.Shared.Paginacion;
@model sistema.Models.CalendarioLinealViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    ViewData["Title"] = "Calendario";
    var usuarioJose = User.Identity.Name == "jose@one.com";
    var pacienteFiltro = (ViewData["PacienteNombre"] as string) ?? string.Empty;
    var tieneFiltroPaciente = !string.IsNullOrWhiteSpace(pacienteFiltro);

    var currentFilter  = (ViewData["CurrentFilter"]  as string) ?? string.Empty;
    var currentFilter2 = (ViewData["CurrentFilter2"] as string) ?? string.Empty;

    string clienteconf = Configuration["Cliente"]; 

    bool esMedicoExterno = User.IsInRole("MedicoExterno") ||
                       User.HasClaim("TipoUsuario", "MedicoExterno");

    bool deshabilitarAcciones = (clienteconf == "M14" && esMedicoExterno);


    // ← NUEVO: modo de calendario
    var defaultModo = "consulta";
if (clienteconf == "SS")
{
    defaultModo = "hospitalizacion";
}
var modoActual = (ViewData["Modo"] as string) ?? defaultModo;

// Si el cliente es Sersalud, forzamos siempre el modo hospitalización (SOP)
if (clienteconf == "SS")
{
    modoActual = "hospitalizacion";
}
    @* var modoActual        = (ViewData["Modo"] as string) ?? "consulta"; *@
    var esHospitalizacion = modoActual == "hospitalizacion";

    // Helpers para construir URLs conservando todos los filtros activos
    string UrlModo(string m) =>
        $"/Cita/CalendarioLineal?buscar={Uri.EscapeDataString(currentFilter)}" +
        $"&buscar2={Uri.EscapeDataString(currentFilter2)}" +
        $"&empleadoId={ViewData["EmpleadoId"]}" +
        $"&especialidadId={ViewData["EspecialidadId"]}" +
        $"&servicioId={ViewData["ServicioId"]}" +
        $"&pacienteNombre={Uri.EscapeDataString(pacienteFiltro)}" +
        $"&modo={m}";

    // Determinar si es vista de día único o de rango
    bool esDiaUnico = !string.IsNullOrEmpty(currentFilter) && 
                      !string.IsNullOrEmpty(currentFilter2) && 
                      currentFilter == currentFilter2;

    // Si ambas están vacías, se considera día único con la fecha actual
    if (string.IsNullOrEmpty(currentFilter) && string.IsNullOrEmpty(currentFilter2))
    {
        esDiaUnico = true;
        currentFilter = Model.Fecha;
        currentFilter2 = Model.Fecha;
    }


}


@await Html.PartialAsync("_MensajeExito")

@* --- LÓGICA DE ESTADÍSTICAS --- *@
@{
    var citas = Model?.Citas ?? new List<Database.Shared.Models.Citas>();

    bool EsFinalizada(Database.Shared.Models.Citas c)
        => c.Finalizada || c.ContadorCitaFinalizada.HasValue;
    bool EsEnEspera(Database.Shared.Models.Citas c)
        => !EsFinalizada(c) && c.ContadorCitaIniciada.HasValue;
    bool EsAgendada(Database.Shared.Models.Citas c)
        => !EsFinalizada(c) && !c.ContadorCitaIniciada.HasValue;

    var totalAgendadas   = citas.Count(c => EsAgendada(c));
    var totalEnEspera    = citas.Count(c => EsEnEspera(c));
    var totalFinalizadas = citas.Count(c => EsFinalizada(c));

    var agPrivado = citas.Count(c => EsAgendada(c) && c.CitaTipoAtencion == "PRIVADO");
    var agIgss    = citas.Count(c => EsAgendada(c) && c.CitaTipoAtencion == "IGSS");
    var agSeguro  = citas.Count(c => EsAgendada(c) && c.CitaTipoAtencion == "SEGURO");

    var esPrivado = citas.Count(c => EsEnEspera(c) && c.CitaTipoAtencion == "PRIVADO");
    var esIgss    = citas.Count(c => EsEnEspera(c) && c.CitaTipoAtencion == "IGSS");
    var esSeguro  = citas.Count(c => EsEnEspera(c) && c.CitaTipoAtencion == "SEGURO");

    var fiPrivado = citas.Count(c => EsFinalizada(c) && c.CitaTipoAtencion == "PRIVADO");
    var fiIgss    = citas.Count(c => EsFinalizada(c) && c.CitaTipoAtencion == "IGSS");
    var fiSeguro  = citas.Count(c => EsFinalizada(c) && c.CitaTipoAtencion == "SEGURO");
}

<input type="hidden" name="modo" value="@modoActual" />


<div class="card shadow-sm border-0 mb-4">

    @* HEADER PRINCIPAL *@
    <div class="card-header bg-white py-3 border-bottom">
        <div class="d-flex align-items-center justify-content-between w-100">
            <div class="d-flex align-items-center">
                <div class="rounded bg-light d-flex align-items-center justify-content-center mr-3"
                     style="width: 40px; height: 40px;">
                    <i class="fas @(esHospitalizacion ? "fa-hospital" : "fa-calendar-alt") text-primary"></i>
                </div>
                <div>
                    <h5 class="m-0 font-weight-bold text-dark text-uppercase" style="letter-spacing: 1px;">
                        @(esHospitalizacion ? "Calendario de Hospitalizaciones" : "Calendario de Citas")
                    </h5>
                    <span class="badge @(esHospitalizacion ? "badge-danger" : "badge-primary") mt-1" style="font-size:10px;">
                        @(esHospitalizacion ? "SALA DE OPERACIONES" : "CONSULTAS EXTERNAS")
                    </span>
                </div>
            </div>
            <div class="d-flex align-items-center" style="gap: 8px;">
                <div class="btn-group btn-group-sm shadow-sm" role="group" aria-label="Modo de calendario">
                    @if(clienteconf != "SS"){ 
                    <a href="@UrlModo("consulta")"
                       class="btn @(!esHospitalizacion ? "btn-primary" : "btn-outline-primary") font-weight-bold text-uppercase px-3">
                        <i class="fas fa-stethoscope mr-1"></i> COEX
                    </a>
                    }
                    <a href="@UrlModo("hospitalizacion")"
                       class="btn @(esHospitalizacion ? "btn-danger" : "btn-outline-danger") font-weight-bold text-uppercase px-3">
                        <i class="fas fa-hospital mr-1"></i> SOP
                    </a>
                </div>
                @if (!usuarioJose)
                {
                    <a asp-action="ReporteCitasFechas" asp-controller="Cita"
                       class="btn btn-sm btn-outline-secondary shadow-sm px-3 font-weight-bold" target="_blank"
                       asp-route-currentFilter="@ViewData["CurrentFilter"]">
                        <i class="fas fa-print mr-1"></i> GENERAL
                    </a>
                }
            </div>
        </div>
    </div>

    <div class="card-body">

        @* --- SECCIÓN 1: CONTADORES (ESTADÍSTICAS) --- *@
        <div class="mb-4">
            <h6 class="text-uppercase text-muted font-weight-bold mb-3">
                <i class="fas fa-chart-pie mr-2"></i>Resumen del Día
            </h6>
            <div class="row justify-content-center">
                <div class="col-md-4 mb-3">
                    <div class="border rounded shadow-sm p-3 bg-white"
                         style="cursor: pointer; border-left: 4px solid #007bff !important;"
                         onclick="toggleDetalles('agendadas')">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h6 class="text-muted small font-weight-bold text-uppercase m-0">Agendadas</h6>
                            <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow-sm"
                                 style="width: 35px; height: 35px;">
                                <i class="fas fa-calendar-check"></i>
                            </div>
                        </div>
                        <h3 class="mb-0 font-weight-bold text-primary">@totalAgendadas</h3>
                        <div id="detalle-agendadas" class="mt-3 collapse">
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">Privada</small>
                                <span class="badge badge-primary badge-pill">@agPrivado</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">IGSS</small>
                                <span class="badge badge-primary badge-pill">@agIgss</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="font-weight-bold text-muted">Seguro</small>
                                <span class="badge badge-primary badge-pill">@agSeguro</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="border rounded shadow-sm p-3 bg-white"
                         style="cursor: pointer; border-left: 4px solid #ffc107 !important;"
                         onclick="toggleDetalles('espera')">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h6 class="text-muted small font-weight-bold text-uppercase m-0">En Espera</h6>
                            <div class="rounded-circle bg-warning text-white d-flex align-items-center justify-content-center shadow-sm"
                                 style="width: 35px; height: 35px;">
                                <i class="fas fa-clock"></i>
                            </div>
                        </div>
                        <h3 class="mb-0 font-weight-bold text-warning">@totalEnEspera</h3>
                        <div id="detalle-espera" class="mt-3 collapse">
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">Privada</small>
                                <span class="badge badge-warning badge-pill">@esPrivado</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">IGSS</small>
                                <span class="badge badge-warning badge-pill">@esIgss</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="font-weight-bold text-muted">Seguro</small>
                                <span class="badge badge-warning badge-pill">@esSeguro</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 mb-3">
                    <div class="border rounded shadow-sm p-3 bg-white"
                         style="cursor: pointer; border-left: 4px solid #28a745 !important;"
                         onclick="toggleDetalles('finalizadas')">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <h6 class="text-muted small font-weight-bold text-uppercase m-0">Finalizadas</h6>
                            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center shadow-sm"
                                 style="width: 35px; height: 35px;">
                                <i class="fas fa-check-circle"></i>
                            </div>
                        </div>
                        <h3 class="mb-0 font-weight-bold text-success">@totalFinalizadas</h3>
                        <div id="detalle-finalizadas" class="mt-3 collapse">
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">Privada</small>
                                <span class="badge badge-success badge-pill">@fiPrivado</span>
                            </div>
                            <div class="d-flex justify-content-between border-bottom pb-1 mb-1">
                                <small class="font-weight-bold text-muted">IGSS</small>
                                <span class="badge badge-success badge-pill">@fiIgss</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <small class="font-weight-bold text-muted">Seguro</small>
                                <span class="badge badge-success badge-pill">@fiSeguro</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <hr class="mb-4" />

        @* --- SECCIÓN 2: FILTROS --- *@
        <div class="mb-4">
            <h6 class="text-uppercase text-muted font-weight-bold mb-3">
                <i class="fas fa-filter mr-2"></i>Filtros de Búsqueda
            </h6>
            <form asp-controller="Cita" asp-action="CitasListadoFecha" method="post">
                <div class="form-row mb-3">
                    <div class="col-md-4 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Fecha Inicial</label>
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light"><i class="far fa-calendar"></i></span>
                            </div>
                            <input type="date" class="form-control shadow-none" id="fechacita" name="fecha"
                                   value="@ViewData["CurrentFilter"]">
                        </div>
                    </div>

                    <div class="col-md-4 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Fecha Final</label>
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light"><i class="far fa-calendar-check"></i></span>
                            </div>
                            <input type="date" class="form-control shadow-none" id="fechacita2" name="fecha2"
                                   value="@ViewData["CurrentFilter2"]">
                        </div>
                    </div>

                    @if (User.IsInRole("Administrador") || User.IsInRole("Desarrollador"))
                    {
                        <div class="col-md-4 mb-2 d-flex align-items-end">
                            @if (Model.FechaBloqueada)
                            {
                                <button type="button"
                                        class="btn btn-sm btn-success btn-block shadow-sm font-weight-bold text-uppercase"
                                        data-bind="click: function() { desbloquearDia('@Model.Fecha') }">
                                    <i class="fas fa-lock-open mr-2"></i> Desbloquear Día
                                </button>
                            }
                            else
                            {
                                <button type="button"
                                        class="btn btn-sm btn-warning btn-block shadow-sm text-white font-weight-bold text-uppercase"
                                        data-bind="click:bloquearDia">
                                    <i class="fas fa-lock mr-2"></i> Bloquear Día
                                </button>
                            }
                        </div>
                    }
                </div>

                <div class="form-row mb-3">
                    <div class="col-md-3 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Sucursal</label>
                        <select class="form-control form-control-sm select2bs4 shadow-none" asp-for="SucursalId"
                                asp-items="Model.SucursalesSelectList" disabled></select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Médico</label>
                        <select class="form-control form-control-sm select2bs4 shadow-none" asp-for="EmpleadoId"
                                asp-items="Model.EmpleadosSelectList">
                            <option>Todos</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Especialidad</label>
                        <select class="form-control form-control-sm select2bs4 shadow-none" asp-for="EspecialidadId"
                                asp-items="Model.EspecialidadSelectListItem">
                            <option>Todos</option>
                        </select>
                    </div>
                    <div class="col-md-3 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Servicio</label>
                        <select class="form-control form-control-sm select2bs4 shadow-none" asp-for="ServicioId"
                                asp-items="Model.ServiciosSelectList">
                            <option>Todos</option>
                        </select>
                    </div>
                </div>

                <div class="form-row">
                    <div class="col-md-6 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Paciente</label>
                        <div class="input-group input-group-sm">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light"><i class="fas fa-search"></i></span>
                            </div>
                            <input type="text" class="form-control shadow-none" id="pacienteNombre"
                                   placeholder="Buscar por nombre..." value="@ViewData["PacienteNombre"]" />
                        </div>
                    </div>

                    <div class="col-md-3 mb-2">
                        <label class="small font-weight-bold text-muted text-uppercase">Habitación</label>
                        <select class="form-control form-control-sm select2bs4 shadow-none" 
                                id="HabitacionId" 
                                name="habitacionId" 
                                asp-for="HabitacionId" 
                                asp-items="Model.HabitacionesSelectList">
                        </select>
                    </div>
                </div>

                <div class="form-row mt-3">
                    <div class="col-md-12">
                        <button type="button" class="btn btn-sm btn-secondary" id="btnLimpiarFiltros">
                            <i class="fas fa-eraser mr-1"></i> Limpiar filtros
                        </button>
                    </div>
                </div>
            </form>

            <input type="hidden" id="modoCalendario" value="@modoActual" />
        </div>

        <hr class="mb-4" />

        @* --- SECCIÓN 3: TABLAS --- *@
        @if (Model.FechaBloqueada)
        {
            <div class="alert alert-danger text-center font-weight-bold mb-4" role="alert">
                <i class="fas fa-ban mr-2"></i> Esta fecha se encuentra bloqueada. <br />
                <small class="font-weight-normal">Motivo: @Model.Motivo</small>
            </div>

            @if (tieneFiltroPaciente)
            {
                <h6 class="text-uppercase text-muted font-weight-bold mb-3">
                    <i class="fas fa-globe mr-2"></i>Citas globales del paciente:
                    <span class="text-primary">@pacienteFiltro</span>
                </h6>

                <div class="border rounded bg-white shadow-sm" style="max-height:520px; overflow-y:auto;">
                    <table class="table table-sm table-hover table-striped mb-0 table-bordered"
                           style="min-width:1200px; font-size:12px;">
                        <thead class="bg-light" style="position:sticky; top:0; z-index:5;">
                            <tr>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Fecha</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Hora</th>
                                <th class="text-uppercase small font-weight-bold">Especialidad / Doctor</th>
                                <th class="text-uppercase small font-weight-bold">Servicios</th>
                                <th class="text-uppercase small font-weight-bold">Paciente</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Telefono</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Asistencia</th>
                                <th class="text-uppercase small font-weight-bold">Tipo de atencion</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in citas.OrderBy(x => x.FechaInicio))
                            {
                                var cliente  = c.Paciente == null ? "" : c.Paciente.Nombre;
                                var telefono = c.Paciente == null ? "" : c.Paciente.Telefono;
                                <tr>
                                    <td class="align-middle text-nowrap">@((c.FechaInicio ?? DateTime.Now).ToString("yyyy-MM-dd"))</td>
                                    <td class="align-middle text-nowrap">@((c.FechaInicio ?? DateTime.Now).ToString("HH:mm"))</td>
                                    <td class="align-middle">@c.EspecialidadText / @c.EmpleadoText</td>
                                    <td class="align-middle">
                                        <div class="d-flex flex-wrap" style="gap:6px;">
                                            @if (c.CitasServicios != null && c.CitasServicios.Count() > 0)
                                            {
                                                foreach (var s in c.CitasServicios)
                                                {
                                                    <span class="badge badge-primary">@s.Servicio.NombreServicio</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted"><i>No hay servicios registrados</i></span>
                                            }
                                        </div>
                                    </td>
                                    <td class="align-middle">@cliente</td>
                                    <td class="align-middle text-nowrap">@telefono</td>
                                    <td class="align-middle text-nowrap">@c.EstadoCita</td>
                                    <td class="align-middle text-nowrap">@c.CitaTipoAtencion</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
        else
        {
            @if (esDiaUnico)
            {
                // ================= VISTA DÍA ÚNICO =================
                <div class="d-flex align-items-center mb-3">
                    <h6 class="text-uppercase text-muted font-weight-bold m-0">
                        <i class="fas @(esHospitalizacion ? "fa-hospital" : "fa-calendar-day") mr-2"></i>
                        @(esHospitalizacion ? "Hospitalizaciones del día:" : "Citas del día:")
                        <span class="text-primary">@Model.Fecha</span>
                    </h6>
                </div>

                <div class="border rounded bg-white shadow-sm" style="max-height:520px; overflow-y:auto;">
                    <table class="table table-sm table-hover table-striped mb-0 table-bordered"
                           style="min-width:1400px; font-size:12px;">
                        <thead class="bg-light" style="position:sticky; top:0; z-index:5;">
                            <tr>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Fecha</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Hora</th>
                                <th class="text-uppercase small font-weight-bold">Especialidad / Doctor</th>
                                <th class="text-uppercase small font-weight-bold">Servicios</th>
                                <th class="text-uppercase small font-weight-bold">Paciente</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Telefono</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Asistencia</th>
                                <th class="text-uppercase small font-weight-bold">Tipo de atencion</th>
                                <th class="text-uppercase small font-weight-bold">Agendado por</th>
                                <th class="text-uppercase small font-weight-bold text-nowrap">Menor de edad</th>
                                @if(!esHospitalizacion){
                                    <th class="text-uppercase small font-weight-bold text-nowrap">Turno</th>
                                }
                                <th class="text-uppercase small font-weight-bold text-nowrap text-center"
                                    style="min-width:180px;">@(esHospitalizacion ? "Hospitalización / Acciones" : "Cita / Acciones")</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                DateTime NormalizarFechaCita(DateTime dt) => dt.AddHours(6);
                                DateTime CalcularSlot(DateTime dt)
                                {
                                    var baseHour = new DateTime(dt.Year, dt.Month, dt.Day, dt.Hour, 0, 0);
                                    var m = dt.Minute;
                                    if (m <= 15) return baseHour;
                                    if (m <= 50) return baseHour.AddMinutes(30);
                                    return baseHour.AddHours(1);
                                }

                                var citasPorSlot = new Dictionary<string, List<Database.Shared.Models.Citas>>(StringComparer.Ordinal);
                                var horaRealPorCita = new Dictionary<int, string>();
                                var fechaHoraRealPorCita = new Dictionary<int, string>();

                                foreach (var c in Model.Citas ?? new List<Database.Shared.Models.Citas>())
                                {
                                    var inicio = c.FechaInicio ?? DateTime.Now;
                                    var inicioNorm = NormalizarFechaCita(inicio);

                                    if (inicioNorm.ToString("yyyy-MM-dd") != Model.Fecha) continue;

                                    var slotDt = CalcularSlot(inicioNorm);
                                    var slotKey = slotDt.ToString("HH:mm");

                                    if (!citasPorSlot.TryGetValue(slotKey, out var lista))
                                    {
                                        lista = new List<Database.Shared.Models.Citas>();
                                        citasPorSlot[slotKey] = lista;
                                    }
                                    lista.Add(c);
                                    horaRealPorCita[c.Id] = inicioNorm.ToString("HH:mm");
                                    fechaHoraRealPorCita[c.Id] = inicioNorm.ToString("yyyy-MM-dd HH:mm");
                                }

                                foreach (var kv in citasPorSlot)
                                {
                                    kv.Value.Sort((a, b) =>
                                    {
                                        var ha = horaRealPorCita.TryGetValue(a.Id, out var hra) ? hra : "00:00";
                                        var hb = horaRealPorCita.TryGetValue(b.Id, out var hrb) ? hrb : "00:00";
                                        var cmp = string.CompareOrdinal(ha, hb);
                                        if (cmp != 0) return cmp;
                                        return a.Id.CompareTo(b.Id);
                                    });
                                }
                            }

                            @foreach (var item in Model.Horas)
                            {
                                var fechaYHoraSlot = $"{Model.Fecha} {item}";
                                if (citasPorSlot.TryGetValue(item, out var citasDelSlot) && citasDelSlot != null && citasDelSlot.Count > 0)
                                {
                                    foreach (var cita in citasDelSlot)
                                    {
