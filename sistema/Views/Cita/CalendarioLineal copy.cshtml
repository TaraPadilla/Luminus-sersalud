@section Scripts {
    <script src="~/ViewModelKo/CitaCalendarioLinealVM.js"></script>

    <script>
        function toggleDetalles(id) {
            const detalle = document.getElementById('detalle-' + id);
            detalle.style.display = (detalle.style.display === 'none') ? 'block' : 'none';
        }

        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });

        // Auto-recarga: no recargar si el usuario está escribiendo
        setTimeout(function () {
            const active = document.activeElement;
            const isTypingControl =
                active &&
                (active.tagName === "INPUT" ||
                 active.tagName === "SELECT" ||
                 active.tagName === "TEXTAREA") &&
                !active.disabled &&
                !active.readOnly;

            if (!isTypingControl) {
                window.location.reload();
            }
        }, 30000);



        $('#btnLimpiarFiltros').click(function() {
            $('#fechacita').val('');
            $('#fechacita2').val('');
            $('#EmpleadoId').val('').trigger('change');
            $('#EspecialidadId').val('').trigger('change');
            $('#ServicioId').val('').trigger('change');
            $('#pacienteNombre').val('');
            $('#HabitacionId').val('').trigger('change'); 
            var modo = $('#modoCalendario').val();
            window.location.href = '/Cita/CalendarioLineal?modo=' + encodeURIComponent(modo);
        });


        $(document).ready(function() {
            $('#HabitacionId').on('change', function() {
                var habitacionId = $(this).val();
                var modo = $('#modoCalendario').val();

                var buscar = $('#fechacita').val();
                var buscar2 = $('#fechacita2').val();
                var empleadoId = $('#EmpleadoId').val();
                var especialidadId = $('#EspecialidadId').val();
                var servicioId = $('#ServicioId').val();
                var pacienteNombre = $('#pacienteNombre').val();

                var url = '/Cita/CalendarioLineal?modo=' + encodeURIComponent(modo);
                if (buscar) url += '&buscar=' + encodeURIComponent(buscar);
                if (buscar2) url += '&buscar2=' + encodeURIComponent(buscar2);
                if (empleadoId) url += '&empleadoId=' + encodeURIComponent(empleadoId);
                if (especialidadId) url += '&especialidadId=' + encodeURIComponent(especialidadId);
                if (servicioId) url += '&servicioId=' + encodeURIComponent(servicioId);
                if (pacienteNombre) url += '&pacienteNombre=' + encodeURIComponent(pacienteNombre);
                if (habitacionId) url += '&habitacionId=' + encodeURIComponent(habitacionId);

                window.location.href = url;
            });
        });
    </script>


    <script>
        (function() {
    var urlParams = new URLSearchParams(window.location.search);
    if (!urlParams.has('buscar')) {
        var today = new Date().toISOString().split('T')[0];
        var modo = urlParams.get('modo') || '@modoActual';
        window.location.href = '/Cita/CalendarioLineal?buscar=' + today + '&buscar2=' + today + '&modo=' + modo;
    }
})();
    </script>
}

