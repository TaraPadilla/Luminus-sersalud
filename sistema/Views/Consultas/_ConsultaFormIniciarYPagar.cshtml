<div title="Confirmar" style="display:none" id="mdl-confirmacion">
    <div class="form-row">
        <div class="col-md-12">
            <hr />
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Precio</th>
                        <th>Indicacion</th>
                        <th>Instrucciones</th>
                        <th>Declaracion</th>
                        <th>Todo</th>
                    </tr>
                </thead>
                <tbody>
                    <!--ko foreach: examenesVenta-->
                    <tr>
                        <td data-bind="text:Id"></td>
                        <td data-bind="text:NombreExamen"></td>
                        <td data-bind="text:PrecioValor"></td>
                        <td>
                            <button class="btn btn-danger"
                                    data-bind="click: function() { generarPdfExamenesLaboratorio(Id,@Model.PacienteId,'indicaciones' ); }">
                                <i class="fa fa-file-pdf"> PDF</i>
                            </button>
                        </td>
                        <td>
                            <button class="btn btn-danger" @*data-bind="click:$root.quitarExamen"*@
                                    data-bind="click: function() { generarPdfExamenesLaboratorio(Id,@Model.PacienteId,'instrucciones' ); }">
                                <i class="fa fa-file-pdf"></i> PDF
                            </button>
                        </td>
                        <td>
                            <button class="btn btn-danger" @*data-bind="click:$root.quitarExamen"*@
                                    data-bind="click: function() { generarPdfExamenesLaboratorio(Id,@Model.PacienteId,'declaraciones' ); }">
                                <i class="fa fa-file-pdf"></i> PDF
                            </button>
                        </td>
                        <td>
                            <button class="btn btn-danger" @*data-bind="click:$root.quitarExamen"*@
                                    data-bind="click: function() { generarPdfExamenesLaboratorio(Id,@Model.PacienteId,'todo' ); }">
                                <i class="fa fa-file-pdf"></i> PDF
                            </button>
                        </td>
                    </tr>
                    <!--/ko-->
                    <!--ko if:examenesVenta().length==0-->
                    <tr>
                        <td colspan="3">
                            <i>No hay examenes agregados</i>
                        </td>
                    </tr>
                    <!--/ko-->
                </tbody>
            </table>
        </div>
    </div>

    <div class="form-row">
        <div class="col-md-12">
            <hr />
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Pregunta</th>
                        <th>Detalles</th>
                        <th>Respuesta</th>

                    </tr>
                </thead>
                <tbody>
                    <!--ko foreach:examenesPreguntas-->
                    <tr>
                        <td data-bind="text:Id"></td>
                        <td data-bind="text:Pregunta"></td>
                        <td>
                            @* <input type="text" data-bind="value: Detalles" /> *@
                            <input type="text" data-bind="value: Detalles, event: { blur: $root.respuestaPregunta }" />
                        </td>
                        <td>
                            <input type="checkbox" data-bind="checked: Respuesta, event: { change: $root.respuestaPregunta }" />
                        </td>

                    </tr>
                    <!--/ko-->
                </tbody>
            </table>
        </div>
    </div>
    <span data-bind="html:txtModalConfirmacion"></span>
</div>