            <div id="tab-datos-paciente" class="d-none">
                <div class="main-card mb-3 card">
                    <div class="card-body">

                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-4">
                                        <div class="position-relative form-group">
                                            <label class="">Nivel Prioridad</label>
                                            @Html.TextBoxFor(m => m.NivelPrioridadCita, new { @class = "form-control ", @readonly = true, @Style = "Background:#f7b924; Color:black;" })

                                        </div>
                                    </div>

                                    <div class="col-md-4">
                                        <div class="position-relative form-group">
                                            <label class="">No Turno</label>
                                            @Html.TextBoxFor(a => a.NumeroTurno, new { @class = "form-control", @readonly = true, @Style = "Background:#2fb9e7; Color:white;" })

                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="position-relative form-group">
                                            <label class="">Estado del Turno</label>
                                            <select asp-for="EstadoTurno" class="form-control">
                                                <option value="ACTIVO">ACTIVO</option>
                                                <option value="PENDIENTE">PENDIENTE</option>
                                                <option value="ENCURSO">EN CURSO</option>
                                                <option value="FINALIZADO">FINALIZADO</option>
                                            </select>

                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Datos personales</b></h5>
                                        <hr>
                                    </div>
                                    <div class="col-md-12">
                                        <b>Nombre: </b>@Model.PacienteNombre<br />
                                        <b>NIT: </b>@Model.PacienteNit<br />
                                        <b>Dirección: </b>@Model.PacienteDireccion<br />
                                        <b>Alias: </b>@Model.PacienteAlias<br />
                                        <b>Sexo: </b>@(Model.PacienteSexo ?? "-")<br />
                                        <b>Fecha de nacimiento: </b>@Model.PacienteFechaNacimiento<br />
                                        <b>Edad: </b>@Model.PacienteEdad<br />
                                        <b>Nivel educativo completado: </b>@Model.PacienteNivelEducativoCompletado<br />
                                        <b>Teléfono: </b>@Model.PacienteTelefono<br />
                                        <b>Departamento de residencia: </b>@Model.PacienteDepartamentoId <br />
                                        <b>Municipio de residencia: </b>@Model.PacienteMunicipioId<br />
                                        <b>Celular: </b>@Model.PacienteCelular <br />

                                        <b>Seguro EPSS: </b>@Model.PacienteSeguroEPSS<br />
                                        @*<b>ConsultaID: </b>@Model.ConsultaId<br />*@
                                        <input type="hidden" class="form-control" asp-for="@Model.ConsultaId" id="ConsultaId" name="ConsultaId" readonly="readonly">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Antecedentes</b></h5>
                                        <hr />
                                    </div>
                                    <div class="col-md-12">
                                        <b>Antecedentes médicos: </b>@Model.PacienteMedicos<br />
                                        <b>Antecedentes quirúrgicos: </b>@Model.PacienteQuirurgicos <br />
                                        <b>Antecedentes traumáticos: </b>@Model.PacienteTraumaticos<br />
                                        <b>Antecedentes alérgicos: </b>@Model.PacienteAlergias<br />
                                        <b>Farmaco dependencias: </b>@Model.PacienteVicios<br />
                                        <b>Medicamentos: </b>@Model.PacienteMedicamentos
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Antecedentes Ginecologicos</b></h5>
                                        <hr />
                                    </div>
                                    <div class="col-md-12">
                                        @* <b>Ciclo Menstrual: </b>@Model.PacienteAbdomenObstetricoGine<br /> *@
                                        <b>ETS: </b>@Model.PacienteETSGine<br />
                                        <b>VIH: </b>@Model.PacienteVIHGine<br />
                                        <b>Grupo Factor: </b>@Model.PacienteGrupoFactorGine<br />
                                        <b>Torch: </b>@Model.PacienteTorchGine<br />
                                        <b>Inicio Vida Sexual: </b>@Model.PacienteInicioVidaSexualGine<br />
                                        <b>Parejas Sexuales: </b>@Model.PacienteParejasSexGine<br />
                                        <b>Obesidad: </b>@Model.PacienteObesidadGine<br />
                                        <b>Desnutricion: </b>@Model.PacienteDesnutricionGine<br />
                                        <b>Q: </b>@Model.PacienteQGine<br />
                                        <b>P: </b>@Model.PacientePGine<br />
                                        <b>AB: </b>@Model.PacienteABGine<br />
                                        <b>C: </b>@Model.PacienteCGine<br />
                                        <b>FUR: </b>@Model.PacienteFURGine<br />
                                        <b>Muerte Neonatal: </b>@Model.PacienteMuerteNeoGine<br />
                                        <b>FPP: </b>@Model.PacienteFPPGine<br />
                                        <b>HV: </b>@Model.PacienteHVGine<br />
                                        <b>Muerte: </b>@Model.PacienteMuerteGine<br />
                                        <b>Control Prenatal: </b>@Model.PacienteControlPrenatalGine<br />
                                        <b>Comadrona: </b>@Model.PacienteComadronaGine<br />
                                        <b>No Controles: </b>@Model.PacienteNoControlesGine<br />

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Datos de la Mamá</b></h5>
                                        <hr />
                                    </div>
                                    @*Datos de la informacion Mamá*@
                                    <div class="col-md-12">
                                        <h5><b>Información de la Mamá</b></h5>
                                        <hr />
                                    </div>
                                    <div class="col-md-4">
                                        <b>Uterio Gravio</b><br>
                                        @Model.EvaluacionObstetricaUteroGravio
                                    </div>
                                    <div class="col-md-4">
                                        <b>Abdomen Obstetrico</b><br>
                                        @Model.EvaluacionObstetricaAbdomenObstetrico
                                    </div>
                                    <div class="col-md-4">
                                        <b>FCF</b><br>
                                        @Model.EvaluacionObstetricaFcf
                                    </div>
                                    <div class="col-md-4">
                                        <b>AU</b><br>
                                        @Model.EvaluacionObstetricaAu
                                    </div>
                                    <div class="col-md-4">
                                        <b>Presentacion de Leopold</b><br>
                                        @Model.EvaluacionObstetricaPresentacionLeopold
                                    </div>
                                    <div class="col-md-4">
                                        <b>Otras</b><br>
                                        @Model.EvaluacionObstetricaOtras
                                    </div>
                                    <div class="col-md-4">
                                        <b>Actividad Uterina</b><br>
                                        @Model.EvaluacionObstetricaActividadUterina
                                    </div>
                                    <div class="col-md-4">
                                        <b>Movimient oFetal Percetible </b><br>
                                        @Model.EvaluacionObstetricaMovimientoFetalPercetible
                                    </div>
                                    <div class="col-md-4">
                                        <b>Especifique</b><br>
                                        @Model.EvaluacionObstetricaMovimientoFetalEspecifique
                                    </div>
                                    <div class="col-md-4">
                                        <b>Tacto Vaginal</b><br>
                                        @Model.EvaluacionObstetricaTactoVaginal
                                    </div>
                                    <div class="col-md-4">
                                        <b>Indice D</b><br>
                                        @Model.EvaluacionObstetricaD
                                    </div>
                                    <div class="col-md-4">
                                        <b>cms</b><br>
                                        @Model.EvaluacionObstetricaCms
                                    </div>

                                    <div class="col-md-4">
                                        <b>B%</b><br>
                                        @Model.EvaluacionObstetricaBPorciento
                                    </div>
                                    <div class="col-md-4">
                                        <b>Altiutud</b><br>
                                        @Model.EvaluacionObstetricaAltitud
                                    </div>
                                    <div class="col-md-4">
                                        <b>Variedad Posicion</b><br>
                                        @Model.EvaluacionObstetricaPosicionCervix
                                    </div>
                                    <div class="col-md-4">
                                        <b>Membranas Ovulares</b><br>
                                        @Model.EvaluacionObstetricaMembranasOvulares
                                    </div>
                                    <div class="col-md-4">
                                        <b>Liquido Amniotico </b><br>
                                        @Model.EvaluacionObstetricaLiquidoAmniotico
                                    </div>
                                    <div class="col-md-4">
                                        <b>Especifique</b><br>
                                        @Model.EvaluacionObstetricaLiquidoAmnioticoEspecifique
                                    </div>
                                    <div class="col-md-4">
                                        <b>Pelvis</b><br>
                                        @Model.EvaluacionObstetricaPelvis
                                    </div>
                                    @*Fin campos informacion ginecologica*@

                                </div>
                            </div>
                        </div>


                    </div>
                </div>

                <div class="form-row">
                    <div class="col-md-12">
                        <button data-bind="click:editarPaciente"
                                class="btn btn-primary">
                            <i class="fas fa-edit"></i>&nbsp;Editar datos del paciente
                        </button>
                    </div>
                </div>
            </div>
            <div id="tab-general">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <div class="form-row">



                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <label class="">Nivel Prioridad</label>
                                    @Html.TextBoxFor(m => m.NivelPrioridadCita, new { @class = "form-control ", @readonly = true, @Style = "Background:#f7b924; Color:black;" })

                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <label class="">No Turno</label>
                                    @Html.TextBoxFor(a => a.NumeroTurno, new { @class = "form-control", @readonly = true, @Style = "Background:#2fb9e7; Color:white;" })

                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="position-relative form-group">
                                    <label class="">Estado del Turno</label>
                                    <select asp-for="EstadoTurno" class="form-control">
                                        <option value="ACTIVO">ACTIVO</option>
                                        <option value="PENDIENTE">PENDIENTE</option>
                                        <option value="ENCURSO">EN CURSO</option>
                                        <option value="FINALIZADO">FINALIZADO</option>
                                    </select>

                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <div class="main-card mb-3 card d-none">
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <h5><b>Información de consulta</b></h5>
                                        <hr>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="position-relative form-group">
                                            <label>Estado de pago</label>
                                            <select class="form-control" asp-for="EstadoPagoId"
