                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="position-relative form-group">
                                            <label>Fecha de creación de consulta</label>
                                            <input class="form-control" asp-for="FechaYHoraInicio" readonly="readonly">
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="position-relative form-group">
                                            <label>Fecha de próxima consulta</label>
                                            <input class="form-control" asp-for="FechaProximaConsulta">
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <div class="position-relative form-group">
                                            <label>Fecha de su última radiografía/TAC/Resonancia magnética</label>
                                            @Html.TextBoxFor(a => a.FechaUltimaRadiografiaDental, new { @type = "date", @class = "form-control" })
                                        </div>
                                    </div>
                                    <div class="col-md-3">
                                        <label>Tipo de consulta</label>
                                        <select class="form-control" asp-for="TipoConsulta">
                                            <option disabled selected>--- SELECCIONE ---</option>
                                            <option value="Primera Consulta">Primera Consulta</option>
                                            <option value="Nueva Consulta">Nueva Consulta</option>
                                            <option value="Reconsulta">Reconsulta</option>
                                            <option value="Observacion">Observacion</option>
                                        </select>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Tipo de referencia</label>
                                        <select class="form-control" asp-for="TipoReferencia">
                                            <option disabled selected>--- SELECCIONE ---</option>
                                            <option value="Hospital Regional">Hospital Regional</option>
                                            <option value="Medico Particular">Medico Particular</option>
                                        </select>
                                    </div>

                                    <div class="col-md-3">
                                        <label>Medico Referido</label>
                                        <input class="form-control" asp-for="MedicoReferido">
                                        @Html.ValidationMessageFor(a => a.MedicoReferido, "", new { @class = "text-danger" })
                                    </div>

                                    <div class="col-md-12">
                                        <label>Anotaciones u Observaciones</label>
                                        <textarea class="form-control" asp-for="ObservacionesAdicionales"
                                                  placeholder="Anotaciones u Observaciones"></textarea>
                                        @Html.ValidationMessageFor(a => a.ObservacionesAdicionales, "", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-12">
                                        <hr />
                                    </div>
                                    <div class="col-md-12 badge badge-warning">
                                        <h4>
                                            <b>
                                                Costo total de consulta: Q <span data-bind="text:valorTotalConsulta"></span>
                                            </b>
                                        </h4>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="main-card mb-3 card d-none">
