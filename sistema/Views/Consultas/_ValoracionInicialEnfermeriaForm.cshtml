          <div class="mb-2">
            <span class="form-label me-2">Conoce el motivo del servicio:</span>
            <div class="d-inline-block">
              <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="si" asp-for="Ve_ConoceMotivo" /><label class="form-check-label">Sí</label></div>
              <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="no" asp-for="Ve_ConoceMotivo" /><label class="form-check-label">No</label></div>
