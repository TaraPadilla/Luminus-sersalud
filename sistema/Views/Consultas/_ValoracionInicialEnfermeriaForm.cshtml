                    <!-- 10) Medicación y Plan -->
                    <div class="border rounded mb-4 p-3">
                      <div class="oft-head"><i class="fas fa-prescription-bottle-alt"></i><h5 class="mb-0">Medicación actual y Plan terapéutico</h5></div>
                      <div class="row">
                        <div class="col-12 col-md-6 mb-3"><div class="text-dark text-uppercase"><strong>Medicación Actual del Paciente (Incluir dosis y frecuencia)</strong></div><div class="text-muted">@Vh(h.MedicacionActual)</div></div>
                        <div class="col-12 col-md-6 mb-3"><div class="text-dark text-uppercase"><strong>Plan Recomendado Terapéutico (Sueroterapia)</strong></div><div class="text-muted">@Vh(h.PlanTerapeutico)</div></div>
                      </div>
                    </div>

                  </div>
                </div>
              </div>
            </div>
          </div>
        }
      </div>
    </div>
  }
  else
  {
    <div class="mt-4 small text-muted">No hay histórico de valoración inicial para este paciente.</div>
  }
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
