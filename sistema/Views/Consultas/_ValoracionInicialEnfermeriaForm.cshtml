    <!-- 10. Medicación y Plan -->
    <div class="oft-card mb-4 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-prescription-bottle"></i><h5 class="mb-0">10. Medicación Actual y Plan Terapéutico</h5></div>
