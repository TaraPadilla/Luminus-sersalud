@model sistema.Models.ConsultasViewModel
@using Database.Shared.Models

@* IDs necesarios para upsert; viajarán en el POST del formulario principal *@
@Html.HiddenFor(m => m.Ve_ConsultaId)
@Html.HiddenFor(m => m.Ve_Id)
  @{
  var _veHist = ViewBag.VeHistorialFull as IEnumerable<ConsultasValoracionInicialEnfermeria>;
      Func<object, string> Vh = (val) =>
      {
          if (val == null) return "Sin definir";
          if (val is string s) return string.IsNullOrWhiteSpace(s) ? "Sin definir" : s;
          return Convert.ToString(val);
      };
      int vidx = 0;
  }


<style>
  :root{
    --ink:#1f2937;--ink-soft:#334155;--muted:#6b7280;--brand:#0ea5e9;--brand-ink:#0369a1;
    --bg:#f7fbff;--card:#ffffff;--card-bdr:#e5edf7;--accent:#dbeafe;
  }
  .oft-wrap{background:var(--bg);color:var(--ink)}
  .oft-card{background:var(--card);border:1px solid var(--card-bdr);border-radius:.9rem;box-shadow:0 8px 24px rgba(2,32,71,.06)}
  .oft-head{display:flex;align-items:center;gap:.6rem;color:var(--brand-ink);font-weight:800;letter-spacing:.2px;margin-bottom:.75rem}
  .oft-head i{font-size:1.3rem;color:var(--brand)}
  .oft-sub{color:var(--muted);font-size:.95rem}
  .oft-pill{display:inline-block;padding:.25rem .6rem;border-radius:9999px;background:var(--accent);color:var(--brand-ink);font-weight:700;font-size:.8rem}
  .form-label{font-weight:600;color:var(--ink-soft)}
  .font-weight-bold{font-weight:700}
  .hr-soft{border-top:1px dashed #e5edf7}
  .table thead th{background:var(--accent);color:var(--ink-soft);border-bottom:1px solid var(--card-bdr)}
</style>

<div class="oft-wrap">
  <div class="d-flex justify-content-between align-items-center mb-3">
    @if (Model.HabilitarEdicion)
    {
      <span class="oft-pill">MODO EDICIÓN</span>
    }
    else
    {
      <span class="oft-pill" style="background:#eaeef6;color:#475569">MODO LECTURA</span>
    }
    <div class="text-danger" asp-validation-summary="ModelOnly"></div>
  </div>

  @* ============================ EDICIÓN ============================ *@
  @if (Model.HabilitarEdicion)
  {
    @* Esta parcial NO abre <form>; el formulario principal la envuelve *@

    <div class="row">
      <!-- 1. Datos de Valoración Inicial -->
      <div class="col-lg-8 mb-3">
        <div class="oft-card p-3 p-md-4">
          <div class="oft-head"><i class="fas fa-file-medical"></i><h5 class="mb-0">1. Datos de Valoración Inicial</h5></div>

          <div class="mb-3">
            <label class="form-label">Motivo de consulta</label>
            <textarea class="form-control" rows="2" asp-for="Ve_Motivo" placeholder="Síntomas principales que motivan la sueroterapia."></textarea>
            <span class="text-danger" asp-validation-for="Ve_Motivo"></span>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Diagnóstico médico (Si aplica)</label>
              <textarea class="form-control" rows="2" asp-for="Ve_DiagnosticoMedico" placeholder="Diagnóstico establecido o presuntivo."></textarea>
              <span class="text-danger" asp-validation-for="Ve_DiagnosticoMedico"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Laboratorios a la vista</label>
              <textarea class="form-control" rows="2" asp-for="Ve_Labs" placeholder="Resultados clave recientes."></textarea>
              <span class="text-danger" asp-validation-for="Ve_Labs"></span>
            </div>
          </div>
        </div>
      </div>

      <!-- 2. ¿Cómo se enteró del servicio? -->
      <div class="col-lg-4 mb-3">
        <div class="oft-card p-3 p-md-4">
          <div class="oft-head"><i class="fas fa-bullhorn"></i><h5 class="mb-0">2. ¿Cómo se enteró del servicio?</h5></div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="Ve_Medio" value="referencia" @(Model?.Ve_Medio != null && Model.Ve_Medio.Contains("referencia") ? "checked" : "") />
              <label class="form-check-label">Referencia personal</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="Ve_Medio" value="redes" @(Model?.Ve_Medio != null && Model.Ve_Medio.Contains("redes") ? "checked" : "") />
              <label class="form-check-label">Redes sociales</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="Ve_Medio" value="salud" @(Model?.Ve_Medio != null && Model.Ve_Medio.Contains("salud") ? "checked" : "") />
              <label class="form-check-label">Personal de salud</label>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="Ve_Medio" value="otro" @(Model?.Ve_Medio != null && Model.Ve_Medio.Contains("otro") ? "checked" : "") />
              <label class="form-check-label">Otro</label>
            </div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Medio"></span>
        </div>
      </div>
    </div>

    <!-- 3. Oxigenación y Circulación -->
    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-lungs"></i><h5 class="mb-0">3. Oxigenación y Circulación</h5></div>
      <div class="row">
        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Sistema Respiratorio</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="sin_alteracion" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="disnea_esfuerzo" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("disnea_esfuerzo") ? "checked" : "") /><label class="form-check-label">Disnea de esfuerzo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="disnea_reposo" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("disnea_reposo") ? "checked" : "") /><label class="form-check-label">Disnea en reposo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="tos_seca" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("tos_seca") ? "checked" : "") /><label class="form-check-label">Tos seca</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="tos_productiva" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("tos_productiva") ? "checked" : "") /><label class="form-check-label">Tos productiva</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="oxigeno" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("oxigeno") ? "checked" : "") /><label class="form-check-label">Oxígeno suplementario</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Resp" value="marcapasos" @(Model?.Ve_Resp != null && Model.Ve_Resp.Contains("marcapasos") ? "checked" : "") /><label class="form-check-label">Marca pasos</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Resp"></span>
        </div>

        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Sistema Circulatorio</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="sin_alteracion" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="palpitaciones" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("palpitaciones") ? "checked" : "") /><label class="form-check-label">Palpitaciones</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="entumecimiento" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("entumecimiento") ? "checked" : "") /><label class="form-check-label">Entumecimiento</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="ext_frio" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("ext_frio") ? "checked" : "") /><label class="form-check-label">Extremidades frías</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="edemas" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("edemas") ? "checked" : "") /><label class="form-check-label">Edemas</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Circ" value="dolor_precordial" @(Model?.Ve_Circ != null && Model.Ve_Circ.Contains("dolor_precordial") ? "checked" : "") /><label class="form-check-label">Dolor precordial</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Circ"></span>
        </div>
      </div>
    </div>

    <!-- 4. Necesidad de Nutrición -->
    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas a-egg"></i><h5 class="mb-0">4. Necesidad de Nutrición</h5></div>

      <div class="mb-2">
        <div class="d-flex flex-wrap gap-3">
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="sin_alteracion" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="masticacion" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("masticacion") ? "checked" : "") /><label class="form-check-label">Dificultad para la masticación</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="protesis" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("protesis") ? "checked" : "") /><label class="form-check-label">Prótesis</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="deglucion" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("deglucion") ? "checked" : "") /><label class="form-check-label">Dificultad para la deglución</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="nauseas" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("nauseas") ? "checked" : "") /><label class="form-check-label">Náuseas</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="vomitos" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("vomitos") ? "checked" : "") /><label class="form-check-label">Vómitos</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="peso" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("peso") ? "checked" : "") /><label class="form-check-label">Alteración del peso</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="ayuda" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("ayuda") ? "checked" : "") /><label class="form-check-label">Necesita ayuda</label></div>
          <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Nutricion" value="dieta" @(Model?.Ve_Nutricion != null && Model.Ve_Nutricion.Contains("dieta") ? "checked" : "") /><label class="form-check-label">Dieta especial</label></div>
        </div>
        <span class="text-danger" asp-validation-for="Ve_Nutricion"></span>
      </div>

      <div class="mb-0">
        <label class="form-label">Observaciones / Detalles de la dieta</label>
        <textarea class="form-control" rows="1" asp-for="Ve_NutricionObs" placeholder="Detalle si dificultad, prótesis o dieta especial."></textarea>
        <span class="text-danger" asp-validation-for="Ve_NutricionObs"></span>
      </div>
    </div>

    <!-- 5. Necesidad de Eliminación -->
    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-tint"></i><h5 class="mb-0">5. Necesidad de Eliminación</h5></div>
      <div class="row">
        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Patrón Urinario</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="sin_alteracion" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="incontinencia" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("incontinencia") ? "checked" : "") /><label class="form-check-label">Incontinencia</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="retencion" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("retencion") ? "checked" : "") /><label class="form-check-label">Retención</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="disuria" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("disuria") ? "checked" : "") /><label class="form-check-label">Disuria</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="hematuria" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("hematuria") ? "checked" : "") /><label class="form-check-label">Hematuria</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="sonda" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("sonda") ? "checked" : "") /><label class="form-check-label">Sonda vesical</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Urinario" value="ostomia" @(Model?.Ve_Urinario != null && Model.Ve_Urinario.Contains("ostomia") ? "checked" : "") /><label class="form-check-label">Ostomía</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Urinario"></span>
        </div>

        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Patrón Intestinal</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="sin_alteracion" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="incontinencia" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("incontinencia") ? "checked" : "") /><label class="form-check-label">Incontinencia</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="estrenimiento" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("estrenimiento") ? "checked" : "") /><label class="form-check-label">Estreñimiento</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="diarrea" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("diarrea") ? "checked" : "") /><label class="form-check-label">Diarrea</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="hematoquesia" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("hematoquesia") ? "checked" : "") /><label class="form-check-label">Hematoquesia</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Intestinal" value="melena" @(Model?.Ve_Intestinal != null && Model.Ve_Intestinal.Contains("melena") ? "checked" : "") /><label class="form-check-label">Melena</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Intestinal"></span>
        </div>
      </div>
    </div>

    <!-- 6. Movilización y Estado de Conciencia -->
    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-person-walking"></i><h5 class="mb-0">6. Movilización y Estado de Conciencia</h5></div>
      <div class="row">
        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Actividad / Movilidad</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Mov" value="independiente" @(Model?.Ve_Mov != null && Model.Ve_Mov.Contains("independiente") ? "checked" : "") /><label class="form-check-label">Completamente independiente</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Mov" value="dispositivo" @(Model?.Ve_Mov != null && Model.Ve_Mov.Contains("dispositivo") ? "checked" : "") /><label class="form-check-label">Requiere dispositivo/equipo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Mov" value="persona" @(Model?.Ve_Mov != null && Model.Ve_Mov.Contains("persona") ? "checked" : "") /><label class="form-check-label">Requiere otra persona</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Mov" value="persona_dispositivo" @(Model?.Ve_Mov != null && Model.Ve_Mov.Contains("persona_dispositivo") ? "checked" : "") /><label class="form-check-label">Persona + dispositivo/equipo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Mov" value="dependiente" @(Model?.Ve_Mov != null && Model.Ve_Mov.Contains("dependiente") ? "checked" : "") /><label class="form-check-label">Dependiente (Ayuda total)</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Mov"></span>
        </div>

        <div class="col-md-6 mb-2">
          <div class="font-weight-bold text-primary mb-2">Estado de Conciencia</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Conciencia" value="consciente" @(Model?.Ve_Conciencia != null && Model.Ve_Conciencia.Contains("consciente") ? "checked" : "") /><label class="form-check-label">Consciente y orientado</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Conciencia" value="desorientado" @(Model?.Ve_Conciencia != null && Model.Ve_Conciencia.Contains("desorientado") ? "checked" : "") /><label class="form-check-label">Desorientado</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Conciencia" value="letargico" @(Model?.Ve_Conciencia != null && Model.Ve_Conciencia.Contains("letargico") ? "checked" : "") /><label class="form-check-label">Letárgico</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Conciencia" value="inconsciente" @(Model?.Ve_Conciencia != null && Model.Ve_Conciencia.Contains("inconsciente") ? "checked" : "") /><label class="form-check-label">Inconsciente/comatoso</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Conciencia"></span>
        </div>
      </div>
    </div>

    <!-- 7. Autocuidado y Reposo -->
    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-hospital"></i><h5 class="mb-0">7. Autocuidado y Reposo</h5></div>
      <div class="row">
        <div class="col-md-4 mb-2">
          <div class="font-weight-bold text-primary mb-2">Necesidad de Reposo y Sueño</div>
          <div class="d-flex flex-column gap-2">
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Sueno" value="sin_alteracion" @(Model?.Ve_Sueno != null && Model.Ve_Sueno.Contains("sin_alteracion") ? "checked" : "") /><label class="form-check-label">Sin alteración observada</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Sueno" value="discontinuo" @(Model?.Ve_Sueno != null && Model.Ve_Sueno.Contains("discontinuo") ? "checked" : "") /><label class="form-check-label">Sueño discontinuo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Sueno" value="insomnio" @(Model?.Ve_Sueno != null && Model.Ve_Sueno.Contains("insomnio") ? "checked" : "") /><label class="form-check-label">Insomnio</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Sueno" value="ayuda" @(Model?.Ve_Sueno != null && Model.Ve_Sueno.Contains("ayuda") ? "checked" : "") /><label class="form-check-label">Necesita ayuda/medicación</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Sueno"></span>
        </div>

        <div class="col-md-4 mb-2">
          <div class="font-weight-bold text-primary mb-2">Autonomía para Vestirse</div>
          <div class="d-flex flex-wrap gap-3">
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="autonomo" asp-for="Ve_Vestirse" /><label class="form-check-label">Autónomo</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="parcial" asp-for="Ve_Vestirse" /><label class="form-check-label">Ayuda parcial</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="total" asp-for="Ve_Vestirse" /><label class="form-check-label">Ayuda total</label></div>
          </div>

          <div class="font-weight-bold text-primary mt-3 mb-2">Autonomía para Higiene</div>
          <div class="d-flex flex-wrap gap-3">
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="autonomo" asp-for="Ve_Higiene" /><label class="form-check-label">Autónomo</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="parcial" asp-for="Ve_Higiene" /><label class="form-check-label">Ayuda parcial</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="radio" value="total" asp-for="Ve_Higiene" /><label class="form-check-label">Ayuda total</label></div>
          </div>
          <span class="text-danger" asp-validation-for="Ve_Vestirse"></span>
          <span class="text-danger" asp-validation-for="Ve_Higiene"></span>
        </div>

        <div class="col-md-4 mb-2">
          <div class="font-weight-bold text-primary mb-2">Estado de Piel y Mucosas</div>
          <div class="d-flex flex-wrap gap-3">
