</div>

  <!-- ====================== HISTÓRICO VALORACIÓN INICIAL (SIEMPRE) ====================== -->
  @if (_veHist != null )
  {
    <div class="mt-4">
      <h3 class="h5 mb-3 text-secondary">Histórico Valoración Inicial de Enfermería (completo)</h3>

      <div class="accordion" id="veHistAccordion">
        @foreach (var h in _veHist)
        {
          var collapseId = $"veHist-{vidx}";
          var headingId  = $"veHead-{vidx}";
          vidx++;

          <div class="card mb-3">
            <div class="card-header" id="@headingId">
              <h2 class="mb-0">
                <button class="btn btn-link collapsed w-100 text-left d-flex justify-content-between align-items-center"
                        type="button"
                        data-toggle="collapse"
                        data-target="#@collapseId"
                        aria-expanded="false"
                        aria-controls="@collapseId">
                  <div class="w-100 d-flex flex-column flex-md-row justify-content-between small">
                    <div>
                      <span class="fw-semibold text-dark">Fecha:</span>
                      @{
                        DateTime? f = h.Fecha;
                      }
                      @(f.HasValue ? f.Value.ToString("dd-MM-yyyy HH:mm") : "Sin definir")
                    </div>
                  </div>
                </button>
              </h2>
            </div>

            <div id="@collapseId" class="collapse" aria-labelledby="@headingId" data-parent="#veHistAccordion">
              <div class="card-body">

                <div class="card border rounded shadow-sm mb-4">
                  <div class="card-body">

                    <!-- 1) Datos de valoración inicial -->
                    <div class="border rounded mb-4 p-3">
                      <div class="oft-head"><i class="fas fa-file-medical"></i><h5 class="mb-0">Datos de valoración inicial</h5></div>
                      <div class="row">
                      <div class="col-12 col-md-4 mb-3">
                        <div class="text-dark text-uppercase"><strong>Motivo de consulta</strong></div>
                        <div class="text-muted">@Vh(h.Motivo)</div>
                      </div>
                        <div class="col-12 col-md-4 mb-3"><div class="text-dark text-uppercase"><strong>Diagnóstico médico (Si aplica)</strong></div><div class="text-muted">@Vh(h.DiagnosticoMedico)</div></div>
                      <div class="col-12 col-md-4 mb-3">
                        <div class="text-dark text-uppercase"><strong>Laboratorios a la vista</strong></div>
                        <div class="text-muted">@Vh(h.Labs)</div>
                      </div>
                      </div>
                    </div>

                    <!-- 2) ¿Cómo se enteró del servicio? -->
                    <div class="border rounded mb-4 p-3">
                      <div class="oft-head"><i class="fas fa-bullhorn"></i><h5 class="mb-0">¿Cómo se enteró del servicio?</h5></div>
                      <div class="text-muted">
                        @{
                          var m = h.Medio ?? Array.Empty<string>();
                        }
                        @(m.Length == 0 ? "Sin definir" : string.Join(", ", m))
                      </div>
                    </div>

                    <!-- 3) Oxigenación y Circulación -->
                    <div class="border rounded mb-4 p-3">
                      <div class="oft-head"><i class="fas fa-lungs"></i><h5 class="mb-0">Oxigenación y Circulación</h5></div>
                      <div class="row">
                        <div class="col-12 col-md-6 mb-3">
                          <div class="text-dark text-uppercase"><strong>Sistema Respiratorio</strong></div>
                          <div class="text-muted">
                            @{
                              var r = h.Resp ?? Array.Empty<string>();
                            }
                            @(r.Length == 0 ? "Sin definir" : string.Join(", ", r))
                          </div>
                        </div>
                        <div class="col-12 col-md-6 mb-3">
                          <div class="text-dark text-uppercase"><strong>Sistema Circulatorio</strong></div>
                          <div class="text-muted">
                            @{
                              var c = h.Circ ?? Array.Empty<string>();
                            }
                            @(c.Length == 0 ? "Sin definir" : string.Join(", ", c))
                          </div>
                        </div>
                      </div>
                    </div>

                    <!-- 4) Nutrición -->
                    <div class="border rounded mb-4 p-3">
                      <div class="oft-head"><i class="fas fa-utensils"></i><h5 class="mb-0">Necesidad de Nutrición</h5></div>
                      <div class="row">
                        <div class="col-12 col-md-6 mb-3">
                          <div class="text-dark text-uppercase"><strong>Aspectos</strong></div>
                          <div class="text-muted">
                            @{
                              var n = h.Nutricion ?? Array.Empty<string>();
                            }
                            @(n.Length == 0 ? "Sin definir" : string.Join(", ", n))
                          </div>
                        </div>
                        <div class="col-12 col-md-6 mb-3">
                          <div class="text-dark text-uppercase"><strong>Observaciones / Detalles de la dieta</strong></div>
                          <div class="text-muted">@Vh(h.NutricionObs)</div>
