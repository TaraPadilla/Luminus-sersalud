            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Oido" value="deficiente" @(Model?.Ve_Oido != null && Model.Ve_Oido.Contains("deficiente") ? "checked" : "") /><label class="form-check-label">Deficiente</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Oido" value="sordo" @(Model?.Ve_Oido != null && Model.Ve_Oido.Contains("sordo") ? "checked" : "") /><label class="form-check-label">Sordo</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Oido" value="protesis" @(Model?.Ve_Oido != null && Model.Ve_Oido.Contains("protesis") ? "checked" : "") /><label class="form-check-label">Prótesis auditiva</label></div>
