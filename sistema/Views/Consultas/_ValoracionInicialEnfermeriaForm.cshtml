            <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="Ve_Seg" value="autolesion" @(Model?.Ve_Seg != null && Model.Ve_Seg.Contains("autolesion") ? "checked" : "") /><label class="form-check-label">Riesgo de autolesión</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="Ve_Seg" value="caida" @(Model?.Ve_Seg != null && Model.Ve_Seg.Contains("caida") ? "checked" : "") /><label class="form-check-label">Riesgo de caída</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="Ve_Seg" value="infeccion" @(Model?.Ve_Seg != null && Model.Ve_Seg.Contains("infeccion") ? "checked" : "") /><label class="form-check-label">Riesgo de infección</label></div>
            <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" name="Ve_Seg" value="ulcera" @(Model?.Ve_Seg != null && Model.Ve_Seg.Contains("ulcera") ? "checked" : "") /><label class="form-check-label">Riesgo de úlcera por presión</label></div>
