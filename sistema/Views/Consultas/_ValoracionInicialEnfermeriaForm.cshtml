          <div class="mb-2">
            <label class="form-label">Observaciones</label>
            <input class="form-control" asp-for="Ve_CreenciasObservaciones" placeholder="Detalle observaciones sobre creencias." />
            <span class="text-danger" asp-validation-for="Ve_CreenciasObservaciones"></span>
