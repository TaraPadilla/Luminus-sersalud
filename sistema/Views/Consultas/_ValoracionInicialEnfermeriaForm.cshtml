            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Vision" value="ceguera" @(Model?.Ve_Vision != null && Model.Ve_Vision.Contains("ceguera") ? "checked" : "") /><label class="form-check-label">Ceguera</label></div>
            <div class="form-check"><input class="form-check-input" type="checkbox" name="Ve_Vision" value="lentes" @(Model?.Ve_Vision != null && Model.Ve_Vision.Contains("lentes") ? "checked" : "") /><label class="form-check-label">Utiliza lentes</label></div>
          </div>
