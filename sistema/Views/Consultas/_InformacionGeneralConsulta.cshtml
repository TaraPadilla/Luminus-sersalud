        </div> *@

        <div class="col-md-12 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold text-dark mb-1">
                    <i class="fas fa-comment-medical text-primary mr-1"></i> Anotaciones u Observaciones
                </div>
                <textarea class="form-control dato-consulta"
