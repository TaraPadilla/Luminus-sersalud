<!-- ================= ÚLTIMA EVALUACIÓN ================= -->
<div class="border rounded p-3 bg-white shadow-sm">

    <!-- Header -->
    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
        <h6 class="mb-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-history mr-2"></i> Última evaluación
        </h6>
    </div>

    <div class="form-row">

        <div class="col-md-12 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold text-dark mb-1">
                    <i class="fas fa-calendar-check text-primary mr-1"></i> Fecha de su última evaluación
                </div>
                <input class="form-control dato-consulta" asp-for="FechaUltimaConsulta" readonly="readonly">
            </div>
        </div>

        <div class="col-md-12">
            <div class="border rounded p-2">
                <div class="font-weight-bold text-dark mb-1">
                    <i class="fas fa-file-medical-alt text-primary mr-1"></i> ¿Qué le hicieron en esa ocasión?
                </div>
                <input class="form-control dato-consulta" asp-for="MotivoUltimaConsulta" readonly="readonly">
            </div>
        </div>

    </div>
</div>
