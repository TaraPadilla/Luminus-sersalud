@model sistema.Models.ConsultasViewModel

<br />
<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-12">
                <h5><b>Revision por sistemas</b></h5>
                <hr>
            </div>
            <div class="col-md-6">
                <b>APARIENCIA GENERAL Y NEUROLOGICO:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaAparienciaGeneral, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>CABEZA:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaCabeza, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>OIDOS Y BOCA:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaOidosBoca, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>CUELLO:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaCuello, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>TORAX:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaTorax, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>ABDOMEN:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaAbdomen, new { @class = "form-control dato-consulta" })
            </div>
                        <div class="col-md-6">
                <b>DORSO Y EXTREMIDADES:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaDorsoYExtremidades, new { @class = "form-control dato-consulta" })
            </div>
            <div class="col-md-6">
                <b>GENITALES:</b><br>
                @Html.TextAreaFor(m => m.RevisionSistemasPediatriaGenitales, new { @class = "form-control dato-consulta" })
            </div>
        </div>
        <br />
        <div class="form-row">
            <div class="col-12">
                <h5><b>Revision por sistemas (historial)</b></h5>
                <hr>
            </div>
            <div class="col-md-12 text-primary texto-cargando-historial" style="display:none">
                Cargando historial...
            </div>
            <div class="col-md-12 text-danger texto-error-cargando-historial" style="display:none">
                Error de servidor y/o conexion. <a href="#" data-bind="click:consultarHistorialConsultas">Reintentar</a>
            </div>
            <!--ko foreach:historialConsultas-->
            <div class="col-md-12" style="background-color:lightgray"><b>Fecha: </b><span data-bind="text:Fecha"></span></div>
            <div class="col-md-2"><b>APARIENCIA GENERAL Y NEUROLOGICO:</b><br /><span data-bind="text:RevisionSistemasPediatriaAparienciaGeneral"></span></div>
            <div class="col-md-2"><b>CABEZA:</b><br /><span data-bind="text:RevisionSistemasPediatriaCabeza"></span></div>
            <div class="col-md-2"><b>OIDOS Y BOCA:</b><br /><span data-bind="text:RevisionSistemasPediatriaOidosBoca"></span></div>
            <div class="col-md-2"><b>CUELLO:</b><br /><span data-bind="text:RevisionSistemasPediatriaCuello"></span></div>
            <div class="col-md-2"><b>TORAX:</b><br /><span data-bind="text:RevisionSistemasPediatriaTorax"></span></div>
            <div class="col-md-2"><b>ABDOMEN:</b><br /><span data-bind="text:RevisionSistemasPediatriaAbdomen"></span></div>
            <!--/ko-->
            <!--ko if:historialConsultas().length==0-->
            <div class="col-md-12">
                No hay registro de consultas anteriores
            </div>
            <!--/ko-->
        </div>
    </div>
</div>
