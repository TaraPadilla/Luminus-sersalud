@model sistema.Models.ConsultasViewModel
<br />

<!-- Impresión clínica -->
<div class="border rounded p-3 bg-white shadow-sm mb-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-notes-medical mr-2"></i> Impresi&oacute;n cl&iacute;nica
        </h6>
         <small class="text-muted">
            <i class="fas fa-microphone-alt mr-1"></i> Dictado habilitado en campos configurados
        </small>
    </div>

    <div class="form-row">
        <div class="col-md-12 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Impresi&oacute;n cl&iacute;nica</div>
                @Html.TextAreaFor(a => a.HistoriaClinicaImpresionClinica, new { @class = "form-control dato-consulta" })
            </div>
        </div>
    </div>

    <div class="mt-3"></div>

    <!-- Header: Historial -->
    <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-history mr-2"></i> Impresi&oacute;n cl&iacute;nica (historial)
        </h6>
    </div>

    <div class="form-row">

        <div class="col-md-12 text-primary texto-cargando-historial mb-2" style="display:none">
            <i class="fas fa-spinner fa-spin mr-1"></i> Cargando historial...
        </div>

        <div class="col-md-12 text-danger texto-error-cargando-historial mb-2" style="display:none">
            <i class="fas fa-exclamation-triangle mr-1"></i>
            Error de servidor y/o conexion. <a href="#" data-bind="click:consultarHistorialConsultas">Reintentar</a>
        </div>

        <!--ko foreach:historialConsultas-->
        <div class="col-md-12 mb-3">
            <div class="border rounded p-3 bg-white">

                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="font-weight-bold text-dark">
                        <i class="fas fa-calendar-alt text-primary mr-1"></i>
                        Fecha: <span data-bind="text:Fecha"></span>
                    </div>
                    <span class="badge badge-light border">
                        <i class="fas fa-clipboard-check text-primary mr-1"></i> Registro
                    </span>
                </div>

                <div>
                    <div class="font-weight-bold text-dark mb-1">Impresi&oacute;n cl&iacute;nica:</div>
                    <span class="text-body" data-bind="text:HistoriaClinicaImpresionClinica"></span>
                </div>

            </div>
        </div>
        <!--/ko-->

        <!--ko if:historialConsultas().length==0-->
        <div class="col-md-12 text-muted">
            <i class="fas fa-info-circle mr-1"></i> No hay registro de consultas anteriores
        </div>
        <!--/ko-->

    </div>
</div>

<!-- Impresión clínica CIE10 -->
<div class="border rounded p-3 bg-white shadow-sm mt-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-notes-medical mr-2"></i> Impresi&oacute;n cl&iacute;nica CIE10
        </h6>
    </div>

    <div class="form-row">
        <div class="col-md-6 mb-3">
            <label for="cie10-codigo" class="font-weight-bold mb-1">C&oacute;digo CIE10</label>

            @if (Model.HabilitarEdicion)
            {
                <div class="input-group">
                    @Html.TextBoxFor(m => m.Cie10Codigo, new { @class = "form-control cie10-control", id = "cie10-codigo", autocomplete = "off", placeholder = "Ej. A00", style = "text-transform:uppercase;", pattern = "[A-Z0-9]+", oninput = "this.value = this.value.toUpperCase().replace(/[^A-Z0-9]/g, '')" })
                    <div class="input-group-append">
                        <button class="btn btn-outline-primary cie10-control" id="buscar-cie10" type="button">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                    </div>
                </div>
            }
            else
            {
                <input type="text" class="form-control" value="@Model.Cie10Codigo" readonly />
            }
        </div>
    </div>

    <div class="form-row">
        <div class="col-md-12 mb-3">
            <label class="font-weight-bold mb-1">Descripci&oacute;n</label>

            @if (Model.HabilitarEdicion)
            {
                <div id="cie10-descripcion" class="form-control bg-light" style="min-height: 38px;">
                    @Model.Cie10Descripcion
                </div>
            }
            else
            {
                <input type="text" class="form-control" value="@Model.Cie10Descripcion" readonly />
            }
        </div>
    </div>

    <!-- Historial CIE-10 -->
    <div class="border rounded p-3 bg-white mt-3">

        <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
            <h6 class="m-0 font-weight-bold text-primary text-uppercase">
                <i class="fas fa-history mr-2"></i> Historial CIE-10
            </h6>
        </div>

        @if (Model.HistorialCie10.Any())
        {
            foreach (var h in Model.HistorialCie10)
            {
                <div class="mb-3 p-3 rounded shadow-sm border bg-white">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <div class="font-weight-bold text-dark">
                            <i class="fas fa-calendar-alt text-primary mr-1"></i>
                            Fecha: @h.Fecha.ToString("g")
                        </div>
                        <span class="badge badge-light border">
                            <i class="fas fa-clipboard-check text-primary mr-1"></i> Registro
                        </span>
                    </div>

                    <p class="mb-1"><b>C&oacute;digo:</b> @h.Cie10Codigo</p>
                    <p class="mb-0"><b>Descripci&oacute;n:</b> @h.Cie10Descripcion</p>
                </div>
            }
        }
        else
        {
            <div class="text-muted">
                <i class="fas fa-info-circle mr-1"></i> No hay registros de CIE-10 anteriores
            </div>
        }
    </div>

</div>
