                <div class="col-md-3 mb-3"><label class="form-label">Adición (siempre con +)</label><input type="number"
                    step="0.25" inputmode="decimal" class="form-control" asp-for="Oft_Final_Adicion"
                    placeholder="+0.75, +1.00" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">DIP (mm)</label><input type="number" step="0.5"
                    inputmode="decimal" class="form-control" asp-for="Oft_Final_DIP_mm" /></div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mb-2">
          <div class="card-header" role="tab" id="retinoHead">
            <h6 class="mb-0"><a class="collapsed" data-toggle="collapse" href="#retino" aria-expanded="false"
                aria-controls="retino">Retinoscopía</a></h6>
          </div>
          <div id="retino" class="collapse" role="tabpanel" aria-labelledby="retinoHead" data-parent="#opticaAcc">
            <div class="card-body">
              <div class="form-row">
                <div class="col-md-3 mb-3"><label class="form-label">OD Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Retino_OD_Esfera" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Retino_OD_Cilindro" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Retino_OD_Eje" /></div>

                <div class="col-12"></div>

                <div class="col-md-3 mb-3"><label class="form-label">OS Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Retino_OS_Esfera" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Retino_OS_Cilindro" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Retino_OS_Eje" /></div>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header" role="tab" id="lenteHead">
            <h6 class="mb-0"><a class="collapsed" data-toggle="collapse" href="#lente" aria-expanded="false"
                aria-controls="lente">Tipo de lente</a></h6>
          </div>
          <div id="lente" class="collapse" role="tabpanel" aria-labelledby="lenteHead" data-parent="#opticaAcc">
            <div class="card-body">
              <div class="form-row">
                <div class="col-md-4 mb-3">
                  <div class="custom-control custom-radio"><input class="custom-control-input" type="radio"
                      asp-for="Oft_TipoLente" id="l1" value="Monofocal" /><label class="custom-control-label"
                      for="l1">Monofocal</label></div>
                  <div class="custom-control custom-radio"><input class="custom-control-input" type="radio"
                      asp-for="Oft_TipoLente" id="l2" value="Bifocal Flaptop" /><label class="custom-control-label"
                      for="l2">Bifocal Flaptop</label></div>
                  <div class="custom-control custom-radio"><input class="custom-control-input" type="radio"
                      asp-for="Oft_TipoLente" id="l3" value="Bifocal Invisible" /><label class="custom-control-label"
                      for="l3">Bifocal Invisible</label></div>
                  <div class="custom-control custom-radio"><input class="custom-control-input" type="radio"
                      asp-for="Oft_TipoLente" id="l4" value="Progresivo" /><label class="custom-control-label"
                      for="l4">Progresivo</label></div>
                  <span class="text-danger" asp-validation-for="Oft_TipoLente"></span>
                </div>
                <div class="col-md-8 mb-1">
                  <label class="form-label">Material y tratamiento <span class="hint">(No retirar insumos)</span></label>
                  <textarea class="form-control" rows="3" asp-for="Oft_LenteMaterialTratamiento"
                  placeholder="Se escribirá directamente..."></textarea>
                  <span class="text-danger" asp-validation-for="Oft_LenteMaterialTratamiento"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div><!-- /opticaAcc -->
    </div>

    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-binoculars"></i>
        <h5 class="mb-0">Inspección, lámpara de hendidura y oftalmoscopía</h5>
      </div>
      <div class="form-row">
        @* CAMBIO: estos campos ahora son TEXTO LIBRE *@
        <div class="col-md-6 mb-3">
          <label class="form-label">Movimientos extraoculares (OD)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_MovExtraoculares_OD" />
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Movimientos extraoculares (OS)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_MovExtraoculares_OS" />
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Cejas (OD)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_Cejas_OD" />
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Cejas (OS)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_Cejas_OS" />
        </div>

        <div class="col-md-6 mb-3">
          <label class="form-label">Párpados y pestañas (OD)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_ParpadosPestanas_OD" />
        </div>
        <div class="col-md-6 mb-3">
          <label class="form-label">Párpados y pestañas (OS)</label>
          <input type="text" class="form-control" asp-for="Oft_Inspeccion_ParpadosPestanas_OS" />
        </div>

