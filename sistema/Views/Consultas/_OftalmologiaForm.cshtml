@if (Model.HabilitarEdicion && !Model.Hospitalizada)
{
  <script>
    // Poblar listas de agudeza visual y defaults "Sin alteración" (solo en edición)
    (function () {
      var AVS = [
        "20/15", "20/20", "20/30", "20/40", "20/50", "20/60", "20/70", "20/80",
        "20/100", "20/200", "20/400", "20/800",
        "abajo de 20/800", "20/1600", "Movimientos de manos", "Percepción de Luz", "NPL"
      ];

      function fillSelectPreservingValue(sel, values) {
        if (!sel) return;
        var prev = sel.value;  // guardar valor actual que pudo venir del modelo
        sel.innerHTML = "";
        values.forEach(function (v) {
          var o = document.createElement('option');
          o.value = v;
          o.textContent = v;
          sel.appendChild(o);
        });
        if (prev) sel.value = prev;  // restaurar si existía
      }

      var avOD = document.getElementById("Oft_AgudezaSC_OD");
      var avOS = document.getElementById("Oft_AgudezaSC_OS");
      var avCOD = document.getElementById("Oft_AVCerca_OD");
      var avCOS = document.getElementById("Oft_AVCerca_OS");

      [avOD, avOS, avCOD, avCOS].forEach(function (sel) {
        fillSelectPreservingValue(sel, AVS);
      });

      if (avOD && avCOD) {
        avOD.addEventListener('change', function () { avCOD.value = avOD.value; });
      }
      if (avOS && avCOS) {
        avOS.addEventListener('change', function () { avCOS.value = avOS.value; });
      }

      // Valores por defecto "Sin alteración"
      var opts = ["Sin alteración", "Con alteración", "Observación"];
      document.querySelectorAll(".default-sin-alt").forEach(function (sel) {
        var prev = sel.value;

        // Solo tiene sentido recrear options si es un SELECT
        if (sel.tagName === "SELECT") {
          sel.innerHTML = "";
          opts.forEach(function (v) {
            var o = document.createElement('option');
            o.value = v;
            o.textContent = v;
            sel.appendChild(o);
          });
        }

        sel.value = prev || "Sin alteración";
      });

      // === Botones Word (solo window.open, sin AJAX) ===
      var consultaId = '@(Model.ConsultaId?.ToString() ?? "")';

      function validarConsultaId() {
        if (!consultaId) {
          alert("Debe guardar primero la consulta antes de generar la receta.");
          return false;
        }
        return true;
      }

      var btnRecetaMedica = document.getElementById("btnRecetaMedica");
      if (btnRecetaMedica) {
        btnRecetaMedica.addEventListener("click", function () {
          if (!validarConsultaId()) return;
          var url = '@Url.Action("RecetaMedicaWord", "Consultas")'
            + '?consultaId=' + encodeURIComponent(consultaId);
          window.open(url, "_blank");
        });
      }

      var btnRecetaGafas = document.getElementById("btnRecetaGafas");
      if (btnRecetaGafas) {
        btnRecetaGafas.addEventListener("click", function () {
          if (!validarConsultaId()) return;
          var url = '@Url.Action("RecetaGafasWord", "Consultas")'
            + '?consultaId=' + encodeURIComponent(consultaId);
          window.open(url, "_blank");
        });
      }
    })();
  </script>
}

