@model sistema.Models.ConsultasViewModel
@using Database.Shared.Models
@{
  var _hist = ViewBag.OftHistorialFull as IEnumerable<ConsultasOftalmologia>;

  // Helper de presentación
  Func<object, string> V = (val) =>
  {
    if (val == null) return "Sin definir";
    if (val is string s) return string.IsNullOrWhiteSpace(s) ? "Sin definir" : s;
    return Convert.ToString(val);
  };

  var idx = 0;
}


@{
  // ===== Helpers de formateo seguro (uso en lectura) =====
  string TextoONada(string? v) => string.IsNullOrWhiteSpace(v) ? "—" : v;

  string DecNulo(decimal? n, string f = "0.00") =>
  n.HasValue ? n.Value.ToString(f, global::System.Globalization.CultureInfo.InvariantCulture) : "—";

  string EntNulo(int? n) =>
  n.HasValue ? n.Value.ToString(global::System.Globalization.CultureInfo.InvariantCulture) : "—";

  string Adicion(decimal? n) =>
  n.HasValue ? n.Value.ToString("+0.00", global::System.Globalization.CultureInfo.InvariantCulture) : "—";

  string Dip(decimal? n) =>
  n.HasValue ? n.Value.ToString("0.0", global::System.Globalization.CultureInfo.InvariantCulture) : "—";
}

@* IDs necesarios para upsert; viajarán en el POST del formulario principal *@
@Html.HiddenFor(m => m.Oft_ConsultaId)
@Html.HiddenFor(m => m.Oft_Id)

<style>
  :root {
    --ink: #1f2937;
    --ink-soft: #334155;
    --muted: #6b7280;
    --brand: #0ea5e9;
    --brand-ink: #0369a1;
    --bg: #f7fbff;
    --card: #ffffff;
    --card-bdr: #e5edf7;
    --accent: #dbeafe;
  }

  .oft-wrap {
    background: var(--bg);
    color: var(--ink)
  }

  .oft-card {
    background: var(--card);
    border: 1px solid var(--card-bdr);
    border-radius: .9rem;
    box-shadow: 0 8px 24px rgba(2, 32, 71, .06);
  }

  .oft-head {
    display: flex;
    align-items: center;
    gap: .6rem;
    color: var(--brand-ink);
    font-weight: 800;
    letter-spacing: .2px;
    margin-bottom: .75rem;
  }

  .oft-head i {
    font-size: 1.3rem;
    color: var(--brand)
  }

  .oft-sub {
    color: var(--muted);
    font-size: .95rem;
  }

  .oft-pill {
    display: inline-block;
    padding: .25rem .6rem;
    border-radius: 9999px;
    background: var(--accent);
    color: var(--brand-ink);
    font-weight: 700;
    font-size: .8rem;
  }

  .table thead th {
    background: var(--accent);
    color: var(--ink-soft);
    border-bottom: 1px solid var(--card-bdr);
  }

  .form-label {
    font-weight: 600;
    color: var(--ink-soft)
  }

  .hint {
    font-size: .85rem;
    color: var(--muted)
  }

  .hr-soft {
    border-top: 1px dashed #e5edf7
  }

  .nav-pills .nav-link {
    font-weight: 700
  }

  .nav-pills .nav-link.active {
    background: var(--brand);
    box-shadow: 0 6px 14px rgba(14, 165, 233, .25)
  }
</style>

<div class="oft-wrap">
  <div class="d-flex justify-content-between align-items-center mb-3">
    @if (Model.HabilitarEdicion)
    {
      <span class="oft-pill">MODO EDICIÓN</span>
    }
    else
    {

      <span class="oft-pill" style="background:#eaeef6;color:#475569">MODO LECTURA</span>
    }
    <div class="text-danger" asp-validation-summary="ModelOnly"></div>
  </div>

  @* ============================ EDICION ============================ *@
  @if (Model.HabilitarEdicion)
  {
    <div class="row">
      <div class="col-lg-6 mb-3">
        <div class="oft-card p-3 p-md-4">
          <div class="oft-head"><i class="fas fa-notes-medical"></i>
            <h5 class="mb-0">Motivo de consulta e historia</h5>
          </div>
          <textarea class="form-control" rows="6" asp-for="Oft_HistoriaEnfermedadActual"
          placeholder="Breve historia de la enfermedad actual"></textarea>
          <span class="text-danger" asp-validation-for="Oft_HistoriaEnfermedadActual"></span>
        </div>
      </div>

      <div class="col-lg-6 mb-3">
        <div class="oft-card p-3 p-md-4">
          <div class="oft-head"><i class="fas fa-clipboard-list"></i>
            <h5 class="mb-0">Antecedentes</h5>
          </div>
          <div class="form-row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Médicos</label>
              <textarea class="form-control" rows="2" asp-for="Oft_PacienteMedicos"></textarea>
              <span class="text-danger" asp-validation-for="Oft_PacienteMedicos"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Quirúrgicos</label>
              <textarea class="form-control" rows="2" asp-for="Oft_PacienteQuirurgicos"></textarea>
              <span class="text-danger" asp-validation-for="Oft_PacienteQuirurgicos"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Traumáticos</label>
              <textarea class="form-control" rows="2" asp-for="Oft_PacienteTraumaticos"></textarea>
              <span class="text-danger" asp-validation-for="Oft_PacienteTraumaticos"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Alérgicos</label>
              <textarea class="form-control" rows="2" asp-for="Oft_PacienteAlergias"></textarea>
              <span class="text-danger" asp-validation-for="Oft_PacienteAlergias"></span>
            </div>
            <div class="col-md-12 mb-1">
              <label class="form-label">Familiares</label>
              <textarea class="form-control" rows="2" asp-for="Oft_PacienteFamiliares"></textarea>
              <span class="text-danger" asp-validation-for="Oft_PacienteFamiliares"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-eye"></i>
        <h5 class="mb-0">Datos objetivos</h5>
      </div>

      <ul class="nav nav-pills mb-3" role="tablist">
        <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#avsc">Agudeza visual sin corrección</a>
        </li>
        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#contraste">Sensibilidad de contraste</a></li>
        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#avcerca">AV cerca sin corrección</a></li>
        <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#testesp">Tests especiales</a></li>
      </ul>

      <div class="tab-content">
        <div id="avsc" class="tab-pane fade show active">
          <div class="form-row">
            <div class="col-md-3 mb-3">
              <label class="form-label">Test</label>
              <select class="form-control" asp-for="Oft_AgudezaSC_Test">
                <option value="SNELLEN LETRAS">SNELLEN LETRAS</option>
                <option value="SNELLEN NÚMEROS">SNELLEN NÚMEROS</option>
                <option value="ALLEN">ALLEN</option>
                <option value="E">E</option>
                <option value="E">C</option>
              </select>
              <span class="text-danger" asp-validation-for="Oft_AgudezaSC_Test"></span>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">OD (Ojo Derecho)</label>
              <select class="form-control" asp-for="Oft_AgudezaSC_OD" id="Oft_AgudezaSC_OD">
                @foreach (var v in new[]{
                            "20/15","20/20","20/30","20/40","20/50","20/60","20/70","20/80","20/100","20/200","20/400","20/800",
                            "20/1600","Movimientos de manos","Percepción de Luz","NPL"})
                {
                  <option value="@v">@v</option>
                }
              </select>

              <span class="text-danger" asp-validation-for="Oft_AgudezaSC_OD"></span>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">OS (Ojo Izquierdo)</label>
              <select class="form-control" asp-for="Oft_AgudezaSC_OS" id="Oft_AgudezaSC_OS">
                @foreach (var v in new[]{
                            "20/15","20/20","20/30","20/40","20/50","20/60","20/70","20/80","20/100","20/200","20/400","20/800",
                            "20/1600","Movimientos de manos","Percepción de Luz","NPL"})
                {
                  <option value="@v">@v</option>
                }
              </select>

              <span class="text-danger" asp-validation-for="Oft_AgudezaSC_OS"></span>
            </div>
          </div>
          <div class="hint mt-1">Valores típicos: 20/15 a 20/800.</div>
        </div>

        <div id="contraste" class="tab-pane fade">
          <div class="form-row">
            <div class="col-md-6 mb-3">
              <label class="form-label">OD</label>
              <input type="text" class="form-control" asp-for="Oft_Contraste_OD" placeholder="Texto libre" />
              <span class="text-danger" asp-validation-for="Oft_Contraste_OD"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">OS</label>
              <input type="text" class="form-control" asp-for="Oft_Contraste_OS" placeholder="Texto libre" />
              <span class="text-danger" asp-validation-for="Oft_Contraste_OS"></span>
            </div>
          </div>
        </div>

        <div id="avcerca" class="tab-pane fade">
          <p class="hint">Toma los valores del combo de agudeza visual.</p>
          <div class="form-row">
            <div class="col-md-4 mb-3">
              <label class="form-label">OD</label>
              <select class="form-control" asp-for="Oft_AVCerca_OD" id="Oft_AVCerca_OD">
                @foreach (var v in new[]{
                            "20/15","20/20","20/30","20/40","20/50","20/60","20/70","20/80","20/100","20/200","20/400","20/800",
                            "abajo de 20/800","20/1600","Movimientos de manos","Percepción de Luz","NPL"})
                {
                  <option value="@v">@v</option>
                }
              </select>
              <span class="text-danger" asp-validation-for="Oft_AVCerca_OD"></span>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">OS</label>
              <select class="form-control" asp-for="Oft_AVCerca_OS" id="Oft_AVCerca_OS">
                @foreach (var v in new[]{
                            "20/15","20/20","20/30","20/40","20/50","20/60","20/70","20/80","20/100","20/200","20/400","20/800",
                            "abajo de 20/800","20/1600","Movimientos de manos","Percepción de Luz","NPL"})
                {
                  <option value="@v">@v</option>
                }
              </select>

              <span class="text-danger" asp-validation-for="Oft_AVCerca_OS"></span>
            </div>
          </div>
        </div>

        <div id="testesp" class="tab-pane fade">
          <div class="form-row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Ishihara (OD)</label>
              <input type="text" class="form-control" asp-for="Oft_TestIshihara_OD" />
              <span class="text-danger" asp-validation-for="Oft_TestIshihara_OD"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Ishihara (OS)</label>
              <input type="text" class="form-control" asp-for="Oft_TestIshihara_OS" />
              <span class="text-danger" asp-validation-for="Oft_TestIshihara_OS"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Estereopsis (OD)</label>
              <input type="text" class="form-control" asp-for="Oft_TestEstereopsis_OD" />
              <span class="text-danger" asp-validation-for="Oft_TestEstereopsis_OD"></span>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Estereopsis (OS)</label>
              <input type="text" class="form-control" asp-for="Oft_TestEstereopsis_OS" />
              <span class="text-danger" asp-validation-for="Oft_TestEstereopsis_OS"></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="oft-card mb-3 p-3 p-md-4">
      <div class="oft-head"><i class="fas fa-glasses"></i>
        <h5 class="mb-0">Óptica</h5>
      </div>

      <div id="opticaAcc" role="tablist">
        <div class="card mb-2">
          <div class="card-header" role="tab" id="lensometriaHead">
            <h6 class="mb-0"><a data-toggle="collapse" href="#lensometria" aria-expanded="true"
                aria-controls="lensometria">Lensometría (Histórico)</a></h6>
          </div>
          <div id="lensometria" class="collapse show" role="tabpanel" aria-labelledby="lensometriaHead"
            data-parent="#opticaAcc">
            <div class="card-body">
              <div class="form-row">
                <div class="col-md-3 mb-3"><label class="form-label">OD Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Lensometria_OD_Esfera" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Lensometria_OD_Cilindro" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Lensometria_OD_Eje" placeholder="0–180" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Agudeza V.</label><input type="text"
                    class="form-control" asp-for="Oft_Lensometria_OD_Agudeza" placeholder="20/20" /></div>

                <div class="col-12"></div>

                <div class="col-md-3 mb-3"><label class="form-label">OS Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Lensometria_OS_Esfera" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Lensometria_OS_Cilindro" placeholder="0.00" />
                </div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Lensometria_OS_Eje" placeholder="0–180" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Agudeza V.</label><input type="text"
                    class="form-control" asp-for="Oft_Lensometria_OS_Agudeza" placeholder="20/20" /></div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mb-2">
          <div class="card-header" role="tab" id="finalHead">
            <h6 class="mb-0"><a class="collapsed" data-toggle="collapse" href="#final" aria-expanded="false"
                aria-controls="final">Final</a></h6>
          </div>
          <div id="final" class="collapse" role="tabpanel" aria-labelledby="finalHead" data-parent="#opticaAcc">
            <div class="card-body">
              <div class="form-row">
                <div class="col-md-3 mb-3"><label class="form-label">OD Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Final_OD_Esfera" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Final_OD_Cilindro" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Final_OD_Eje" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OD Agudeza V.</label><input type="text"
                    class="form-control" asp-for="Oft_Final_OD_Agudeza" /></div>

                <div class="col-md-3 mb-3"><label class="form-label">OS Esfera</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Final_OS_Esfera" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Cilindro</label><input type="number" step="0.25"
                    inputmode="decimal" class="form-control" asp-for="Oft_Final_OS_Cilindro" /></div>
                <div class="col-md-3 mb-3"><label class="form-label">OS Eje</label><input type="number" step="1" min="0"
                    max="180" class="form-control" asp-for="Oft_Final_OS_Eje" /></div>
