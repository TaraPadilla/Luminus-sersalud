</style>

<script>
    function toggleContent(id) {
        const content = document.getElementById(id);
        if (content.style.display === "none") {
            content.style.display = "block";
        } else {
            content.style.display = "none";
        }
    }
</script>
<script>
    (function () {
        var storageKey = "consultaTabs:activeHref";
        var $tabsRoot = $("#tabs");
        var $tabLinks = $('#consultaTabs a[href^="#tab-"]');

        // Tooltips Bootstrap 4.3
        $tabLinks.filter('[data-toggle="tooltip"]').tooltip({ container: 'body' });

        function ensureTabsInitialized() {
            // Si ya está inicializado, ok. Si no, inicializa sin pisar active aún.
            if (!$tabsRoot.data("ui-tabs")) {
                $tabsRoot.tabs();
            }
        }

        function setActiveByHref(href) {
            if (!href) return false;

            ensureTabsInitialized();

            var $a = $tabsRoot.find('> ul > li:visible > a[href="' + href + '"]');
            if (!$a.length) return false;

            var idx = $a.parent().index();
            $tabsRoot.tabs("option", "active", idx);

            // Sincronizar clase Bootstrap
            $('#consultaTabs a.nav-link').removeClass('active');
            $a.addClass('active');

            return true;
        }

        // Guardar tab activo con jQuery UI
        $tabsRoot.on("tabsactivate", function (event, ui) {
            var href = ui.newTab && ui.newTab.find("a").attr("href");
            if (href) localStorage.setItem(storageKey, href);

            // Bootstrap active
            $('#consultaTabs a.nav-link').removeClass('active');
            ui.newTab.find('a.nav-link').addClass('active');
        });

        // Restaurar al cargar: prioridad hash > localStorage
        $(function () {
            ensureTabsInitialized();

            var target = (window.location.hash && window.location.hash.indexOf("#tab-") === 0)
                ? window.location.hash
                : localStorage.getItem(storageKey);

            // IMPORTANTE: forzar restore al final para que no lo pise otro script global
            setTimeout(function () {
                if (!setActiveByHref(target)) {
                    // Si no existe (ej pediátricos ya no está), caer al primero
                    $tabsRoot.tabs("option", "active", 0);
                    var $first = $tabsRoot.find('> ul > li:visible:first > a');
                    $('#consultaTabs a.nav-link').removeClass('active');
                    $first.addClass('active');
                }
            }, 0);
        });

    })();
</script>


