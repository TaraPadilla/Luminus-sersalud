@model sistema.Models.ConsultasViewModel

@functions {
    public int GetEdadEnAños(string edad)
    {
        // Extraer la parte de los años de la cadena "19 Años, 6 Meses y 15 Días"
        if (!string.IsNullOrEmpty(edad))
        {
            var partes = edad.Split(' ');
            if (int.TryParse(partes[0], out int años))
            {
                return años;
            }
        }
        // Si no se puede extraer, devolver 0 como valor predeterminado
        return 0;
    }
}

@{
    int edadEnAños = GetEdadEnAños(Model.PacienteEdad);
}
<style>
    /* Estilos para asegurar suavidad y simetría */
    .info-card {
        border: 1px solid #e3e6f0 !important;
        border-radius: 0.35rem;
        transition: all 0.2s ease;
        background: #fff;
    }

    .header-section {
        border-bottom: 2px solid #f8f9fc;
        margin-bottom: 1.5rem;
    }

    /* Forzar que las columnas de una fila tengan la misma altura */
    .row-equal-height {
        display: flex;
        flex-wrap: wrap;
    }

    .row-equal-height>[class*='col-'] {
        display: flex;
        flex-direction: column;
    }

    .row-equal-height .card {
        flex: 1 0 auto;
    }

    /* Estilo para los labels para que no ocupen tanto espacio */
    .label-custom {
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        color: #858796;
        margin-bottom: 0.5rem;
    }
</style>

