@model sistema.Models.ConsultasViewModel

<br />

<div class="border rounded p-3 bg-white shadow-sm">

    <!-- Header -->
    <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
        <h6 class="mb-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-stethoscope mr-2"></i>
            Ginecología - Examen físico
        </h6>
    </div>

    <!-- Form -->
    <div class="form-row">

        <div class="col-sm-6 col-md-2 mb-3">
            <label class="font-weight-bold small text-muted">Mamas</label>
            @Html.TextAreaFor(a => a.GinecologiaExamenFisicoMamas,
                new { @class = "form-control dato-consulta", rows = "3" })
        </div>

        <div class="col-sm-6 col-md-2 mb-3">
            <label class="font-weight-bold small text-muted">Especuloscopía</label>
            @Html.TextAreaFor(a => a.GinecologiaExamenFisicoEspeculoscopia,
                new { @class = "form-control dato-consulta", rows = "3" })
        </div>

        <div class="col-sm-6 col-md-2 mb-3">
            <label class="font-weight-bold small text-muted">Tacto vaginal</label>
            @Html.TextAreaFor(a => a.GinecologiaExamenFisicoTactoVaginal,
                new { @class = "form-control dato-consulta", rows = "3" })
        </div>

        <div class="col-sm-6 col-md-2 mb-3">
            <label class="font-weight-bold small text-muted">Tacto rectal</label>
            @Html.TextAreaFor(a => a.GinecologiaExamenFisicoTactoRectal,
                new { @class = "form-control dato-consulta", rows = "3" })
        </div>

        <div class="col-sm-12 col-md-2 mb-3">
            <label class="font-weight-bold small text-muted">Vulva y vagina</label>
            @Html.TextAreaFor(a => a.GinecologiaExamenFisicoVulvaVagina,
                new { @class = "form-control dato-consulta", rows = "3" })
        </div>

    </div>

    <!-- Historial -->
    <div class="mt-4">
        <div class="d-flex align-items-center mb-3 pb-2 border-bottom">
            <h6 class="mb-0 font-weight-bold text-primary text-uppercase">
                <i class="fas fa-history mr-2"></i>
                Historial examen físico
            </h6>
        </div>

        <div class="text-primary texto-cargando-historial mb-2" style="display:none">
            <i class="fas fa-spinner fa-spin mr-1"></i> Cargando historial...
        </div>

        <div class="text-danger texto-error-cargando-historial mb-2" style="display:none">
            <i class="fas fa-exclamation-triangle mr-1"></i>
            Error de servidor y/o conexión.
            <a href="#" data-bind="click:consultarHistorialConsultas">Reintentar</a>
        </div>

        <!--ko foreach:historialConsultas-->
        <div class="border rounded p-3 mb-3 bg-white">

            <div class="font-weight-bold text-dark mb-2">
                <i class="fas fa-calendar-alt text-primary mr-1"></i>
                Fecha: <span data-bind="text:Fecha"></span>
            </div>

            <div class="row small">
                <div class="col-md-2">
                    <b>Mamas:</b><br />
                    <span data-bind="text:GinecologiaExamenFisicoMamas"></span>
                </div>
                <div class="col-md-2">
                    <b>Especuloscopía:</b><br />
                    <span data-bind="text:GinecologiaExamenFisicoEspeculoscopia"></span>
                </div>
                <div class="col-md-2">
                    <b>Tacto vaginal:</b><br />
                    <span data-bind="text:GinecologiaExamenFisicoTactoVaginal"></span>
                </div>
                <div class="col-md-2">
                    <b>Tacto rectal:</b><br />
                    <span data-bind="text:GinecologiaExamenFisicoTactoRectal"></span>
                </div>
                <div class="col-md-2">
                    <b>Vulva y vagina:</b><br />
                    <span data-bind="text:GinecologiaExamenFisicoVulvaVagina"></span>
                </div>
            </div>

        </div>
        <!--/ko-->

        <!--ko if:historialConsultas().length==0-->
        <div class="text-muted">
            <i class="fas fa-info-circle mr-1"></i>
            No hay registro de consultas anteriores
        </div>
        <!--/ko-->
    </div>

</div>
