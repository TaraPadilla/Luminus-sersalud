@model sistema.Models.InfoConsultaViewModel

<div class="form-row">
    <div class="col-md-12 table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <td>
                        <b>
                            Nota Operatoria
                        </b>
                    </td>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>
                        <label class="">Describa la Nota Operatoria</label>
                        @Html.TextAreaFor(a => a.Consulta.notaOperatoria, new
                        {
                        @class = "form-control",
                        @placeholder = "Describa ",
                         @readonly = true
                        })
                        @Html.ValidationMessageFor(a => a.Consulta.notaOperatoria, "", new { @class = "text-danger" })
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>