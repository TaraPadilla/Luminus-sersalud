@model sistema.Models.ConsultasViewModel

<br />

<div class="border rounded p-3 bg-white shadow-sm mb-3">

    <!-- Header -->
    <div class="d-flex align-items-center justify-content-between mb-3 pb-2 border-bottom">
        <h6 class="m-0 font-weight-bold text-primary text-uppercase">
            <i class="fas fa-list-alt mr-2"></i> Revisi&oacute;n por Sistemas
        </h6>
        <small class="text-muted">
            <i class="fas fa-notes-medical mr-1"></i> Evaluaci&oacute;n por &aacute;reas
        </small>
    </div>

    <div class="form-row">

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Sistema Neurol&oacute;gico:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasNeurologico, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Sistema Cardiovascular:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasCardiovascular, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Sistema Respiratorio:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasRespiratorio, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Gastrointestinal:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasGastrointestinal, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Sistema Musculoesquel&eacute;tico - Todas las Extremidades:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasMusculoesqueletico, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Piel y Fanera:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasPielFanera, new { @class = "form-control dato-consulta" })
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="border rounded p-2">
                <div class="font-weight-bold mb-1">Genitourinario:</div>
                @Html.TextAreaFor(m => m.NewRevisionSistemasGenitourinario, new { @class = "form-control dato-consulta" })
            </div>
        </div>

    </div>

    <div class="mt-2"></div>

