@using Database.Shared.Models
@model sistema.Models.ConsultasViewModel

@{
    ViewData["Title"] = "Consultas";
    var usuarioAdministrador = User.IsInRole("Administrador");
    var usuarioJefaturaMedica = User.IsInRole("Jefatura Medica");

    var urlListadoData = Url.Action("ListadoData", "Consultas");
    var urlInformacion = Url.Action("Informacion", "Consultas", new { id = 0 });
    var urlGenerarVenta = Url.Action("GenerarVenta", "Consultas", new { id = 0 });
    var urlDelete = Url.Action("Delete", "Consultas", new { id = 0 });
    var urlEditarSignos = Url.Action("EditarConsultaSignosVitales", "Consultas", new { id = 0 });
}

<link rel="stylesheet" href="~/js/DataTables/datatables.css" />

@await Html.PartialAsync("_MensajeExito")

@Html.AntiForgeryToken()

<div class="card mb-3">
    <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="mb-0">Lista de consultas</h5>
    </div>

    <div class="card-body">
        <div class="form-row">
            <div class="col-12 col-md-3 mb-2">
                <label class="mb-1">Fecha</label>
                <input type="date" class="form-control" id="fechacita" value="@ViewData["CurrentFilter"]">
            </div>

            <div class="col-12 col-md-3 mb-2">
                <label class="mb-1">Paciente</label>
                <input type="text"
                       class="form-control"
                       id="pacienteNombre"
                       autocomplete="off"
                       placeholder="Buscar por nombre de paciente">
            </div>

            <div class="col-12 col-md-3 mb-2">
                <label class="mb-1">Médico</label>

                @if (Model.HabilitarListaEmpleados)
                {
                    <select class="form-control" asp-for="EmpleadoId" asp-items="Model.EmpleadosSelectList">
                        <option value="">Todos</option>
                    </select>
                }
                else
                {
                    <select class="form-control" asp-for="EmpleadoId" asp-items="Model.EmpleadosSelectList" disabled="disabled">
                        <option value="">Todos</option>
                    </select>
                }
            </div>

            <div class="col-12 col-md-2 mb-2">
                <label class="mb-1">Especialidad</label>
                <select class="form-control" asp-for="EspecialidadId" asp-items="Model.EspecialidadSelectListItem">
                    <option value="">Todos</option>
                </select>
            </div>

            <div class="col-12 col-md-1 d-flex align-items-end mb-2">
                <button type="button" id="btn-aplicar-filtros" class="btn btn-primary btn-block" data-toggle="tooltip"
                        title="Aplicar filtros">
                    <i class="fas fa-filter"></i>
                </button>
            </div>
        </div>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <div class="table-responsive">
            <table id="tabla-consultas" class="table table-sm table-striped table-hover table-bordered mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>#</th>
                        <th>Fecha y hora</th>
                        <th>Turno</th>
                        <th>Paciente</th>
                        <th>Tipo de atención</th>
                        <th>Médico</th>
                        <th>Especialidad</th>
                        <th>Servicios</th>
                        <th>Pago</th>
                        <th>Precio</th>
                        <th style="width: 140px;">Acciones</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.js"></script>

<script>
    function confirmarEliminarConsulta(consultaId) {
        if (confirm("¿Está seguro que desea eliminar esta consulta?")) {
            $.ajax({
                url: '/Consultas/Delete',
                type: 'POST',
                data: { id: consultaId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.exitoso) {
                        $('#tabla-consultas').DataTable().ajax.reload();
                    } else {
                        alert("Error: " + (response.mensaje || "No se pudo eliminar"));
                    }
                },
                error: function(xhr, status, error) {
                    alert("Error al eliminar la consulta: " + error);
                }
            });
        }
    }
    (function () {
        var usuarioPuedeEliminar = @((usuarioAdministrador || usuarioJefaturaMedica) ? "true" : "false");

        // urls (0 es placeholder)
        var urlListadoData = '@urlListadoData';
        var urlInformacion = '@urlInformacion';   // termina en .../0 o ?id=0 según routing
        var urlGenerarVenta = '@urlGenerarVenta';
        var urlDelete = '@urlDelete';
        var urlEditarSignos = '@urlEditarSignos';

        function buildUrlConId(urlConCero, id) {
            // Funciona tanto si el routing genera /Accion/0 como si genera ?id=0
            if (urlConCero.indexOf("=0") >= 0) return urlConCero.replace("=0", "=" + encodeURIComponent(id));
            return urlConCero.replace(/\/0($|\?)/, "/" + encodeURIComponent(id) + "$1").replace(/\/0$/, "/" + encodeURIComponent(id));
        }

        function badgeTipoAtencion(tipo, igssNumero, codigoDeCita, codigoAutorizacion) {
            var t = (tipo || 'N/A').toUpperCase();
            var cls = 'badge-secondary';

            if (t === 'PRIVADO') cls = 'badge-primary';
            else if (t === 'IGSS') cls = 'badge-danger';
            else if (t === 'SEGURO') cls = 'badge-info';

            var html = `<span class="badge ${cls}">${tipo || 'N/A'}</span>`;

            if (t === 'IGSS') {
                html += `<div class="small text-muted mt-1"><strong>Numero de IGSS:</strong><br/>${igssNumero || 'N/A'}</div>`;
            } else if (t === 'SEGURO') {
                html += `<div class="small text-muted mt-1"><strong>Cod. seguro:</strong><br/>${codigoDeCita || 'N/A'}<br/><strong>Autorización:</strong><br/>${codigoAutorizacion || 'N/A'}</div>`;
            }

            return html;
        }

        function badgeServicios(servicios) {
            if (!servicios || !servicios.length) return '<span class="text-muted"><i>No hay servicios registrados</i></span>';

            return servicios.map(function (s) {
                var nombre = (s || 'N/A').toUpperCase();
                var cls = 'badge-secondary';

                if (nombre === 'CONSULTA' || nombre === 'RE CONSULTA') cls = 'badge-success';
                else if (nombre === 'LABORATORIOS') cls = 'badge-info';
                else if (nombre === 'RAYOS X') cls = 'badge-danger';
                else if (nombre === 'USG') cls = 'badge-primary';
                else if (nombre === 'EMERGENCIA') cls = 'badge-warning';
                else cls = 'badge-dark';

                return `<span class="badge ${cls} mr-1 mb-1">${s}</span>`;
            }).join('');
        }

        function clasePago(pago) {
            return (pago === 'Pagado') ? 'text-success font-weight-bold' : 'text-danger font-weight-bold';
        }

        function abrirVentanaEditarConsultaSignosVitales(consultaId) {
            var url = buildUrlConId(urlEditarSignos, consultaId);

            var width = 600;
            var height = 600;
            var left = (screen.width / 2) - (width / 2);
            var top = (screen.height / 2) - (height / 2);

            var windowFeatures = "width=" + width + ",height=" + height + ",top=" + top + ",left=" + left + ",scrollbars=yes,resizable=yes";
            window.open(url, "EditarConsultaSignosVitales", windowFeatures);
        }
        window.abrirVentanaEditarConsultaSignosVitales = abrirVentanaEditarConsultaSignosVitales;

        $(document).ready(function () {
            var token = $('input[name="__RequestVerificationToken"]').val();

            var table = $('#tabla-consultas').DataTable({
                serverSide: true,
                processing: true,
                searching: false, // <-- quitamos el buscador nativo de DataTables
                pageLength: 10,
                order: [[0, "desc"]],
                deferRender: true,
                ajax: {
                    url: urlListadoData,
                    type: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    data: function (d) {
                        d.empleadoId = $('#EmpleadoId').val() || null;
                        d.especialidadId = $('#EspecialidadId').val() || null;
                        d.fecha = $('#fechacita').val() || null;

                        // buscador manual (solo paciente)
                        d.pacienteNombre = $('#pacienteNombre').val() || null;
                    }
                },
                columns: [
                    { data: 'id' },
                    {
                        data: 'fechaYHoraInicioConsulta',
                        render: function (v) { return v || ''; }
                    },
                    { data: 'numeroTurno', defaultContent: '' },
                    { data: 'paciente', defaultContent: '' },
                    {
                        data: null,
                        render: function (row) {
                            return badgeTipoAtencion(row.tipoAtencion, row.igssNumero, row.codigoDeCita, row.codigoAutorizacion);
                        }
                    },
                    { data: 'medico', defaultContent: 'N/A' },
                    {
                        data: null,
                        render: function (row) {
                            // Respeta tu lógica original: CategoriaHabitacionId == 3 -> Sala de Operaciones
                            if (row.categoriaHabitacionId === 3) return 'Sala de Operaciones';
                            return row.especialidad || 'N/A';
                        }
                    },
                    {
                        data: 'servicios',
                        orderable: false,
                        render: function (servicios) { return badgeServicios(servicios); }
                    },
                    {
                        data: 'pago',
                        render: function (p) { return `<span class="${clasePago(p)}">${p || 'N/A'}</span>`; }
                    },
                    { data: 'precio', defaultContent: '' },
                    {
                        data: null,
                        orderable: false,
                        searchable: false,
                        render: function (row) {
                            var id = row.id;

                            var btnConsultar =
                                `<a class="btn btn-outline-info" data-toggle="tooltip" data-placement="top" title="Consultar"
                                    href="${buildUrlConId(urlInformacion, id)}">
                                    <i class="fas fa-eye"></i>
                                 </a>`;

                            var btnSignos =
                                `<button type="button" class="btn btn-outline-success" data-toggle="tooltip" data-placement="top" title="Ingresar signos vitales"
                                    onclick="abrirVentanaEditarConsultaSignosVitales('${id}')">
                                    <i class="fas fa-heart"></i>
                                 </button>`;

                            // Tu regla: mostrar GenerarVenta si NO es Pagado
                            var btnVenta = '';
                            if (row.pago !== 'Pagado') {
                                btnVenta =
                                    `<a class="btn btn-outline-warning" data-toggle="tooltip" data-placement="top" title="Generar venta"
                                        href="${buildUrlConId(urlGenerarVenta, id)}">
                                        <i class="fas fa-store"></i>
                                     </a>`;
                            }

                            var btnDelete = '';
                            if (usuarioPuedeEliminar && row.pago === 'Pendiente') {
                                btnDelete =
                                    `<button type="button" class="btn btn-outline-danger" data-toggle="tooltip" data-placement="top" title="Eliminar"
                                        onclick="confirmarEliminarConsulta(${id})">
                                        <i class="fas fa-trash"></i>
                                     </button>`;
                            }
                            

                            return `<div class="btn-group btn-group-sm" role="group" aria-label="Acciones">
                                        ${btnConsultar}${btnSignos}${btnVenta}${btnDelete}
                                    </div>`;
                        }
                    }
                ],
                language: {
                    lengthMenu: "Mostrar _MENU_ registros por página",
                    zeroRecords: "No se encontraron resultados",
                    info: "Mostrando _START_ a _END_ de _TOTAL_",
                    infoEmpty: "No hay registros disponibles",
                    infoFiltered: "(filtrado de _MAX_ registros totales)",
                    paginate: { first: "Primero", last: "Último", next: "Siguiente", previous: "Anterior" }
                },
                drawCallback: function () {
                    // Re-inicializa tooltips tras cada draw
                    $('[data-toggle="tooltip"]').tooltip();
                }
            });

            // Restaurar fecha desde URL (compatibilidad)
            var urlParams = new URLSearchParams(window.location.search);
            var fechaParam = urlParams.get('fecha') || urlParams.get('Fecha');
            if (fechaParam) $('#fechacita').val(fechaParam);

            $('[data-toggle="tooltip"]').tooltip();

            $('#btn-aplicar-filtros').on('click', function () {
                table.ajax.reload();
            });

            $('#EspecialidadId, #EmpleadoId, #fechacita').on('change', function () {
                table.ajax.reload();
            });

            // Buscador manual (solo paciente) con debounce
            var pacienteTimer = null;
            $('#pacienteNombre').on('keyup', function (e) {
                // Enter: recarga inmediata
                if (e.key === 'Enter') {
                    if (pacienteTimer) clearTimeout(pacienteTimer);
                    table.ajax.reload();
                    return;
                }

                if (pacienteTimer) clearTimeout(pacienteTimer);
                pacienteTimer = setTimeout(function () {
                    table.ajax.reload();
                }, 300);
            });
        });
    })();
</script>