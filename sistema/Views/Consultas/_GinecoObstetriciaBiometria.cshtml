        <div class="form-group">
            <label for="biometriaSelect"><b>Seleccionar número de formularios de biometría</b></label>
            <select id="biometriaSelect" class="form-control">
                <option value="1">1 Biometría</option>
                <option value="2">2 Biometrías</option>
                <option value="3">3 Biometrías</option>
                <option value="4">4 Biometrías</option>
            </select>
        </div>
