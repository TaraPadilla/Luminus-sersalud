<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        // Establece el valor del select al cargar la página
        $("#biometriaSelect").val(@Model.NumeroBebes);

        // Manejo del evento change en el select
        document.getElementById('biometriaSelect').addEventListener('change', function () {
            var selectedValue = this.value;

            // Oculta todas las biometrias
            document.querySelector('.biometria').style.display = 'none';
            document.querySelector('.biometria2').style.display = 'none';
            document.querySelector('.biometria3').style.display = 'none';
            document.querySelector('.biometria4').style.display = 'none';

            // Muestra la cantidad seleccionada
            if (selectedValue >= 1) {
                document.querySelector('.biometria').style.display = '';
            }
            if (selectedValue >= 2) {
                document.querySelector('.biometria2').style.display = '';
            }
            if (selectedValue >= 3) {
                document.querySelector('.biometria3').style.display = '';
            }
            if (selectedValue == 4) {
                document.querySelector('.biometria4').style.display = '';
            }
        });

        // Ejecuta el evento change al cargar la página para mostrar la biometría seleccionada por defecto
        document.getElementById('biometriaSelect').dispatchEvent(new Event('change'));

        // Maneja el clic del botón para generar los PDFs
        document.getElementById("generarObstetricaBiometriaPDFBtn").addEventListener("click", function () {
            var numeroBebes = @Model.NumeroBebes; // Obtener el valor de NumeroBebes desde el modelo
            var consultaId = @Model.ConsultaId;

            if (numeroBebes >= 1) {
                generarObstetricaBiometriaPDF(consultaId);
            }
            if (numeroBebes >= 2) {
                generarObstetricaBiometriaPDF2(consultaId);
            }
            if (numeroBebes >= 3) {
                generarObstetricaBiometriaPDF3(consultaId);
            }
            if (numeroBebes == 4) {
                generarObstetricaBiometriaPDF4(consultaId);
            }
        });
    });
</script>
