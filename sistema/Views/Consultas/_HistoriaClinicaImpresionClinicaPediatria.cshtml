@model sistema.Models.ConsultasViewModel
<br />
<div class="card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <h5><b>Impresi&oacute;n clinica</b></h5>
                <hr />
            </div>
            <div class="col-md-12">
                <b>Impresi&oacute;n clinica</b><br>
                @Html.TextAreaFor(a => a.HistoriaPediatriaHistoriaClinicaImpresionClinica, new { @class = "form-control dato-consulta" })
            </div>
        </div>
        <br />
        <div class="form-row">
            <div class="col-md-12">
                <h5><b>Impresi&oacute;n clinica (historial)</b></h5>
                <hr />
            </div>
            <div class="col-md-12 text-primary texto-cargando-historial" style="display:none">
                Cargando historial...
            </div>
            <div class="col-md-12 text-danger texto-error-cargando-historial" style="display:none">
                Error de servidor y/o conexion. <a href="#" data-bind="click:consultarHistorialConsultas">Reintentar</a>
            </div>
            <!--ko foreach:historialConsultas-->
            <div class="col-md-12" style="background-color:lightgray">
                <b>Fecha: </b><span data-bind="text:Fecha"></span>
            </div>
            <div class="col-md-12">
                <b>Impresi&oacute;n clinica:</b><br><span data-bind="text:HistoriaPediatriaHistoriaClinicaImpresionClinica"></span>
            </div>
            <!--/ko-->
            <!--ko if:historialConsultas().length==0-->
            <div class="col-md-12">
                No hay registro de consultas anteriores
            </div>
            <!--/ko-->
        </div>
    </div>
</div>