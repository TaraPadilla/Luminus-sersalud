@model sistema.Models.ConsultasViewModel

<br />
<div class="form-row">
    <div class="main-card mb-3 card col-md-12 datos-edicion-consulta">
        <div class="card-body">
            <div class="form-row">
                <div class="col-md-12">
                    <b>Subir archivo</b><br />
                    <input type="file" id="archivo-cargar" class="form-control" /><br>
                    <a href="#" class="btn btn-primary text-light" data-bind="click:subirArchivoConsulta">Subir</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-12 table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Fecha de carga</th>
                    <th>Nombre</th>
                    <th>Ver</th>
                    @if (Model.HabilitarEdicion)
                    {
                        <th>Eliminar</th>
                    }
                </tr>
            </thead>
            <tbody>
                <!--ko foreach: archivosConsulta-->
                <tr>
                    <td data-bind="text:Fecha"></td>
                    <td data-bind="text:Nombre"></td>
                    <td>
                        <a data-bind="attr:{href:UrlArchivo}" href="#" class="btn btn-warning text-light" target="_blank">
                            <i class="fas fa-eye"></i>
                        </a>
                    </td>
                    @if (Model.HabilitarEdicion)
                    {
                        <td class="datos-edicion-consulta">
                            <a data-bind="click:$root.eliminarArchivoConsulta" href="#" class="btn btn-danger text-light">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    }
                </tr>
                <!--/ko-->
            </tbody>
        </table>
    </div>
</div>