@{
    ViewData["Title"] = "Modificar sucursa";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>Modificar sucursal</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_SucursalForm")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <button class="btn btn-danger" data-bind="click:cancelarEditarSucursal">Cancelar</button>
                <button class="btn btn-primary" data-bind="click:editarSucursal">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
<script src="~/ViewModelKo/SucursalVM.js"></script>
}