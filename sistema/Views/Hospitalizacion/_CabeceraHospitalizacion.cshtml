<script>
    hospWhenReady(function ($) {
        document.querySelectorAll('.collapsible-card').forEach(card => {
            card.addEventListener('click', function(e) {
                if (e.target.closest('.collapse') || e.target.closest('button') || e.target.closest('select') || e.target.closest('input')) {
                    return;
                }
                const targetId = this.getAttribute('data-target');
                const collapseEl = document.getElementById(targetId);
                if (collapseEl) {
                    $(collapseEl).collapse('toggle');
                }
            });
        });

        $('#collapsePeso').on('shown.bs.collapse', function () {
            var input = document.getElementById('pesoInput');
            if (input) { input.focus(); input.select(); }
        });
        $('#collapseEstatura').on('shown.bs.collapse', function () {
            var input = document.getElementById('estaturaInput');
            if (input) { input.focus(); input.select(); }
        });

        var sangreActual = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PacienteTipoSangre ?? ""));
        if (sangreActual) {
            $('#bloodTypeSelect').val(sangreActual);
        }
    });

    function actualizarTipoSangre(pacienteId) {
        const nuevoValor = document.getElementById('bloodTypeSelect').value;
        if (!nuevoValor) return;
        $.ajax({
            url: '/Pacientes/ActualizarCampo',
            type: 'POST',
            dataType: 'json',
            data: { pacienteId: pacienteId, campo: 'TipoSangre', valor: nuevoValor },
            success: function(resp) {
                resp = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(resp) : resp;
                if (resp && resp.success) {
                    document.getElementById('spanTipoSangre').innerHTML = '<i class="fas fa-tint mr-2"></i>' + nuevoValor;
                    var sangreHidden = document.getElementById('PacienteTipoSangre');
                    if (sangreHidden) sangreHidden.value = nuevoValor;
                    if (window.detallesVm && typeof detallesVm.syncMedNoControladosDatosPaciente === 'function') {
                        detallesVm.syncMedNoControladosDatosPaciente();
                    }
                    $('#collapseBloodType').collapse('hide');
                    toastr.success('Tipo de sangre actualizado');
                } else {
                    toastr.error('Error al actualizar');
                }
            },
            error: function() { toastr.error('Error de conexión'); }
        });
    }

    function actualizarPeso(pacienteId) {
        const nuevoValor = document.getElementById('pesoInput').value;
        if (!nuevoValor) return;
        $.ajax({
            url: '/Pacientes/ActualizarCampo',
            type: 'POST',
            dataType: 'json',
            data: { pacienteId: pacienteId, campo: 'Peso', valor: nuevoValor },
            success: function(resp) {
                resp = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(resp) : resp;
                if (resp && resp.success) {
                    document.getElementById('spanPeso').innerHTML = '<i class="fas fa-weight mr-2"></i>' + nuevoValor;
                    $('#collapsePeso').collapse('hide');
                    var pesoHidden = document.getElementById('PacientePeso');
                    if (pesoHidden) pesoHidden.value = nuevoValor;
                    if (window.detallesVm && typeof detallesVm.syncMedNoControladosDatosPaciente === 'function') {
                        detallesVm.syncMedNoControladosDatosPaciente();
                    }
                    toastr.success('Peso actualizado');
                } else {
                    toastr.error('Error al actualizar');
                }
            },
            error: function() { toastr.error('Error de conexión'); }
        });
    }

    function actualizarEstatura(pacienteId) {
        const nuevoValor = document.getElementById('estaturaInput').value;
        if (!nuevoValor) return;
        $.ajax({
            url: '/Pacientes/ActualizarCampo',
            type: 'POST',
            dataType: 'json',
            data: { pacienteId: pacienteId, campo: 'Estatura', valor: nuevoValor },
            success: function(resp) {
                resp = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(resp) : resp;
                if (resp && resp.success) {
                    document.getElementById('spanEstatura').innerHTML = '<i class="fas fa-ruler-vertical mr-2"></i>' + nuevoValor;
                    $('#collapseEstatura').collapse('hide');
                    var tallaHidden = document.getElementById('PacienteTalla');
                    if (tallaHidden) tallaHidden.value = nuevoValor;
                    if (window.detallesVm && typeof detallesVm.syncMedNoControladosDatosPaciente === 'function') {
                        detallesVm.syncMedNoControladosDatosPaciente();
                    }
                    toastr.success('Estatura actualizada');
                } else {
                    toastr.error('Error al actualizar');
                }
            },
            error: function() { toastr.error('Error de conexión'); }
        });
    }
</script>

