<script>
    let currentPage = 1;
    let pageSize = 10;
    let currentFilteredData = [];
    let allData = [];

    // ── Devolución inline ──────────────────────────────────
    let _aplicacionIdADevolver = null;

    function abrirPanelDevolucion(aplicacionId, btn) {
        if (_aplicacionIdADevolver === aplicacionId) {
            cerrarPanelDevolucion();
            return;
        }
        _aplicacionIdADevolver = aplicacionId;
        document.getElementById('selectMotivoDevolucion').value = '';
        const panel = document.getElementById('panelDevolucion');
        panel.style.display = 'block';
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function cerrarPanelDevolucion() {
        _aplicacionIdADevolver = null;
        document.getElementById('panelDevolucion').style.display = 'none';
        document.getElementById('selectMotivoDevolucion').value = '';
    }

    function confirmarDevolucionInsumo() {
        const motivo = document.getElementById('selectMotivoDevolucion').value;
        if (!motivo) {
            toastr.warning('Debe seleccionar un motivo de devolución.');
            return;
        }

        const btn = document.getElementById('btnConfirmarDevolucion');
        btn.disabled = true;
        btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Procesando...';

        $.ajax({
            url: '/Hospitalizacion/DevolverInsumoAplicadoAPendiente',
            method: 'POST',
            data: { aplicacionId: _aplicacionIdADevolver, motivoDevolucion: motivo },
            success: function(resp) {
                const data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(resp) : resp;
                if (data.Exitoso) {
                    const idx = allData.findIndex(r => r.Id === _aplicacionIdADevolver && r.Origen === 'Control de Insumos');
                    if (idx !== -1) {
                        allData[idx].Aplicado         = false;
                        allData[idx].FechaAplicacion  = '-';
                        allData[idx].MotivoDevolucion = motivo;
                    }
                    actualizarBadges();
                    aplicarFiltros();
                    renderizarHistorialMedPaginated();
                    cerrarPanelDevolucion();
                    toastr.success('Insumo devuelto a Pendiente correctamente.');
                } else {
                    toastr.error('Error: ' + (data.Mensaje || 'No se pudo devolver.'));
                }
            },
            error: function() {
                toastr.error('Error de conexión.');
            },
            complete: function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-undo-alt mr-1"></i> Confirmar';
            }
        });
    }
    // ──────────────────────────────────────────────────────

    function actualizarBadges() {
        const total = allData.length;
        document.getElementById('badgeTotalMed').textContent = `Total: ${total}`;
        document.getElementById('badgeAplicadosMed').textContent = `Aplicados: ${total}`;
    }

    function aplicarFiltros() {
        const origenFiltro = document.getElementById('selectFiltroOrigenMed').value;
        currentFilteredData = allData.filter(r => {
            return !origenFiltro || r.Origen === origenFiltro;
        });
    }

    function renderizarHistorialMedPaginated() {
        const totalRegistros = currentFilteredData.length;
        const totalPages     = Math.ceil(totalRegistros / pageSize) || 1;
        if (currentPage < 1) currentPage = 1;
        if (currentPage > totalPages) currentPage = totalPages;

        const start       = (currentPage - 1) * pageSize;
        const end         = start + pageSize;
        const datosPagina = currentFilteredData.slice(start, end);
        const tbody       = document.getElementById('tablaHistorialMedicamentosBody');
        tbody.innerHTML   = '';

        if (datosPagina.length === 0) {
            tbody.innerHTML = '<tr><td colspan="11" class="text-center text-muted py-3">No hay medicamentos o insumos aplicados.</td></tr>';
        } else {
            datosPagina.forEach(r => {
                const estadoBadge = '<span class="badge badge-success"><i class="fas fa-check mr-1"></i>Aplicado</span>';

                const origenBadge = r.Origen === 'Control de Medicamentos'
                    ? '<span class="badge badge-primary" style="font-size:0.72rem;">Control de Medicamentos</span>'
                    : '<span class="badge badge-info"    style="font-size:0.72rem;">Control de Insumos</span>';

                const hospitalizacionPagada = document.getElementById('HospitalizacionPagada')?.value === 'true';
                let accionesCell = '<span class="text-muted">—</span>';
                if (!hospitalizacionPagada && r.Origen === 'Control de Insumos') {
                    accionesCell = `<button class="btn btn-warning btn-sm text-dark font-weight-bold"
                                        onclick="abrirPanelDevolucion(${r.Id}, this)">
                                        <i class="fas fa-undo-alt mr-1"></i>Devolver
                                    </button>`;
                }

                tbody.innerHTML += `
                    <tr>
                        <td>${origenBadge}</td>
                        <td><strong>${escapeHtml(r.Nombre || '-')}</strong></td>
                        <td>${escapeHtml(r.Indicaciones || '-')}</td>
                        <td>${escapeHtml(r.Via || '-')}</td>
                        <td>${escapeHtml(r.Frecuencia || '-')}</td>
                        <td class="text-center">${r.CantidadTotal || 0}</td>
                        <td class="text-center">${r.Cantidad || 0}</td>
                        <td class="text-center">${estadoBadge}</td>
                        <td>${escapeHtml(r.FechaAplicacion || '-')}</td>
                        <td>${escapeHtml(r.FechaRegistro || '-')}</td>
                        <td class="text-center">${accionesCell}</td>
                    </tr>`;
            });
        }

        document.getElementById('btnPrimeraPagina').disabled  = (currentPage === 1);
        document.getElementById('btnAnteriorPagina').disabled = (currentPage === 1);
        document.getElementById('btnSiguientePagina').disabled = (currentPage === totalPages);
        document.getElementById('btnUltimaPagina').disabled   = (currentPage === totalPages);
        document.getElementById('paginacionInfo').innerHTML   = `Página ${currentPage} de ${totalPages}`;
        const desde = totalRegistros === 0 ? 0 : start + 1;
        const hasta = Math.min(end, totalRegistros);
        document.getElementById('rangoRegistrosInfo').innerHTML = `Mostrando ${desde} a ${hasta} de ${totalRegistros} registros`;
    }

    function filtrarHistorialMed(estado) {
        aplicarFiltros();
        currentPage = 1;
        renderizarHistorialMedPaginated();
    }

    function cambiarPagina(direccion) {
        const totalPages = Math.ceil(currentFilteredData.length / pageSize) || 1;
        let nuevaPagina = currentPage;
        switch (direccion) {
            case 'primera':   nuevaPagina = 1; break;
            case 'anterior':  nuevaPagina = Math.max(1, currentPage - 1); break;
            case 'siguiente': nuevaPagina = Math.min(totalPages, currentPage + 1); break;
            case 'ultima':    nuevaPagina = totalPages; break;
            default: return;
        }
        if (nuevaPagina !== currentPage) {
            currentPage = nuevaPagina;
            renderizarHistorialMedPaginated();
        }
    }

    function cambiarPageSize(nuevoTamanio) {
        pageSize = nuevoTamanio;
        currentPage = 1;
        renderizarHistorialMedPaginated();
    }

    function recargarHistorialMedicamentos() {
        const hospId = $("#HospitalizacionId").val();
        if (!hospId) return;
        $.ajax({
            url: '/Hospitalizacion/ConsultarHistorialMedicamentosHospitalizacion',
            method: 'POST',
            data: { hospitalizacionId: hospId },
            success: function(resp) {
                const data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(resp) : resp;
                if (data.Exitoso && typeof window.cargarDatosHistorial === 'function') {
                    window.cargarDatosHistorial(data.Resultado || []);
                }
            }
        });
    }

    function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }

    window.cargarDatosHistorial = function(datosDesdeServidor) {
        cerrarPanelDevolucion();
        allData = (datosDesdeServidor || [])
            .filter(item => item.Aplicado === true)
            .map(item => ({
            Id:               item.Id,
            HospitalizacionProductoId: item.HospitalizacionProductoId,
            Origen:           item.Origen,
            Nombre:           item.Nombre,
            CantidadTotal:    item.CantidadTotal,
            Cantidad:         item.Cantidad,
            Indicaciones:     item.Indicaciones,
            Via:              item.Via,
            Frecuencia:       item.Frecuencia,
            Aplicado:         item.Aplicado,
            FechaAplicacion:  item.FechaAplicacion,
            FechaRegistro:    item.FechaRegistro,
            MotivoDevolucion: item.MotivoDevolucion 
        }));
        actualizarBadges();
        aplicarFiltros();
        currentPage = 1;
        renderizarHistorialMedPaginated();
    };
</script>


<script>
    // ===================== HISTORIAL DE SERVICIOS =====================
let currentPageServ = 1;
let pageSizeServ = 10;
let currentFilteredDataServ = [];
let allDataServ = [];

function actualizarBadgesServ() {
    const total      = allDataServ.length;
    const aplicados  = allDataServ.filter(s => s.Aplicado).length;
    const pendientes = total - aplicados;
    document.getElementById('badgeTotalServ').textContent     = `Total: ${total}`;
    document.getElementById('badgeAplicadosServ').textContent  = `Aplicados: ${aplicados}`;
    document.getElementById('badgePendientesServ').textContent = `Pendientes: ${pendientes}`;
}

function aplicarFiltrosServ() {
    const estadoFiltro = getFiltroEstadoActivoServ();
    currentFilteredDataServ = allDataServ.filter(s => {
        let pasaEstado = true;
        if (estadoFiltro === 'aplicados')  pasaEstado = s.Aplicado === true;
        else if (estadoFiltro === 'pendientes') pasaEstado = s.Aplicado === false;
        return pasaEstado;
    });
}

function getFiltroEstadoActivoServ() {
    const activeBtn = document.querySelector('#mdl-historial-servicios .btn-group .active');
    if (!activeBtn) return 'todos';
    const id = activeBtn.id;
    if (id === 'btnFiltroServTodos') return 'todos';
    if (id === 'btnFiltroServAplicados') return 'aplicados';
    if (id === 'btnFiltroServPendientes') return 'pendientes';
    return 'todos';
}


function renderizarHistorialServPaginated() {
    const totalRegistros = currentFilteredDataServ.length;
    const totalPages     = Math.ceil(totalRegistros / pageSizeServ) || 1;
    if (currentPageServ < 1) currentPageServ = 1;
    if (currentPageServ > totalPages) currentPageServ = totalPages;

    const start = (currentPageServ - 1) * pageSizeServ;
    const end   = start + pageSizeServ;
    const datosPagina = currentFilteredDataServ.slice(start, end);
    const tbody = document.getElementById('tablaHistorialServiciosBody');
    tbody.innerHTML = '';

    if (datosPagina.length === 0) {
        tbody.innerHTML = '<tr><td colspan="10" class="text-center text-muted py-3">No hay servicios con este filtro.</td></tr>';
    } else {
        datosPagina.forEach(s => {
            const estadoBadge = s.Aplicado
                ? '<span class="badge badge-success"><i class="fas fa-check mr-1"></i>Aplicado</span>'
                : '<span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pendiente</span>';

            // Botón eliminar SOLO si está pendiente y la hospitalización no está pagada
            const hospitalizacionPagadaServ = document.getElementById('HospitalizacionPagada')?.value === 'true';
            let acciones = '';
            if (!hospitalizacionPagadaServ && !s.Aplicado) {
                acciones = `<button class="btn btn-danger btn-sm" onclick="eliminarServicioHistorial(${s.Id})" title="Eliminar servicio">
                                <i class="fas fa-trash"></i>
                            </button>`;
            } else {
                acciones = '<span class="text-muted">—</span>';
            }

            tbody.innerHTML += `
                <tr>
                    <td><strong>${escapeHtml(s.Nombre || '-')}</strong></td>
                    <td>${escapeHtml(s.Indicaciones || '-')}</td>
                    <td class="text-center">${s.Cantidad || 1}</td>
                    <td class="text-right">${(s.Precio || 0).toFixed(2)}</td>
                    <td class="text-center">${estadoBadge}</td>
                    <td class="text-center">${escapeHtml(s.FechaHoraAplicacion || '-')}</td>
                    <td class="text-center">${escapeHtml(s.PersonaAplica || '-')}</td>
                    <td class="text-center">${escapeHtml(s.FechaHoraAplicacionManual || s.FechaRegistro || '-')}</td>
                    <td class="text-center">${escapeHtml(s.PersonaCrea || '-')}</td>
                    <td class="text-center">${acciones}</td>
                </tr>
            `;
        });
    }

    // Actualizar controles de paginación
    document.getElementById('btnPrimeraPaginaServ').disabled  = (currentPageServ === 1);
    document.getElementById('btnAnteriorPaginaServ').disabled = (currentPageServ === 1);
    document.getElementById('btnSiguientePaginaServ').disabled = (currentPageServ === totalPages);
    document.getElementById('btnUltimaPaginaServ').disabled   = (currentPageServ === totalPages);
    document.getElementById('paginacionInfoServ').innerHTML   = `Página ${currentPageServ} de ${totalPages}`;
    const desde = totalRegistros === 0 ? 0 : start + 1;
    const hasta = Math.min(end, totalRegistros);
    document.getElementById('rangoRegistrosInfoServ').innerHTML = `Mostrando ${desde} a ${hasta} de ${totalRegistros} registros`;
}

function cambiarPaginaServ(direccion) {
    const totalPages = Math.ceil(currentFilteredDataServ.length / pageSizeServ) || 1;
    let nuevaPagina = currentPageServ;
    switch (direccion) {
        case 'primera':   nuevaPagina = 1; break;
        case 'anterior':  nuevaPagina = Math.max(1, currentPageServ - 1); break;
        case 'siguiente': nuevaPagina = Math.min(totalPages, currentPageServ + 1); break;
        case 'ultima':    nuevaPagina = totalPages; break;
        default: return;
    }
    if (nuevaPagina !== currentPageServ) {
        currentPageServ = nuevaPagina;
        renderizarHistorialServPaginated();
    }
}

function cambiarPageSizeServ(nuevoTamanio) {
    pageSizeServ = nuevoTamanio;
    currentPageServ = 1;
    renderizarHistorialServPaginated();
}

function filtrarHistorialServ(estado) {
    document.querySelectorAll('#mdl-historial-servicios .btn-group .btn').forEach(btn => btn.classList.remove('active'));
    let btnActivo = null;
    if (estado === 'todos')      btnActivo = document.getElementById('btnFiltroServTodos');
    else if (estado === 'aplicados')  btnActivo = document.getElementById('btnFiltroServAplicados');
    else if (estado === 'pendientes') btnActivo = document.getElementById('btnFiltroServPendientes');
    if (btnActivo) btnActivo.classList.add('active');
    aplicarFiltrosServ();
    currentPageServ = 1;
    renderizarHistorialServPaginated();
}

function cargarHistorialServicios() {
    const hospitalizacionId = document.getElementById('HospitalizacionId')?.value;
    if (!hospitalizacionId) return;
    $.ajax({
        url: '/Hospitalizacion/ConsultarServiciosHospitalizacion',
        method: 'POST',
        data: { hospitalizacionId: hospitalizacionId },
        success: function(response) {
            let data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(response) : response;
            if (data.Exitoso && data.Resultado) {
                // Mapear campos para mantener consistencia
                allDataServ = data.Resultado.map(s => ({
                    Id: s.Id,
                    Nombre: s.Nombre,
                    Indicaciones: s.Indicaciones || '',
                    Cantidad: s.Cantidad || 1,
                    Precio: s.Precio || 0,
                    Aplicado: s.Aplicado,
                    FechaHoraAplicacion: s.FechaHoraAplicacion || '-',
                    PersonaAplica: s.PersonaAplica || '-',
                    FechaRegistro: s.FechaHoraAplicacionManual || '-',
                    PersonaCrea: s.PersonaCrea || '-'
                }));
                actualizarBadgesServ();
                aplicarFiltrosServ();
                currentPageServ = 1;
                renderizarHistorialServPaginated();
            } else {
                document.getElementById('tablaHistorialServiciosBody').innerHTML =
                    '<tr><td colspan="10" class="text-center text-danger">Error al cargar servicios.</td></tr>';
            }
        },
        error: function() {
            document.getElementById('tablaHistorialServiciosBody').innerHTML =
                '<tr><td colspan="10" class="text-center text-danger">Error de conexión al cargar servicios.</td></tr>';
        }
    });
}

// Función para abrir el modal (debes agregarla al viewmodel o llamarla directamente)
function verModalHistorialServicios() {
    cargarHistorialServicios();
    $('#mdl-historial-servicios').dialog({
        modal: true,
        width: 1300,
        buttons: {
            "Cerrar": function() {
                $(this).dialog("close");
            }
        }
    });
}

// Evento delegado para aplicar servicio desde el historial
hospWhenReady(function ($) {
$(document).on('click', '.aplicarServicioDesdeHistorial', function() {
    const servicioId = $(this).data('id');
    if (!servicioId) return;
    if (!confirm('¿Aplicar este servicio ahora?')) return;

    $.ajax({
        url: '/Hospitalizacion/AplicarServicio',
        method: 'POST',
        data: {
            hospitalizacionServicioId: servicioId,
            cuentaId: document.getElementById('CuentaId')?.value || 0
        },
        success: function(response) {
            let data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(response) : response;
            if (data.Exitoso) {
                // Recargar el historial para reflejar cambio
                cargarHistorialServicios();
                // También actualizar el modal de control de servicios si está abierto
                if (typeof consultarServiciosHospitalizacion === 'function') {
                    consultarServiciosHospitalizacion();
                }
                // Actualizar totales si está disponible
                if (typeof detallesVm !== 'undefined' && detallesVm.actualizarTotales) {
                    detallesVm.actualizarTotales();
                }
                toastr.success('Servicio aplicado correctamente');
            } else {
                toastr.error(data.Mensaje || 'Error al aplicar servicio');
            }
        },
        error: function() {
            toastr.error('Error de comunicación al aplicar servicio');
        }
    });
});
});
</script>


<script>
    // ===================== HISTORIAL DE EXÁMENES / LABORATORIOS =====================
let currentPageExa = 1;
let pageSizeExa = 10;
let currentFilteredDataExa = [];
let allDataExa = [];

function actualizarBadgesExa() {
    const total      = allDataExa.length;
    const realizados = allDataExa.filter(e => e.Aplicado).length;
    const pendientes = total - realizados;
    document.getElementById('badgeTotalExa').textContent     = `Total: ${total}`;
    document.getElementById('badgeAplicadosExa').textContent  = `Realizados: ${realizados}`;
    document.getElementById('badgePendientesExa').textContent = `Pendientes: ${pendientes}`;
}

function aplicarFiltrosExa() {
    const estadoFiltro = getFiltroEstadoActivoExa();
    currentFilteredDataExa = allDataExa.filter(e => {
        let pasaEstado = true;
        if (estadoFiltro === 'aplicados')  pasaEstado = e.Aplicado === true;
        else if (estadoFiltro === 'pendientes') pasaEstado = e.Aplicado === false;
        return pasaEstado;
    });
}

function getFiltroEstadoActivoExa() {
    const activeBtn = document.querySelector('#mdl-historial-examenes .btn-group .active');
    if (!activeBtn) return 'todos';
    const id = activeBtn.id;
    if (id === 'btnFiltroExaTodos') return 'todos';
    if (id === 'btnFiltroExaAplicados') return 'aplicados';
    if (id === 'btnFiltroExaPendientes') return 'pendientes';
    return 'todos';
}

function renderizarHistorialExaPaginated() {
    const totalRegistros = currentFilteredDataExa.length;
    const totalPages     = Math.ceil(totalRegistros / pageSizeExa) || 1;
    if (currentPageExa < 1) currentPageExa = 1;
    if (currentPageExa > totalPages) currentPageExa = totalPages;

    const start = (currentPageExa - 1) * pageSizeExa;
    const end   = start + pageSizeExa;
    const datosPagina = currentFilteredDataExa.slice(start, end);
    const tbody = document.getElementById('tablaHistorialExamenesBody');
    tbody.innerHTML = '';

    if (datosPagina.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">No hay exámenes con este filtro.</td></tr>';
    } else {
        datosPagina.forEach(e => {
            const estadoBadge = e.Aplicado
                ? '<span class="badge badge-success"><i class="fas fa-check mr-1"></i>Realizado</span>'
                : '<span class="badge badge-warning text-dark"><i class="fas fa-clock mr-1"></i>Pendiente</span>';

            // Botón eliminar SOLO si está pendiente y la hospitalización no está pagada
            const hospitalizacionPagadaExa = document.getElementById('HospitalizacionPagada')?.value === 'true';
            let acciones = '';
            if (!hospitalizacionPagadaExa && !e.Aplicado) {
                acciones = `<button class="btn btn-danger btn-sm" onclick="eliminarExamenHistorial(${e.Id})" title="Eliminar examen">
                                <i class="fas fa-trash"></i>
                            </button>`;
            } else {
                acciones = '<span class="text-muted">—</span>';
            }

            tbody.innerHTML += `
                <tr>
                    <td><strong>${escapeHtml(e.Nombre || '-')}</strong></td>
                    <td class="text-center">${estadoBadge}</td>
                    <td class="text-center">${escapeHtml(e.FechaSolicitud || '-')}</td>
                    <td class="text-center">${escapeHtml(e.SolicitadoPor || '-')}</td>
                    <td class="text-center">${escapeHtml(e.FechaRealizacion || '-')}</td>
                    <td class="text-center">${escapeHtml(e.RealizadoPor || '-')}</td>
                    <td class="text-center">${escapeHtml(e.Observaciones || '-')}</td>
                    <td class="text-center">${acciones}</td>
                </tr>
            `;
        });
    }

    document.getElementById('btnPrimeraPaginaExa').disabled  = (currentPageExa === 1);
    document.getElementById('btnAnteriorPaginaExa').disabled = (currentPageExa === 1);
    document.getElementById('btnSiguientePaginaExa').disabled = (currentPageExa === totalPages);
    document.getElementById('btnUltimaPaginaExa').disabled   = (currentPageExa === totalPages);
    document.getElementById('paginacionInfoExa').innerHTML   = `Página ${currentPageExa} de ${totalPages}`;
    const desde = totalRegistros === 0 ? 0 : start + 1;
    const hasta = Math.min(end, totalRegistros);
    document.getElementById('rangoRegistrosInfoExa').innerHTML = `Mostrando ${desde} a ${hasta} de ${totalRegistros} registros`;
}

function cambiarPaginaExa(direccion) {
    const totalPages = Math.ceil(currentFilteredDataExa.length / pageSizeExa) || 1;
    let nuevaPagina = currentPageExa;
    switch (direccion) {
        case 'primera':   nuevaPagina = 1; break;
        case 'anterior':  nuevaPagina = Math.max(1, currentPageExa - 1); break;
        case 'siguiente': nuevaPagina = Math.min(totalPages, currentPageExa + 1); break;
        case 'ultima':    nuevaPagina = totalPages; break;
        default: return;
    }
    if (nuevaPagina !== currentPageExa) {
        currentPageExa = nuevaPagina;
        renderizarHistorialExaPaginated();
    }
}

function cambiarPageSizeExa(nuevoTamanio) {
    pageSizeExa = nuevoTamanio;
    currentPageExa = 1;
    renderizarHistorialExaPaginated();
}

function filtrarHistorialExa(estado) {
    document.querySelectorAll('#mdl-historial-examenes .btn-group .btn').forEach(btn => btn.classList.remove('active'));
    let btnActivo = null;
    if (estado === 'todos')      btnActivo = document.getElementById('btnFiltroExaTodos');
    else if (estado === 'aplicados')  btnActivo = document.getElementById('btnFiltroExaAplicados');
    else if (estado === 'pendientes') btnActivo = document.getElementById('btnFiltroExaPendientes');
    if (btnActivo) btnActivo.classList.add('active');
    aplicarFiltrosExa();
    currentPageExa = 1;
    renderizarHistorialExaPaginated();
}

function cargarHistorialExamenes() {
    const hospitalizacionId = document.getElementById('HospitalizacionId')?.value;
    if (!hospitalizacionId) return;

    $.ajax({
        url: '/Hospitalizacion/ConsultarExamenesHospitalizacion',
        method: 'POST',
        data: { hospitalizacionId: hospitalizacionId },
        success: function(response) {
            let data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(response) : response;
            if (data.Exitoso && data.Resultado) {
             
                allDataExa = (data.Resultado || []).map(ex => ({
                        Id: ex.Id,  
                    Nombre: ex.Nombre || '-',
                    Aplicado: false, 
                    FechaSolicitud: ex.FechaHora || '-',
                    SolicitadoPor: 'Sistema', 
                    FechaRealizacion: '-',
                    RealizadoPor: '-',
                    Observaciones: ''
                }));
                actualizarBadgesExa();
                aplicarFiltrosExa();
                currentPageExa = 1;
                renderizarHistorialExaPaginated();
            } else {
                document.getElementById('tablaHistorialExamenesBody').innerHTML =
                    '<tr><td colspan="7" class="text-center text-danger">Error al cargar exámenes.</td></tr>';
            }
        },
        error: function() {
            document.getElementById('tablaHistorialExamenesBody').innerHTML =
                '<tr><td colspan="7" class="text-center text-danger">Error de conexión al cargar exámenes.</td></tr>';
        }
    });
}

function verModalHistorialExamenes() {
    cargarHistorialExamenes();
    $('#mdl-historial-examenes').dialog({
        modal: true,
        width: 1200,
        buttons: {
            "Cerrar": function() {
                $(this).dialog("close");
            }
        }
    });
}




function eliminarServicioHistorial(servicioId) {
    if (!confirm('¿Eliminar este servicio? Se eliminará lógicamente (no podrá aplicarse después).')) return;

    $.ajax({
        url: '/Hospitalizacion/EliminarServicio',
        method: 'POST',
        data: { hospitalizacionServicioId: servicioId },
        success: function(response) {
            let data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(response) : response;
            if (data.Exitoso) {
                toastr.success('Servicio eliminado correctamente');
                cargarHistorialServicios();  
                if (typeof consultarServiciosHospitalizacion === 'function') {
                    consultarServiciosHospitalizacion();
                }
                if (typeof detallesVm !== 'undefined' && detallesVm.actualizarTotales) {
                    detallesVm.actualizarTotales();
                }
            } else {
                toastr.error(data.Mensaje || 'Error al eliminar servicio');
            }
        },
        error: function() {
            toastr.error('Error de conexión al eliminar servicio');
        }
    });
}

// Delegar evento para los botones de eliminar (se agregan dinámicamente)
hospWhenReady(function ($) {
$(document).on('click', '.eliminarServicioHistorial', function() {
    const servicioId = $(this).data('id');
    if (servicioId) eliminarServicioHistorial(servicioId);
});
});


function eliminarExamenHistorial(examenId) {
    if (!confirm('¿Eliminar este examen? Se eliminará lógicamente y no se podrá recuperar.')) return;

    $.ajax({
        url: '/Hospitalizacion/EliminarExamen',
        method: 'POST',
        data: { hospitalizacionExamenId: examenId },
        success: function(response) {
            let data = (window.HospAjax && HospAjax.parseHospJson) ? HospAjax.parseHospJson(response) : response;
            if (data.Exitoso) {
                toastr.success('Examen eliminado correctamente');
                cargarHistorialExamenes();
                if (typeof detallesVm !== 'undefined' && detallesVm.actualizarTotales) {
                    detallesVm.actualizarTotales();
                }
            } else {
                toastr.error(data.Mensaje || 'Error al eliminar examen');
            }
        },
        error: function() {
            toastr.error('Error de conexión al eliminar examen');
        }
    });
}

hospWhenReady(function ($) {
$(document).on('click', '.eliminarExamenHistorial', function() {
    const examenId = $(this).data('id');
    if (examenId) eliminarExamenHistorial(examenId);
});

    var seguroActual = $('#CodigoSeguro').val();
    if (seguroActual) {
        $('#seguroSelect').val(seguroActual).trigger('change');
    }

    var medicoActualId = $('#CitaCirujanoId').val();
    if (medicoActualId) {
        $('#medicoAsignadoSelect').val(medicoActualId).trigger('change');
    }
});
</script>
