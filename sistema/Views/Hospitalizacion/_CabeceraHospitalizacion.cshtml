@model sistema.Models.HospitalizacionDetallesViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Config
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var logoUrl = Config["ImagenLogoBase64"];
    if (string.IsNullOrWhiteSpace(logoUrl))
    {
        var clienteLogo = Configuration["Cliente"];
        logoUrl = !string.IsNullOrWhiteSpace(clienteLogo)
            ? $"/assets/images/logos/logo{clienteLogo}.png"
            : "/assets/images/logos/logoAVM.png";
    }
    var idHospi = @Model.HospitalizacionId.ToString();
    string cliente = Configuration["Cliente"]; 
    var usuarioMedicoExterno = User.IsInRole("Medico Externo");
    bool quitarDataTarget = (cliente == "M14" && usuarioMedicoExterno);

    var tipoSangreDisplay = string.IsNullOrWhiteSpace(Model.PacienteTipoSangre) ? "No registrado" : Model.PacienteTipoSangre;
    var pesoDisplay = string.IsNullOrWhiteSpace(Model.PacientePeso) ? "No registrado" : Model.PacientePeso;
    var tallaDisplay = string.IsNullOrWhiteSpace(Model.PacienteTalla) ? "No registrado" : Model.PacienteTalla;
}


<input type="hidden" id="MedicoAsignadoNombre"       value="@(Model.MedicoAsignado ?? "")" />
<input type="hidden" id="CitaCirujanoId"              value="@(Model.CitaCirujanoId?.ToString() ?? Model.MedicoAsignadoEmpleadoId?.ToString() ?? Model.Consulta?.Citas?.EmpleadoId?.ToString() ?? "")" />
<input type="hidden" id="CodigoSeguro"                value="@(Model.CodigoSeguro ?? "")" />
<input type="hidden" id="CitaPrimerAyudanteNombre"    value="@(Model.CitaPrimerAyudante ?? "")" />

<input type="hidden" id="HospitalizacionPagada" value="@Model.Pagada.ToString().ToLower()" />
<input type="hidden" id="HospitalizacionFinalizada" value="@Model.HospitalizacionFinalizada.ToString().ToLower()" />
<input type="hidden" id="CuentaPagada" value="@Model.Pagada.ToString().ToLower()" />

@* #Region Cabecera Hospitalización *@
<div class="main-card mb-3 card">
    <div class="d-flex flex-column align-items-center pt-4" style="height: auto;">
        <img src="@logoUrl" alt="Logo" style="width: 350px; max-width: 90%; height: auto;" class="d-block"> 
        <div class="text-center mb-2">
            <h4 class="display-5 font-weight-bold text-primary mb-1">
                Admisión #@Model.HospitalizacionId
            </h4>
        </div>
    </div>
    <hr />

    <div class="card-body">
        <div class="row">
            <div class="col-md-12">


@if (!Model.Pagada)
{
    <div class="mb-4 p-3 border rounded" id="acciones-cuenta-hosp" style="background-color: #f8f9fa; border-left: 5px solid #28a745 !important; position: relative; z-index: 5;">
        <h6 class="text-success small text-uppercase font-weight-bold">Acciones de Cuenta</h6>
        <div class="d-flex flex-wrap mt-2" style="gap: 12px;">
            
            @if (!User.IsInRole("Enfermeria"))
            {
                <button type="button" class="btn btn-shadow btn-success btn-lg px-4" data-hosp-accion="pagarCuenta">
                    <i class="fas fa-money-check-alt mr-2"></i>
                    Pagar Q <span data-bind="text:totalPagar" class="font-weight-bold"></span>
                </button>
            }

               @if (!User.IsInRole("Enfermeria") && !User.IsInRole("Medico Interno") 
                    || (User.IsInRole("Enfermeria") && (cliente == "SS" || cliente == "M14"))
                    || (User.IsInRole("Medico Interno") && cliente == "M14"))
                {
                    <button type="button" class="btn btn-shadow btn-outline-primary btn-lg px-4" data-hosp-accion="verModalCambioHabitacion">
                        <i class="fas fa-exchange-alt mr-2"></i> Cambiar habitación
                    </button>
                }

                @if (!User.IsInRole("Enfermeria"))
                {
                   
                        <button type="button" class="btn btn-shadow btn-outline-success btn-lg px-4" data-hosp-accion="verModalDetalleTotales">
                            <i class="fas fa-list-alt mr-2"></i> Detalle de totales
                        </button>

                    <button type="button" class="btn btn-danger btn-hosp-email-paciente"
                            data-hosp-id="@Model.HospitalizacionId"
                            data-paciente="@Model.PacienteNombre"
                            data-email="@(Model.PacienteEmail ?? "")"
                            data-paciente-id="@Model.PacienteIdPDF"
                            data-habitacion-id="@Model.HabitacionIdPDF"
                            data-cita-id="@Context.Request.Query["citaId"]"
                            title="Enviar por Correo">
                        <i class="fas fa-envelope"></i>
                    </button>

                    <button type="button" class="btn btn-danger btn-hosp-email-inventario"
                            data-email="@(Config["EstablecimientoCorreoElectronico"] ?? "")"
                            title="Enviar alerta de inventario por correo">
                        <i class="fas fa-envelope"></i>
                    </button>

                    <button type="button" class="btn btn-success btn-hosp-whatsapp"
                            data-hosp-id="@Model.HospitalizacionId"
                            data-paciente="@Model.PacienteNombre"
                            data-celular="@(Model.PacienteCelular ?? Model.PacienteTelefono ?? "")"
                            title="Enviar por WhatsApp">
                        <i class="fab fa-whatsapp"></i>
                    </button>
                }
                    <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                            data-hosp-accion="verModalHistorialMedicamentos">
                        <i class="fas fa-pills mr-2"></i> Historial Medicamentos
                    </button>

                    <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                            data-hosp-accion="verModalHistorialServicios">
                        <i class="fas fa-hand-holding-medical mr-2"></i> Historial Servicios
                    </button>

                    <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                            data-hosp-accion="verModalHistorialExamenes">
                        <i class="fas fa-microscope mr-2"></i> Historial Exámenes
                    </button>
        </div>
    </div>
}
else
{
    <div class="mb-4 p-3 border rounded" style="background-color: #f0fff4; border-left: 5px solid #28a745 !important;">
        <div class="d-flex align-items-center flex-wrap mb-2" style="gap: 10px;">
            <span class="badge badge-success px-3 py-2" style="font-size: 1rem;">
                <i class="fas fa-check-circle mr-1"></i> HOSPITALIZACIÓN PAGADA
            </span>
            <small class="text-muted">Esta cuenta ya fue liquidada. Solo puede visualizarla.</small>
        </div>
        <div class="d-flex flex-wrap" style="gap: 12px;">
            @if (!User.IsInRole("Enfermeria"))
            {
                <button type="button" class="btn btn-shadow btn-outline-success btn-lg px-4" data-hosp-accion="verPagosCuenta">
                    <i class="fas fa-receipt mr-2"></i> Ver pagos realizados
                </button>
            }

            <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                    data-hosp-accion="verModalHistorialMedicamentos">
                <i class="fas fa-pills mr-2"></i> Historial Medicamentos
            </button>

            <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                    data-hosp-accion="verModalHistorialServicios">
                <i class="fas fa-hand-holding-medical mr-2"></i> Historial Servicios
            </button>

            <button type="button" class="btn btn-shadow btn-outline-info btn-lg px-4"
                    data-hosp-accion="verModalHistorialExamenes">
                <i class="fas fa-microscope mr-2"></i> Historial Exámenes
            </button>
        </div>
    </div>
}

