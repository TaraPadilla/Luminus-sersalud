<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script type="text/javascript">
    var chartJSAnestesia = null;

    function calcularImcAnestesia() {
        var pesoEl = document.getElementById("an_peso");
        var tallaEl = document.getElementById("an_talla");
        var pesoTxt = (pesoEl?.value || "").replace(",", ".");
        var tallaTxt = (tallaEl?.value || "").replace(",", ".");
        var peso = parseFloat(pesoTxt);
        var talla = parseFloat(tallaTxt);
        var imcEl = document.getElementById("an_imc");
        if (!imcEl || !peso || !talla) {
            if (imcEl) imcEl.value = "";
            return;
        }
        var tallaM = talla > 3 ? talla / 100 : talla;
        if (tallaM <= 0) return;
        imcEl.value = (peso / (tallaM * tallaM)).toFixed(2);
    }

    function guardarPesoTallaPacienteAnestesia() {
        var pacienteId = parseInt($("#PacienteId").val() || "@Model.PacienteId", 10);
        if (!pacienteId) return;
        var peso = document.getElementById("an_peso")?.value;
        var talla = document.getElementById("an_talla")?.value;
        if (peso) {
            $.post("/Pacientes/ActualizarCampo", { pacienteId: pacienteId, campo: "Peso", valor: peso });
        }
        if (talla) {
            $.post("/Pacientes/ActualizarCampo", { pacienteId: pacienteId, campo: "Estatura", valor: talla });
        }
    }

    function agregarFilaBalanceAnestesia(tableId, subtotalId) {
        var tbody = document.querySelector("#" + tableId + " tbody");
        if (!tbody) return;
        var tr = document.createElement("tr");
        tr.innerHTML = '<td><input type="time" class="form-control form-control-sm bal-hora" /></td>'
            + '<td><input type="number" min="0" step="1" class="form-control form-control-sm bal-ml" oninput="recalcularSubtotalAnestesia(\'' + tableId + '\',\'' + subtotalId + '\')" /></td>'
            + '<td><button type="button" class="btn btn-sm btn-link text-danger" onclick="this.closest(\'tr\').remove(); recalcularSubtotalAnestesia(\'' + tableId + '\',\'' + subtotalId + '\')">&times;</button></td>';
        tbody.appendChild(tr);
    }

    function agregarFilaIngestaAnestesia() { agregarFilaBalanceAnestesia("tbl-ingesta-anestesia", "ingesta-subtotal"); }
    function agregarFilaExcretaAnestesia() { agregarFilaBalanceAnestesia("tbl-excreta-anestesia", "excreta-subtotal"); }

    function recalcularSubtotalAnestesia(tableId, subtotalId) {
        var total = 0;
        document.querySelectorAll("#" + tableId + " .bal-ml").forEach(function (inp) {
            total += parseFloat(inp.value) || 0;
        });
        var el = document.getElementById(subtotalId);
        if (el) el.textContent = total;
    }

    hospWhenReady(function ($) {
        $(document).on("change", "#an_posicion", function () {
            var show = $(this).val() === "Otro";
            $("#an_posicion_otro_wrap").toggle(show);
        });
    });

    function initChartJS() {
        var ctx = document.getElementById('canvas-anestesia');
        if (!ctx) return;
        
        if (chartJSAnestesia !== null) return;

        chartJSAnestesia = new Chart(ctx, {
            type: 'line', 
            data: {
                labels: [], 
                datasets: [
                    {
                        label: 'PA Sistólica',
                        data: [],
                        backgroundColor: 'black',
                        borderColor: 'black',
                        pointStyle: 'triangle', 
                        pointRadius: 8,
                        showLine: false 
                    },
                    {
                        label: 'PA Diastólica',
                        data: [],
                        backgroundColor: 'black',
                        borderColor: 'black',
                        pointStyle: 'triangle', 
                        rotation: 180, 
                        pointRadius: 8,
                        showLine: false
                    },
                    {
                        label: 'Frec. Cardíaca',
                        data: [],
                        backgroundColor: '#007bff',
                        borderColor: '#007bff',
                        pointStyle: 'circle',
                        pointRadius: 6,
                        showLine: false
                    },
                    {
                        label: 'Frec. Respiratoria',
                        data: [],
                        backgroundColor: 'transparent', 
                        borderColor: '#28a745',       
                        borderWidth: 2,
                        pointStyle: 'circle',
                        pointRadius: 6,
                        showLine: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        title: { display: true, text: 'Hora' }
                    },
                    y: {
                        title: { display: true, text: 'Valores' },
                        min: 0,
                        max: 200,
                        ticks: {
                            stepSize: 10 
                        }
                    }
                },
                plugins: {
                    legend: {
                        position: 'top',
                    }
                }
            }
        });
    }

    function agregarPuntoChartJS() {
        // Inicializar la gráfica a la fuerza si por algún motivo no se cargó al abrir el tab
        if (!chartJSAnestesia) {
            initChartJS();
        }

        if (!chartJSAnestesia) {
            alert("La gráfica no pudo inicializarse correctamente.");
            return;
        }

        var hora = document.getElementById('graf_hora').value;
        var pas = document.getElementById('graf_pas').value;
        var pad = document.getElementById('graf_pad').value;
        var fc = document.getElementById('graf_fc').value;
        var fr = document.getElementById('graf_fr').value;

        if (!hora) {
            alert("Por favor ingrese al menos la hora para añadir el punto.");
            return;
        }

        // Leer datos directos desde la configuración de Chart.js
        var labels = chartJSAnestesia.data.labels;
        var index = labels.indexOf(hora);
        
        if (index === -1) {
            labels.push(hora);
            index = labels.length - 1; 
        }

        // Asignación directa a los datasets de ChartJS
        chartJSAnestesia.data.datasets[0].data[index] = pas ? parseInt(pas) : null;
        chartJSAnestesia.data.datasets[1].data[index] = pad ? parseInt(pad) : null;
        chartJSAnestesia.data.datasets[2].data[index] = fc ? parseInt(fc) : null;
        chartJSAnestesia.data.datasets[3].data[index] = fr ? parseInt(fr) : null;

        // Comando crítico para refrescar la vista
        chartJSAnestesia.update();

        // Limpiar campos
        document.getElementById('graf_pas').value = '';
        document.getElementById('graf_pad').value = '';
        document.getElementById('graf_fc').value = '';
        document.getElementById('graf_fr').value = '';
        document.getElementById('graf_otros').value = '';
    }

    // Lógica de navegación reescrita de manera segura
    var oldShowStep = window.showAnestesiaStep;
    window.showAnestesiaStep = function(step) {
        if (typeof oldShowStep === 'function') {
            oldShowStep(step);
        } else {
            $('[id^=anestesia-step-]').hide();
            $('#anestesia-step-' + step).show();
        }
        
        if (step === 1) {
            calcularImcAnestesia();
        }
        if (step === 5) {
            setTimeout(function() {
                initChartJS();
            }, 200); 
        }
    };

    function recolectarDatosRegistroAnestesia() {
        var form = document.getElementById("formAnestesia");
        var radios = {};
        if (form) {
            form.querySelectorAll('input[type=radio]:checked').forEach(function (el) {
                if (el.name) radios[el.name] = el.value;
            });
        }
        var campos = {};
        document.querySelectorAll("#formAnestesia [id^='an_']").forEach(function (el) {
            if (el.id) campos[el.id] = el.value || "";
        });
        if (document.getElementById("an_posicion")) {
            var pos = document.getElementById("an_posicion").value;
            if (pos === "Otro") {
                campos.an_posicion = (document.getElementById("an_posicion_otro")?.value || "").trim() || "Otro";
            } else {
                campos.an_posicion = pos;
            }
        }
        var indTipo = document.getElementById("induccionTipo");
        if (indTipo) campos.an_induccion_tipo = indTipo.value;
        var indDetalle = [];
        var inhOpc = document.getElementById("an_ind_inh_opcion");
        if (inhOpc && inhOpc.value) indDetalle.push("Inhalada: " + inhOpc.value);
        var ivSel = document.getElementById("induccionIVSelect");
        if (ivSel && ivSel.value) indDetalle.push("IV: " + ivSel.value);
        var ivOtro = document.getElementById("an_ind_iv_otro");
        if (ivOtro && ivOtro.value) indDetalle.push("Otros IV: " + ivOtro.value);
        if (indDetalle.length) campos.an_induccion_detalle = indDetalle.join("; ");

        function recolectarMedicamentosGrid() {
            var result = { horas: [], notaHora: "", filas: [] };
            var table = document.getElementById("tbl-medicamentos-anestesia");
            if (!table) return result;
            table.querySelectorAll("tbody tr:first-child .med-hora-col").forEach(function (inp) {
                if (inp.value) result.horas.push(inp.value);
            });
            var notaHora = table.querySelector(".med-nota-hora");
            if (notaHora && notaHora.value) result.notaHora = notaHora.value;
            table.querySelectorAll("tbody tr[data-item]").forEach(function (tr) {
                var vals = [];
                tr.querySelectorAll(".med-val").forEach(function (inp) { vals.push(inp.value || ""); });
                var nota = tr.querySelector(".med-nota")?.value || "";
                if (vals.some(function (v) { return v; }) || nota) {
                    result.filas.push({ item: tr.getAttribute("data-item"), valores: vals, nota: nota });
                }
            });
            return result;
        }

        function filasBalance(tableId) {
            var filas = [];
            document.querySelectorAll("#" + tableId + " tbody tr").forEach(function (tr) {
                var hora = tr.querySelector(".bal-hora")?.value || "";
                var ml = tr.querySelector(".bal-ml")?.value || "";
                if (hora || ml) filas.push({ hora: hora, ml: ml });
            });
            return filas;
        }

        var graficaPuntos = [];
        if (chartJSAnestesia && chartJSAnestesia.data && chartJSAnestesia.data.labels) {
            chartJSAnestesia.data.labels.forEach(function (hora, idx) {
                graficaPuntos.push({
                    hora: hora,
                    pas: chartJSAnestesia.data.datasets[0].data[idx] ?? "",
                    pad: chartJSAnestesia.data.datasets[1].data[idx] ?? "",
                    fc: chartJSAnestesia.data.datasets[2].data[idx] ?? "",
                    fr: chartJSAnestesia.data.datasets[3].data[idx] ?? ""
                });
            });
        }

        return {
            fecha: document.getElementById("an_fecha")?.value || "",
            qx: document.getElementById("an_qx")?.value || "",
            radios: radios,
            campos: campos,
            ingestaFilas: filasBalance("tbl-ingesta-anestesia"),
            excretaFilas: filasBalance("tbl-excreta-anestesia"),
            graficaPuntos: graficaPuntos,
            medicamentosGrid: recolectarMedicamentosGrid()
        };
    }

    function aplicarDatosRegistroAnestesia(datos) {
        if (!datos) return;
        if (datos.fecha && document.getElementById("an_fecha")) document.getElementById("an_fecha").value = datos.fecha;
        if (datos.qx && document.getElementById("an_qx")) document.getElementById("an_qx").value = datos.qx;
        if (datos.radios) {
            Object.keys(datos.radios).forEach(function (name) {
                var el = document.querySelector('#formAnestesia input[type=radio][name="' + name + '"][value="' + datos.radios[name] + '"]');
                if (el) el.checked = true;
            });
        }
        if (datos.campos) {
            Object.keys(datos.campos).forEach(function (key) {
                var el = document.getElementById(key);
                if (el) el.value = datos.campos[key] || "";
            });
        }
        if (datos.medicamentosGrid) {
            var grid = datos.medicamentosGrid;
            var table = document.getElementById("tbl-medicamentos-anestesia");
            if (table && grid.horas) {
                var horaInputs = table.querySelectorAll("tbody tr:first-child .med-hora-col");
                grid.horas.forEach(function (h, idx) {
                    if (horaInputs[idx]) horaInputs[idx].value = h;
                });
            }
            if (table && grid.notaHora) {
                var notaHora = table.querySelector(".med-nota-hora");
                if (notaHora) notaHora.value = grid.notaHora;
            }
            if (table && grid.filas) {
                var itemAliases = {
                    "Oxigeno (l/min)": "Oxígeno (l/min)",
                    "Oxígeno": "Oxígeno (l/min)",
                    "Oxigeno": "Oxígeno (l/min)",
                    "N2O": "N2O (l/min)",
                    "Sevoflurano": "Sevoflurano (%)",
                    "Desflurano": "Desflurano (%)",
                    "Propofol": "Propofol (mg)",
                    "Midazolam": "Midazolam (mg)",
                    "Fentanyl": "Fentanyl (mcg)",
                    "Atracurio": "Atracurio (mg)",
                    "Vecuronio": "Vecuronio (mg)",
                    "Succinilcolina": "Succinilcolina (mg)",
                    "Efedrina": "Efedrina (mg)",
                    "Morfina": "Morfina (mg)",
                    "Petidina": "Petidina (mg)"
                };
                grid.filas.forEach(function (fila) {
                    var itemKey = fila.item || "";
                    if (itemAliases[itemKey]) itemKey = itemAliases[itemKey];
                    var tr = table.querySelector('tbody tr[data-item="' + itemKey + '"]');
                    if (!tr) return;
                    var vals = fila.valores || [];
                    tr.querySelectorAll(".med-val").forEach(function (inp, idx) {
                        inp.value = vals[idx] || "";
                    });
                    var nota = tr.querySelector(".med-nota");
                    if (nota) nota.value = fila.nota || "";
                });
            }
        }
        calcularImcAnestesia();
        if (document.getElementById("an_posicion")) {
            $("#an_posicion").trigger("change");
        }

        function aplicarFilasBalance(tableId, subtotalId, filas) {
            if (!filas || !filas.length) return;
            var tbody = document.querySelector("#" + tableId + " tbody");
            if (!tbody) return;
            tbody.innerHTML = "";
            filas.forEach(function (f) {
                agregarFilaBalanceAnestesia(tableId, subtotalId);
                var rows = tbody.querySelectorAll("tr");
                var tr = rows[rows.length - 1];
                if (tr) {
                    var horaInp = tr.querySelector(".bal-hora");
                    var mlInp = tr.querySelector(".bal-ml");
                    if (horaInp) horaInp.value = f.hora || "";
                    if (mlInp) mlInp.value = f.ml || "";
                }
            });
            recalcularSubtotalAnestesia(tableId, subtotalId);
        }

        if (datos.ingestaFilas && datos.ingestaFilas.length) {
            aplicarFilasBalance("tbl-ingesta-anestesia", "ingesta-subtotal", datos.ingestaFilas);
        }
        if (datos.excretaFilas && datos.excretaFilas.length) {
            aplicarFilasBalance("tbl-excreta-anestesia", "excreta-subtotal", datos.excretaFilas);
        }

        if (datos.graficaPuntos && datos.graficaPuntos.length) {
            setTimeout(function () {
                initChartJS();
                if (!chartJSAnestesia) return;
                datos.graficaPuntos.forEach(function (p) {
                    var hora = p.hora;
                    if (!hora) return;
                    var labels = chartJSAnestesia.data.labels;
                    var index = labels.indexOf(hora);
                    if (index === -1) {
                        labels.push(hora);
                        index = labels.length - 1;
                    }
                    chartJSAnestesia.data.datasets[0].data[index] = p.pas ? parseInt(p.pas, 10) : null;
                    chartJSAnestesia.data.datasets[1].data[index] = p.pad ? parseInt(p.pad, 10) : null;
                    chartJSAnestesia.data.datasets[2].data[index] = p.fc ? parseInt(p.fc, 10) : null;
                    chartJSAnestesia.data.datasets[3].data[index] = p.fr ? parseInt(p.fr, 10) : null;
                });
                chartJSAnestesia.update();
            }, 350);
        }
    }

    window.cargarRegistroAnestesia = function () {
        var hospId = parseInt($("#HospitalizacionId").val(), 10);
        if (!hospId) return;
        $.post("/RegistroAnestesia/Obtener", { hospitalizacionId: hospId }, function (dataResult) {
            try {
                var data = typeof dataResult === "string" ? JSON.parse(dataResult) : dataResult;
                if (!data.exitoso || !data.resultado || !data.resultado.DatosJson) return;
                var datos = JSON.parse(data.resultado.DatosJson);
                aplicarDatosRegistroAnestesia(datos);
            } catch (e) { console.warn("Registro anestesia:", e); }
        });
    };

    window.guardarRegistroAnestesia = function () {
        var hospId = parseInt($("#HospitalizacionId").val(), 10);
        if (!hospId) {
            alert("No se encontró la hospitalización.");
            return;
        }
        guardarPesoTallaPacienteAnestesia();
        var payload = {
            HospitalizacionId: hospId,
            DatosJson: JSON.stringify(recolectarDatosRegistroAnestesia())
        };
        if (typeof showLoading === "function") showLoading();
        $.ajax({
            url: "/RegistroAnestesia/Guardar",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (dataResult) {
                if (typeof hideLoading === "function") hideLoading();
                var data = typeof dataResult === "string" ? JSON.parse(dataResult) : dataResult;
                if (data.exitoso) {
                    if (typeof mensajeEmergente === "function") mensajeEmergente("Registro anestésico guardado.");
                    $("#mdl-registro-anestesia").dialog("close");
                } else {
                    alert(data.resultado || "Error al guardar.");
                }
            },
            error: function () {
                if (typeof hideLoading === "function") hideLoading();
                alert("Error de conexión al guardar el registro anestésico.");
            }
        });
    };

    hospOnReady(function () {
        calcularImcAnestesia();
        var pesoInput = document.getElementById("an_peso");
        var tallaInput = document.getElementById("an_talla");
        if (pesoInput) pesoInput.addEventListener("input", calcularImcAnestesia);
        if (tallaInput) tallaInput.addEventListener("input", calcularImcAnestesia);
        if (!document.querySelector("#tbl-ingesta-anestesia tbody tr")) agregarFilaIngestaAnestesia();
        if (!document.querySelector("#tbl-excreta-anestesia tbody tr")) agregarFilaExcretaAnestesia();
    });
</script>