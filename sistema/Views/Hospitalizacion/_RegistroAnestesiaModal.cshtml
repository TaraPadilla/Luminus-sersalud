@model sistema.Models.HospitalizacionDetallesViewModel

<div style="display:none;" id="mdl-registro-anestesia">
    <div style="padding:16px 20px 20px; background:#f8fafc;">
        <form id="formAnestesia">
            
            <div id="anestesia-step-1">
                <div class="main-card mb-3 card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-muted small font-weight-bold">Paso 1 de 6</span>
                            <span class="text-primary small">Datos Generales</span>
                        </div>
                        <div class="progress mb-4" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 16%;" aria-valuenow="16" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <h5 class="card-title text-primary">Primera Sección</h5>
                        <div class="form-row mt-3">
                            <div class="form-group col-md-3"><label class="text-muted">Fecha</label><input type="date" class="form-control"></div>
                            <div class="form-group col-md-3"><label class="text-muted">Qx</label><input type="text" class="form-control"></div>
                            <div class="form-group col-md-6"><label class="text-muted">Paciente</label><input type="text" class="form-control bg-light" value="@Model.PacienteNombre" readonly></div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-3"><label class="text-muted">Sexo</label><input type="text" class="form-control bg-light" value="@Model.PacienteSexo" readonly></div>
                            <div class="form-group col-md-3"><label class="text-muted">Edad</label><input type="text" class="form-control bg-light" value="@Model.EdadPaciente" readonly></div>
                            <div class="form-group col-md-3"><label class="text-muted">Peso</label><input type="text" class="form-control bg-light" value="@Model.PacientePeso" readonly></div>
                            <div class="form-group col-md-3"><label class="text-muted">Talla</label><input type="text" class="form-control bg-light" value="@Model.PacienteTalla" readonly></div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-3"><label class="text-muted">ASA</label><input type="text" class="form-control"></div>
                            <div class="form-group col-md-3"><label class="text-muted">Técnica Anestésica</label><input type="text" class="form-control"></div>
                            <div class="form-group col-md-3"><label class="text-muted">Chequeo de máquina</label><input type="number" class="form-control"></div>
                            <div class="form-group col-md-3"><label class="text-muted">Índice de masa corporal</label><input type="number" class="form-control"></div>
                        </div>
                        <hr>
                        <div class="d-flex justify-content-end mt-3">
                            <button type="button" class="btn btn-primary px-4" onclick="showAnestesiaStep(2)">Siguiente</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="anestesia-step-2" style="display: none;">
                <div class="main-card mb-3 card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-muted small font-weight-bold">Paso 2 de 6</span>
                            <span class="text-primary small">Evaluación Clínica</span>
                        </div>
                        <div class="progress mb-4" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 33%;" aria-valuenow="33" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <h5 class="card-title text-primary mb-4">Segunda Sección</h5>
                        
                        <fieldset class="border p-3 mb-4 rounded bg-white">
                            <legend class="w-auto px-2 text-info" style="font-size: 1.05rem; font-weight: bold;">Preparación</legend>
                            <div class="form-row">
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Identificación</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_prep_identificacion" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_prep_identificacion" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Revisión de expediente</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_prep_expediente" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_prep_expediente" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Consentimiento</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_prep_consentimiento" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_prep_consentimiento" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Miembro marcado</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_prep_miembro" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_prep_miembro" value="NO" class="mr-1"> NO</label></div></div>
                            </div>
                            <div class="form-row mt-2">
                                <div class="form-group col-md-12 mb-0"><label class="text-muted">Ayuno</label><input type="text" class="form-control"></div>
                            </div>
                        </fieldset>

                        <fieldset class="border p-3 mb-4 rounded bg-white">
                            <legend class="w-auto px-2 text-info" style="font-size: 1.05rem; font-weight: bold;">Seguridad</legend>
                            <div class="form-row">
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Revisión de equipo</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_seg_equipo" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_seg_equipo" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Plancha de cauterio</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_seg_cauterio" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_seg_cauterio" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Puntos de presión</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_seg_presion" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_seg_presion" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Protección ocular</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_seg_ocular" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_seg_ocular" value="NO" class="mr-1"> NO</label></div></div>
                            </div>
                        </fieldset>

                        <fieldset class="border p-3 mb-4 rounded bg-white">
                            <legend class="w-auto px-2 text-info" style="font-size: 1.05rem; font-weight: bold;">Monitores</legend>
                             <div class="form-row">
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Esfigmomanómetro</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_esfigmo" value="Derecho" class="mr-1"> Der.</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_esfigmo" value="Izquierdo" class="mr-1"> Izq.</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">EKG</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_ekg" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_ekg" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Oxímetro</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_oximetro" value="Derecho" class="mr-1"> Der.</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_oximetro" value="Izquierdo" class="mr-1"> Izq.</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">BIS</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_bis" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_bis" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">Capno</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_capno" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_capno" value="NO" class="mr-1"> NO</label></div></div>
                            </div>
                            <div class="form-row mt-2">
                                <div class="form-group col-md-3 mb-0"><label class="text-muted">Foley</label><input type="number" class="form-control"></div>
                                <div class="form-group col-md-3 mb-0"><label class="text-muted d-block mb-1">Monitor</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_mon_monitor" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_mon_monitor" value="NO" class="mr-1"> NO</label></div></div>
                            </div>
                        </fieldset>

                        <fieldset class="border p-3 mb-4 rounded bg-white">
                            <legend class="w-auto px-2 text-info" style="font-size: 1.05rem; font-weight: bold;">Posición</legend>
                            <div class="form-row">
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">D. supino</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-2 mb-0"><input type="radio" name="an_pos_supino" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_pos_supino" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">D. prono</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-2 mb-0"><input type="radio" name="an_pos_prono" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_pos_prono" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">D. lateral</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-2 mb-0"><input type="radio" name="an_pos_lateral" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_pos_lateral" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">Litotomía</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-2 mb-0"><input type="radio" name="an_pos_lito" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_pos_lito" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted d-block mb-1">N. sevillana</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-2 mb-0"><input type="radio" name="an_pos_navaja" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_pos_navaja" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted">Otro</label><input type="text" class="form-control"></div>
                            </div>
                        </fieldset>

                        <fieldset class="border p-3 mb-4 rounded bg-white">
                            <legend class="w-auto px-2 text-info" style="font-size: 1.05rem; font-weight: bold;">Procedimientos de Vía y Canalización</legend>
                            <h6 class="text-secondary mt-2 mb-3 border-bottom pb-1">Canalización</h6>
                            <div class="form-row">
                                <div class="form-group col-md-1"><label class="text-muted">Cat</label><input type="number" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">Mano</label><select class="form-control"><option>Derecho</option><option>Izquierdo</option></select></div>
                                <div class="form-group col-md-2"><label class="text-muted">Antebrazo</label><select class="form-control"><option>Derecho</option><option>Izquierdo</option></select></div>
                                <div class="form-group col-md-2"><label class="text-muted">P. cubital</label><select class="form-control"><option>Derecho</option><option>Izquierdo</option></select></div>
                                <div class="form-group col-md-2"><label class="text-muted">Brazo</label><select class="form-control"><option>Derecho</option><option>Izquierdo</option></select></div>
                                <div class="form-group col-md-2"><label class="text-muted">Otro</label><input type="text" class="form-control"></div>
                                <div class="form-group col-md-1"><label class="text-muted">Intentos</label><input type="number" class="form-control"></div>
                            </div>
                            
                            <h6 class="text-secondary mt-3 mb-3 border-bottom pb-1">Inducción</h6>
                            <div class="form-row">
                                <div class="form-group col-md-4">
                                    <label class="text-muted">Tipo de Inducción</label>
                                    <select class="form-control" id="induccionTipo"><option value="">Seleccione</option><option value="inhalada">Inhalada</option><option value="iv">IV</option></select>
                                </div>
                            </div>
                            <div id="induccionInhalada" style="display: none;">
                                <div class="form-row">
                                    <div class="form-group col-md-4"><label class="text-muted">Opción Inhalada</label><select class="form-control"><option>Sevoflurano</option><option>Desflurano</option><option>Vaporizador</option></select></div>
                                    <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Confirmar</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_ind_inh" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_ind_inh" value="NO" class="mr-1"> NO</label></div></div>
                                </div>
                            </div>
                            <div id="induccionIV" style="display: none;">
                                <div class="form-row">
                                    <div class="form-group col-md-4">
                                        <label class="text-muted">Opción IV</label>
                                        <select class="form-control" id="induccionIVSelect"><option>Propofol</option><option>Midazolam</option><option>Fentanyl</option><option>Lidocaína</option><option value="otros">Otros</option></select>
                                    </div>
                                    <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Confirmar</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_ind_iv" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_ind_iv" value="NO" class="mr-1"> NO</label></div></div>
                                    <div class="form-group col-md-5" id="induccionIVOtro" style="display: none;"><label class="text-muted">Especifique otros</label><input type="text" class="form-control"></div>
                                </div>
                            </div>

                            <h6 class="text-secondary mt-3 mb-3 border-bottom pb-1">Vía Aérea e Intubación</h6>
                            <div class="form-row">
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Cánula binasal</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_via_binasal" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_via_binasal" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-3"><label class="text-muted d-block mb-1">Mascarilla c/ reserv.</label><div class="chequeo-si-no d-flex"><label class="chequeo-radio-label mr-3 mb-0"><input type="radio" name="an_via_mascarilla" value="SI" class="mr-1"> SÍ</label><label class="chequeo-radio-label mb-0"><input type="radio" name="an_via_mascarilla" value="NO" class="mr-1"> NO</label></div></div>
                                <div class="form-group col-md-2"><label class="text-muted">OT</label><input type="number" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">NT</label><input type="number" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">Fijado en</label><input type="number" class="form-control"></div>
                            </div>
                            <div class="form-row mt-2">
                                <div class="form-group col-md-4"><label class="text-muted">Método</label><select class="form-control"><option>Macintosh</option><option>Miller</option><option>Fibroscopia</option><option>Glidescope</option></select></div>
                                <div class="form-group col-md-4"><label class="text-muted">Estado</label><input type="text" class="form-control" placeholder="Corroborado"></div>
                                <div class="form-group col-md-4"><label class="text-muted">Intentos</label><input type="number" class="form-control" placeholder="Intentos"></div>
                            </div>

                            <h6 class="text-secondary mt-3 mb-3 border-bottom pb-1">Regional</h6>
                            <div class="form-row">
                                <div class="form-group col-md-2"><label class="text-muted">Epidural Nivel</label><input type="text" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">Raquídeo Nivel</label><input type="text" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">Bloq. Nerv.</label><input type="text" class="form-control"></div>
                                <div class="form-group col-md-2"><label class="text-muted">+Est. Nerv.</label><input type="text" class="form-control"></div>
                                <div class="form-group col-md-4"><label class="text-muted">Otros</label><input type="text" class="form-control"></div>
                            </div>
                        </fieldset>

                        <hr>
                        <div class="d-flex justify-content-between mt-3">
                            <button type="button" class="btn btn-outline-secondary px-4" onclick="showAnestesiaStep(1)">Anterior</button>
                            <button type="button" class="btn btn-primary px-4" onclick="showAnestesiaStep(3)">Siguiente</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="anestesia-step-3" style="display: none;">
                <div class="main-card mb-3 card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-muted small font-weight-bold">Paso 3 de 6</span>
                            <span class="text-primary small">Cuadrícula de Medicamentos</span>
                        </div>
                        <div class="progress mb-4" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 50%;" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

                        <h5 class="card-title text-primary mb-4">Tercera Sección</h5>
                        <div class="table-responsive shadow-sm rounded">
                            <table class="table table-bordered table-hover table-sm mb-0" style="font-size: 0.85rem;">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 150px; vertical-align: middle;">Item</th>
                                        <th class="text-center">1</th><th class="text-center">2</th><th class="text-center">3</th><th class="text-center">4</th><th class="text-center">5</th><th class="text-center">6</th><th class="text-center">7</th><th class="text-center">8</th><th class="text-center">9</th>
                                        <th class="text-center" style="width: 200px;">Notas</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="bg-light">
                                        <td class="font-weight-bold text-muted">Hora</td>
                                        @for (int i = 0; i < 9; i++) { <td><input type="time" class="form-control form-control-sm border-0 bg-transparent text-center"></td> }
                                        <td><input type="text" class="form-control form-control-sm border-0 bg-transparent" placeholder="Nota general de hora"></td>
                                    </tr>
                                    @{
                                        var items = new[] { "Sevoflurano", "Desflurano", "Propofol", "Midazolam", "Fentanyl", "Atracurio", "Vecuronio", "Succinilcolina", "Agente inhalado", "Relajante N.M.", "Ketamina", "Dexmedetomidina", "Antibióticos", "Analgésico", "Anestésico local", "Otros" };
                                        foreach (var item in items)
                                        {
                                            <tr>
                                                <td class="text-secondary">@item</td>
                                                @for (int i = 0; i < 9; i++) { <td><input type="text" class="form-control form-control-sm border-0 text-center"></td> }
                                                <td class="col-3"><input type="text" class="form-control form-control-sm border-0" placeholder="Añadir nota..."></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                        <hr class="mt-4">
                        <div class="d-flex justify-content-between mt-3">
                            <button type="button" class="btn btn-outline-secondary px-4" onclick="showAnestesiaStep(2)">Anterior</button>
                            <button type="button" class="btn btn-primary px-4" onclick="showAnestesiaStep(4)">Siguiente</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="anestesia-step-4" style="display: none;">
                <div class="main-card mb-3 card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-end mb-2">
                            <span class="text-muted small font-weight-bold">Paso 4 de 6</span>
                            <span class="text-primary small">Ingesta y Pérdidas</span>
                        </div>
                        <div class="progress mb-4" style="height: 6px;">
                            <div class="progress-bar bg-primary" role="progressbar" style="width: 66%;" aria-valuenow="66" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>

