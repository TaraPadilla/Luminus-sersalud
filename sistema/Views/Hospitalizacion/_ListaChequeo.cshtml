@model sistema.Models.HospitalizacionDetallesViewModel
<div class="tab-pane tabs-animation fade" id="tab-content-chequeo" role="tabpanel">
    <div class="form-row">
        <div class="col-md-12">
            <div class="main-card mb-3 nota-clinica-card">

                <div class="nota-header nota-header-chequeo">
                    <div class="d-flex align-items-center">
                        <div class="nota-header-icon nota-header-icon-chequeo">
                            <i class="fas fa-clipboard-check"></i>
                        </div>
                        <div>
                            <h5 class="nota-header-title">Lista de Chequeo Quir&uacute;rgica</h5>
                            <p class="nota-header-subtitle">Lista de chequeo WHO — Fase I (Ingreso) · Fase II (Pausa) · Fase III (Salida) · Fase IV (Recuperaci&oacute;n)</p>
                        </div>
                    </div>
                    @if(!User.IsInRole("Medico Externo")){
                    <div>
                        <button type="button" class="btn btn-nota-primary btn-nota-primary-chequeo" data-hosp-accion="verModalAgregarChequeo">
                            <i class="fas fa-plus mr-1"></i> Nueva Lista de Chequeo
                        </button>
                    </div>
                    }
                </div>

                <div class="nota-card-body">
                    <div class="table-responsive">
                        <table class="table tabla-notas">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Procedimiento / Cirugía</th>
                                    <th class="text-center">Etapas completadas</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-listas-chequeo">
                                <tr>
                                    <td colspan="4">
                                        <div class="nota-empty-state">
                                            <i class="fas fa-clipboard-check d-block"></i>
                                            <p>No hay listas de chequeo registradas</p>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="nota-footer">
                    <span><i class="fas fa-clipboard-check mr-1" style="color:var(--chequeo-color)"></i> Registros: <strong id="listas-chequeo-total">0</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>
