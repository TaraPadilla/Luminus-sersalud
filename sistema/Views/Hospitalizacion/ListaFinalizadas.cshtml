@using Database.Shared.Enumeraciones
@using sistema.Models
@model List<HospitalizacionHabitacionViewModel>

    
@{
    ViewData["Title"] = "Hospitalizacion - Lista";
}



<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="col-md-12 text-center">
            <h5><b>Hospitalización - Lista</b></h5>
        </div>
    </div>
</div>


<div class="main-card mb-3 card">
    <div class="card-body">
        <div id="">
            <div class="form-row">
                <div class="col-md-12 text-primary" style="display:none" id="texto-cargando-hospitalizaciones">
                    Cargando hospitalizaciones...
                </div>
                <div class="col-md-12 text-danger" style="display:none" id="texto-error-consultar-hospitalizaciones">
                    Error de conexion.
                    <a href="#" data-bind="click:consultarHospitalizaciones">Reintentar</a>
                </div>
                <div class="col-md-12">
                    <div class="main-card mb-3 card">
                        <div class="card-body">
                            <table id="tabla-hospitalizaciones">
                                <thead>
                                    <tr>
                                        <th>Id</th>
                                        <th>Habitacion</th>
                                        <th>Paciente</th>
                                        <th>Consulta</th>
                                        <th>Estado</th>
                                        <th>Periodo</th>
                                        <th>Especialidad</th>
                                        <th>Ver</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!--ko foreach:hospitalizaciones-->
                                    <tr>
                                        <td data-bind="text:HospitalizacionId"></td>
                                        <td data-bind="text:HabitacionNumeroNombre"></td>
                                        <td data-bind="text:PacienteNombre"></td>
                                        <td>
                                            <!--ko if:ConsultaId==null-->
                                            <span>
                                                N/A
                                            </span>
                                            <!--/ko-->
                                            <!--ko ifnot:ConsultaId==null-->
                                            <a href="#" target="_blank" 
                                            data-bind="attr:{href:'/Consultas/Informacion?id='+ConsultaId}" 
                                            class="btn btn-warning">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <!--/ko-->
                                        </td>
                                        <td>
                                            <!--ko if:HospitalizacionEstado == 'Finalizada'-->
                                            <span class="badge badge-success" data-bind="text:HospitalizacionEstado"></span>
                                            <!--/ko-->
                                            <!--ko if:HospitalizacionEstado == 'En curso'-->
                                            <span class="badge badge-danger" data-bind="text:HospitalizacionEstado"></span>
                                            <!--/ko-->
                                        </td>
                                        <td data-bind="text:Periodo"></td>
                                        <td data-bind="text:EspecialidadNombre"></td>
                                        <td>
                                            <a href="#" class="btn btn-primary" data-bind="attr:{href:'/Hospitalizacion/Detalles?hospitalizacionId='+HospitalizacionId}">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                    <!--/ko-->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/ViewModelKo/HospitalizacionListaVM.js"></script>
}
