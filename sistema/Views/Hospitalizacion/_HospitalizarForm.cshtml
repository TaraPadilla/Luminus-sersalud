<div class="form-row paso" id="paso-especialidad">
    <div class="col-md-12">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <div class="form-row">
                    <div class="col-md-12">
                        <h5><b>1. Seleccionar especialidad</b></h5>
                        <hr />
                    </div>

                    <div class="col-md-12" id="texto-validacion-especialidad">
                        <label class="text-danger">Debe seleccionar una especialidad</label>
                    </div>

                    <div class="col-md-12">
                        <select class="select2bs4 form-control" data-bind="
                            options: especialidades,
                            optionsText: 'NombreEspecialidad',
                            optionsValue: 'Id',
                            value: especialidadId,
                            event: {
                            change: function () {
                            var id = especialidadId();
                            var sel = null;

                            // Buscar objeto seleccionado para mantener especialidadSeleccionada y nombre
                            ko.utils.arrayForEach(especialidades(), function (e) {
                            if (e && e.Id == id) { sel = e; }
                            });

                            especialidadSeleccionada(sel);
                            especialidadNombre(sel ? sel.NombreEspecialidad : 'Medicina General');

                            // Regla: si queda vacío/0, forzar MG
                            if (!id || id == 0) {
                            especialidadId(1);
                            especialidadNombre('Medicina General');
                            especialidadSeleccionada(null);
                            }
                            }
                            }">
                        </select>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="col-md-12 text-right">
        <button class="btn btn-primary" data-bind="click:pasoTarifas">
            Siguiente <i class="fas fa-arrow-alt-circle-right"></i>
        </button>
    </div>

</div>


