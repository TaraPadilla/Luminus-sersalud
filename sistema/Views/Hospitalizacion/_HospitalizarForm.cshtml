                                                                    <p class="firma-hint text-muted" id="hint-paciente"
                                                                       style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
                                                                              font-size:0.8rem;pointer-events:none;user-select:none;white-space:nowrap;">
                                                                        Firma aquí
