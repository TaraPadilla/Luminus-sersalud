</div>

                                                                <script>

                                                                        // ── Variables globales (accesibles desde funciones globales) ──
                                                                        var urlCuestionario = null;
                                                                        var urlListaChequeo = null;
                                                                        var habitacionId    = '@habitacionId';
                                                                        var pacienteId      = '@Model.PacienteId';

                                                                       
                                                                        function abrirVentanaHija(tipo) {
                                                                            var url = tipo === 'cuestionario' ? urlCuestionario : urlListaChequeo;
                                                                            if (!url) {
                                                                                alert('Primero debe seleccionar un paciente.');
                                                                                return;
                                                                            }
                                                                            window.open(url, '_blank');
                                                                        }

                                                                        document.addEventListener("DOMContentLoaded", function () {
                                                                            $(".paso").hide();
                                                                            $("#paso-especialidad").show();
                                                                            actualizarVisualizacionStepper(1);
                                                                            // habitacionId y pacienteId ya son globales arriba
                                                                            var consultaId = '@consultaId';
                                                                            var citaId     = '@Model.CitaId';

                                                                            // Iniciar el intervalo para calcular las URLs cuando pacienteId esté disponible
                                                                            var interval = setInterval(function () {
                                                                                if (!pacienteId || pacienteId === "0") {
                                                                                    pacienteId = document.querySelector('[data-bind="value:pacienteId"]').value;
                                                                                }

                                                                                if (pacienteId && pacienteId !== "0") {
                                                                                    var newHref = '@Url.Action("CrearFormConsentimientoHospi", "Pacientes", new { HabitacionId = "__habitacionId__", PacienteId = "__pacienteId__", ConsultaId = "__consultaId__", CitaId = "__citaId__" })'
                                                                                        .replace('__habitacionId__', habitacionId)
                                                                                        .replace('__pacienteId__', pacienteId)
                                                                                        .replace('__consultaId__', consultaId)
                                                                                        .replace('__citaId__', citaId)
                                                                                        .replace(/&amp;/g, '&');

                                                                                    urlCuestionario = '@Url.Action("CargarCuestionarioPreAnestesico", "Hospitalizacion", new { HabitacionId = "__habitacionId__", PacienteId = "__pacienteId__", CitaId = "__citaId__" })'
                                                                                        .replace('__habitacionId__', habitacionId)
                                                                                        .replace('__pacienteId__', pacienteId)
                                                                                        .replace('__citaId__', citaId)
                                                                                        .replace(/&amp;/g, '&');

                                                                                    urlListaChequeo = '@Url.Action("CargarListaChequeo", "Hospitalizacion", new { HabitacionId = "__habitacionId__", PacienteId = "__pacienteId__", CitaId = "__citaId__" })'
                                                                                        .replace('__habitacionId__', habitacionId)
                                                                                        .replace('__pacienteId__', pacienteId)
                                                                                        .replace('__citaId__', citaId)
                                                                                        .replace(/&amp;/g, '&');

                                                                                    // El consentimiento sigue con href directo (no necesita window.opener)
                                                                                    document.getElementById('irAhora').href = newHref;

                                                                                    clearInterval(interval);
                                                                                }
                                                                            }, 500);

                                                                            function consultarExistenciaConsentimiento() {
                                                                                var pidActual = (typeof hospitalizarVm !== 'undefined' && hospitalizarVm.pacienteId && hospitalizarVm.pacienteId())
                                                                                    ? hospitalizarVm.pacienteId()
                                                                                    : pacienteId;

                                                                                if (!pidActual || pidActual === "0" || pidActual === 0) return;

                                                                                $.ajax({
                                                                                    url: "/ConsentimientoHospi/ObtenerPorPacienteYHabitacion",
                                                                                    method: "GET",
                                                                                    data: {
                                                                                        pacienteId: parseInt(pidActual),
                                                                                        habitacionId: parseInt(habitacionId)
                                                                                    },
                                                                                    success: function (dataResult) {
                                                                                        let data = JSON.parse(dataResult);
                                                                                        if (data.exitoso) {
                                                                                            $('#mensajeConsulta').show();
                                                                                            $('#botonImprimir').show();
                                                                                            $('#botonImprimir2').show();

                                                                                            var resultado = data.resultado;
                                                                                            if (resultado) {
                                                                                                var urlFirmaPac  = resultado.URLFirmaPaciente    || resultado.urlFirmaPaciente    || '';
                                                                                                var urlFirmaResp = resultado.URLFirmaResponsable || resultado.urlFirmaResponsable || '';

                                                                                                if (urlFirmaPac && !hospitalizarVm.urlFirmaPaciente()) {
                                                                                                    hospitalizarVm.urlFirmaPaciente(urlFirmaPac);
                                                                                                    hospitalizarVm.firmaPacienteBase64(urlFirmaPac);
                                                                                                    // Mostrar badge y preview en el paso de firmas
                                                                                                    var estadoPac = document.getElementById('estado-firma-paciente');
                                                                                                    var previewPac = document.getElementById('preview-firma-guardada-paciente');
                                                                                                    if (estadoPac) estadoPac.style.display = '';
                                                                                                    if (previewPac) previewPac.src = urlFirmaPac;
                                                                                                    // Ocultar el hint del canvas
                                                                                                    var hintPac = document.getElementById('hint-paciente');
                                                                                                    if (hintPac) hintPac.style.display = 'none';
                                                                                                    _firmaState['paciente'].firmada = true;
                                                                                                }

                                                                                                if (urlFirmaResp && !hospitalizarVm.urlFirmaResponsable()) {
                                                                                                    hospitalizarVm.urlFirmaResponsable(urlFirmaResp);
                                                                                                    hospitalizarVm.firmaResponsableBase64(urlFirmaResp);
                                                                                                    var estadoResp = document.getElementById('estado-firma-responsable');
                                                                                                    var previewResp = document.getElementById('preview-firma-guardada-responsable');
                                                                                                    if (estadoResp) estadoResp.style.display = '';
                                                                                                    if (previewResp) previewResp.src = urlFirmaResp;
                                                                                                    var hintResp = document.getElementById('hint-responsable');
                                                                                                    if (hintResp) hintResp.style.display = 'none';
                                                                                                    _firmaState['responsable'].firmada = true;
                                                                                                }
                                                                                            }

                                                                                            // Evaluar estado del botón Finalizar con los datos ya cargados
                                                                                            actualizarEstadoBtnFinalizar(true);

                                                                                            if (hospitalizarVm && hospitalizarVm.listaChequeo) {
                                                                                                hospitalizarVm.listaChequeo.ci_consentimiento('SI');
                                                                                            }
                                                                                        } else {
                                                                                            $('#mensajeConsulta').hide();
                                                                                            $('#botonImprimir').hide();
                                                                                            $('#botonImprimir2').hide();
                                                                                            actualizarEstadoBtnFinalizar(false);
                                                                                        }
                                                                                    },
                                                                                    error: function (dataError) {
                                                                                        console.log('Error consultando consentimiento:', dataError);
                                                                                    }
                                                                                });
                                                                            }

                                                                           
                                                                            function actualizarEstadoBtnFinalizar(tieneConsentimiento) {
                                                                                var tieneFirmaPaciente    = !!(hospitalizarVm && hospitalizarVm.urlFirmaPaciente && hospitalizarVm.urlFirmaPaciente());
                                                                                var tieneFirmaResponsable = !!(hospitalizarVm && hospitalizarVm.urlFirmaResponsable && hospitalizarVm.urlFirmaResponsable());

                                                                                $('#mensajeFirmaPaciente').toggle(!tieneFirmaPaciente);
                                                                                $('#mensajeFirmaResponsable').toggle(!tieneFirmaResponsable);

                                                                                if (tieneConsentimiento && tieneFirmaPaciente && tieneFirmaResponsable) {
                                                                                    $('#btnFinalizar').show();
                                                                                    $('#mensajeConsentimiento').hide();
                                                                                } else {
                                                                                    $('#btnFinalizar').hide();
                                                                                    $('#mensajeConsentimiento').toggle(!tieneConsentimiento);
                                                                                }
                                                                            }

                                                                            function consultarExistenciaCuestionario() {
                                                                                // Logica para verificar si el cuestionario ya existe
                                                                            }

                                                                            setInterval(function () {
                                                                                consultarExistenciaConsentimiento();
                                                                            }, 3000)

                                                                            // Asignamos el manejador de eventos al botón de imprimir
                                                                            $('#botonImprimir').on('click', function () {
                                                                                generarPDFConsentimiento(parseInt(pacienteId), parseInt(habitacionId));
                                                                            });

                                                                            $('#botonImprimir2').on('click', function () {
                                                                                generarPDFConsentimiento(parseInt(pacienteId), parseInt(habitacionId));
                                                                            });

                                                                            function generarPDFConsentimiento(idPaciente, idHabitacion, idHospi = null) {
                                                                                // citaId viene de la variable global del script (query param de la URL)
                                                                                const idCita = (typeof citaId !== 'undefined' && citaId && citaId !== '0') ? citaId : null;
                                                                                const url = `/CrearPDF/GenerarPDFConsentimientoHospi?idPaciente=${idPaciente}&idHabitacion=${idHabitacion}&idHospi=${idHospi}&citaId=${idCita}`;
                                                                                window.open(url, "_blank");
                                                                            }
                                                                        });

                                                                        // ── CANVAS DE FIRMAS — PASO 8 ────────────────────────────────
                                                                        var _firmaState = {
                                                                            paciente:    { lineas: [], drawing: false, firmada: false },
                                                                            responsable: { lineas: [], drawing: false, firmada: false }
                                                                        };

                                                                        // Inicializa ambos canvas al entrar al paso 8
                                                                        function inicializarCanvases() {
                                                                            setupCanvas('paciente');
                                                                            setupCanvas('responsable');
                                                                        }

                                                                        function setupCanvas(tipo) {
                                                                            var canvasId = tipo === 'paciente' ? 'canvasFirmaPaciente' : 'canvasFirmaResponsable';
                                                                            var canvas   = document.getElementById(canvasId);
                                                                            if (!canvas) return;

                                                                            var state = _firmaState[tipo];

                                                                            var wrapper = canvas.parentElement;
                                                                            canvas.width  = wrapper.offsetWidth  || 400;
                                                                            canvas.height = 180;

                                                                            var ctx = canvas.getContext('2d');
                                                                            ctx.strokeStyle = '#1a1a2e';
                                                                            ctx.lineWidth   = 2.5;
                                                                            ctx.lineJoin    = 'round';
                                                                            ctx.lineCap     = 'round';
                                                                            ctx.fillStyle   = '#f9fafb';
                                                                            ctx.fillRect(0, 0, canvas.width, canvas.height);

                                                                            _redibujarLineas(tipo);

                                                                            function getPos(e) {
                                                                                var rect   = canvas.getBoundingClientRect();
                                                                                var scaleX = canvas.width  / rect.width;
                                                                                var scaleY = canvas.height / rect.height;
                                                                                var clientX = e.touches ? e.touches[0].clientX : e.clientX;
                                                                                var clientY = e.touches ? e.touches[0].clientY : e.clientY;
                                                                                return {
                                                                                    x: (clientX - rect.left) * scaleX,
                                                                                    y: (clientY - rect.top)  * scaleY
                                                                                };
                                                                            }

                                                                            function onStart(e) {
                                                                                e.preventDefault();
                                                                                state.drawing = true;
                                                                                var p = getPos(e);
                                                                                state.lineas.push([{ x: p.x, y: p.y }]);
                                                                                // Ocultar hint la primera vez que se dibuja
                                                                                var hint = document.getElementById('hint-' + tipo);
                                                                                if (hint) hint.style.display = 'none';
                                                                            }

                                                                            function onMove(e) {
                                                                                if (!state.drawing) return;
                                                                                e.preventDefault();
                                                                                var p = getPos(e);
                                                                                state.lineas[state.lineas.length - 1].push({ x: p.x, y: p.y });
                                                                                _redibujarLineas(tipo);
                                                                            }

                                                                            function onEnd(e) {
                                                                                state.drawing = false;
                                                                            }

                                                                            // Limpiar listeners previos clonando el nodo
                                                                            var nuevoCanvas = canvas.cloneNode(true);
                                                                            canvas.parentNode.replaceChild(nuevoCanvas, canvas);
                                                                            canvas = nuevoCanvas;

                                                                            // Restaurar ctx con el nuevo nodo
                                                                            ctx = canvas.getContext('2d');
                                                                            ctx.fillStyle = '#f9fafb';
                                                                            ctx.fillRect(0, 0, canvas.width, canvas.height);
                                                                            ctx.strokeStyle = '#1a1a2e';
                                                                            ctx.lineWidth   = 2.5;
                                                                            ctx.lineJoin    = 'round';
                                                                            ctx.lineCap     = 'round';
                                                                            _redibujarLineas(tipo);

                                                                            // Mouse
                                                                            canvas.addEventListener('mousedown',  onStart, { passive: false });
                                                                            canvas.addEventListener('mousemove',  onMove,  { passive: false });
                                                                            canvas.addEventListener('mouseup',    onEnd);
                                                                            canvas.addEventListener('mouseleave', onEnd);

                                                                            // Touch (permite dibujar sin hacer scroll)
                                                                            canvas.addEventListener('touchstart', onStart, { passive: false });
                                                                            canvas.addEventListener('touchmove',  onMove,  { passive: false });
                                                                            canvas.addEventListener('touchend',   onEnd,   { passive: false });
                                                                        }

                                                                        function _redibujarLineas(tipo) {
                                                                            var canvasId = tipo === 'paciente' ? 'canvasFirmaPaciente' : 'canvasFirmaResponsable';
                                                                            var canvas   = document.getElementById(canvasId);
                                                                            if (!canvas) return;
                                                                            var ctx    = canvas.getContext('2d');
                                                                            var lineas = _firmaState[tipo].lineas;

                                                                            ctx.clearRect(0, 0, canvas.width, canvas.height);
                                                                            ctx.fillStyle = '#f9fafb';
                                                                            ctx.fillRect(0, 0, canvas.width, canvas.height);
                                                                            ctx.strokeStyle = '#1a1a2e';
                                                                            ctx.lineWidth   = 2.5;
                                                                            ctx.lineJoin    = 'round';
                                                                            ctx.lineCap     = 'round';

                                                                            lineas.forEach(function(seg) {
                                                                                if (seg.length < 1) return;
                                                                                ctx.beginPath();
                                                                                ctx.moveTo(seg[0].x, seg[0].y);
                                                                                seg.forEach(function(p) { ctx.lineTo(p.x, p.y); });
                                                                                ctx.stroke();
                                                                            });
                                                                        }

                                                                        // Limpia el canvas Y el estado de trazos
                                                                        function limpiarFirmaCanvas(tipo) {
                                                                            var canvasId = tipo === 'paciente' ? 'canvasFirmaPaciente' : 'canvasFirmaResponsable';
                                                                            var canvas   = document.getElementById(canvasId);
                                                                            if (!canvas) return;
                                                                            _firmaState[tipo].lineas  = [];
                                                                            _firmaState[tipo].firmada = false;
                                                                            var ctx = canvas.getContext('2d');
                                                                            ctx.clearRect(0, 0, canvas.width, canvas.height);
                                                                            ctx.fillStyle = '#f9fafb';
                                                                            ctx.fillRect(0, 0, canvas.width, canvas.height);
                                                                            // Mostrar hint de nuevo
                                                                            var hint = document.getElementById('hint-' + tipo);
                                                                            if (hint) hint.style.display = '';
                                                                        }

                                                                        // Sube la firma al servidor y guarda la URL en el ViewModel
                                                                        function subirFirmaCanvas(tipo) {
                                                                            var canvasId = tipo === 'paciente' ? 'canvasFirmaPaciente' : 'canvasFirmaResponsable';
                                                                            var canvas   = document.getElementById(canvasId);
                                                                            if (!canvas) return;

                                                                            if (_firmaState[tipo].lineas.length === 0) {
                                                                                alert('Por favor dibuje la firma antes de confirmar.');
                                                                                return;
                                                                            }

                                                                            var dataBase64 = canvas.toDataURL('image/png');
                                                                            showLoading();

                                                                            $.ajax({
                                                                                method: 'POST',
                                                                                url: '/Files/SubirArchivo',
                                                                                data: { base64Archivo: dataBase64, extension: '.png' },
                                                                                success: function(data) {
                                                                                    if (!data.exitoso) {
                                                                                        hideLoading();
                                                                                        alert(data.mensaje || 'Error al subir la firma');
                                                                                        return;
                                                                                    }

                                                                                    var url = data.url;

                                                                                    // 1. Guardar en el ViewModel (para enviarlo al finalizar)
                                                                                    if (tipo === 'paciente') {
                                                                                        hospitalizarVm.firmaPacienteBase64(dataBase64);
                                                                                        hospitalizarVm.urlFirmaPaciente(url);
                                                                                    } else {
                                                                                        hospitalizarVm.firmaResponsableBase64(dataBase64);
                                                                                        hospitalizarVm.urlFirmaResponsable(url);
                                                                                    }

                                                                                    // 2. Persistir en BD en el ConsentimientoHospi existente
                                                                                    var pidActual = (hospitalizarVm.pacienteId && hospitalizarVm.pacienteId())
                                                                                        ? hospitalizarVm.pacienteId()
                                                                                        : pacienteId;

                                                                                    var payload = {
                                                                                        pacienteId:   parseInt(pidActual),
                                                                                        habitacionId: parseInt(habitacionId)
                                                                                    };
                                                                                    if (tipo === 'paciente') {
                                                                                        payload.urlFirmaPaciente = url;
                                                                                    } else {
                                                                                        payload.urlFirmaResponsable = url;
                                                                                    }

                                                                                    $.ajax({
                                                                                        method: 'POST',
                                                                                        url: '/ConsentimientoHospi/ActualizarFirmas',
                                                                                        data: payload,
                                                                                        success: function(result) {
                                                                                            hideLoading();
                                                                                            var res = typeof result === 'string' ? JSON.parse(result) : result;
                                                                                            if (res.exitoso) {
                                                                                                _firmaState[tipo].firmada = true;
                                                                                                var estado = document.getElementById('estado-firma-' + tipo);
                                                                                                if (estado) {
                                                                                                    var previewGuardada = document.getElementById('preview-firma-guardada-' + tipo);
                                                                                                    if (previewGuardada) previewGuardada.src = dataBase64;
                                                                                                    estado.style.display = '';
                                                                                                }
                                                                                                mensajeEmergente('Firma guardada correctamente');
                                                                                            } else {
                                                                                                alert(res.mensaje || 'La firma se subió pero no se pudo guardar en el consentimiento');
                                                                                            }
                                                                                        },
                                                                                        error: function() {
                                                                                            hideLoading();
                                                                                            alert('Error al guardar la firma en el consentimiento');
                                                                                        }
                                                                                    });
                                                                                },
                                                                                error: function() {
                                                                                    hideLoading();
                                                                                    alert('Error de conexión al subir la firma');
                                                                                }
                                                                            });
                                                                        }

                                                                        // Elimina una firma ya guardada
                                                                        function eliminarFirmaGuardada(tipo) {
                                                                            if (tipo === 'paciente') {
                                                                                hospitalizarVm.firmaPacienteBase64(null);
                                                                                hospitalizarVm.urlFirmaPaciente('');
                                                                            } else {
                                                                                hospitalizarVm.firmaResponsableBase64(null);
                                                                                hospitalizarVm.urlFirmaResponsable('');
                                                                            }
                                                                            _firmaState[tipo].firmada = false;
                                                                            var estado = document.getElementById('estado-firma-' + tipo);
                                                                            if (estado) estado.style.display = 'none';
                                                                            limpiarFirmaCanvas(tipo);
                                                                        }

                                                                        function switchTabFirma(tipo, modo) {
                                                                            var panelCanvas  = document.getElementById('panel-canvas-'  + tipo);
                                                                            var panelArchivo = document.getElementById('panel-archivo-' + tipo);
                                                                            if (modo === 'canvas') {
                                                                                panelCanvas.classList.remove('d-none');
                                                                                panelArchivo.classList.add('d-none');
                                                                                // Re-inicializar canvas al volver a este panel
                                                                                setTimeout(function() { setupCanvas(tipo); }, 50);
                                                                            } else {
                                                                                panelCanvas.classList.add('d-none');
                                                                                panelArchivo.classList.remove('d-none');
                                                                            }
                                                                        }

                                                                        window.previsualizarFirma = function (input, imgId) {
                                                                            var file = input.files[0];
                                                                            if (!file) return;
                                                                            var reader = new FileReader();
                                                                            reader.onload = function (e) {
                                                                                var img = document.getElementById(imgId);
                                                                                img.src = e.target.result;
                                                                                img.style.display = 'block';
                                                                                if (imgId === 'prev-paciente') {
                                                                                    hospitalizarVm.firmaPacienteBase64(e.target.result);
                                                                                } else if (imgId === 'prev-responsable') {
                                                                                    hospitalizarVm.firmaResponsableBase64(e.target.result);
                                                                                }
                                                                            };
                                                                            reader.readAsDataURL(file);
                                                                        };
                                                                </script>


