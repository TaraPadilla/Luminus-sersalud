                                                                        Eliminar
                                                                    </a>
                                                                    <img id="preview-firma-guardada-responsable"
                                                                         style="display:block; max-height:60px; margin-top:4px; border:1px solid #e2e8f0; border-radius:4px;" />
                                                                </div>
                                                            </div>

                                                            <div id="panel-archivo-responsable" class="d-none">
                                                                <input type="file" class="form-control form-control-sm" accept="image/*"
                                                                       onchange="previsualizarFirma(this, 'prev-responsable')" />
                                                                <img id="prev-responsable" style="max-height:80px; display:none; margin-top:6px;
