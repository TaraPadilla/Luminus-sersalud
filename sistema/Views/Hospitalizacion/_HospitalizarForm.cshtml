<style>
    .select2-container {
        width: 100% !important;
    }




    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        margin-bottom: 30px;
        padding: 10px 0;
        position: relative;
    }

    .stepper-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        flex: 1;
        @* z-index: 2; *@
    }

    .stepper-item::before {
        position: absolute;
        content: "";
        border-bottom: 3px solid #e0e0e0;
        width: 100%;
        top: 20px;
        left: -50%;
        z-index: 1;
    }

    .stepper-item:first-child::before {
        content: none;
    }

    .step-counter {
        position: relative;
        z-index: 5;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #e0e0e0;
        color: #666;
        font-weight: bold;
        border: 2px solid #fff;
        transition: all 0.3s ease;
    }

    .stepper-item.active .step-counter {
        background-color: #3f6ad8;
        color: #fff;
        transform: scale(1.1);
        box-shadow: 0 0 10px rgba(63, 106, 216, 0.4);
    }

    .stepper-item.completed .step-counter {
        background-color: #3ac47d;
        color: #fff;
    }

    .stepper-item.completed::before {
        border-bottom-color: #3ac47d;
    }

    .step-name {
        color: #999;
        font-size: 0.85rem;
        margin-top: 8px;
        text-align: center;
        font-weight: 500;
    }

    .stepper-item.active .step-name {
        color: #3f6ad8;
        font-weight: bold;
    }

    @@media (max-width: 768px) {
        .step-name {
            display: none;
        }

        .step-counter {
            width: 30px;
            height: 30px;
            font-size: 12px;
        }

        .stepper-item::before {
            top: 15px;
        }
    }
</style>

