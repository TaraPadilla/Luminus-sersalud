                        <b>DPI del paciente</b><br />
                        <span data-bind="text:pacienteDpi"></span>
                    </div>
                    <div class="col-md-4">
                        <b>Telefono del paciente</b><br />
                        <span data-bind="text:pacienteTelefono"></span>
                    </div>
                    <div class="col-md-4">
                        <b>Fecha de nacimiento</b><br />
                        <span data-bind="text:pacienteFechaNacimiento"></span>
