                                                                     style="background:#f9fafb; position:relative; touch-action:none;">
                                                                    <canvas id="canvasFirmaResponsable"
                                                                            style="display:block; width:100%; cursor:crosshair; touch-action:none;"></canvas>
                                                                    <p class="firma-hint text-muted" id="hint-responsable"
                                                                       style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
                                                                              font-size:0.8rem;pointer-events:none;user-select:none;white-space:nowrap;">
                                                                        Firma aquí
                                                                    </p>
                                                                </div>
                                                                <div class="d-flex justify-content-between align-items-center mt-1">
                                                                    <button type="button" class="btn btn-link btn-sm text-danger p-0"
                                                                            onclick="limpiarFirmaCanvas('responsable')">
                                                                        <i class="fas fa-trash-alt mr-1"></i> Limpiar
                                                                    </button>
                                                                    <button type="button" class="btn btn-success btn-sm"
                                                                            onclick="subirFirmaCanvas('responsable')">
                                                                        <i class="fas fa-check mr-1"></i> Confirmar firma
                                                                    </button>
