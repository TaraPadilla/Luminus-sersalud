                        <b>Tarifa</b><br />
                        <span data-bind="text: tarifaSeleccionada() ? tarifaSeleccionada().NombreTarifa + ' - Q ' + tarifaSeleccionada().ValorTarifa : 'No seleccionada'"></span>
                    </div>
