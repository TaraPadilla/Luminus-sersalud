    <div class="col-md-12">
        <div class="card">
            <div class="card-body">
                <div class="form-row">
                    <div class="col-md-12">
                        <h5><b>Consentimiento</b></h5>
                        <a class="btn btn-danger" target="_blank" style="color: white; display:none;" id="botonImprimir2">
                            <i class="fas fa-print"></i>&nbsp; Imprimir Consentimiento
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-12 text-right mt-3">
        <button class="btn btn-warning" data-bind="click:volverFirmas">
            <i class="fas fa-arrow-alt-circle-left"></i> Anterior
        </button>
        <!-- Mensaje si no hay consentimiento -->
        <p id="mensajeConsentimiento" class="text-danger" style="display: none;">
            El formulario de consentimiento es obligatorio antes de finalizar la hospitalización.
        </p>
        <!-- Mensajes si faltan firmas -->
        <p id="mensajeFirmaPaciente" class="text-danger" style="display: none;">
            <i class="fas fa-exclamation-triangle mr-1"></i>
            La firma del paciente es obligatoria. Regrese al paso 8 y confirme la firma.
        </p>
        <p id="mensajeFirmaResponsable" class="text-danger" style="display: none;">
            <i class="fas fa-exclamation-triangle mr-1"></i>
            La firma del responsable de cuenta es obligatoria. Regrese al paso 8 y confirme la firma.
        </p>
        <!-- Botón Finalizar: se muestra solo cuando existe consentimiento -->
        <button id="btnFinalizar" class="btn btn-primary" data-bind="click:registrarHospitalizacion" style="display: none;">
            Finalizar
        </button>
