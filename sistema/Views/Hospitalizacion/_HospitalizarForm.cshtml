                                                                <input type="file" class="form-control form-control-sm" accept="image/*"
                                                                       onchange="previsualizarFirma(this, 'prev-paciente')" />
                                                                <img id="prev-paciente" style="max-height:80px; display:none; margin-top:6px;
                                                                     border:1px solid #e2e8f0; border-radius:4px;" />
