                                                        </div>

                                                        @* ── Firma Responsable ── *@
                                                        <div class="col-md-6 mb-3">
                                                            <h6><b>Firma del Responsable de Cuenta</b></h6>

                                                            <ul class="nav nav-pills mb-2" style="gap:5px;">
                                                                <li class="nav-item">
                                                                    <a class="nav-link active btn-sm" href="#"
                                                                       onclick="switchTabFirma('responsable','canvas'); return false;">
                                                                        <i class="fas fa-pen mr-1"></i> Dibujar
                                                                    </a>
                                                                </li>
