                                                                @* Estado de firma guardada *@
                                                                <div id="estado-firma-paciente" class="mt-2" style="display:none;">
                                                                    <span class="badge badge-success">
                                                                        <i class="fas fa-check-circle mr-1"></i> Firma guardada
                                                                    </span>
                                                                    <a href="#" class="btn btn-link btn-sm text-danger p-0 ml-2"
                                                                       onclick="eliminarFirmaGuardada('paciente'); return false;">
                                                                        Eliminar
                                                                    </a>
                                                                    <img id="preview-firma-guardada-paciente"
                                                                         style="display:block; max-height:60px; margin-top:4px; border:1px solid #e2e8f0; border-radius:4px;" />
                                                                </div>
