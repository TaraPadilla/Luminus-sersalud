@model sistema.Models.HospitalizacionDetallesViewModel
@{
    var usuarioAdmisiones = User.IsInRole("Admisiones");
} 
<div class="tab-pane tabs-animation fade " id="tab-content-pagos" role="tabpanel">
    <div class="form-row">
        <div class="col-md-12">
            <div class="main-card mb-3 card" style="border-radius: 10px">
                <div class="card-body">
                    <div class="form-row mb-3">
                        <div class="col-md-12 d-flex justify-content-between align-items-center">
                            <h6 class="mb-0"><b>Control de medicamentos e insumos</b></h6>
                            <button type="button" class="btn btn-outline-danger btn-sm"
                                    data-bind="click: verModalHistorialMedicamentos">
                                <i class="fas fa-pills mr-1"></i> Ver historial completo
                            </button>
                        </div>
                        <div class="col-md-12">
                            <hr class="mt-2 mb-2" />
                        </div>
                        <div class="col-md-12">
                            <span class="badge badge-warning mr-2" data-bind="text: 'Pendientes: ' + medicamentosPendientesPagos()"></span>
                            <span class="badge badge-success" data-bind="text: 'Aplicados: ' + medicamentosAplicadosPagos()"></span>
                        </div>
                        <div class="col-md-12 mt-2">
                            <div class="table-responsive">
                                <table class="table table-hover table-sm" style="font-size:0.85rem;">
                                    <thead>
                                        <tr>
                                            <th>Origen</th>
                                            <th>Medicamento / Insumo</th>
                                            <th>Indicaciones</th>
                                            <th>Estado</th>
                                            <th>Fecha programada</th>
                                            <th>Fecha aplicación</th>
                                        </tr>
                                    </thead>
                                    <tbody data-bind="foreach: resumenMedicamentosPagos">
                                        <tr>
                                            <td data-bind="text: Origen"></td>
                                            <td data-bind="text: Nombre"></td>
                                            <td data-bind="text: Indicaciones"></td>
                                            <td>
                                                <span class="badge"
                                                      data-bind="text: Aplicado ? 'APLICADO' : 'PENDIENTE',
                                                                 css: { 'badge-success': Aplicado, 'badge-warning': !Aplicado }"></span>
                                            </td>
                                            <td data-bind="text: FechaRegistro"></td>
                                            <td data-bind="text: FechaAplicacion"></td>
                                        </tr>
                                    </tbody>
                                    <tbody data-bind="visible: resumenMedicamentosPagos().length === 0">
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-3">
                                                Sin medicamentos o insumos registrados en esta hospitalización.
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="form-row">
        <div class="col-md-12">
            <div class="main-card mb-3 card" style="border-radius: 10px">
                <div class="card-body">
                    <div class="form-row">
                        <div class="col-md-12">
                            <h6><b>Dep&oacute;sitos</b></h6>
                            <hr />
                        </div>
                        @if (!Model.HospitalizacionFinalizada)
                        {
                            <div class="col-md-12 form-row">
                                <div class="col-md-12 form-row">
                                    <label><b>Agregar dep&oacute;sito:</b></label>
                                </div>
                                <div class="col-md-4">
                                    <label>Forma de pago</label>
                                    <select class="select2bs4 form-control"
                                            asp-for="@Model.FormaPagoId"
                                            asp-items="@Model.FormaPagoSelectListItems">
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="">Moneda</label>
                                    <select class="select2bs4 form-control"
                                            asp-for="@Model.MonedaId"
                                            asp-items="@Model.MonedaSelectListItems">
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label>Valor</label>
                                    <input class="form-control" data-bind="value:valorDepositoAgregar" />
                                </div>
                                <div class="col-md-1">
                                    <br />
                                    <button class="btn btn-primary" data-bind="click:agregarDeposito">Agregar</button>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="form-row">
                        <div class="col-md-12">
                            <div class="table-responsive">
                                <hr />
                                <table class='table table-hover'>
                                    <thead>
                                        <tr>
                                            <th>Ver comprobante</th>
                                            <th>Fecha y hora</th>
                                            <th>Forma de pago</th>
                                            <th>Moneda</th>
                                            <th>Monto</th>
                                            <th>Eliminar</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!--ko foreach: depositosHospitalizacion-->
                                        <tr>
                                            <td>
                                                <a class="btn btn-danger"
                                                    data-bind="attr:{href:'/CrearPDF/CuentasPorCobrarReciboPagoPDF?pagoParcial=true&parcialPagoId='+Id}"
                                                    target="_blank">
                                                    <i class="fas fa-file-pdf"></i>
                                                </a>
                                            </td>
                                            <td data-bind="text:FechaHora"></td>
                                            <td data-bind="text:FormaPago"></td>
                                            <td data-bind="text:Moneda"></td>
                                            <td data-bind="text:Monto"></td>
                                            <td>
                                                <button class="btn btn-danger"
                                                        data-bind="click:$root.eliminarDeposito">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                        <!--/ko-->
                                        <tr class="fila-total">
                                            <td colspan="3"><b>TOTAL</b></td>
                                            <td><b>Q <span data-bind="text:valorTotalDepositosHospitalizacion"></span></b></td>
                                            <th></th>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>