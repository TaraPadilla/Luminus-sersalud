@* Fases II–IV del checklist quirúrgico (wizard hospitalización) *@

<div style="border:1px solid #fde68a; border-radius:10px; margin-bottom:10px; overflow:hidden;">
    <div style="background:linear-gradient(135deg,#fef9c3,#fde68a); padding:12px 16px; cursor:pointer; display:flex; align-items:center; justify-content:space-between;"
         data-toggle="collapse" data-target="#collapse-pausa-wizard" aria-expanded="false">
        <div>
            <div style="font-size:0.7rem;font-weight:700;color:#92400e;">FASE II — Pausa quirúrgica</div>
            <div style="font-size:1rem;font-weight:800;color:#d97706;">PAUSA</div>
        </div>
        <i class="fas fa-chevron-down" style="color:#d97706;"></i>
    </div>
    <div id="collapse-pausa-wizard" class="collapse" style="background:#fff; padding:16px 20px;">
        <div class="form-row mb-2">
            <div class="col-md-6">
                <label style="font-size:0.78rem;">Presentación del equipo</label>
                <div style="display:flex;gap:12px;">
                    <label><input type="radio" name="cp_presentacion" value="SI" data-bind="checked: listaChequeo.cp_presentacion" /> SÍ</label>
                    <label><input type="radio" name="cp_presentacion" value="NO" data-bind="checked: listaChequeo.cp_presentacion" /> NO</label>
                    <label><input type="radio" name="cp_presentacion" value="NO APLICA" data-bind="checked: listaChequeo.cp_presentacion" /> N/A</label>
                </div>
            </div>
            <div class="col-md-6">
                <label style="font-size:0.78rem;">Nombre de la cirugía</label>
                <input type="text" class="form-control form-control-sm" data-bind="value: listaChequeo.cp_nombreCirugia" />
            </div>
        </div>
        <div class="form-row mb-2">
            <div class="col-md-3">
                <label style="font-size:0.78rem;">Eventos críticos</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cp_eventos" value="SI" data-bind="checked: listaChequeo.cp_eventosCriticos" /> SÍ</label>
                    <label><input type="radio" name="cp_eventos" value="NO" data-bind="checked: listaChequeo.cp_eventosCriticos" /> NO</label>
                    <label><input type="radio" name="cp_eventos" value="NO APLICA" data-bind="checked: listaChequeo.cp_eventosCriticos" /> N/A</label>
                </div>
            </div>
            <div class="col-md-3">
                <label style="font-size:0.78rem;">Imágenes diagnósticas</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cp_imagenes" value="SI" data-bind="checked: listaChequeo.cp_imagenesDiagnosticas" /> SÍ</label>
                    <label><input type="radio" name="cp_imagenes" value="NO" data-bind="checked: listaChequeo.cp_imagenesDiagnosticas" /> NO</label>
                    <label><input type="radio" name="cp_imagenes" value="NO APLICA" data-bind="checked: listaChequeo.cp_imagenesDiagnosticas" /> N/A</label>
                </div>
            </div>
            <div class="col-md-3">
                <label style="font-size:0.78rem;">Profilaxis antibiótica</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cp_antibiotico" value="SI" data-bind="checked: listaChequeo.cp_profilaxisAntibiotica" /> SÍ</label>
                    <label><input type="radio" name="cp_antibiotico" value="NO" data-bind="checked: listaChequeo.cp_profilaxisAntibiotica" /> NO</label>
                    <label><input type="radio" name="cp_antibiotico" value="NO APLICA" data-bind="checked: listaChequeo.cp_profilaxisAntibiotica" /> N/A</label>
                </div>
            </div>
            <div class="col-md-3">
                <label style="font-size:0.78rem;">Tromboprofilaxis</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cp_trombo" value="SI" data-bind="checked: listaChequeo.cp_tromboprofilaxis" /> SÍ</label>
                    <label><input type="radio" name="cp_trombo" value="NO" data-bind="checked: listaChequeo.cp_tromboprofilaxis" /> NO</label>
                    <label><input type="radio" name="cp_trombo" value="NO APLICA" data-bind="checked: listaChequeo.cp_tromboprofilaxis" /> N/A</label>
                </div>
            </div>
        </div>
    </div>
</div>

<div style="border:1px solid #bbf7d0; border-radius:10px; margin-bottom:10px; overflow:hidden;">
    <div style="background:linear-gradient(135deg,#dcfce7,#bbf7d0); padding:12px 16px; cursor:pointer; display:flex; align-items:center; justify-content:space-between;"
         data-toggle="collapse" data-target="#collapse-salida-wizard" aria-expanded="false">
        <div>
            <div style="font-size:0.7rem;font-weight:700;color:#166534;">FASE III — Antes de salir de quirófano</div>
            <div style="font-size:1rem;font-weight:800;color:#16a34a;">SALIDA</div>
        </div>
        <i class="fas fa-chevron-down" style="color:#16a34a;"></i>
    </div>
    <div id="collapse-salida-wizard" class="collapse" style="background:#fff; padding:16px 20px;">
        <div class="form-row mb-2">
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Operación registrada</label>
                <input type="text" class="form-control form-control-sm" data-bind="value: listaChequeo.cs_nombreOperacion" />
            </div>
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Enfermera circulante</label>
                <input type="text" class="form-control form-control-sm" data-bind="value: listaChequeo.cs_nombreEnfermera" />
            </div>
        </div>
        <div class="form-row mb-2">
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Recuento completo</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cs_recuento" value="SI" data-bind="checked: listaChequeo.cs_recuentoCompleto" /> SÍ</label>
                    <label><input type="radio" name="cs_recuento" value="NO" data-bind="checked: listaChequeo.cs_recuentoCompleto" /> NO</label>
                    <label><input type="radio" name="cs_recuento" value="NO APLICA" data-bind="checked: listaChequeo.cs_recuentoCompleto" /> N/A</label>
                </div>
            </div>
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Muestras etiquetadas</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cs_muestras" value="SI" data-bind="checked: listaChequeo.cs_etiquetadoMuestras" /> SÍ</label>
                    <label><input type="radio" name="cs_muestras" value="NO" data-bind="checked: listaChequeo.cs_etiquetadoMuestras" /> NO</label>
                    <label><input type="radio" name="cs_muestras" value="NO APLICA" data-bind="checked: listaChequeo.cs_etiquetadoMuestras" /> N/A</label>
                </div>
            </div>
        </div>
        <p style="font-size:0.72rem;font-weight:700;color:#64748b;margin:12px 0 8px;">FASE IV — Recuperación y traslado</p>
        <div class="form-row mb-2">
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Repaso post-operatorio</label>
                <div style="display:flex;gap:10px;">
                    <label><input type="radio" name="cs_repaso" value="SI" data-bind="checked: listaChequeo.cs_repasoPostOp" /> SÍ</label>
                    <label><input type="radio" name="cs_repaso" value="NO" data-bind="checked: listaChequeo.cs_repasoPostOp" /> NO</label>
                    <label><input type="radio" name="cs_repaso" value="NO APLICA" data-bind="checked: listaChequeo.cs_repasoPostOp" /> N/A</label>
                </div>
            </div>
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Traslado del paciente</label>
                <select class="form-control form-control-sm" data-bind="value: listaChequeo.cs_traslado">
                    <option value="">Seleccione...</option>
                    <option value="Cuidado intensivo">Cuidado intensivo</option>
                    <option value="Encamamiento">Encamamiento</option>
                    <option value="Cuidados intermedios">Cuidados intermedios</option>
                    <option value="Casa">Casa</option>
                </select>
            </div>
            <div class="col-md-4">
                <label style="font-size:0.78rem;">Servicio y número de cama</label>
                <input type="text" class="form-control form-control-sm" data-bind="value: listaChequeo.cs_servicioNumCama" />
            </div>
        </div>
    </div>
</div>
