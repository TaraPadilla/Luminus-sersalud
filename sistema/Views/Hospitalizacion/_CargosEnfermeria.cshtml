            optionsValue: 'valor',
            value: editTarifaCambio,
            optionsCaption: '-- Seleccione una tarifa --'">
        </select>
        <small class="form-text text-muted">Se cargan automáticamente las tarifas registradas para esta habitación.</small>
    </div>

    <div class="alert alert-info mt-3 p-2 small">
        <strong>Total calculado:</strong>
        Q <span data-bind="text: (parseFloat(editTarifaCambio()) * parseInt(editDiasCambio()) || 0).toFixed(2)"></span>
    </div>
