<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- jQuery UI CSS -->
<link rel="stylesheet" href="https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css">

<!-- jQuery UI JS -->
<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>
<script>
    let examenesSeleccionados = [];

    function verModalOrdenMedica() {
        $("#mdl-agregar-orden-medica").dialog({
            width: 1000,
            modal: true,
            buttons: {
                "Cerrar": function () {
                    $(this).dialog("close");
                    limpiarFormulario();
                }
            }
        });
    }


    function agregarExamenALaLista() {
        const examenNombre = $('#examenSelect option:selected').text();
        const examenIdRaw = $('#examenSelect').val();

        // Convertir a número (puente crítico: el backend espera int)
        const examenId = parseInt(examenIdRaw, 10);

        if (!examenNombre || examenNombre === "Seleccione un examen") {
            alert('Debes seleccionar un examen válido.');
            return;
        }

        if (!Number.isInteger(examenId) || examenId <= 0) {
            alert('El examen seleccionado no tiene un ID válido.');
            return;
        }

        // Unicidad por ID numérico
        if (examenesSeleccionados.some(e => e.id === examenId)) {
            alert('Este examen ya ha sido agregado.');
            return;
        }

        examenesSeleccionados.push({ id: examenId, nombre: examenNombre });

        $('#listaExamenesAgregados').append(`
        <li class="list-group-item d-flex justify-content-between align-items-center" data-id="${examenId}">
            <span>${examenNombre}</span>
            <input type="text" class="form-control ml-2 mr-2" placeholder="Observaciones"
                   style="width: 200px;" data-observacion-id="${examenId}">
            <button class="btn btn-danger btn-sm" onclick="eliminarExamenDeLaLista(${examenId})">Eliminar</button>
        </li>
    `);
    }


    function eliminarExamenDeLaLista(examenId) {
        examenesSeleccionados = examenesSeleccionados.filter(e => e.id !== examenId);
        $(`#listaExamenesAgregados li[data-id='${examenId}']`).remove();
    }


    function agregarOrdenMedica() {
        const descripcion = $('#descripcion').val().trim();

        if (!descripcion) {
            alert('Debes ingresar una descripción para la orden médica.');
            return;
        }

        const observaciones = examenesSeleccionados.map(examen => {
            return $(`input[data-observacion-id='${examen.id}']`).val() || '';
        });

        const examenes = examenesSeleccionados.map(e => e.nombre);

        const nuevaOrden = {
            Profesional: correoUsuario,
            Descripcion: descripcion,
            HospitalizacionId: hospitalizacionIdGlobal,
            Examenes: examenes.length > 0 ? examenes : null,
            Observaciones: observaciones.length > 0 ? observaciones : null
        };

        $.ajax({
            url: '/api/OrdenesMedicas/AgregarOrdenMedica',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(nuevaOrden),
            success: function () {
                if (examenesSeleccionados.length > 0) {
                    agregarExamenAHospitalizacion(codigoSeguro);
                }
                $("#mdl-agregar-orden-medica").dialog("close");
                limpiarFormulario();
                cargarOrdenesMedicas();
            },
            error: function (xhr) {
                alert('Error al agregar la orden médica: ' + xhr.responseText);
            }
        });
    }


    function agregarExamenAHospitalizacion(codigoSeguro) {
        // Convertir IDs principales a número (puente crítico)
        const hospitalizacionId = parseInt(hospitalizacionIdGlobal, 10);
        const pacienteId = parseInt($("#PacienteId").val(), 10);
        const cuentaId = parseInt($("#CuentaId").val(), 10);

        if (!Number.isInteger(hospitalizacionId) || hospitalizacionId <= 0) {
            mensajeEmergenteError("⚠ HospitalizacionId inválido. No se puede registrar el examen.");
            console.error("HospitalizacionId inválido:", hospitalizacionIdGlobal);
            return;
        }

        if (!Number.isInteger(pacienteId) || pacienteId <= 0) {
            mensajeEmergenteError("⚠ PacienteId inválido. No se puede registrar el examen.");
            console.error("PacienteId inválido:", $("#PacienteId").val());
            return;
        }

        if (!Number.isInteger(cuentaId) || cuentaId <= 0) {
            mensajeEmergenteError("⚠ CuentaId inválido. No se puede registrar el examen.");
            console.error("CuentaId inválido:", $("#CuentaId").val());
            return;
        }

        if (!codigoSeguro) {
            // No rompo el flujo, pero dejo traza porque afecta selección de precio
            console.warn("⚠ CodigoSeguro viene vacío. Se usará fallback de precios en backend.");
        }

        if (!examenesSeleccionados || examenesSeleccionados.length === 0) {
            alert('Debe agregar al menos un examen.');
            return;
        }

        // Asegurar ExamenLabClinicoId numérico
        let examenesPayload = examenesSeleccionados.map(examen => ({
            ExamenLabClinicoId: parseInt(examen.id, 10),
            Observacion: $(`input[data-observacion-id='${examen.id}']`).val() || ''
        })).filter(x => Number.isInteger(x.ExamenLabClinicoId) && x.ExamenLabClinicoId > 0);

        if (examenesPayload.length === 0) {
            mensajeEmergenteError("⚠ No hay exámenes con ID válido para registrar.");
            console.error("Exámenes seleccionados inválidos:", examenesSeleccionados);
            return;
        }

        let payload = {
            HospitalizacionId: hospitalizacionId,
            PacienteId: pacienteId,
            CuentaId: cuentaId,
            CodigoSeguro: codigoSeguro,
            Examenes: examenesPayload
        };

        // Trazabilidad mínima (para ver exactamente qué se envía)
        console.log("📌 Payload /Hospitalizacion/AgregarExamen:", payload);

        $.ajax({
            url: "/Hospitalizacion/AgregarExamen",
            method: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (dataResult) {
                // El controller devuelve string (JsonSerializer.Serialize), por eso parseamos string.
                // Si algún middleware cambia el content-type a JSON, soportamos objeto también.
                let data;
                try {
                    data = (typeof dataResult === "string") ? JSON.parse(dataResult) : dataResult;
                } catch (e) {
                    console.error("❌ Respuesta no parseable de /Hospitalizacion/AgregarExamen:", dataResult, e);
                    mensajeEmergenteError("⚠ Error interpretando respuesta al registrar exámenes.");
                    return;
                }

                console.log("✅ Respuesta /Hospitalizacion/AgregarExamen:", data);

                if (data && data.Exitoso) {
                    // Limpiar lista local
                    examenesSeleccionados = [];
                    $("#listaExamenesAgregados").empty();

                    // ✅ Refrescar tab Exámenes Complementarios (KO global en Detalles)
                    if (typeof detallesVm !== "undefined" && detallesVm) {
                        if (typeof detallesVm.consultarExamenesHospitalizacion === "function") {
                            detallesVm.consultarExamenesHospitalizacion();
                        }
                        if (typeof detallesVm.actualizarTotales === "function") {
                            detallesVm.actualizarTotales();
                        }
                    }
                } else {
                    console.error("❌ Backend respondió Exitoso=false:", data);
                    mensajeEmergenteError("❌ " + (data && data.Mensaje ? data.Mensaje : "Error al registrar exámenes."));
                }
            },
            error: function (xhr) {
                console.error("❌ Error AJAX /Hospitalizacion/AgregarExamen:", xhr);
                mensajeEmergenteError("⚠ Error al agregar los exámenes.");
            }
        });
    }





    function limpiarFormulario() {
        $('#descripcion').val('');
        $('#examenSelect').val('');
        $('#listaExamenesAgregados').empty();
        examenesSeleccionados = [];
    }

    function eliminarOrdenMedica(ordenId) {
        if (confirm('¿Estás seguro de que deseas eliminar esta orden médica?')) {
            $.ajax({
                url: `/api/OrdenesMedicas/EliminarOrdenMedica/${ordenId}`,
                type: 'DELETE',
                success: function (response) {
                    @* alert('Orden médica eliminada exitosamente'); *@
                        cargarOrdenesMedicas(); // Recargar la tabla de órdenes médicas
                },
                error: function (xhr) {
                    console.error(xhr);
                    alert('Error al eliminar la orden médica: ' + xhr.responseText);
                }
            });
        }
    }

</script>
<script>
    function aplicarOrdenMedica(ordenId) {

        if (confirm('¿Deseas marcar esta orden médica como realizada?')) {
            $.ajax({
                url: `/api/OrdenesMedicas/AplicarOrdenMedica/${ordenId}`,
                type: 'PUT',
                contentType: 'application/json',
                data: JSON.stringify({
                    Realizada: true,
                    ProfesionalRealiza: correoUsuario
                }),
                success: function (response) {
                    alert('Orden médica marcada como realizada.');
                    cargarOrdenesMedicas(); // Recargar la tabla para reflejar los cambios
                },
                error: function (xhr) {
                    console.error(xhr);
                    alert('Error al aplicar la orden médica: ' + xhr.responseText);
                }
            });
        }
    }


    function abrirModalAgregarMedicamentos() {
        TipoBodega = "Global";
        $("#modalAgregarMedicamentos").data("directa", false);
        consultarMedicamentosExistentes();
        $("#modalAgregarMedicamentos").dialog({
            modal: true,
            width: 1000,
            buttons: {
                "Cerrar": function () {
                    $(this).dialog("close");
                }
            }
        });
    }

    function abrirModalAgregarMedicamentosArea() {
        TipoBodega = "Area";
        $("#modalAgregarMedicamentos").data("directa", true);
        consultarMedicamentosExistentes();
        $("#modalAgregarMedicamentos").dialog({
            modal: true,
            width: 1000,
            buttons: {
                "Cerrar": function () {
                    $(this).dialog("close");
                }
            }
        });
    }



    let productosExistentes = [];

    function consultarMedicamentosExistentes() {
        let bodegaUsar = (TipoBodega === "Global") ? 14 : $("#BodegaId").val();

        $.ajax({
            method: "POST",
            url: '/HospitalizacionPaquetes/ConsultarProductosExistentes',
            data: { BodegaId: bodegaUsar },
            success: function (dataResult) {
                let data = JSON.parse(dataResult);
                if (data.Exitoso) {
                    let agrupados = {};
                    let codigoSeguro = '@codigoSeguroHospi';
                    @* console.log(codigoSeguro) *@
                        // Recorrer los productos para agruparlos por ProductoId
                        data.Resultado.forEach(producto => {
                            if (!agrupados[producto.ProductoId]) {
                                agrupados[producto.ProductoId] = {
                                    ProductoId: producto.ProductoId,
                                    ProductoNombre: producto.ProductoNombre,
                                    Precios: [] // Inicializar array de precios
                                };
                            }

                            // Filtrar los precios por el código de seguro
                            // Normalización segura
                            const codigoSeguroNorm = (codigoSeguro ?? "").toString().trim().toUpperCase();
                            const precioNombreNorm = (producto.PrecioNombre ?? "").toString().trim().toUpperCase();

                            // Si codigoSeguro viene vacío, mostrar ambos precios permitidos
                            const allowedWhenNoSeguro = new Set(["NORMAL", "SIN SEGURO"]);

                            // Regla de inclusión
                            const incluirPrecio = codigoSeguroNorm
                                ? (precioNombreNorm === codigoSeguroNorm)
                                : allowedWhenNoSeguro.has(precioNombreNorm);

                            // Agregar precio si aplica y evitar duplicados por PrecioId
                            if (incluirPrecio) {
                                const precios = agrupados[producto.ProductoId].Precios;

                                if (!precios.some(p => p.PrecioId === producto.PrecioId)) {
                                    precios.push({
                                        PrecioId: producto.PrecioId,
                                        PrecioValor: producto.PrecioValor,
                                        PrecioNombre: producto.PrecioNombre
                                    });
                                }
                            }
                        });

                    // Convertir a array para usar en los selects
                    productosExistentes = Object.values(agrupados);

                    // Llenar el select de productos (solo los que tienen precio válido)
                    let productoSelect = $('#productoSelect');
                    productoSelect.empty().append('<option value="">Seleccione un producto</option>');

                    productosExistentes.forEach(producto => {
                        if (producto.Precios.length > 0) { // Solo agregar productos con precios válidos
                            productoSelect.append(`<option value="${producto.ProductoId}">${producto.ProductoNombre}</option>`);
                        }
                    });
                }
            },
            error: function () {
                alert('Error al consultar medicamentos existentes.');
            }
        });
    }

    // Evento para manejar la selección de productos y asignar automáticamente su precio
    $('#productoSelect').on('change', function () {
        const productoId = $(this).val();
        const productoSeleccionado = productosExistentes.find(p => p.ProductoId == productoId);

        let precioSelect = $('#precioSelect');
        precioSelect.empty();

        if (productoSeleccionado && productoSeleccionado.Precios.length > 0) {
            let precio = productoSeleccionado.Precios[0]; // Solo hay una opción
            precioSelect.append(`<option value="${precio.PrecioId}" selected>${precio.PrecioNombre} - Q${precio.PrecioValor}</option>`);
        }
    });


    function consultarMedicamentoPrecio(productoId) {
        $.ajax({
            method: "POST",
            url: '/HospitalizacionPaquetes/ConsultarPrecioProducto',
            data: { ProductoId: productoId },
            success: function (dataResult) {
                let data = JSON.parse(dataResult);
                if (data.Exitoso) {
                    $('#precioSelect').empty();
                    data.Resultado.forEach(precio => {
                        $('#precioSelect').append(`<option value="${precio.PrecioValor}">${precio.Precio}</option>`);
                    });
                }
            },
            error: function () {
                alert('Error al consultar precios del medicamento.');
            }
        });
    }

    function imprimirOrdenMedica(ordenId) {
        window.open(`/CrearPDF/HospitalizacionOrdenMedicaPDF?ordenMedicaId=${ordenId}`, '_blank');
    }


    function cargarOrdenesMedicas() {
        $.ajax({
            url: `/api/OrdenesMedicas/ObtenerOrdenesPorHospitalizacion/${hospitalizacionIdGlobal}`,
            type: 'GET',
            success: function (ordenes) {
                const tbody = $('#tabla-ordenes-medicas tbody');
                tbody.empty();

                ordenes.forEach(orden => {
                    const filaClase = orden.realizada ? 'orden-realizada' : '';

                    const examenes = (Array.isArray(orden.examenes) ? orden.examenes : []).map((examen, index) => {
                        const observacion = (Array.isArray(orden.observaciones) && orden.observaciones[index]) ? orden.observaciones[index] : '';
                        return `<strong>${examen}</strong><br><small>Obs: ${observacion}</small>`;
                    }).join('<hr>');


                    tbody.append(`
                    <tr class="${filaClase}">
                        <td>${new Date(orden.fechaHora).toLocaleString('es-ES')}</td>
                        @* <td>${orden.id}</td> *@
                        <td>${orden.profesional}</td>
                        <td style="white-space: pre-wrap;">${orden.descripcion}</td>
                        <td>${(Array.isArray(orden.examenes) ? orden.examenes.join('<br>') : '')}</td>
                        <td>${(Array.isArray(orden.observaciones) ? orden.observaciones.join('<br>') : '')}</td>
                        <td>${orden.fechaRealizacion && new Date(orden.fechaRealizacion).getTime() > 0 ? new Date(orden.fechaRealizacion).toLocaleString('es-ES') : ''}</td>
                        <td>${orden.profesionalRealiza || ''}</td>
                        <td>
                            ${!orden.realizada ? `
                                <button class="btn btn-success" onclick="aplicarOrdenMedica(${orden.id})">
                                    <i class="fa fa-syringe"></i> 
                                </button>
                            ` : ''}
                            <button class="btn btn-primary" onclick="imprimirOrdenMedica(${orden.id})">
                                <i class="fa fa-print"></i>
                            </button>
                        </td>

                    </tr>
                `);
                });
            },
            error: function () {
                alert('Error al obtener las órdenes médicas.');
            }
        });
    }

    function toggleFormularioMedicamento() {
        const formulario = document.getElementById('formularioAgregarMedicamento');

        if (formulario.style.display === 'none') {
            formulario.style.display = 'block';
        } else {
            formulario.style.display = 'none';
        }
    }



    $(document).ready(function () {
        cargarOrdenesMedicas();
        cargarDataTables();
    });




    function agregarMedicamento() {
        let hospitalizacionId = $("#HospitalizacionId").val();
        let productoId = $("#productoSelect").val();
        let precioId = $("#precioSelect").val();
        let cantidad = $("#cantidadInput").val();
        let indicaciones = $("#indicacionesInput").val();
        let viaAdministracion = $("#viaAdministracion").val();
        let frecuenciaAdministracion = $("#frecuenciaAdministracionSelect").val();

        let fechaHoraAplicacionManual = document.getElementById("fechaHoraManualInput").value;

        if (fechaHoraAplicacionManual) {
            let fechaLocal = new Date(fechaHoraAplicacionManual);
            let fechaGuatemala = new Date(fechaLocal.getTime() - (fechaLocal.getTimezoneOffset() * 60000) - (6 * 60 * 60000));

            // Formatear fecha en "dd/MM/yyyy h:mm:ss a"
            let opcionesFormato = {
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: true
            };

            fechaHoraAplicacionManual = new Intl.DateTimeFormat('es-ES', opcionesFormato).format(fechaGuatemala).replace(',', '');
        }



        if (!cantidad || isNaN(cantidad) || cantidad <= 0) {
            alert("Proporcione una cantidad válida para el medicamento");
            return;
        }

        if (!productoId) {
            alert("Seleccione un producto válido");
            return;
        }

        if (!precioId) {
            alert("Seleccione un precio válido");
            return;
        }

        let productoSeleccionado = productosExistentes.find(p => p.ProductoId == productoId);
        if (!productoSeleccionado) {
            alert("El producto seleccionado no es válido");
            return;
        }

        let precioSeleccionado = productoSeleccionado.Precios.find(p => p.PrecioId == precioId);
        if (!precioSeleccionado) {
            alert("El precio seleccionado no es válido");
            return;
        }

        let confirmAgregar = "¿Desea solicitar este medicamento?";
        if (!confirm(confirmAgregar)) {
            return;
        }

        // ✅ Construcción de la solicitud
        let solicitud = {
            HospitalizacionId: hospitalizacionId,
            ProductoId: productoId,
            UnidadMedidaVentaId: 1, // Si tienes una selección de unidad, cámbiala
            Cantidad: cantidad,
            Precio: precioSeleccionado.PrecioValor,
            Indicaciones: indicaciones,
            ViaAdministracion: viaAdministracion,
            FrecuenciaAdministracion: frecuenciaAdministracion,
            PrecioId: precioSeleccionado.PrecioId,
            FechaHoraAplicacionManual: fechaHoraAplicacionManual

        };

        // ✅ Llamar a la API para crear la solicitud
        crearSolicitudMedicamento(solicitud);
    }

    function crearSolicitudMedicamento(solicitud) {
        let tipoProductoId;

        productosExistentes.forEach(e => {
            if (e.ProductoId === solicitud.ProductoId) {
                tipoProductoId = e.TipoProductoId;
            }
        });

        var solicitudCompleta = {
            HospitalizacionId: solicitud.HospitalizacionId || 0,
            ProductoId: solicitud.ProductoId || 0,
            UnidadMedidaVentaId: solicitud.UnidadMedidaVentaId || 0,
            Cantidad: solicitud.Cantidad || 0,
            Precio: solicitud.Precio || 0.00,
            Indicaciones: solicitud.Indicaciones || "",
            ViaAdministracion: solicitud.ViaAdministracion || "",
            FrecuenciaAdministracion: solicitud.FrecuenciaAdministracion || "",
            IdProductoPrecioInventario: solicitud.IdProductoPrecioInventario || 0,
            PrecioId: solicitud.PrecioId || 0,
            TipoProducto: tipoProductoId ? tipoProductoId.toString() : "1",
            FechaHoraAplicacionManual: solicitud.FechaHoraAplicacionManual || "-"
        };

        @* console.log("Solicitud Enviada:", solicitudCompleta); *@

            $.ajax({
                url: '/SolicitudMedicamento/Add',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(solicitudCompleta),
                success: function (response) {
                    if (response.exitoso) {
                        alert(`✅ ${response.mensaje}\n📅 Fecha de solicitud: ${response.fechaSolicitud}`);
                    } else {
                        alert(`❌ Error: ${response.mensaje}`);
                    }
                },
                error: function (xhr, status, error) {
                    alert(`⚠ Error inesperado: ${xhr.responseJSON ? xhr.responseJSON.Mensaje : error}`);
                }
            });
    }

</script>
