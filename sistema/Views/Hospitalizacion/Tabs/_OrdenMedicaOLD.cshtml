<script>
    let productosSeleccionados = [];
    function agregarMedicamentoALaLista() {
        let hospitalizacionId = $("#HospitalizacionId").val();
        let productoId = $("#productoSelect").val();
        let precioId = $("#precioSelect").val();
        let cantidad = $("#cantidadInput").val();
        let indicaciones = $("#indicacionesInput").val();
        let viaAdministracion = $("#viaAdministracion").val();
        let frecuenciaAdministracion = $("#frecuenciaAdministracionSelect").val();
        let directa = $("#modalAgregarMedicamentos").data("directa");

        let fechaHoraAplicacionManualInput = document.getElementById("FechaHoraManualInput");
        let fechaHoraAplicacionManual = null;

        if (fechaHoraAplicacionManualInput) {
            fechaHoraAplicacionManual = fechaHoraAplicacionManualInput.value;

            if (fechaHoraAplicacionManual) {
                let fechaLocal = new Date(fechaHoraAplicacionManual);
                let fechaGuatemala = new Date(fechaLocal.getTime() - (fechaLocal.getTimezoneOffset() * 60000) - (6 * 60 * 60000));
                fechaHoraAplicacionManual = fechaGuatemala.toISOString().slice(0, 19);
            }
        }

        if (!cantidad || isNaN(cantidad) || cantidad <= 0) {
            alert("Proporcione una cantidad válida para el medicamento");
            return;
        }

        if (!productoId) {
            alert("Seleccione un producto válido");
            return;
        }

        let productoSeleccionado = productosExistentes.find(p => p.ProductoId == productoId);
        if (!productoSeleccionado) {
            alert("El producto seleccionado no es válido");
            return;
        }

        let precioSeleccionado = productoSeleccionado.Precios.find(p => p.PrecioId == precioId);
        if (!precioSeleccionado) {
            alert("El precio seleccionado no es válido");
            return;
        }

        let producto = {
            HospitalizacionId: hospitalizacionId,
            ProductoId: productoId,
            Nombre: productoSeleccionado.ProductoNombre,
            UnidadMedidaVentaId: 1,
            Cantidad: cantidad,
            Precio: precioSeleccionado.PrecioValor,
            Indicaciones: indicaciones,
            ViaAdministracion: viaAdministracion,
            FrecuenciaAdministracion: frecuenciaAdministracion,
            PrecioId: precioSeleccionado.PrecioId,
            Directa: directa,
            FechaHoraAplicacionManual: fechaHoraAplicacionManual
        };

        console.log("✅ Producto agregado:", producto);

        productosSeleccionados.push(producto);
        actualizarListaProductos();
    }

    function actualizarListaProductos() {
        let lista = $("#listaProductosAgregados");
        lista.empty();

        productosSeleccionados.forEach((producto, index) => {
            lista.append(`
                                                        <li class="list-group-item d-flex justify-content-between align-items-center">
                                                            <span><strong>${producto.Nombre}</strong> - Cantidad: ${producto.Cantidad}</span>
                                                            <button class="btn btn-danger btn-sm" onclick="eliminarProductoDeLista(${index})">Eliminar</button>
                                                        </li>
                                                    `);
        });
    }

    function eliminarProductoDeLista(index) {
        productosSeleccionados.splice(index, 1);
        actualizarListaProductos();
    }

    function enviarListaProductos() {
        if (productosSeleccionados.length === 0) {
            alert("No hay productos en la lista.");
            return;
        }

        productosSeleccionados.forEach(producto => {
            $.ajax({
                url: '/SolicitudMedicamento/Add',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(producto),
                success: function (response) {
                    if (response.exitoso) {
                        @* console.log(`✅ ${response.mensaje}`); *@
                                        } else {
                        console.error(`❌ Error: ${response.mensaje}`);
                    }
                },
                error: function (xhr) {
                    console.error(`⚠ Error inesperado: ${xhr.responseJSON ? xhr.responseJSON.Mensaje : xhr.responseText}`);
                }
            });
        });

        productosSeleccionados = [];
        actualizarListaProductos();
        $("#modalAgregarMedicamentos").dialog("close");

        // ✅ Si hay productos directos, registrar solicitudes despachadas
        @* if (productosSeleccionados.some(p => p.Directa)) { *@
            registrarSolicitudesDespachadas();
        @* } *@
                        }


    function registrarSolicitudesDespachadas() {
        let hospitalizacionId = $("#HospitalizacionId").val();

        @* console.log(`📌 Buscando solicitudes para la hospitalización: ${hospitalizacionId}`); *@

            $.ajax({
                url: `/SolicitudMedicamento/GetByHospitalizacion?hospitalizacionId=${hospitalizacionId}`,
                method: "GET",
                success: function (solicitudes) {
                    @* console.log("📌 TODAS las solicitudes obtenidas:", solicitudes); *@

                        let solicitudesPendientes = solicitudes.filter(s => s.estado === "Despachado" && !s.esRegistroHospitalizacion);

                    @* console.log("📌 SOLICITUDES FILTRADAS con estado 'Despachado':", solicitudesPendientes); *@

                        @* if (solicitudesPendientes.length === 0) {
                alert("⚠ No hay solicitudes pendientes de registro.");
                return;
            } *@

                        procesarSolicitud(0, solicitudesPendientes);
                },
                error: function () {
                    alert("❌ Error al obtener solicitudes de medicamentos.");
                }
            });
    }
</script>
<script>
    async function consultarProductosAplicacionHospitalizacion(tipoProductoId) {
        showLoading();
        try {
            @* console.log("📌 Consultando productos para tipoProductoId:", tipoProductoId); *@
                let response = await $.ajax({
                    url: "/Hospitalizacion/ConsultarProductosAplicacionHospitalizacion",
                    method: "POST",
                    contentType: "application/x-www-form-urlencoded",
                    data: {
                        hospitalizacionId: $("#HospitalizacionId").val(),
                        tipoProductoId: tipoProductoId
                    }
                });

            hideLoading();

            let data = JSON.parse(response);
            @* console.log("📌 Datos de la API:", data); *@

                                                                if (data.Exitoso) {
                if (data.Resultado && data.Resultado.length > 0) {
                    renderizarTablaControlAplicaciones(data.Resultado, tipoProductoId);
                    return true;
                } else {
                    alert("No se encontró ningún producto aplicable.");
                    return false;
                }
            } else {
                mensajeEmergenteError(data.Mensaje);
                return false;
            }
        } catch (error) {
            hideLoading();
            console.error("❌ Error en la solicitud:", error);
            mensajeEmergenteError("Error al obtener los datos.");
            return false;
        }
    }




    function renderizarTablaControlAplicaciones(productos, tipoProductoId) {
        let tbody = $("#tablaControlAplicacionesBody");
        let tabla = $("#tablaControlAplicaciones");

        if ($.fn.DataTable.isDataTable(tabla)) {
            tabla.DataTable().destroy();
        }

        tbody.empty();

        if (!productos || productos.length === 0) {
            tbody.append(`<tr><td colspan="10" class="text-center">No hay productos en la hospitalización.</td></tr>`);
            return;
        }

        productos.forEach((producto) => {
            let aplicado = producto.Aplicado
                ? '<span class="badge badge-success">SI</span>'
                : '<span class="badge badge-danger">NO</span>';

            let aplicarBtn = !producto.Aplicado
                ? `<button class="btn btn-primary aplicarProductoBtn" data-id="${producto.Id}">
                                                                        <i class="fas fa-syringe"></i>
                                                                   </button>`
                : '';

            let tipoElemento = tipoProductoId === 1 ? "Medicamento" : "Insumo";

            tbody.append(`
                                                                <tr>
                                                                    <td><label class="badge badge-warning">${tipoElemento}</label></td>
                                                                    <td>${producto.Nombre}</td>
                                                                    <td>${producto.Indicaciones || '-'}</td>
                                                                    <td>${producto.Cantidad}</td>
                                                                    <td>${producto.UnidadMedidaVentaNombre || '-'}</td>
                                                                    <td>${producto.PersonaCrea || '-'}</td>
                                                                    <td>${aplicado}</td>
                                                                    <td>${producto.FechaHoraAplicacion || '-'}</td>
                                                                    <td>${producto.FechaHoraAplicacionManual || '-'}</td>
                                                                    <td>${producto.FrecuenciaAdministracion || '-'}</td>
                                                                    <td>${producto.PersonaAplica || '-'}</td>
                                                                    <td>${aplicarBtn}</td>
                                                                </tr>
                                                            `);
        });
        setTimeout(initializeDataTable, 100);
    }



    function initializeDataTable() {


        // Eliminar instancia previa si ya existe
        if ($.fn.DataTable.isDataTable("#tablaControlAplicaciones")) {
            $("#tablaControlAplicaciones").DataTable().destroy();
        }

        $("#tablaControlAplicaciones").DataTable({
            paging: true,
            pageLength: 5,
            lengthMenu: [5, 8, 15, 25],
            searching: true,
            ordering: true,
            autoWidth: false,
            responsive: true,
            deferRender: true,
            processing: true,
            language: {
                lengthMenu: "Mostrar _MENU_ registros por página",
                zeroRecords: "No se encontraron registros",
                info: "Página _PAGE_ de _PAGES_",
                infoEmpty: "No hay registros disponibles",
                search: "Buscar:",
                paginate: {
                    first: "Primero",
                    last: "Último",
                    next: "Siguiente",
                    previous: "Anterior"
                }
            }
        });
    }


    function cargarDataTables() {
        let cssLink = document.createElement('link');
        cssLink.rel = 'stylesheet';
        cssLink.href = 'https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css';
        document.head.appendChild(cssLink);

        let scriptTag = document.createElement('script');
        scriptTag.src = 'https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js';
        scriptTag.onload = function () {
            @* console.log('✅ DataTables cargado correctamente'); *@
                initializeDataTable();
        };
        document.body.appendChild(scriptTag);
    }


    async function abrirModalControlAplicaciones(tipoProductoId) {
        $("#tablaControlAplicacionesBody").empty();

        let hayProductos = await consultarProductosAplicacionHospitalizacion(tipoProductoId);

        if (!hayProductos) return;

        $("#modalControlAplicaciones").dialog({
            modal: true,
            width: 1400,
            maxWidth: 1800,
            buttons: {
                "Cerrar": function () {
                    $(this).dialog("close");
                }
            }
        });

    }





    $(document).on("click", ".aplicarProductoBtn", function () {
        let productoId = $(this).data("id");
        aplicarProducto(productoId);
    });

    function aplicarProducto(productoId) {
        @* console.log(`Aplicando producto ID: ${productoId}`); *@
            $.ajax({
                url: `/Hospitalizacion/AplicarProducto`,
                method: "POST",
                data: {
                    hospitalizacionProductoAplicacionId: productoId,
                    cuentaId: $("#CuentaId").val()
                },
                success: function (response) {
                    let data = JSON.parse(response);
                    if (data.Exitoso) {
                        actualizarFilaProducto(data.ProductoAplicado);
                    } else {
                        alert("Error: " + data.Mensaje);
                    }
                },
                error: function (xhr) {
                    console.error("❌ Error al aplicar producto:", xhr);
                    alert("No se pudo aplicar el producto.");
                }
            });
    }


    function actualizarFilaProducto(producto) {
        let fila = $(`#tablaControlAplicacionesBody tr button[data-id='${producto.hospitalizacionProductoAplicacionId}']`).closest("tr");

        if (fila.length) {
            // Formatear la fecha en el formato "13/02/2025 5:08:41 p. m."
            let fechaAplicacion = new Date(producto.FechaHoraAplicacion).toLocaleString('es-ES', {
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                hour12: true
            });

            fila.find("td:nth-child(7)").html('<span class="badge badge-success">SI</span>');
            fila.find("td:nth-child(8)").text(fechaAplicacion.replace(',', ''));
            fila.find("td:nth-child(11)").text(producto.UsuarioAplica);
            fila.find("td:nth-child(12)").empty();
        }
    }


</script>
<script>
    async function consultarServiciosHospitalizacion() {
        showLoading();
        try {
            let response = await $.ajax({
                url: "/Hospitalizacion/ConsultarServiciosHospitalizacion",
                method: "POST",
                data: { hospitalizacionId: $("#HospitalizacionId").val() }
            });

            hideLoading();

            let data = JSON.parse(response);
            if (data.Exitoso) {
                if (data.Resultado && data.Resultado.length > 0) {
                    renderizarTablaControlServicios(data.Resultado);
                    return true;
                } else {
                    alert("No hay servicios aplicables.");
                    return false;
                }
            } else {
                mensajeEmergenteError(data.Mensaje);
                return false;
            }
        } catch (error) {
            hideLoading();
            console.error("❌ Error en la solicitud:", error);
            mensajeEmergenteError("Error al obtener los datos.");
            return false;
        }
    }

    function renderizarTablaControlServicios(servicios) {
        let tbody = $("#tablaControlServiciosBody");
        tbody.empty(); // Limpiar tabla

        if (servicios.length === 0) {
            tbody.append(`<tr><td colspan="8" class="text-center">No hay servicios asignados.</td></tr>`);
        } else {
            servicios.forEach((servicio) => {
                let aplicado = servicio.Aplicado
                    ? '<span class="badge badge-success">SI</span>'
                    : '<span class="badge badge-danger">NO</span>';
                let aplicarBtn = !servicio.Aplicado
                    ? `<button class="btn btn-primary aplicarServicioBtn" data-id="${servicio.Id}"><i class="fas fa-check-circle"></i></button>`
                    : '';

                tbody.append(`
                                                                                                                                <tr>
                                                                                                                                    <td>${servicio.Nombre}</td>
                                                                                                                                    <td>${servicio.Indicaciones || '-'}</td>
                                                                                                                                    <td>${servicio.PersonaCrea || '-'}</td>
                                                                                                                                    <td>${aplicado}</td>
                                                                                                                                    <td>${servicio.FechaHoraAplicacion || '-'}</td>
                                                                                                                                    <td>${servicio.PersonaAplica || '-'}</td>
                                                                                                                                    <td>${aplicarBtn}</td>
                                                                                                                                    @* <td>
                                        <button class="btn btn-primary btn-sm verObservacionBtn" data-id="${servicio.Id}">
                                            <i class="bi bi-eye"></i> Ver
                                        </button>
                                    </td> *@
                                                                                                                                </tr>
                                                                                                                            `);
            });
        }

        // Inicializar DataTable después de cargar los datos
        setTimeout(() => {
            if (!$.fn.DataTable.isDataTable("#tablaControlServicios")) {
                $("#tablaControlServicios").DataTable({
                    paging: true,
                    pageLength: 5,
                    searching: true,
                    ordering: true,
                    autoWidth: false,
                    responsive: true,
                    language: {
                        lengthMenu: "Mostrar _MENU_ registros por página",
                        zeroRecords: "No se encontraron registros",
                        info: "Página _PAGE_ de _PAGES_",
                        infoEmpty: "No hay registros disponibles",
                        search: "Buscar:",
                        paginate: {
                            first: "Primero",
                            last: "Último",
                            next: "Siguiente",
                            previous: "Anterior"
                        }
                    }
                });
            }
        }, 100);
    }

    // Abrir Modal de Servicios
    async function abrirModalControlServicios() {
        let hayServicios = await consultarServiciosHospitalizacion();
        if (!hayServicios) return;

        $("#modalControlServicios").dialog({
            modal: true,
            width: 1200,
            buttons: {
                "Cerrar": function () {
                    $(this).dialog("close");
                }
            }
        });
    }

    // Aplicar un servicio
    $(document).on("click", ".aplicarServicioBtn", function () {
        let servicioId = $(this).data("id");
        aplicarServicio(servicioId);
    });

    function aplicarServicio(servicioId) {
        $.ajax({
            url: `/Hospitalizacion/AplicarServicio`,
            method: "POST",
            data: {
                hospitalizacionServicioId: servicioId,
                cuentaId: $("#CuentaId").val()
            },
            success: function (response) {
                let data = JSON.parse(response);
                if (data.Exitoso) {
                    actualizarFilaServicio(data.ServicioAplicado);
                } else {
                    alert("Error: " + data.Mensaje);
                }
            },
            error: function (xhr) {
                console.error("❌ Error al aplicar servicio:", xhr);
                alert("No se pudo aplicar el servicio.");
            }
        });
    }


    // Actualizar fila cuando un servicio es aplicado
    function actualizarFilaServicio(servicio) {
        let fila = $(`#tablaControlServiciosBody tr button[data-id='${servicio.servicioId}']`).closest("tr");

        if (fila.length) {
            let fechaAplicacion = new Date(servicio.FechaHoraAplicacion).toLocaleString('es-ES', {
                day: '2-digit', month: '2-digit', year: 'numeric',
                hour: '2-digit', minute: '2-digit', second: '2-digit',
                hour12: true
            });

            fila.find("td:nth-child(4)").html('<span class="badge badge-success">SI</span>'); // Aplicado
            fila.find("td:nth-child(5)").text(fechaAplicacion.replace(',', '')); // Fecha de aplicación con espacio limpio
            fila.find("td:nth-child(6)").text(servicio.UsuarioAplica); // Usuario que aplicó
            fila.find("td:nth-child(7)").empty(); // Eliminar botón de aplicar
        }
    }


    $(document).on("click", "#btnAplicarTodosInsumos", function () {
        let dataTable = $("#tablaControlAplicaciones").DataTable();
        let insumosNoAplicados = dataTable.rows().nodes(); // Obtener todas las filas sin importar la paginación
        let elementosPendientes = $(insumosNoAplicados).find("button.aplicarProductoBtn");

        if (elementosPendientes.length === 0) {
            alert("No hay items pendientes de aplicar.");
            return;
        }

        if (!confirm("¿Estás seguro de que deseas hacer una aplicación en masa?")) {
            return;
        }

        setTimeout(() => {
            if (!confirm("Esta acción no se puede deshacer. ¿Deseas continuar?")) {
                alert("Operación cancelada.");
                return;
            }

            elementosPendientes.each(function () {
                let productoId = $(this).data("id");
                aplicarProducto(productoId);
            });

            @* alert("Aplicación en masa completada."); *@
                    }, 100);

    });
</script>