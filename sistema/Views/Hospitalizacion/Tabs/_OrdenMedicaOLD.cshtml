@{
    var usuarioAdmisiones = User.IsInRole("Admisiones");
    var hospitalizacionId = Model.HospitalizacionId;
    var correoUsuario = User.Identity.Name;
    var codigoSeguroHospi = Model.CodigoSeguro;

}
<script>
    var hospitalizacionIdGlobal = '@hospitalizacionId';
    var correoUsuario = '@correoUsuario';
    var codigoSeguro = '@codigoSeguroHospi';
    var TipoBodega = 'Area';
</script>



<div class="col-md-12">

    <!-- Botón para abrir el modal -->
    @if (!usuarioAdmisiones)
    {
        @if (!User.IsInRole("Coordinador Laboratorio") && !User.IsInRole("Tecnico laboratorio"))
        {
            @if (!User.IsInRole("Enfermeria"))
