$(document).on("click", "#btnAplicarTodosInsumos", function () {
    let dataTable = $("#tablaControlAplicaciones").DataTable();
    let insumosNoAplicados = dataTable.rows().nodes();
    let elementosPendientes = $(insumosNoAplicados).find("button.aplicarProductoBtn:not(:disabled)");

    if (elementosPendientes.length === 0) {
        alert("No hay items pendientes de aplicar.");
        return;
    }

    if (!confirm("¿Estás seguro de que deseas hacer una aplicación en masa?")) {
        return;
    }

    if (!confirm("Esta acción no se puede deshacer. ¿Deseas continuar?")) {
        return;
    }

    (async () => {
        if (typeof showLoading === "function") showLoading();

        const listaBotones = elementosPendientes.toArray();

        for (const boton of listaBotones) {
            let productoId = $(boton).data("id");
            try {
                await aplicarProducto(productoId);
                console.log("Aplicado correctamente ID:", productoId);
            } catch (error) {
                console.error("Error en el proceso masivo para ID " + productoId, error);
            }
        }

        if (typeof hideLoading === "function") hideLoading();
        alert("Proceso de aplicación en masa finalizado.");

        // Refrescar totales al terminar la aplicación masiva
        if (typeof detallesVm !== "undefined") {
            detallesVm.consultarMedicamentosHospitalizacion();
            detallesVm.consultarProductosAplicacionHospitalizacion();
        }

        if (typeof cargarProductosHospitalizacion === "function") {
            cargarProductosHospitalizacion();
        }
    })();
});
</script>