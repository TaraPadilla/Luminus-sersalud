<script>
    let currentPageOrdenes = 1;
    const rowsPerPageOrdenes = 4;

    function paginateTableOrdenes() {
        let table = document.getElementById("tabla-ordenes-medicas").getElementsByTagName("tbody")[0];
        let rows = Array.from(table.getElementsByTagName("tr"));
        let totalPages = Math.max(1, Math.ceil(rows.length / rowsPerPageOrdenes));

        rows.forEach((row, index) => {
            row.style.display = (index >= (currentPageOrdenes - 1) * rowsPerPageOrdenes && index < currentPageOrdenes * rowsPerPageOrdenes)
                ? "table-row" : "none";
        });

        document.getElementById("page-info-ordenes").innerText = `Página ${currentPageOrdenes} de ${totalPages}`;

        // Deshabilitar botones si es necesario
        document.querySelector("button[onclick='previousPageOrdenes()']").disabled = (currentPageOrdenes === 1);
        document.querySelector("button[onclick='nextPageOrdenes()']").disabled = (currentPageOrdenes >= totalPages);
    }

    function nextPageOrdenes() {
        let table = document.getElementById("tabla-ordenes-medicas").getElementsByTagName("tbody")[0];
        let totalPages = Math.ceil(table.getElementsByTagName("tr").length / rowsPerPageOrdenes);
        if (currentPageOrdenes < totalPages) {
            currentPageOrdenes++;
            paginateTableOrdenes();
        }
    }

    function previousPageOrdenes() {
        if (currentPageOrdenes > 1) {
            currentPageOrdenes--;
            paginateTableOrdenes();
        }
    }

    // Detectar cambios en la tabla de órdenes médicas
    function waitForTableUpdateOrdenes() {
        let observer = new MutationObserver(() => {
            paginateTableOrdenes();
        });

        let tableBody = document.getElementById("tabla-ordenes-medicas").getElementsByTagName("tbody")[0];
        if (tableBody) {
            observer.observe(tableBody, { childList: true, subtree: true });
        }
    }

    // Ejecutar paginación al cargar la página y cuando la tabla se actualice
    document.addEventListener("DOMContentLoaded", () => {
        paginateTableOrdenes();
        waitForTableUpdateOrdenes();
    });
</script>

