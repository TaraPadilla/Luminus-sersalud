        d.hospitalizacionProductoAplicacionId === producto.Id
    );

    const esAprobada = registroDevolucion && registroDevolucion.estado === "Aprobada";
    const esRechazada = registroDevolucion && registroDevolucion.estado === "Rechazada";

    // --- FILTRO DE OCULTAMIENTO ---
