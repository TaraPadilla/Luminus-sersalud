<style>
    .orden-dieta-aplicada { background-color: #f8d7da !important; }

    /* Grupos de botones */
    .grupo-botones {
        margin-bottom: 1.5rem;
    }
    .grupo-botones h6 {
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: #495057;
        border-left: 3px solid #0d6efd;
        padding-left: 0.75rem;
    }
    /* Grid con número fijo de columnas */
    .botones-grid {
        display: grid;
        gap: 0.75rem;
    }
    /* Escritorio grande: 4 columnas */
    @@media (min-width: 1200px) {
        .botones-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }
    /* Escritorio mediano / laptop: 3 columnas */
    @@media (min-width: 992px) and (max-width: 1199px) {
        .botones-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
    /* Tablet: 2 columnas */
    @@media (min-width: 576px) and (max-width: 991px) {
        .botones-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    /* Móvil: 1 columna */
    @@media (max-width: 575px) {
        .botones-grid {
            grid-template-columns: 1fr;
        }
    }
    /* Estilo uniforme de los botones */
    .botones-grid .btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.6rem 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
        text-align: center;
        white-space: normal;
        word-break: break-word;
        border-radius: 0.375rem;
        transition: all 0.2s;
        min-height: 48px;
    }
    /* Ajuste para iconos */
    .botones-grid .btn i {
        font-size: 1rem;
        flex-shrink: 0;
    }
</style>

