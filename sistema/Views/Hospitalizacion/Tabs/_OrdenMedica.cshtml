                    console.error(`⚠ Error inesperado: ${xhr.responseJSON ? xhr.responseJSON.Mensaje : xhr.responseText}`);
                }
            });
        });

        productosSeleccionados = [];
        actualizarListaProductos();
        $("#modalAgregarMedicamentos").dialog("close");

        // ✅ Si hay productos directos, registrar solicitudes despachadas
        @* if (productosSeleccionados.some(p => p.Directa)) { *@
