    let productosExistentes = [];

 function consultarMedicamentosExistentes() {
    @* let bodegaUsar = (TipoBodega === "Global") ? 14 : $("#BodegaId").val(); *@
    let cliente = $("#Cliente").val();

// 2. Aplicamos la condición
let bodegaUsar;

if (cliente === "SS") {
    bodegaUsar = 8;
} else {
    bodegaUsar = (TipoBodega === "Global") ? 14 : $("#BodegaId").val();
}
    
    $.ajax({
        method: "POST",
        url: '/HospitalizacionPaquetes/ConsultarProductosExistentes',
        data: { BodegaId: bodegaUsar },
        success: function (dataResult) {
            let data = JSON.parse(dataResult);
            if (data.Exitoso) {
                let agrupados = {};

                // Agrupar productos sin filtrar precios por seguro
                data.Resultado.forEach(producto => {
                    if (!agrupados[producto.ProductoId]) {
                        agrupados[producto.ProductoId] = {
                            ProductoId: producto.ProductoId,
                            ProductoNombre: producto.ProductoNombre,
                            Precios: []
                        };
                    }
                    // Agregar precio si no está duplicado
                    const precios = agrupados[producto.ProductoId].Precios;
                    if (!precios.some(p => p.PrecioId === producto.PrecioId)) {
                        precios.push({
                            PrecioId: producto.PrecioId,
                            PrecioValor: producto.PrecioValor,
                            PrecioNombre: producto.PrecioNombre
                        });
                    }
                });

                productosExistentes = Object.values(agrupados);

                // Llenar el select de productos
                let productoSelect = $('#productoSelect');
                productoSelect.empty().append('<option value="">Seleccione un producto</option>');

                productosExistentes.forEach(producto => {
                    if (producto.Precios.length > 0) {
                        productoSelect.append(`<option value="${producto.ProductoId}">${producto.ProductoNombre}</option>`);
                    }
                });

                if ($.fn.select2) {
                    $('#productoSelect').select2('destroy');
                    $('#productoSelect').select2({
                        theme: 'bootstrap4',
                        dropdownParent: $('#modalAgregarMedicamentos')
                    });
                }
            }
        },
        error: function () {
            alert('Error al consultar medicamentos existentes.');
        }
    });
}

