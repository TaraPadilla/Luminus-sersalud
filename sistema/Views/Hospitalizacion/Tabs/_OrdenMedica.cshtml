    function agregarExamenAHospitalizacion(codigoSeguro, examenesLista) {
    const hospitalizacionId = parseInt(hospitalizacionIdGlobal, 10);
    const pacienteId = parseInt($("#PacienteId").val(), 10);
    const cuentaId = parseInt($("#CuentaId").val(), 10);
 
    if (!Number.isInteger(hospitalizacionId) || hospitalizacionId <= 0) {
        mensajeEmergenteError("⚠ HospitalizacionId inválido. No se puede registrar el examen.");
        console.error("HospitalizacionId inválido:", hospitalizacionIdGlobal);
        return;
    }
    if (!Number.isInteger(pacienteId) || pacienteId <= 0) {
        mensajeEmergenteError("⚠ PacienteId inválido. No se puede registrar el examen.");
        return;
    }
    if (!Number.isInteger(cuentaId) || cuentaId <= 0) {
        mensajeEmergenteError("⚠ CuentaId inválido. No se puede registrar el examen.");
        return;
    }
    if (!codigoSeguro) {
        console.warn("⚠ CodigoSeguro vacío. Se usará fallback de precios en backend.");
    }
 
    // FIX BUG 1: Usar la lista pasada como parámetro, no la global
    const listaAUsar = (Array.isArray(examenesLista) && examenesLista.length > 0)
        ? examenesLista
        : examenesSeleccionados;
 
    if (!listaAUsar || listaAUsar.length === 0) {
        alert('Debe agregar al menos un examen.');
        return;
    }
 
    let examenesPayload = listaAUsar.map(examen => ({
        ExamenLabClinicoId: parseInt(examen.id, 10),
        // Las observaciones ya no se pueden leer del DOM porque el modal se cerró,
        // así que las tomamos del objeto si ya venían guardadas, o cadena vacía.
        Observacion: examen.observacion || ''
    })).filter(x => Number.isInteger(x.ExamenLabClinicoId) && x.ExamenLabClinicoId > 0);
 
    if (examenesPayload.length === 0) {
        mensajeEmergenteError("⚠ No hay exámenes con ID válido para registrar.");
        return;
    }
 
    let payload = {
        HospitalizacionId: hospitalizacionId,
        PacienteId: pacienteId,
        CuentaId: cuentaId,
        CodigoSeguro: codigoSeguro,
        Examenes: examenesPayload
    };
 
    console.log("📌 Payload /Hospitalizacion/AgregarExamen:", payload);
 
    $.ajax({
        url: "/Hospitalizacion/AgregarExamen",
        method: "POST",
        contentType: "application/json",
        data: JSON.stringify(payload),
        success: function (dataResult) {
            let data;
            try {
                data = (typeof dataResult === "string") ? JSON.parse(dataResult) : dataResult;
            } catch (e) {
                mensajeEmergenteError("⚠ Error interpretando respuesta al registrar exámenes.");
                return;
            }
 
            console.log("✅ Respuesta /Hospitalizacion/AgregarExamen:", data);
 
            if (data && data.Exitoso) {
                if (typeof detallesVm !== "undefined" && detallesVm) {
                    // FIX BUG 2: Destruir DataTable antes de que KO actualice el observable
                    // para evitar que ambos rendericen filas al mismo tiempo y dupliquen.
                    const tablaId = "tabla-producto-laboratorio";
                    if ($.fn.DataTable && $.fn.DataTable.isDataTable(`#${tablaId}`)) {
                        $(`#${tablaId}`).DataTable().destroy();
                        console.log("🗑 DataTable destruido antes de recarga KO");
                    }
 
                    // Resetear bandera y forzar recarga
                    detallesVm.examenesComplementariosCargados = false;
                    if (typeof detallesVm.consultarExamenesHospitalizacion === "function") {
                        detallesVm.consultarExamenesHospitalizacion(true);
                    }
                    if (typeof detallesVm.actualizarTotales === "function") {
                        detallesVm.actualizarTotales();
                    }
                }
            } else {
                console.error("❌ Backend respondió Exitoso=false:", data);
                mensajeEmergenteError("❌ " + (data && data.Mensaje ? data.Mensaje : "Error al registrar exámenes."));
            }
        },
        error: function (xhr) {
            console.error("❌ Error AJAX /Hospitalizacion/AgregarExamen:", xhr);
            mensajeEmergenteError("⚠ Error al agregar los exámenes.");
        }
    });
}


