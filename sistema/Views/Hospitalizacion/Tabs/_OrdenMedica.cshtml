<!-- jQuery UI JS -->
<script src="https://code.jquery.com/ui/1.12.1/jquery-ui.js"></script>

<script>
    let examenesSeleccionados = [];
    let dietasSeleccionadas = []; // { id: int, nombre: string }
    let dietasCatalogoCargado = false;

let quillOrdenMedica = null; // variable global para el editor

function verModalOrdenMedica() {
    cargarDietasExistentesOrdenMedica();

    $("#mdl-agregar-orden-medica").dialog({
        width: 1000,
        modal: true,
        open: function() {
            // Inicializar Quill solo una vez
            if (!quillOrdenMedica) {
                quillOrdenMedica = new Quill('#editor-orden-medica', {
                    theme: 'snow',
                    placeholder: 'Ingrese la descripción detallada de la orden...',
                    modules: {
                        toolbar: [
                            ['bold', 'italic', 'underline', 'strike'],
                            ['blockquote', 'code-block'],
                            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                            [{ 'script': 'sub'}, { 'script': 'super' }],
                            [{ 'indent': '-1'}, { 'indent': '+1' }],
                            [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
                            [{ 'color': [] }, { 'background': [] }],
                            ['clean']
                        ]
                    }
                });
            } else {
                // Si ya existe, limpiar el contenido
                quillOrdenMedica.root.innerHTML = '';
            }
        },
        close: function() {
            // Opcional: limpiar contenido al cerrar
            if (quillOrdenMedica) {
                quillOrdenMedica.root.innerHTML = '';
            }
            limpiarFormulario();
        },
        buttons: {
            "Cerrar": function () {
                $(this).dialog("close");
                limpiarFormulario();
            }
        }
    });
}

function agregarOrdenMedica() {
    // Obtener el contenido HTML del editor Quill
    const descripcion = quillOrdenMedica ? quillOrdenMedica.root.innerHTML.trim() : '';
    
    if (!descripcion) {
        alert('Debes ingresar una descripción para la orden médica.');
        return;
    }

    // El resto del código permanece igual...
    const observacionesExamenes = examenesSeleccionados.map(examen => {
        const obs = $(`input[data-observacion-id='${examen.id}']`).val() || '';
        return `EXAMEN: ${examen.nombre} | ${obs}`;
    });

    const observacionesDietas = dietasSeleccionadas.map(dieta => {
        const obs = $(`input[data-observacion-dieta-id='${dieta.id}']`).val() || '';
        return `DIETA: ${dieta.nombre} | ${obs}`;
    });

    const observaciones = [...observacionesExamenes, ...observacionesDietas];
    const examenes = examenesSeleccionados.map(e => e.nombre);
    const dietas = dietasSeleccionadas.map(d => d.nombre);
    const examenesParaRegistrar = examenesSeleccionados.length > 0 ? [...examenesSeleccionados] : [];

    const nuevaOrden = {
        Profesional: correoUsuario,
        Descripcion: descripcion,
        HospitalizacionId: hospitalizacionIdGlobal,
        Examenes: examenes.length > 0 ? examenes : null,
        Dietas: dietas.length > 0 ? dietas : null,
        Observaciones: observaciones.length > 0 ? observaciones : null
    };

    $.ajax({
        url: '/api/OrdenesMedicas/AgregarOrdenMedica',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(nuevaOrden),
        success: function () {
            $("#mdl-agregar-orden-medica").dialog("close");
            limpiarFormulario();
            cargarOrdenesMedicas();

            if (examenesParaRegistrar.length > 0) {
                agregarExamenAHospitalizacion(codigoSeguro, examenesParaRegistrar);
            }
        },
        error: function (xhr) {
            alert('Error al agregar la orden médica: ' + xhr.responseText);
        }
    });
}

    function cargarDietasExistentesOrdenMedica() {
        // Evitar recargas innecesarias
        if (dietasCatalogoCargado && $("#recetaSelect option").length > 1) return;

        $.ajax({
            url: '/Receta/ConsultarRecetasExistentes',
            type: 'POST',
            success: function (resp) {
                let data;
                try {
                    data = (typeof resp === 'string') ? JSON.parse(resp) : resp;
                } catch (e) {
                    console.error("Respuesta inválida ConsultarRecetasExistentes:", resp, e);
                    alert("Error al cargar dietas: respuesta inválida.");
                    return;
                }

                if (!data || data.Exitoso !== true || !Array.isArray(data.Resultado)) {
                    console.error("ConsultarRecetasExistentes no exitoso:", data);
                    alert("Error al cargar dietas.");
                    return;
                }

                const $select = $("#recetaSelect");
                $select.empty();
                $select.append(`<option value="">Seleccione una dieta</option>`);

                data.Resultado.forEach(function (r) {
                    if (!r) return;

                    const id = parseInt(r.Id, 10);
                    const nombre = (r.NombreReceta || "").trim();

                    if (!Number.isInteger(id) || id <= 0) return;
                    if (!nombre) return;

                    $select.append(`<option value="${id}">${nombre}</option>`);
                });

                dietasCatalogoCargado = true;
            },
            error: function (xhr) {
                console.error("Error ConsultarRecetasExistentes:", xhr);
                alert("Error al cargar dietas.");
            }
        });
    }

function agregarExamenALaLista() {
    const examenNombre = $('#examenSelect option:selected').text();
    const examenIdRaw = $('#examenSelect').val();
    const examenId = parseInt(examenIdRaw, 10);
 
    if (!examenNombre || examenNombre === "Seleccione un examen") {
        alert('Debes seleccionar un examen válido.');
        return;
    }
    if (!Number.isInteger(examenId) || examenId <= 0) {
        alert('El examen seleccionado no tiene un ID válido.');
        return;
    }
    if (examenesSeleccionados.some(e => e.id === examenId)) {
        alert('Este examen ya ha sido agregado.');
        return;
    }
 
    examenesSeleccionados.push({ id: examenId, nombre: examenNombre, observacion: '' });
 
    $('#listaGeneralAgregados').append(`
        <li class="list-group-item d-flex justify-content-between align-items-center"
            data-tipo="EXAMEN" data-id="${examenId}">
            <div>
                <span class="badge badge-primary mr-2">EXAMEN</span>
                <span>${examenNombre}</span>
            </div>
            <div class="d-flex align-items-center">
                <input type="text" class="form-control mr-2" placeholder="Observaciones"
                       style="width: 220px;" data-observacion-id="${examenId}"
                       oninput="actualizarObservacionExamen(${examenId}, this.value)">
                <button class="btn btn-danger btn-sm" onclick="eliminarExamenDeLaLista(${examenId})">Eliminar</button>
            </div>
        </li>
    `);
}

function actualizarObservacionExamen(examenId, valor) {
    const item = examenesSeleccionados.find(e => e.id === examenId);
    if (item) item.observacion = valor;
}
    function eliminarExamenDeLaLista(examenId) {
        examenesSeleccionados = examenesSeleccionados.filter(e => e.id !== examenId);
        $(`#listaGeneralAgregados li[data-tipo='EXAMEN'][data-id='${examenId}']`).remove();
    }

    function agregarDietaALaLista() {
        const recetaNombre = $('#recetaSelect option:selected').text();
        const recetaIdRaw = $('#recetaSelect').val();

        const recetaId = parseInt(recetaIdRaw, 10);

        if (!recetaNombre || recetaNombre === "Seleccione una dieta") {
            alert('Debes seleccionar una dieta válida.');
            return;
        }

        if (!Number.isInteger(recetaId) || recetaId <= 0) {
            alert('La dieta seleccionada no tiene un ID válido.');
            return;
        }

        // Unicidad por ID numérico
        if (dietasSeleccionadas.some(d => d.id === recetaId)) {
            alert('Esta dieta ya ha sido agregada.');
            return;
        }

