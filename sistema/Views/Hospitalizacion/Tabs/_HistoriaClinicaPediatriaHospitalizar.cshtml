@model sistema.Models.HospitalizacionDetallesViewModel
@{
    var estadoGeneral = Model.Consulta?.ExamenFisico?.EstadoGeneral ?? "-";
    var motivoConsulta = Model.Consulta?.ConsultaMotivoPediatria ?? "-";
    var historiaEnfermedadActual = Model.Consulta?.HistoriaPediatria?.HistoriaEnfermedadActual ?? "-";
    var antecedentesMedicos = Model.Consulta?.Citas?.Paciente?.AntecedentesMedicos ?? "-";
    var antecedentesQuirurgicos = Model.Consulta?.Citas?.Paciente?.AntecedentesQuirurgicos ?? "-";
    var antecedentesAlergicos = Model.Consulta?.Citas?.Paciente?.AntecedentesAlergias ?? "-";
    var antecedentesTraumaticos = Model.Consulta?.Citas?.Paciente?.AntecedentesTraumaticos ?? "-";
    var antecedentesVicios = Model.Consulta?.Citas?.Paciente?.AntecedentesVicios ?? "-";
    var antecedentesMedicamentos = Model.Consulta?.Citas?.Paciente?.AntecedentesMedicamentos ?? "-";
    var peso = Model.Consulta?.ExamenFisico?.Peso?.ToString() ?? "-";
    var talla = Model.Consulta?.ExamenFisico?.Talla?.ToString() ?? "-";
    var frecuenciaCardiaca = Model.Consulta?.ExamenFisico?.FrecuenciaCardiaca?.ToString() ?? "-";
    var frecuenciaRespiratoria = Model.Consulta?.ExamenFisico?.FrecuenciaRespiratoria?.ToString() ?? "-";
    var presionArterial = Model.Consulta?.ExamenFisico?.PresionArterial ?? "-";
    var temperatura = Model.Consulta?.ExamenFisico?.Temperatura?.ToString() ?? "-";
    var saturacionOxigeno = Model.Consulta?.ExamenFisico?.SaturacionDeOxigeno?.ToString() ?? "-";
    var glasgow = Model.Consulta?.ExamenFisico?.Glasgow?.ToString() ?? "-";
    var comentario = Model.Consulta?.HistoriaPediatria?.Comentario ?? "-";
    var impresionClinica = Model.Consulta?.HistoriaPediatria?.ImpresionClinica ?? "-";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>


<br />
<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <h5><b>Historia cl&iacute;nica Pedi&aacute;trica</b></h5>
                <hr />
            </div>
            <div class="col-md-4">
                <b>Motivo de consulta</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @motivoConsulta
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Historia de la enfermedad actual</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @historiaEnfermedadActual
                </textarea>
            </div>
        </div>
        @* <br />
