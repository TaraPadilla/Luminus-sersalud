<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <h5><b>Antecedentes patológicos</b></h5>
                <hr />
            </div>
            <div class="col-md-4">
                <b>Medicos:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesMedicos
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Quirúrgicos:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesQuirurgicos
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Alergicos:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesAlergicos
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Traumáticos:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesTraumaticos
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Vicios y/o manías:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesVicios
                </textarea>
            </div>
            <div class="col-md-4">
                <b>Medicamento de uso actual:</b><br />
                <textarea class="form-control dato-consulta" readonly>
                    @antecedentesMedicamentos
                </textarea>
            </div>
        </div>
    </div>
</div>

<br />
<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <h5><b>Examen físico</b></h5>
                <hr>
            </div>
            <div class="col-md-5">
                <b>ESTADO GENERAL:</b><br>
                @Html.TextBoxFor(m => estadoGeneral , new { @class = "form-control dato-consulta", @readonly = "readonly" })
            </div>
            <div class="col-md-4">
                <b>PESO (KG):</b><br />
                @Html.TextBoxFor(m => peso, new { @class = "form-control dato-consulta", @placeholder = "Peso", @onchange = "getIMC()", @readonly = "readonly" })
            </div>
            <div class="col-md-3">
                TALLA (M):<br />
                @Html.TextBoxFor(m => talla, new { @class = "form-control dato-consulta", @placeholder = "Talla", @onchange = "getIMC()", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                FC:<br>
                @Html.TextBoxFor(m => frecuenciaCardiaca, new { @class = "form-control dato-consulta", @placeholder = "Frecuencia cardiaca", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                FR:<br>
                @Html.TextBoxFor(m => frecuenciaRespiratoria, new { @class = "form-control dato-consulta", @placeholder = "Frecuencia respiratoria", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                P/A:<br>
                @Html.TextBoxFor(m => presionArterial, new { @class = "form-control dato-consulta", @placeholder = "P/A", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                TEMP:<br>
                @Html.TextBoxFor(m => temperatura, new { @class = "form-control dato-consulta", @placeholder = "Temperatura", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                SpO2:<br>
                @Html.TextBoxFor(m => saturacionOxigeno, new { @class = "form-control dato-consulta", @placeholder = "Saturación de oxígeno", @readonly = "readonly" })
            </div>
            <div class="col-md-2">
                GLASGOW:<br>
                @Html.TextBoxFor(m => glasgow, new { @class = "form-control dato-consulta", @readonly = "readonly" })
            </div>
        </div>
        @* <br />
