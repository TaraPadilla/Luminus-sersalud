                        }
                    </div> *@
                    <div class="col-md-4">
                        <b>Seguro</b><br />
                        <label class="badge badge-warning">
                            @(string.IsNullOrEmpty(Model.CodigoSeguro) ? "Sin seguro" : Model.CodigoSeguro)
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


