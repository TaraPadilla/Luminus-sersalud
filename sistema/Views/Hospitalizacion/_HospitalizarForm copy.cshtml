@using Database.Shared.Enumeraciones
@model sistema.Models.HospitalizacionHospitalizarViewModel
@Html.HiddenFor(a => a.EspecialidadId)
@Html.HiddenFor(a => a.PacienteId)
@Html.HiddenFor(a => a.ConsultaId)
@Html.HiddenFor(a => a.EmergenciaId)
@Html.HiddenFor(a => a.CodigoSeguro)
