                            options: especialidades,
                            optionsText: 'NombreEspecialidad',
                            optionsValue: 'Id',
                            value: especialidadId,
                            event: {
                            change: function () {
                            var id = especialidadId();
                            var sel = null;

                            // Buscar objeto seleccionado para mantener especialidadSeleccionada y nombre
                            ko.utils.arrayForEach(especialidades(), function (e) {
                            if (e && e.Id == id) { sel = e; }
                            });

                            especialidadSeleccionada(sel);
                            especialidadNombre(sel ? sel.NombreEspecialidad : 'Medicina General');

                            // Regla: si queda vacío/0, forzar MG
                            if (!id || id == 0) {
                            especialidadId(1);
                            especialidadNombre('Medicina General');
                            especialidadSeleccionada(null);
                            }
                            }
                            }">
                        </select>
