                                                    </a>
                                                    @* <!-- Verifica si la URL del archivo está presente y muestra el iframe -->
                <!-- Si la URL está vacía, muestra un mensaje -->
                <div data-bind="if: urlArchivoConsentimiento() && urlArchivoConsentimiento() !== ''">
                    <iframe data-bind="attr: { src: urlArchivoConsentimiento }" width="100%" height="400px"
                        style="zoom:3;"></iframe>
                </div>
                <div data-bind="if: !urlArchivoConsentimiento() || urlArchivoConsentimiento() === ''">
                    <p class="text-danger">No hay archivo de consentimiento cargado.</p>
                </div>  *@
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <script>

                                        document.addEventListener("DOMContentLoaded", function () {
                                            var habitacionId = '@habitacionId'; // El valor de habitacionId
                                            var consultaId = '@consultaId'; // El valor de consultaId
                                            var pacienteId = '@Model.PacienteId'; // El valor de pacienteId desde el modelo
                                            var citaId = '@Model.CitaId'; // El valor de citaId desde el modelo

                                            // Iniciar el intervalo para verificar cambios en pacienteId
                                            var interval = setInterval(function () {
                                                // Verificar si pacienteId es nulo o 0 y obtener el valor del input si es necesario
                                                if (!pacienteId || pacienteId === "0") {
                                                    pacienteId = document.querySelector('[data-bind="value:pacienteId"]').value; // Obtener el valor del input
                                                }

                                                // Solo actualizar el enlace si pacienteId ya tiene un valor válido
                                                if (pacienteId && pacienteId !== "0") {
                                                    // Generar la URL usando Url.Action con todos los parámetros, incluyendo citaId
                                                    var newHref = '@Url.Action("CrearFormConsentimientoHospi", "Pacientes", new { HabitacionId = "__habitacionId__", PacienteId = "__pacienteId__", ConsultaId = "__consultaId__", CitaId = "__citaId__" })'
                                                        .replace('__habitacionId__', habitacionId)
                                                        .replace('__pacienteId__', pacienteId)
                                                        .replace('__consultaId__', consultaId)
                                                        .replace('__citaId__', citaId);

                                                    // Reemplazar '&amp;' con '&' para obtener el formato correcto en la URL
                                                    newHref = newHref.replace(/&amp;/g, '&');

                                                    document.getElementById('irAhora').href = newHref;
                                                    console.log(newHref);

                                                    // Detener el intervalo una vez que el valor se haya actualizado
                                                    clearInterval(interval);
                                                }
                                            }, 500); // Ejecutar cada 500ms

                                            function consultarExistenciaConsentimiento() {
                                                $.ajax({
                                                    url: "/ConsentimientoHospi/ObtenerPorPacienteYHabitacion",
                                                    method: "GET",
                                                    data: {
                                                        pacienteId: parseInt(pacienteId),
                                                        habitacionId: parseInt(habitacionId)
                                                    },
                                                    success: function (dataResult) {
                                                        let data = JSON.parse(dataResult);
                                                        if (data.exitoso) {
                                                            @* console.log(data.resultado); *@
                                                                $('#mensajeConsulta').show(); // Muestra el mensaje de la consulta
                                                            // Si existe el consentimiento, muestra el botón de impresión
                                                            $('#botonImprimir').show();
                                                            $('#botonImprimir2').show();
                                                            $('#btnFinalizar').show(); // Mostrar el botón de finalizar
                                                            $('#mensajeConsentimiento').hide(); // Ocultar mensaje
                                                        } else {
                                                            @* console.log(data.mensaje); *@
                                                                $('#mensajeConsulta').hide();
                                                            $('#botonImprimir').hide();
                                                            $('#botonImprimir2').hide();
                                                            $('#btnFinalizar').hide(); // Ocultar el botón de finalizar
                                                            $('#mensajeConsentimiento').show(); // Mostrar mensaje
                                                        }
                                                    },
                                                    error: function (dataError) {
                                                        @* console.log(dataError); *@
                                                    }
                                                });
