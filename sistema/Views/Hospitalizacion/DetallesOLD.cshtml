@if (!User.IsInRole("Medico General") && !User.IsInRole("Coordinador Laboratorio") && !User.IsInRole("Tecnico laboratorio") && !User.IsInRole("Enfermeria"))
{
    <div class="row">
        <!-- Cambiar seguro -->
        <div class="col-12 col-md-4">
            <div class="main-card mb-3 card">
                <div class="card-body">
                    <select id="seguroSelect" class="form-control select2bs4" style="width: 100%;">
                        <option value="">Seleccionar seguro...</option>
                        @foreach (var item in Model.SegurosSelectListItem)
                        {
                            <option value="@item.Text">@item.Text</option>
                        }
                    </select>

                    <button class="btn btn-primary mt-2" onclick="actualizarSeguro(@Model.CitaIdPDF, @Model.HospitalizacionId)">
                        <i class="fas fa-check"></i> Cambiar seguro
                    </button>
                </div>
            </div>
        </div>

        <!-- Médico principal -->
        <div class="col-12 col-md-4">
            <div class="main-card mb-3 card">
                <div class="card-body">
                    <select id="medicoAsignadoSelect" class="form-control select2bs4" style="width: 100%;">
                        <option value="">Seleccionar médico principal...</option>
                        @foreach (var item in Model.DoctoresSelectListItem)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>

                    <button class="btn btn-primary mt-2" onclick="actualizarMedicoAsignado(@Model.CitaIdPDF)">
                        <i class="fas fa-check"></i> Cambiar Médico Principal
                    </button>
                </div>
            </div>
        </div>

        <!-- Médicos secundarios (Contenedor separado) -->
        <div class="col-12 col-md-4">
            <div class="main-card mb-3 card">
                <div class="card-body">
                    <!-- Selector para agregar médicos secundarios -->
                    <select id="medicoSecundarioSelect" class="form-control select2bs4" style="width: 100%;">
                        <option value="">Seleccionar médico secundario...</option>
                        @foreach (var item in Model.DoctoresSelectListItem)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>

                    <button class="btn btn-primary mt-2" onclick="agregarMedicoSecundario(@Model.CitaIdPDF)">
                        <i class="fas fa-user-plus"></i> Agregar Médico Secundario
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- Contenedor de Médicos Secundarios -->
    <div class="row mt-3">
        <div class="col-12">
            <div class="main-card mb-3 card">
                <div class="card-body">
                    <h6 class="mt-3">Médicos Secundarios:</h6>
                    <ul id="listaMedicosSecundarios" class="list-group">
                        @foreach (var secundario in Model.MedicosSecundarios)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center" id="medico-secundario-@secundario.Id">
                                @secundario.NombreCompleto
                                <button class="btn btn-sm btn-danger" onclick="quitarMedicoSecundario(@Model.CitaIdPDF, @secundario.Id, this)">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

