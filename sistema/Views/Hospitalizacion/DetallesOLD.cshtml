<script>
    // Variable global para almacenar la data y evitar repetir consultas
    var pdfDataLoaded = false;
    var pdfRecords = []; // Listado de registros traídos de GetByHospitalizacionId

    // Función que actúa como interruptor para mostrar/ocultar la sección de PDFs
    function togglePdfSection() {
        var $pdfSection = $("#pdfSection");
        var $btnText = $("#togglePdfBtnText");
        if ($pdfSection.is(":visible")) {
            $pdfSection.slideUp();
            $btnText.text("Ver PDFs");
        } else {
            if (!pdfDataLoaded) {
                loadPdfData();
            }
            $pdfSection.slideDown();
            $btnText.text("Ocultar PDFs");
        }
    }

    // Función para cargar la data de PDFs desde el servidor
    function loadPdfData() {
        var hospitalizacionId = $("#HospitalizacionId").val();
        $.ajax({
            url: '/HospitalizacionExamenPdf/GetByHospitalizacionId',
            type: 'GET',
            data: { hospitalizacionId: hospitalizacionId },
            success: function (response) {
                // Suponemos que 'response' es un array de objetos que ya incluyen la propiedad "NombreExamen"
                pdfRecords = response;
                // Agrupar registros por examenId
                var groups = {}; // clave: examenId, valor: array de registros
                $.each(pdfRecords, function (index, record) {
                    var examId = record.examenId;
                    if (!groups[examId]) {
                        groups[examId] = [];
                    }
                    groups[examId].push(record);
                });
                // Renderizar las tarjetas con las tablas para cada grupo (sin encabezado extra)
                renderPdfTables(groups);
                pdfDataLoaded = true;
            },
            error: function () {
                alert("Error al obtener los registros de PDFs.");
            }
        });
    }

    // Función para generar y renderizar las tarjetas con tablas según los grupos de examenId
    function renderPdfTables(groups) {
        var $container = $("#pdfSection");
        $container.empty(); // Limpiar contenido anterior

        $.each(groups, function (examId, records) {
            // Se construye la tarjeta (card) para cada grupo
            var cardHtml = "<div class='col-md-12' style='padding:0; margin-bottom:20px;'>" +
                               "<div class='main-card mb-3 card' style='border-radius: 10px;'>" +
                                   "<div class='card-body'>" +
                                       "<div class='table-responsive'>" +
                                           "<table class='table table-bordered'>" +
                                               "<thead>" +
                                                   "<tr>" +
                                                       "<th>Nombre Examen</th>" +
                                                       "<th>PDF URL</th>" +
                                                       "<th>Estado</th>" +
                                                       "<th>Fecha de Creación</th>" +
                                                       "<th>Usuario</th>" +
                                                       "<th>Principal</th>" +
                                                   "</tr>" +
                                               "</thead>" +
                                               "<tbody>";

            $.each(records, function (index, record) {
                cardHtml += "<tr>" +
                                "<td>" + record.nombreExamen + "</td>" +
                                "<td><a href='" + record.pdfUrl + "' target='_blank'>" + record.pdfUrl + "</a></td>" +
                                "<td>" + (record.eliminado ? "Eliminado" : "Activo") + "</td>" +
                                "<td>" + record.fechaCreacionFormatted + "</td>" +
                                "<td>" + record.userId + "</td>" +
                                "<td>" + (record.isPrincipalPdf ? "Sí" : "No") + "</td>" +
                            "</tr>";
            });

            cardHtml +=         "</tbody>" +
                                       "</table>" +
                                   "</div>" +
                               "</div>" +
                           "</div>" +
                        "</div>";

            $container.append(cardHtml);
        });
    }
</script>

}