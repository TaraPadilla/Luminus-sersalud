<script>
    // Función para cargar la vista de edición al cargar la página
    $(document).ready(function() {
        // Cargar historial de consultas y luego cargar la vista de edición de la última consulta
        consultarHistorialConsultasPaciente(); 
    });

    // Función para obtener el ID de la última consulta
    function obtenerConsultaIdMasReciente(historial) {
        if (historial && historial.length > 0) {
            return historial[0].ConsultaId; // Asegúrate de que el formato del resultado es correcto
        }
        return null;
    }

    // Función para consultar historial de consultas
    function consultarHistorialConsultasPaciente() {
        let textoCargando = $("#texto-cargando-consultas");
        let textoError = $("#texto-error-consultar-consultas");
        textoCargando.show();
        textoError.hide();

        $.ajax({
            url: "/Hospitalizacion/ConsultarHistorialConsultasPaciente",
            method: "POST",
            data: {
                pacienteId: $("#PacienteId").val()
            },
            success: function(result) {
                textoCargando.hide();
                let data = JSON.parse(result);

                if (data.Exitoso) {
                    let historial = data.Resultado;

                    // Obtener el ID de la consulta más reciente
                    let consultaId = obtenerConsultaIdMasReciente(historial);

                    if (consultaId) {
                        // Llamar a la función para cargar la vista de edición
                        cargarVistaEditarConsulta(consultaId);
                    } else {
                        textoError.show();
                    }
                } else {
                    textoError.show();
                }
            },
            error: function(resultError) {
                textoCargando.hide();
                textoError.show();
                console.log(resultError);
            }
        });
    }


    // Cargar la vista de edición directamente
    function cargarVistaEditarConsulta(consultaId) {
        var url = '/Consultas/EditarConsultaHistoriaClinicaHospitalizacion/' + consultaId;

        $('#contenedor-editar-consulta-historia-clinica').html('<p>Cargando vista de edición...</p>');

        $.ajax({
            url: url,
            type: 'GET',
            success: function(response) {
                $('#contenedor-editar-consulta-historia-clinica').html(response); // Cargar la vista de edición en el contenedor
            },
            error: function() {
                $('#contenedor-editar-consulta-historia-clinica').html('<p>Error al cargar la vista de edición.</p>');
            }
        });
    }
</script>
<script>
      
function actualizarSeguro(citaId,hospitalizacionId) {
    const seguroSeleccionado = document.getElementById("seguroSelect").value;

    if (!seguroSeleccionado) {
        alert("⚠️ Error: No has seleccionado un seguro. Por favor selecciona uno antes de continuar.");
        return;
    }

    // Confirmación del usuario
    const confirmacion = confirm(`¿Estás seguro de cambiar el seguro a: ${seguroSeleccionado}?`);
    if (!confirmacion) {
        alert("Operación cancelada por el usuario.");
        return;
    }

    // Enviar solicitud al servidor
    fetch('/Hospitalizacion/ActualizarCodigoSeguro', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        },
        body: JSON.stringify({
            citaId: citaId,
            hospitalizacionId: hospitalizacionId,
            nuevoCodigoSeguro: seguroSeleccionado 
        }),
    })
    .then(response => {
        if (!response.ok) {
            // Manejo de errores HTTP (500, 404, etc.)
            throw new Error(`HTTP error! Status: ${response.status} - ${response.statusText}`);
        }
        return response.json();
    })
    .then(data => {
        if (data.exitoso) {
            console.log(`Éxito al cambiar el seguro`);        
            location.reload(); 
        } else {
            alert(`Error: ${data.Mensaje}`);
        }
    })
    .catch(error => {
        console.error('Error inesperado:', error);
        alert(`Error inesperado: Ocurrió un problema al comunicarse con el servidor. Detalles: ${error.message}`);
    });
}

      
