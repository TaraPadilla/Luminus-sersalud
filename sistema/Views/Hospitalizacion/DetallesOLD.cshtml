                            <div class="col-md-12 mb-3">
                                <input type="text" class="form-control" id="buscarInput" placeholder="Buscar..." oninput="filtrarTabla()">
                            </div>
                            <div class="col-md-12 mb-3">
                                <select class="form-control" id="cantidadSelect" onchange="cambiarCantidad()">
                                    <option value="10" selected>Mostrar 10</option>
                                    <option value="20">Mostrar 20</option>
                                    <option value="30">Mostrar 30</option>
                                </select>
                            </div>
                            <div class="col-md-12">
                                <table class="table table-hover" id="tablaPaquetes">
                                    <thead>
                                        <tr>
                                            <th>Tipo</th>
                                            <th>Codigo</th>
                                            <th>Nombre</th>
                                            <th>Descripci&oacute;n</th>
                                            <th>Cantidad</th>
                                            <th>Cantidad Aplicada</th>
                                            <th>Aplicado</th>
                                            <th>Fecha y hora de aplicaci&oacute;n</th>
                                            <th>Persona</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!--ko foreach: listaProductosAplicacion-->
                                        <tr class="tabla-item">
                                            <td><span class="badge badge-danger" data-bind="text:Tipo"></span></td>
                                            <td data-bind="text:Codigo"></td>
                                            <td data-bind="text:Nombre"></td>
                                            <td data-bind="text:Descripcion"></td>
                                            <td data-bind="text: Cantidad"></td>
                                            <td data-bind="text: CantidadAplicados()"></td>

                                            <td>
                                                <label class="badge badge-success" data-bind="if:Aplicado">SI</label>
                                                <label class="badge badge-danger" data-bind="ifnot:Aplicado">NO</label>
                                            </td>
                                            <td data-bind="text:FechaHoraAplicacion"></td>
                                            <td data-bind="text:Persona"></td>
                                            <td style="display: flex; align-items: center; gap: 10px;">
                                            <input type="number" class="form-control" 
                                                data-bind="value: CantidadAplicar, valueUpdate: 'input', attr: { max: Cantidad - CantidadAplicados, min: 1 }" 
                                                style="width: 70px; display: inline-block;">
                                                <!--ko if: Cantidad() > CantidadAplicados() -->
                                                <button class="btn btn-primary" data-bind="click: function() { $root.aplicarPaquete($data); }">
                                                    <i class="fas fa-syringe"></i>
                                                </button>
                                                <!--/ko-->
                                            </td>

                                        </tr>
                                        <!--/ko-->
                                    </tbody>
                                </table>
                            </div>
                            <div class="col-md-12 text-center mt-3">
                                <button class="btn btn-outline-primary" onclick="paginaAnterior()">&#9665; Anterior</button>
                                <span class="mx-3 font-weight-bold" id="paginaActual">1</span>
                                <button class="btn btn-outline-primary" onclick="paginaSiguiente()">Siguiente &#9655;</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let pagina = 1;
    let cantidad = 10;

    function cambiarCantidad() {
        cantidad = parseInt(document.getElementById("cantidadSelect").value);
        pagina = 1;
        mostrarPagina();
    }

    function paginaAnterior() {
        if (pagina > 1) {
            pagina--;
            mostrarPagina();
        }
    }

    function paginaSiguiente() {
        let totalFilas = document.querySelectorAll('#tablaPaquetes tbody tr:not(.hidden)').length;
        if ((pagina * cantidad) < totalFilas) {
            pagina++;
            mostrarPagina();
        }
    }

    function mostrarPagina() {
        let filas = document.querySelectorAll('#tablaPaquetes tbody tr:not(.hidden)');
        filas.forEach((fila, index) => {
            fila.style.display = (index >= (pagina - 1) * cantidad && index < pagina * cantidad) ? '' : 'none';
        });
        document.getElementById('paginaActual').innerText = pagina;
    }

    function filtrarTabla() {
        let valor = document.getElementById("buscarInput").value.toLowerCase();
        let filas = document.querySelectorAll('#tablaPaquetes tbody tr');
        filas.forEach(fila => {
            let texto = fila.innerText.toLowerCase();
            fila.classList.toggle('hidden', !texto.includes(valor));
            fila.style.display = texto.includes(valor) ? '' : 'none';
        });
        pagina = 1;
        mostrarPagina();
    }

    window.onload = function () {
        cambiarCantidad();
    }
</script>

