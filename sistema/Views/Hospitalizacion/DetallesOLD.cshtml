<script>
    // Función genérica para alternar la visibilidad de un contenedor
    function toggleSection(contentId, buttonId, callback) {
        let content = document.getElementById(contentId);
        let button = document.getElementById(buttonId);
        if (content.classList.contains("d-none")) {
            content.classList.remove("d-none");
            button.innerHTML = "⬆️";
            if (callback) callback();
        } else {
            content.classList.add("d-none");
            button.innerHTML = "⬇️";
        }
    }

    // Objeto para almacenar el estado de paginación de cada tabla o grupo de tablas.
    // Cuando se usan ids, se usa la clave directamente; si se usan clases, se generará una clave única por cada índice.
    var paginationStates = {};

    /**
     * Configura la paginación en una o varias tablas.
     * {string} tableId - Si useClass es false, se trata del id de la tabla; si es true, se trata de la clase.
     * {string} controlsId - Id o clase del contenedor con los botones de paginación.
     * {string} pageInfoId - Id o clase del elemento donde se muestra la info de página.
     * {number} rowsPerPage - Número de filas a mostrar por página.
     * {boolean} [useClass=false] - Si es true, se buscarán elementos por clase en lugar de por id.
     */
    function setupTablePagination(tableId, controlsId, pageInfoId, rowsPerPage, useClass = false) {
        // Obtener los elementos: si se usa clases, se convierten a Array; de lo contrario, se encapsulan en un array.
        let tables = useClass ? Array.from(document.getElementsByClassName(tableId))
                              : [document.getElementById(tableId)];
        let controlsList = useClass ? Array.from(document.getElementsByClassName(controlsId))
                                    : [document.getElementById(controlsId)];
        let pageInfoList = useClass ? Array.from(document.getElementsByClassName(pageInfoId))
                                    : [document.getElementById(pageInfoId)];

        // Iterar por cada grupo (tabla, controles e info de página)
        tables.forEach((table, index) => {
            // Generar una clave única para esta tabla (en caso de usar clases)
            let stateKey = useClass ? tableId + "_" + index : tableId;
            paginationStates[stateKey] = { currentPage: 1, rowsPerPage: rowsPerPage };

            // Función interna que aplica la paginación a esta tabla.
            function paginate() {
                let state = paginationStates[stateKey];
                // Obtener el tbody de la tabla
                let tbody = table.getElementsByTagName("tbody")[0];
                if (!tbody) return;
                let rows = Array.from(tbody.getElementsByTagName("tr"));
                let totalPages = Math.max(1, Math.ceil(rows.length / state.rowsPerPage));

                rows.forEach((row, idx) => {
                    row.style.display = (idx >= (state.currentPage - 1) * state.rowsPerPage &&
                                         idx < state.currentPage * state.rowsPerPage) ? "table-row" : "none";
                });

                // Actualizar la información de la página.
                if (pageInfoList[index]) {
                    pageInfoList[index].innerText = "Página " + state.currentPage + " de " + totalPages;
                }

                // Actualizar los botones de navegación.
                let controls = controlsList[index];
                if (controls) {
                    let prevButton = controls.querySelector("button.prev");
                    let nextButton = controls.querySelector("button.next");
                    if (prevButton) prevButton.disabled = (state.currentPage === 1);
                    if (nextButton) nextButton.disabled = (state.currentPage >= totalPages);
                }
            }

            // Función para avanzar a la siguiente página.
            function next() {
                let state = paginationStates[stateKey];
                let tbody = table.getElementsByTagName("tbody")[0];
                let totalPages = Math.max(1, Math.ceil(tbody.getElementsByTagName("tr").length / state.rowsPerPage));
                if (state.currentPage < totalPages) {
                    state.currentPage++;
                    paginate();
                }
            }

            // Función para retroceder a la página anterior.
            function previous() {
                let state = paginationStates[stateKey];
                if (state.currentPage > 1) {
                    state.currentPage--;
                    paginate();
                }
            }

            // Usar MutationObserver para detectar cambios en el tbody y actualizar la paginación.
            let tbody = table.getElementsByTagName("tbody")[0];
            if (tbody) {
                const observer = new MutationObserver(function() {
                    paginationStates[stateKey].currentPage = 1;
                    paginate();
                });
                observer.observe(tbody, { childList: true, subtree: true });
            }

            // Asignar los eventos a los botones (se asume que tienen las clases "prev" y "next").
            let controls = controlsList[index];
            if (controls) {
                let prevButton = controls.querySelector("button.prev");
                let nextButton = controls.querySelector("button.next");
                if (prevButton) prevButton.addEventListener("click", previous);
                if (nextButton) nextButton.addEventListener("click", next);
            }

            // Llamada inicial para aplicar la paginación.
            paginate();
        });
    }
</script>

<div class="main-card mb-3 card">
    <div style="text-align: center;">
        <img src="@logoBase64" 
             style="max-width: 100%; height: auto; width: 300px;">
    </div>
    <div class="card-body">
        <div class="col-md-12">
            <center><h4><b>Admisión #@Model.HospitalizacionId</b></h4></center>
            <hr />
            @if (!Model.Pagada)
            {
                @if (!User.IsInRole("Enfermeria"))
                {
                    <button class="btn btn-success mr-2"
                            data-bind="click:pagarCuenta">                        
                        <i class="fas fa-dollar-sign"></i>&nbsp;
                        Pagar Q <span data-bind="text:totalPagar"></span>
                    </button>                    
                    <button class="btn btn-primary" data-bind="click:verModalCambioHabitacion">
                        Cambiar de habitaci&oacute;n
                    </button>
                } 
            }
            @if (!User.IsInRole("Enfermeria"))
            {
                 <button class="btn btn-danger" data-bind="click:verInformeGeneral">
                    <i class="fas fa-file-pdf"></i>&nbsp;Informe general
                </button> 
                <button class="btn btn-danger" data-bind="click:verExpedientePaciente">
                    <i class="fas fa-file-pdf"></i> Expediente del paciente 
                </button>
            }
            <a class="btn btn-danger" 
               href="@Url.Action("GenerarPDFConsentimientoHospiHospi", "CrearPDF", new { idPaciente = @Model.PacienteIdPDF, idHabitacion = @Model.HabitacionIdPDF, idHospi = @idHospi })" target="_blank">
                <i class="fas fa-file-pdf"></i>&nbsp;Consentimiento de Hospitalización
            </a>
            <a class="btn btn-danger" href="@Url.Action("GenerarPDFAdmisionPacientes","CrearPDF", new {id = @Model.CitaIdPDF})" target="_blank">
                <i class="fas fa-file-pdf"></i>&nbsp;Reporte de Admisión
            </a>
            <a class="btn btn-success" style="color:white">
                <i class="fas fa-shield"></i> SEGURO: @(string.IsNullOrEmpty(Model.CodigoSeguro) ? "SIN SEGURO" : Model.CodigoSeguro)
            </a>
            <a class="btn btn-success" style="color:white">
                <i class="fas fa-shield"></i> MEDICO: @(string.IsNullOrEmpty(Model.MedicoAsignado) ? "SIN MEDICO" : Model.MedicoAsignado)
            </a>
        </div>
    </div>
</div>

