   @model sistema.Models.HospitalizacionDetallesViewModel
@{
    var usuarioAdmisiones = User.IsInRole("Admisiones");
} 
<div class="tab-pane tabs-animation fade " id="tab-content-archivos" role="tabpanel">
                <div class="main-card mb-3 card" style="border-radius: 10px">
                    <div class="card-body">
                        <div class="form-row">
                            <div class="col-md-12">
                                <h5><b>Archivos de consultas</b></h5>
                            </div>
                            <div class="col-md-12 text-primary" style="display:none" id="texto-cargando-archivos-paciente">
                                Cargando archivos...
                            </div>
                            <div class="col-md-12 text-danger" style="display:none" id="texto-error-consultar-archivos-paciente">
                                Error de conexion.
                                <a href="#" data-bind="click: consultarArchivosPaciente">Reintentar</a>
                            </div>
                            <div class="col-md-12 table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th>Fecha de carga</th>
                                            <th>Nombre</th>
                                            <th>Ver</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!--ko foreach: archivosPaciente-->
                                        <tr>
                                            <td data-bind="text:ArchivoFecha"></td>
                                            <td data-bind="text:ArchivoNombre"></td>
                                            <td>
                                                <a data-bind="attr:{href:ArchivoUrl}" href="#" target="_blank">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        <!--/ko-->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>