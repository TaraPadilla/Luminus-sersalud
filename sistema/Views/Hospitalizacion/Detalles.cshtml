<script>
    let productosDirectoLista      = [];
    let productosDirectoExistentes = [];

    function abrirModalDirecto() {
        productosDirectoLista = [];
        actualizarListaProductosDirecto();
        consultarProductosParaDirecto();
        $("#modalAgregarDirecto").dialog({
            modal  : true,
            width  : 1050,
            buttons: { "Cerrar": function () { $(this).dialog("close"); } }
        });
    }

    function consultarProductosParaDirecto() {
        let bodegaId = $("#BodegaId").val();
        $.ajax({
            method : "POST",
            url    : '/HospitalizacionPaquetes/ConsultarProductosExistentes',
            data   : { BodegaId: bodegaId },
            success: function (dataResult) {
                let data = HospAjax.parseHospJson(dataResult);
                if (!data || !HospAjax.hospExitoso(data)) { alert('Error al consultar productos.'); return; }

                let agrupados = {};
                HospAjax.hospResultado(data).forEach(p => {
                    if (!agrupados[p.ProductoId]) {
                        agrupados[p.ProductoId] = {
                            ProductoId: p.ProductoId, ProductoNombre: p.ProductoNombre, Precios: []
                        };
                    }
                    if (!agrupados[p.ProductoId].Precios.some(x => x.PrecioId === p.PrecioId)) {
                        agrupados[p.ProductoId].Precios.push({
                            PrecioId: p.PrecioId, PrecioValor: p.PrecioValor, PrecioNombre: p.PrecioNombre
                        });
                    }
                });

                productosDirectoExistentes = Object.values(agrupados);

                let $sel = $('#productoSelectDirecto');
                $sel.empty().append('<option value="">Seleccione un producto</option>');
                productosDirectoExistentes.forEach(p => {
                    if (p.Precios.length > 0)
                        $sel.append(`<option value="${p.ProductoId}">${p.ProductoNombre}</option>`);
                });

              if ($.fn.select2) {
    if ($sel.hasClass('select2-hidden-accessible')) {
        $sel.select2('destroy');
    }
    $sel.select2({
        theme: 'bootstrap4',
        dropdownParent: $('#modalAgregarDirecto'),
        placeholder: 'Buscar producto...',
        allowClear: true,
        width: '100%',
        language: {
            noResults: function () { return "No se encontraron productos"; },
            searching: function () { return "Buscando..."; }
        }
    });
}
            },
            error: function () { alert('Error al consultar productos.'); }
        });
    }

    // Autocargar precio al cambiar producto
    $(document).on('change', '#productoSelectDirecto', function () {
        const id   = $(this).val();
        const prod = productosDirectoExistentes.find(p => p.ProductoId == id);
        let $precio = $('#precioSelectDirecto');
        $precio.empty();
        if (prod && prod.Precios.length > 0) {
            prod.Precios.forEach(pr =>
                $precio.append(`<option value="${pr.PrecioId}">${pr.PrecioNombre} - Q${pr.PrecioValor}</option>`)
            );
        }
    });

    function agregarProductoDirectoALista() {
        let productoId  = $('#productoSelectDirecto').val();
        let precioId    = $('#precioSelectDirecto').val();
        let cantidad    = parseInt($('#cantidadDirecto').val());
        let indicaciones      = $('#indicacionesDirecto').val();
        let viaAdmin          = $('#viaAdministracionDirecto').val();
        let frecuencia        = $('#frecuenciaDirecto').val();
        let fechaHoraRaw      = $('#fechaHoraDirecto').val();

        if (!productoId)                             { alert("Seleccione un producto.");       return; }
        if (!cantidad || isNaN(cantidad) || cantidad < 1) { alert("Ingrese una cantidad válida."); return; }

        let prod   = productosDirectoExistentes.find(p => p.ProductoId == productoId);
        if (!prod)                                   { alert("Producto no válido.");           return; }
        let precio = prod.Precios.find(p => p.PrecioId == precioId);
        if (!precio)                                 { alert("Precio no válido.");             return; }

        // Hora Guatemala → UTC
        let fechaHoraManual = null;
if (fechaHoraRaw) {
    // Enviar directo como "YYYY-MM-DDTHH:mm:ss" sin manipulación UTC
    // El servidor está en Guatemala, la hora ya es local
    fechaHoraManual = fechaHoraRaw.length === 16
        ? fechaHoraRaw + ":00"   // "2026-05-29T10:01" → "2026-05-29T10:01:00"
        : fechaHoraRaw;
}

        productosDirectoLista.push({
            HospitalizacionId       : $("#HospitalizacionId").val(),
            ProductoId              : productoId,
            Nombre                  : prod.ProductoNombre,
            UnidadMedidaVentaId     : 1,
            Cantidad                : cantidad,
            Precio                  : precio.PrecioValor,
            PrecioId                : precio.PrecioId,
            Indicaciones            : indicaciones,
            ViaAdministracion       : viaAdmin,
            FrecuenciaAdministracion: frecuencia,
            FechaHoraAplicacionManual: fechaHoraManual
        });

        actualizarListaProductosDirecto();

        // Limpiar para siguiente ingreso
        if ($.fn.select2) $('#productoSelectDirecto').val(null).trigger('change');
        else              $('#productoSelectDirecto').val('');
        $('#cantidadDirecto').val(1);
        $('#indicacionesDirecto, #viaAdministracionDirecto, #fechaHoraDirecto').val('');
        $('#precioSelectDirecto').empty().append('<option value="">Seleccione un precio</option>');
    }

    function actualizarListaProductosDirecto() {
        let $lista = $("#listaProductosDirecto");
        $lista.empty();
        if (productosDirectoLista.length === 0) {
            $lista.append(`<li class="list-group-item text-muted text-center">
                <i class="fa fa-info-circle mr-1"></i> Sin productos aún.
            </li>`);
            return;
        }
        productosDirectoLista.forEach((p, i) => {
            $lista.append(`
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <span class="badge badge-warning text-dark mr-2">
                            <i class="fa fa-bolt"></i> Directo
                        </span>
                        <strong>${p.Nombre}</strong>
                        <small class="text-muted ml-2">
                            Cant: ${p.Cantidad} | ${p.FrecuenciaAdministracion || 'STAT'}
                        </small>
                        ${p.Indicaciones ? `<br><small class="text-muted ml-1">${p.Indicaciones}</small>` : ''}
                    </div>
                    <button class="btn btn-danger btn-sm" onclick="eliminarProductoDirecto(${i})">
                        <i class="fa fa-trash"></i>
                    </button>
                </li>`);
        });
    }

    function eliminarProductoDirecto(index) {
        productosDirectoLista.splice(index, 1);
        actualizarListaProductosDirecto();
    }

    async function enviarListaProductosDirecto() {
        if (productosDirectoLista.length === 0) { alert("No hay productos en la lista."); return; }
        if (!confirm(`¿Registrar ${productosDirectoLista.length} producto(s) directamente?\n\nEstarán listos en Control de Insumos para aplicar.`)) return;

        showLoading();
        let errores    = [];
        let registrados = 0;
        const total    = productosDirectoLista.length;

        for (let p of productosDirectoLista) {
            try {
                const resp = await $.ajax({
                    url   : '/Hospitalizacion/AgregarInsumoDirecto',
                    method: 'POST',
                    data  : {
                        HospitalizacionId       : p.HospitalizacionId,
                        ProductoId              : p.ProductoId,
                        UnidadMedidaVentaId     : p.UnidadMedidaVentaId,
                        Cantidad                : p.Cantidad,
                        Precio                  : p.Precio,
                        PrecioId                : p.PrecioId,
                        Indicaciones            : p.Indicaciones,
                        ViaAdministracion       : p.ViaAdministracion,
                        FrecuenciaAdministracion: p.FrecuenciaAdministracion,
                        FechaHoraAplicacionManual: p.FechaHoraAplicacionManual
                    }
                });
                const data = HospAjax.parseHospJson(resp);
                if (!data) {
                    errores.push(`${p.Nombre}: Respuesta inválida`);
                    continue;
                }
                HospAjax.hospExitoso(data) ? registrados++ : errores.push(`${p.Nombre}: ${HospAjax.hospMensaje(data)}`);
            } catch (err) {
                errores.push(`${p.Nombre}: Error de comunicación`);
                console.error(err);
            }
        }

        hideLoading();
        productosDirectoLista = [];
        actualizarListaProductosDirecto();
        $("#modalAgregarDirecto").dialog("close");

        if (errores.length > 0) {
            alert(`⚠ ${registrados} de ${total} registrados.\nErrores:\n${errores.join("\n")}`);
        } else {
            mensajeEmergente(`${registrados} producto(s) registrado(s). Ya están en Control de Insumos.`);
        }
    }


    // ════════════════════════════════════════════════════════
    // FLUJO B — Control de Insumos Directos (nueva tabla)
    // ════════════════════════════════════════════════════════

    async function abrirModalControlInsumosDirectos() {
        $("#tablaControlInsumosDirectosBody").empty();

        const ok = await consultarInsumosDirectosAplicacion();
        if (!ok) return;

        $("#modalControlInsumosDirectos").dialog({
            modal : true,
            width : 1400,
            buttons: {
                "Cerrar": function () { $(this).dialog("close"); }
            }
        });
    }

    async function consultarInsumosDirectosAplicacion() {
        showLoading();
        try {
            const resp = await $.ajax({
                url   : "/Hospitalizacion/ConsultarInsumosDirectosAplicacion",
                method: "POST",
                dataType: "json",
                data  : { hospitalizacionId: HospAjax.getHospitalizacionId() }
            });
            hideLoading();

            const data = HospAjax.parseHospJson(resp);
            if (!data) {
                mensajeEmergenteError("No se pudo interpretar la respuesta del servidor.");
                return false;
            }

            if (HospAjax.hospExitoso(data)) {
                renderizarTablaInsumosDirectos(HospAjax.hospResultado(data));
                return true;
            } else {
                mensajeEmergenteError(HospAjax.hospMensaje(data));
                return false;
            }
        } catch (err) {
            hideLoading();
            console.error("Error consultarInsumosDirectos:", err);
            mensajeEmergenteError("Error al obtener los insumos directos.");
            return false;
        }
    }

function renderizarTablaInsumosDirectos(productos) {
    let tbody = $("#tablaControlInsumosDirectosBody");
    let tabla = $("#tablaControlInsumosDirectos");

    if ($.fn.DataTable.isDataTable(tabla)) tabla.DataTable().destroy();
    tbody.empty();

    if (!productos || productos.length === 0) {
        tbody.append(`<tr><td colspan="11" class="text-center text-muted py-3">
            No hay insumos pendientes.
        </td></tr>`);
        return;
    }

console.log("🔍 Campos del primer insumo directo:", productos[0]);

    productos.forEach(p => {
        if (p.Aplicado) return;

        // Intentar precio con varios nombres posibles que puede devolver el backend
        const precioVal = p.Precio || p.PrecioUnitario || p.ValorUnitario || p.PrecioVenta || 0;

        tbody.append(`
            <tr data-precio="${precioVal}" data-cantidad="${p.Cantidad || 0}">
                <td>${p.Nombre || '-'}</td>
                <td>${p.Indicaciones || '-'}</td>
                <td>${p.Cantidad || '0'}</td>
                <td>${p.UnidadMedidaVentaNombre || '-'}</td>
                <td>${p.PersonaCrea || '-'}</td>
                <td><span class="badge badge-danger">NO</span></td>
                <td>-</td>
                <td>${p.FechaHoraAplicacionManual || '-'}</td>
                <td>${p.FrecuenciaAdministracion || '-'}</td>
                <td>-</td>
                <td>
                    <button class="btn btn-primary btn-sm aplicarInsumoDirectoBtn"
                            data-id="${p.Id}" title="Aplicar">
                        <i class="fas fa-syringe"></i>
                    </button>
                </td>
            </tr>`);
    });

    if (tbody.children().length === 0) {
        tbody.append(`<tr><td colspan="11" class="text-center text-muted py-3">No hay insumos pendientes de aplicación.</td></tr>`);
    }

    setTimeout(() => {
        if (!$.fn.DataTable.isDataTable("#tablaControlInsumosDirectos")) {
            $("#tablaControlInsumosDirectos").DataTable({
                paging    : true,
                pageLength: 5,
                lengthMenu: [5, 10, 25],
                searching : true,
                ordering  : true,
                autoWidth : false,
                responsive: true,
                language  : {
                    lengthMenu: "Mostrar _MENU_ registros",
                    zeroRecords: "No se encontraron registros",
                    info       : "Página _PAGE_ de _PAGES_",
                    infoEmpty  : "No hay registros disponibles",
                    search     : "Buscar:",
                    paginate   : { next: "Siguiente", previous: "Anterior" }
                }
            });
        }
    }, 100);
}

    // Clic en botón Aplicar de la nueva tabla
    $(document).on("click", ".aplicarInsumoDirectoBtn", function () {
        let id = $(this).data("id");
        aplicarInsumoDirecto(id, $(this).closest("tr"));
    });

function aplicarInsumoDirecto(id, fila) {
    return $.ajax({
        url   : `/Hospitalizacion/AplicarInsumoDirecto`,
        method: "POST",
        data  : {
            insumoDirectoAplicacionId: id,
            cuentaId: $("#CuentaId").val()
        },
        success: function (resp) {
            const data = HospAjax.parseHospJson(resp);
            if (!data) {
                alert("No se pudo interpretar la respuesta del servidor.");
                return;
            }
            if (HospAjax.hospExitoso(data)) {
                fila.find("td:nth-child(6)").html('<span class="badge badge-success">SI</span>');
fila.find("td:nth-child(7)").text((data.ProductoAplicado || data.productoAplicado || {}).FechaHoraAplicacion || '');
                fila.find("td:nth-child(11)").empty();
                // Subtotal viene directo del servidor
                if (typeof detallesVm !== "undefined") {
                    var aplicado = data.ProductoAplicado || data.productoAplicado || {};
                    detallesVm.consultarInsumosDirectosAplicados(aplicado.Subtotal || aplicado.subtotal);
                }
            } else {
                alert("Error: " + HospAjax.hospMensaje(data));
            }
        },
        error: function (xhr) {
            console.error("Error al aplicar insumo directo:", xhr);
            alert("No se pudo aplicar el insumo.");
        }
    });
}

 // Aplicar todos (tabla de insumos directos)
    $(document).on("click", "#btnAplicarTodosInsumosDirectos", function () {
        let botones = $("#tablaControlInsumosDirectosBody .aplicarInsumoDirectoBtn:not(:disabled)");
        if (botones.length === 0) { alert("No hay insumos pendientes."); return; }
        if (!confirm("¿Aplicar todos los insumos directos pendientes?")) return;
        if (!confirm("Esta acción no se puede deshacer. ¿Confirmar?")) return;

        (async () => {
            showLoading();
            for (const btn of botones.toArray()) {
                let id   = $(btn).data("id");
                let fila = $(btn).closest("tr");
                try { await aplicarInsumoDirecto(id, fila); }
                catch (e) { console.error("Error en aplicación masiva ID:", id, e); }
            }
            hideLoading();
            alert("Proceso de aplicación masiva finalizado.");
            // ✅ Refrescar totales al terminar aplicación masiva
            if (typeof detallesVm !== "undefined") {
                detallesVm.consultarInsumosDirectosAplicados();
            }
        })();
    });
</script>



<script>
var _paqueteItemParaDevolver = null;

function filtrarPaquetesUI(estado) {
    document.querySelectorAll('#tab-content-cirugia .btn-group .btn').forEach(function(b) {
        b.classList.remove('active');
    });
    var mapa = { todos: 'btnPaqFiltroTodos', aplicados: 'btnPaqFiltroAplicados', pendientes: 'btnPaqFiltroPendientes' };
    var el = document.getElementById(mapa[estado]);
    if (el) el.classList.add('active');
}

// Conectar filtros con KO VM
if (typeof ko !== 'undefined') {
    ko.bindingHandlers.paqueteFiltro = {};
}


$(document).ready(function () {

    // Mostrar/ocultar campo "Otro motivo" en devolución de paquete
    $(document).on('change', '#selectMotivoPaqueteDevolucion', function () {
        if ($(this).val() === 'Otro') {
            $('#divOtroMotivoPaquete').show();
        } else {
            $('#divOtroMotivoPaquete').hide();
            $('#inputOtroMotivoPaquete').val('');
        }
    });

    // Cambio de producto → cargar unidades y precios
    $(document).on('change', '#selectProductoPaquete', function () {
        var productoId = $(this).val();
        $('#selectUnidadPaquete').html('<option value="">-- Seleccione unidad --</option>');
        $('#selectPrecioPaquete').html('<option value="">-- Seleccione precio --</option>');
        if (!productoId || !detallesVm) return;

        // Reutiliza registrosInventario del VM (ya cargado)
        var registros = ko.toJS(detallesVm.registrosInventario());
        var unidadesVistas = {};
        registros.forEach(function (r) {
            if (r.ProductoId == productoId && r.UnidadMedidaVentaId && !unidadesVistas[r.UnidadMedidaVentaId]) {
                unidadesVistas[r.UnidadMedidaVentaId] = true;
                $('#selectUnidadPaquete').append(
                    $('<option>').val(r.UnidadMedidaVentaId).text(r.UnidadMedidaVentaNombre || r.UnidadMedidaVentaId)
                );
            }
        });
    });

$(document).on('change', '#selectUnidadPaquete', function () {
    var productoId = $('#selectProductoPaquete').val();
    var unidadId   = $(this).val();
    var $precioSelect = $('#selectPrecioPaquete');
    $precioSelect.empty().append('<option value="">-- Seleccione precio --</option>');
    if (!productoId || !unidadId || !detallesVm) return;

    var registros = ko.toJS(detallesVm.registrosInventario());
    var preciosVistos = {};
    registros.forEach(function (r) {
        if (r.ProductoId == productoId && r.UnidadMedidaVentaId == unidadId && r.PrecioId && !preciosVistos[r.PrecioId]) {
            preciosVistos[r.PrecioId] = true;
            // Mostrar el nombre del precio y su valor; guardar el valor numérico en el value
            var precioNombre = r.PrecioNombre || 'Precio';
            var valor = parseFloat(r.PrecioValor || r.Valor || 0);
            if (valor > 0) {
                $precioSelect.append('<option value="' + valor + '">' + precioNombre + ' — Q ' + valor.toFixed(2) + '</option>');
            }
        }
    });
    // Si no hay precios, mostrar mensaje
    if ($precioSelect.children('option').length === 1) {
        $precioSelect.append('<option disabled>No hay precios disponibles</option>');
    }
});

});
</script>

