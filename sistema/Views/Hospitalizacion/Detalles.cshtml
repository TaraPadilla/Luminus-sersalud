        }

        const confirmacion = confirm(`¿Deseas agregar a ${medicoSeleccionadoNombre} como médico secundario?`);
        if (!confirmacion) {
            alert("Operación cancelada por el usuario.");
            return;
        }

        // --- TRAZABILIDAD: ENTREGA DE DATA (API FETCH) ---
        fetch('/Hospitalizacion/AgregarMedicoSecundario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    citaId: citaId,
                    empleadoId: medicoSeleccionado
