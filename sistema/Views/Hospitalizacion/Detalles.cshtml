                                <button type="button" class="btn btn-outline-primary btn-sm"
                                        data-paquete-accion="pagina-siguiente"
                                        data-bind="enable: paginaActualPaquetes() < totalPaginasPaquetes()">
                                    Siguiente &#9655;
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

