                                        Todos
                                        <span class="badge badge-secondary ml-1" data-bind="text: totalPaquetesBadge"></span>
                                    </button>
                                    <button type="button" class="btn btn-outline-success"
                                            id="btnPaqFiltroAplicados"
                                            data-paquete-accion="filtrar"
                                            data-paquete-filtro="aplicados"
                                            data-bind="css: { active: filtroActivo() === 'aplicados' }">
                                        Aplicados
                                        <span class="badge badge-success ml-1" data-bind="text: totalPaquetesAplicadosBadge"></span>
                                    </button>
                                    <button type="button" class="btn btn-outline-warning"
