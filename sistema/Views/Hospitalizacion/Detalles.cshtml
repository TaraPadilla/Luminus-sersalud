    function agregarMedicoSecundario(citaId) {
        const medicoSeleccionado = obtenerValorSelect("medicoSecundarioSelect");
        const medicoSeleccionadoNombre = obtenerTextoSelect("medicoSecundarioSelect");

        if (!medicoSeleccionado) {
