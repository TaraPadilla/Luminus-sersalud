<div class="modal fade" id="mdl-firma-turno-enfermeria" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;overflow:hidden;">
            <div class="modal-header py-3" style="background:linear-gradient(135deg,#fff8e7 0%,#fdecc8 100%);border-bottom:3px solid #e6a817;">
                <div class="d-flex align-items-center">
                    <div style="width:40px;height:40px;border-radius:10px;background:#fdecc8;display:flex;align-items:center;justify-content:center;margin-right:12px;">
                        <i class="fas fa-signature" style="color:#e6a817;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title mb-0 font-weight-bold">Firmar Turno de Enfermería</h5>
                        <small class="text-muted">Dibuje, suba una imagen o use su firma registrada</small>
                    </div>
                </div>
                <button type="button" class="close ml-auto" data-dismiss="modal"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-body p-4" style="background:#f7f9fc;">
                <div id="selectorFirmaTurno">
                    <ul class="nav nav-pills mb-3" style="gap:8px;">
                        <li class="nav-item">
                            <a class="nav-link active" href="#" id="tabCanvasFirmaTurno" onclick="window._switchFirmaTabTurno('canvas'); return false;">
                                <i class="fas fa-pen mr-1"></i> Dibujar firma
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#" id="tabArchivoFirmaTurno" onclick="window._switchFirmaTabTurno('archivo'); return false;">
                                <i class="fas fa-upload mr-1"></i> Subir imagen
                            </a>
                        </li>
                    </ul>
                    <div id="panelCanvasFirmaTurno">
                        <div class="text-center">
                            <canvas id="canvasFirmaTurno" width="560" height="180" style="border:2px dashed #c5cedd;border-radius:10px;background:#fff;cursor:crosshair;max-width:100%;touch-action:none;"></canvas>
                        </div>
                        <div class="d-flex justify-content-between mt-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.limpiarCanvasFirmaTurno()"><i class="fas fa-eraser mr-1"></i> Limpiar</button>
                            <button type="button" class="btn btn-sm btn-outline-success" onclick="window.usarCanvasFirmaTurno()"><i class="fas fa-check mr-1"></i> Usar esta firma</button>
                        </div>
                    </div>
                    <div id="panelArchivoFirmaTurno" class="d-none">
                        <div class="p-3 border rounded text-center" style="background:#fff;">
                            <i class="fas fa-image fa-2x text-muted mb-2"></i>
                            <p class="small text-muted mb-2">Seleccione una imagen PNG o JPG de su firma</p>
                            <input type="file" class="form-control-file" accept="image/*" onchange="window.previsualizarArchivoFirmaTurno(this)" />
                        </div>
                    </div>
                </div>
                <div id="contenedorPrevFirmaTurno" class="d-none mt-3 text-center">
                    <p class="small font-weight-bold text-muted text-uppercase mb-2">Vista previa de la firma</p>
                    <img id="imgPrevFirmaTurno" alt="Firma" style="max-height:140px;max-width:340px;border:1px solid #dee2e6;border-radius:8px;padding:6px;background:#fff;display:none;" onload="this.style.display='inline-block';" onerror="this.style.display='none';" />
                    <div class="mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" data-bind="click: resetearFirmaTurno"><i class="fas fa-redo mr-1"></i> Cambiar firma</button>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="background:#fff;border-top:1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary" data-dismiss="modal"><i class="fas fa-times mr-1"></i> Cancelar</button>
                <button type="button" class="btn btn-warning font-weight-bold" id="btnConfirmarFirmaTurno" disabled data-bind="click: confirmarFirmaTurno"><i class="fas fa-signature mr-1"></i> Confirmar Firma</button>
            </div>
        </div>
    </div>
</div>



