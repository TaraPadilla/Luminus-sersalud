<script>
    var historiaClinicaCargada = false;

    function obtenerCitaIdDesdePagina() {
        var citaId = parseInt($("#CitaIdPDF").val(), 10);
        if (!isNaN(citaId) && citaId > 0) {
            return citaId;
        }

        var params = new URLSearchParams(window.location.search);
        citaId = parseInt(params.get("citaId"), 10);
        return (!isNaN(citaId) && citaId > 0) ? citaId : null;
    }

    function mostrarSinConsultaHistoriaClinica(mensaje) {
        $("#texto-cargando-historia-clinica").hide();
        $("#texto-error-historia-clinica").hide();
        $("#contenedor-editar-consulta-historia-clinica").html(
            "<div class='alert alert-warning mb-0'>" + (mensaje || "No se encontr&oacute; una consulta vinculada a esta hospitalizaci&oacute;n.") + "</div>"
        );
    }

    function mostrarErrorHistoriaClinica(mensaje) {
        $("#texto-cargando-historia-clinica").hide();
        $("#texto-error-historia-clinica").show();
        $("#contenedor-editar-consulta-historia-clinica").html(
            "<div class='alert alert-danger mb-0'>" + (mensaje || "No se pudo cargar la historia cl&iacute;nica.") + "</div>"
        );
    }

    function dispararCargaTabHospitalizacion(hash) {
        if (!hash || typeof detallesVm === "undefined" || !detallesVm) return;
        var map = {
            "#tab-content-evolucion": "abrirTabSignosVitales",
            "#tab-content-increta-excreta": "abrirTabIncretaExcreta",
            "#tab-content-control-glucometria": "abrirTabGlucometria",
            "#tab-content-pagos": "abrirTabPagos",
            "#tab-content-nota-medica": "abrirTabNotaMedica2",
            "#tab-content-nota-operatoria": "abrirTabNotaOperatoria",
            "#tab-content-archivos": "abrirTabArchivos",
            "#tab-content-historial-consultas": "abrirTabHistorialConsultas",
            "#tab-content-historial-hospitalizaciones": "abrirTabHistorialHospitalizaciones",
            "#tab-content-chequeo": "abrirTabChequeo",
            "#tab-content-kitIngreso": "abrirTabKitIngreso",
            "#tab-content-historial-autorizaciones": "abrirTabAutorizaciones",
            "#tab-content-preanestesico": "abrirTabPreanestesico",
            "#tab-content-medicamentos-no-controlados": "abrirTabMedicamentosNoControlados",
            "#tab-content-cirugia": "abrirTabCirugiaPaquete"
        };
        var fn = map[hash];
        if (fn && typeof detallesVm[fn] === "function") {
            detallesVm[fn]();
        }
    }

    function activarTabInicialHospitalizacion() {
        var hash = window.location.hash;
        if (hash && hash.indexOf("#tab-content-") === 0) {
            var $tabLink = $('#myTab a[href="' + hash + '"]');
            if ($tabLink.length) {
                $tabLink.tab("show");
                $(hash).addClass("active show");
                dispararCargaTabHospitalizacion(hash);
                return;
            }
        }

        @if (cliente == "SS")
        {
            <text>$('#myTab a[href="#tab-content-historia-clinica"]').tab("show");</text>
        }
    }

    function scrollATabHistoriaClinica() {
        var $pane = $("#tab-content-historia-clinica");
        if (!$pane.length) return;
        var top = $pane.offset().top - 120;
        $("html, body").animate({ scrollTop: top }, 250);
    }

    function resolverConsultaIdServidor(callback) {
        $.ajax({
            url: "/Hospitalizacion/ObtenerConsultaIdHistoriaClinica",
            method: "POST",
            data: {
                hospitalizacionId: $("#HospitalizacionId").val(),
                citaId: obtenerCitaIdDesdePagina()
            },
            success: function(result) {
                var data = HospAjax.parseHospJson(result);
                if (!data) {
                    mostrarErrorHistoriaClinica();
                    return;
                }
                if (HospAjax.hospExitoso(data) && (data.ConsultaId || data.consultaId)) {
                    var consultaId = data.ConsultaId || data.consultaId;
                    $("#ConsultaIdHistoriaClinica").val(consultaId);
                    callback(consultaId);
                } else {
                    mostrarSinConsultaHistoriaClinica(HospAjax.hospMensaje(data));
                }
            },
            error: function() {
                mostrarErrorHistoriaClinica();
            }
        });
    }

    function cargarVistaEditarConsulta(consultaId, reintentarConServidor) {
        var url = "/Consultas/EditarConsultaHistoriaClinicaHospitalizacion/" + consultaId;
        var $contenedor = $("#contenedor-editar-consulta-historia-clinica");

        $("#texto-error-historia-clinica").hide();
        $("#texto-cargando-historia-clinica").show();
        $contenedor.html("<p class='text-primary mb-0'>Cargando vista de edici&oacute;n...</p>");

        $.ajax({
            url: url,
            type: "GET",
            success: function(response) {
                historiaClinicaCargada = true;
                $("#texto-cargando-historia-clinica").hide();
                $contenedor.html(response);
            },
            error: function() {
                historiaClinicaCargada = false;
                $("#texto-cargando-historia-clinica").hide();

                if (reintentarConServidor !== false) {
                    resolverConsultaIdServidor(function(consultaIdServidor) {
                        if (consultaIdServidor !== consultaId) {
                            cargarVistaEditarConsulta(consultaIdServidor, false);
                        } else {
                            mostrarErrorHistoriaClinica();
                        }
                    });
                } else {
                    mostrarErrorHistoriaClinica();
                }
            }
        });
    }

    function cargarHistoriaClinicaSiNecesario(forceReload) {
        if (!forceReload && historiaClinicaCargada && !$("#contenedor-editar-consulta-historia-clinica").is(":empty")) {
            return;
        }

        var consultaIdLocal = parseInt($("#ConsultaIdHistoriaClinica").val(), 10);
        if (!forceReload && !isNaN(consultaIdLocal) && consultaIdLocal > 0) {
            cargarVistaEditarConsulta(consultaIdLocal, true);
            return;
        }

        $("#texto-cargando-historia-clinica").show();
        $("#texto-error-historia-clinica").hide();
        $("#contenedor-editar-consulta-historia-clinica").empty();

        resolverConsultaIdServidor(function(consultaId) {
            cargarVistaEditarConsulta(consultaId, false);
        });
    }

    function inicializarTabsHistoriaClinica() {
        $("#reintentar-historia-clinica").on("click", function(e) {
            e.preventDefault();
            historiaClinicaCargada = false;
            $("#ConsultaIdHistoriaClinica").val("0");
            cargarHistoriaClinicaSiNecesario(true);
        });

        $('a[data-toggle="tab"][href="#tab-content-historia-clinica"]').on("shown.bs.tab", function() {
            if (window.location.hash !== "#tab-content-historia-clinica") {
                history.replaceState(null, "", window.location.pathname + window.location.search + "#tab-content-historia-clinica");
            }
            scrollATabHistoriaClinica();
            cargarHistoriaClinicaSiNecesario(false);
        });

        $('a[data-toggle="tab"][href="#tab-content-historia-clinica"]').on("click", function() {
            if ($(this).hasClass("active")) {
                scrollATabHistoriaClinica();
                cargarHistoriaClinicaSiNecesario(false);
            }
        });

        $('#myTab a[data-toggle="tab"]').not('[href="#tab-content-historia-clinica"]').on("shown.bs.tab", function(e) {
            var hash = $(e.target).attr("href");
            if (hash && hash.indexOf("#tab-content-") === 0) {
                history.replaceState(null, "", window.location.pathname + window.location.search + hash);
                $(".tab-content > .tab-pane").removeClass("active show");
                $(hash).addClass("active show");
                dispararCargaTabHospitalizacion(hash);
            }
        });

        activarTabInicialHospitalizacion();

        if ($("#tab-historia-clinica").hasClass("active")) {
            scrollATabHistoriaClinica();
            cargarHistoriaClinicaSiNecesario(false);
        }
    }

    $(document).ready(function() {
        inicializarTabsHistoriaClinica();
    });
</script>

<script>
    // Variable global para almacenar la data y evitar repetir consultas
    var pdfDataLoaded = false;
    var pdfRecords = []; // Listado de registros traídos de GetByHospitalizacionId

    // Función que actúa como interruptor para mostrar/ocultar la sección de PDFs
    function togglePdfSection() {
        var $pdfSection = $("#pdfSection");
        var $btnText = $("#togglePdfBtnText");
        if ($pdfSection.is(":visible")) {
            $pdfSection.slideUp();
            $btnText.text("Ver PDFs");
        } else {
            if (!pdfDataLoaded) {
                loadPdfData();
            }
            $pdfSection.slideDown();
            $btnText.text("Ocultar PDFs");
        }
    }

    // Función para cargar la data de PDFs desde el servidor
    function loadPdfData() {
        var hospitalizacionId = $("#HospitalizacionId").val();
        $.ajax({
            url: '/HospitalizacionExamenPdf/GetByHospitalizacionId',
            type: 'GET',
            data: { hospitalizacionId: hospitalizacionId },
            success: function (response) {
                // Suponemos que 'response' es un array de objetos que ya incluyen la propiedad "NombreExamen"
                pdfRecords = response;
                // Agrupar registros por examenId
                var groups = {}; // clave: examenId, valor: array de registros
                $.each(pdfRecords, function (index, record) {
                    var examId = record.examenId;
                    if (!groups[examId]) {
                        groups[examId] = [];
                    }
                    groups[examId].push(record);
                });
                // Renderizar las tarjetas con las tablas para cada grupo (sin encabezado extra)
                renderPdfTables(groups);
                pdfDataLoaded = true;
            },
            error: function () {
                alert("Error al obtener los registros de PDFs.");
            }
        });
    }

    // Función para generar y renderizar las tarjetas con tablas según los grupos de examenId
    function renderPdfTables(groups) {
        var $container = $("#pdfSection");
        $container.empty(); // Limpiar contenido anterior

        $.each(groups, function (examId, records) {
            // Se construye la tarjeta (card) para cada grupo
            var cardHtml = "<div class='col-md-12' style='padding:0; margin-bottom:20px;'>" +
                               "<div class='main-card mb-3 card' style='border-radius: 10px;'>" +
                                   "<div class='card-body'>" +
                                       "<div class='table-responsive'>" +
                                           "<table class='table table-bordered'>" +
                                               "<thead>" +
                                                   "<tr>" +
                                                       "<th>Nombre Examen</th>" +
                                                       "<th>PDF URL</th>" +
                                                       "<th>Estado</th>" +
                                                       "<th>Fecha de Creación</th>" +
                                                       "<th>Usuario</th>" +
                                                       "<th>Principal</th>" +
                                                   "</tr>" +
                                               "</thead>" +
                                               "<tbody>";

            $.each(records, function (index, record) {
                cardHtml += "<tr>" +
                                "<td>" + record.nombreExamen + "</td>" +
                                "<td><a href='" + record.pdfUrl + "' target='_blank'>" + record.pdfUrl + "</a></td>" +
                                "<td>" + (record.eliminado ? "Eliminado" : "Activo") + "</td>" +
                                "<td>" + record.fechaCreacionFormatted + "</td>" +
                                "<td>" + record.userId + "</td>" +
                                "<td>" + (record.isPrincipalPdf ? "Sí" : "No") + "</td>" +
                            "</tr>";
            });

            cardHtml +=         "</tbody>" +
                                       "</table>" +
                                   "</div>" +
                               "</div>" +
                           "</div>" +
                        "</div>";

            $container.append(cardHtml);
        });
    }

    function mostrarMensaje(texto, tipo = "success") {
    const el = document.getElementById("mensajeAccion");
    if (!el) { alert(texto); return; } // fallback
    el.className = `alert alert-${tipo}`;
    el.textContent = texto;
    el.classList.remove("d-none");
    setTimeout(() => el.classList.add("d-none"), 5000);
}

// Para que el mensaje aparezca después de reload
document.addEventListener("DOMContentLoaded", () => {
    const msg = sessionStorage.getItem("mensajeAccion");
    const tipo = sessionStorage.getItem("mensajeTipo") || "success";
    if (msg) {
        mostrarMensaje(msg, tipo);
        sessionStorage.removeItem("mensajeAccion");
        sessionStorage.removeItem("mensajeTipo");
    }
});

function guardarMensajeParaReload(texto, tipo="success") {
    sessionStorage.setItem("mensajeAccion", texto);
    sessionStorage.setItem("mensajeTipo", tipo);
}

</script>

<script>
    // Función genérica para alternar la visibilidad de un contenedor
    function toggleSection(contentId, buttonId, callback) {
        let content = document.getElementById(contentId);
        let button = document.getElementById(buttonId);
        if (content.classList.contains("d-none")) {
            content.classList.remove("d-none");
            button.innerHTML = "⬆️";
            if (callback) callback();
        } else {
            content.classList.add("d-none");
            button.innerHTML = "⬇️";
        }
    }

    // Objeto para almacenar el estado de paginación de cada tabla o grupo de tablas.
    // Cuando se usan ids, se usa la clave directamente; si se usan clases, se generará una clave única por cada índice.
    var paginationStates = {};

    /**
     * Configura la paginación en una o varias tablas.
     * {string} tableId - Si useClass es false, se trata del id de la tabla; si es true, se trata de la clase.
     * {string} controlsId - Id o clase del contenedor con los botones de paginación.
     * {string} pageInfoId - Id o clase del elemento donde se muestra la info de página.
     * {number} rowsPerPage - Número de filas a mostrar por página.
     * {boolean} [useClass=false] - Si es true, se buscarán elementos por clase en lugar de por id.
     */
    function setupTablePagination(tableId, controlsId, pageInfoId, rowsPerPage, useClass = false) {
        // Obtener los elementos: si se usa clases, se convierten a Array; de lo contrario, se encapsulan en un array.
        let tables = useClass ? Array.from(document.getElementsByClassName(tableId))
                              : [document.getElementById(tableId)];
        let controlsList = useClass ? Array.from(document.getElementsByClassName(controlsId))
                                    : [document.getElementById(controlsId)];
        let pageInfoList = useClass ? Array.from(document.getElementsByClassName(pageInfoId))
                                    : [document.getElementById(pageInfoId)];

        // Iterar por cada grupo (tabla, controles e info de página)
        tables.forEach((table, index) => {
            // Generar una clave única para esta tabla (en caso de usar clases)
            let stateKey = useClass ? tableId + "_" + index : tableId;
            paginationStates[stateKey] = { currentPage: 1, rowsPerPage: rowsPerPage };

            // Función interna que aplica la paginación a esta tabla.
            function paginate() {
                let state = paginationStates[stateKey];
                // Obtener el tbody de la tabla
                let tbody = table.getElementsByTagName("tbody")[0];
                if (!tbody) return;
                let rows = Array.from(tbody.getElementsByTagName("tr"));
                let totalPages = Math.max(1, Math.ceil(rows.length / state.rowsPerPage));

                rows.forEach((row, idx) => {
                    row.style.display = (idx >= (state.currentPage - 1) * state.rowsPerPage &&
                                         idx < state.currentPage * state.rowsPerPage) ? "table-row" : "none";
                });

                // Actualizar la información de la página.
                if (pageInfoList[index]) {
                    pageInfoList[index].innerText = "Página " + state.currentPage + " de " + totalPages;
                }

                // Actualizar los botones de navegación.
                let controls = controlsList[index];
                if (controls) {
                    let prevButton = controls.querySelector("button.prev");
                    let nextButton = controls.querySelector("button.next");
                    if (prevButton) prevButton.disabled = (state.currentPage === 1);
                    if (nextButton) nextButton.disabled = (state.currentPage >= totalPages);
                }
            }

            // Función para avanzar a la siguiente página.
            function next() {
                let state = paginationStates[stateKey];
                let tbody = table.getElementsByTagName("tbody")[0];
                let totalPages = Math.max(1, Math.ceil(tbody.getElementsByTagName("tr").length / state.rowsPerPage));
                if (state.currentPage < totalPages) {
                    state.currentPage++;
                    paginate();
                }
            }

            // Función para retroceder a la página anterior.
            function previous() {
                let state = paginationStates[stateKey];
                if (state.currentPage > 1) {
                    state.currentPage--;
                    paginate();
                }
            }

            // Usar MutationObserver para detectar cambios en el tbody y actualizar la paginación.
            let tbody = table.getElementsByTagName("tbody")[0];
            if (tbody) {
                const observer = new MutationObserver(function() {
                    paginationStates[stateKey].currentPage = 1;
                    paginate();
                });
                observer.observe(tbody, { childList: true, subtree: true });
            }

            // Asignar los eventos a los botones (se asume que tienen las clases "prev" y "next").
            let controls = controlsList[index];
            if (controls) {
                let prevButton = controls.querySelector("button.prev");
                let nextButton = controls.querySelector("button.next");
                if (prevButton) prevButton.addEventListener("click", previous);
                if (nextButton) nextButton.addEventListener("click", next);
            }

            // Llamada inicial para aplicar la paginación.
            paginate();
        });
    }
</script>


