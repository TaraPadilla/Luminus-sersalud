    color: #343a40;
    transition: background-color 0.3s ease, color 0.3s ease;
    vertical-align: middle; /* Asegura alineación con el radio */
  }

  /* Cuando el radio está seleccionado */
  .custom-radio:checked + .custom-label {
    background-color: #e7f1ff; /* Fondo azul suave */
    border-radius: 5px;
    padding: 0.3rem 0.5rem; /* Espaciado interno */
    color: #0056b3; /* Color de texto más oscuro */
  }

  /* Efecto al hacer hover */
  .custom-radio:hover {
    cursor: pointer;
    transform: scale(1.1);
  }

  .custom-label:hover {
    cursor: pointer;
    color: #007bff; /* Azul más vivo en hover */
  }

  .estilos-subtitulo-ingesta-excreta {
    color: #000000; /* Texto negro */
    background-color: #00cec9; /* Fondo */
    padding: 5px; /* Espaciado alrededor del texto */
    border-radius: 3px; /* Bordes redondeados */
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1); /* Sombra sutil alrededor */
    display: inline-block; /* Asegura que el subtítulo se vea en una sola línea */
    font-weight: bold; /* Negrita para mayor énfasis */
  }

  .highlight-intervalo {
    background-color: rgba(85, 239, 196, 0.5); /* Color de fondo */
    font-weight: bold; /* Negrita */
  }

  .highlight-dia {
    background-color: rgba(0, 206, 201, 0.5); /* Color de fondo */
    font-style: italic; /* Cursiva */
    font-weight: 600; /* Semi Negrita */
  }

  /* =========================================================
     Tabs Hospitalizacion (NAV/TABS) en Card
     Scope: solo dentro de .tabs-hosp-card y #myTab
     Bootstrap: 4.3.1
     ========================================================= */

  .tabs-hosp-card {
    border: 1px solid #dee2e6;
    border-radius: .5rem;
    box-shadow: 0 1px 2px rgba(0,0,0,.06);
    background: #ffffff;
  }

  .tabs-hosp-card__body {
    padding: .75rem;
  }

  /* Grilla 6 columnas */
  .tabs-hosp-card #myTab.nav.nav-tabs {
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: .35rem .35rem;
    border-bottom: 0; /* ya no necesitamos la línea inferior del nav-tabs */
    padding-bottom: 0;
    margin-bottom: 0;
  }

  /* Responsive (doble @@ por Razor) */
  @@media (max-width: 1199.98px) {
    .tabs-hosp-card #myTab.nav.nav-tabs { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @@media (max-width: 991.98px) {
    .tabs-hosp-card #myTab.nav.nav-tabs { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @@media (max-width: 575.98px) {
    .tabs-hosp-card #myTab.nav.nav-tabs { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }

  .tabs-hosp-card #myTab.nav.nav-tabs > .nav-item {
    margin-bottom: 0;
  }

  /* Tab: mismo ancho, ícono alineado y texto alineado de forma consistente */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: flex-start; /* <-- clave: alinear a la izquierda */

    gap: .45rem;                /* separación ícono-texto */
    color: #212529;             /* negro Bootstrap */
    background: #ffffff;

    border: 1px solid #dee2e6;
    border-radius: .45rem;
    padding: .50rem .60rem;

    line-height: 1.1;
    font-size: .90rem;

    white-space: nowrap;
    overflow: hidden;           /* necesario para elipsis en flex */
  }

  /* Ícono: “columna” fija para que el texto arranque siempre en el mismo punto */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link .tab-icn {
    flex: 0 0 1.25rem;          /* ancho fijo */
    width: 1.25rem;             /* refuerzo */
    text-align: center;         /* centra el ícono dentro de su columna */
    font-size: 1rem;
    line-height: 1;
    opacity: .85;
    color: inherit;             /* hereda el color del link */
  }

  /* Texto: permitir truncado real dentro del contenedor flex */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link > span {
    flex: 1 1 auto;
    min-width: 0;               /* CLAVE: permite ellipsis en flex */
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    text-align: left;
  }

  /* Hover/Focus */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link:hover,
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link:focus {
    background: #f8f9fa;
    text-decoration: none;
    outline: none;
    color: #212529;
  }

  /* Activo: ícono y texto blanco */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link.active,
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-item.show .nav-link {
    background: #313131; /* azul Bootstrap */
    border-color: #686868;
    box-shadow: 0 0 0 2px rgba(0, 123, 255, 0.25);
    font-weight: 600;
    color: #ffffff;
  }

  /* Refuerzo explícito (por si el ícono o el span traen color propio) */
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link.active .tab-icn,
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-item.show .nav-link .tab-icn,
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-link.active > span,
  .tabs-hosp-card #myTab.nav.nav-tabs .nav-item.show .nav-link > span {
    color: #ffffff;
  }
</style>
}




