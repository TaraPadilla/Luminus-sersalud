@model sistema.Models.HospitalizacionDetallesViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    // Leer el valor del appsettings.json. 
    // Cambia "Cliente" por la clave exacta que decidas usar para identificar la abreviatura.
    Layout = farmamest.Utilidades.SerSaludUiHelper.ResolverLayout(Configuration);
    ViewData["Title"] = "Hospitalizacion - Detalles";
    var logoBase64 = Configuration["ImagenLogoBase64"];
    string cliente = farmamest.Utilidades.SerSaludUiHelper.NormalizarCliente(Configuration["Cliente"]);
}
<script src="~/js/hosp-jquery-defer.js"></script>
<script src="~/js/hospitalizacion-ajax.js"></script>
@await Html.PartialAsync("_MensajeExito")

@Html.HiddenFor(m => m.HospitalizacionId)
@Html.HiddenFor(m => m.CuentaId)
@Html.HiddenFor(m => m.HabitacionId)
@Html.HiddenFor(m => m.PacienteId)
@Html.HiddenFor(m => m.FechaInicial)
@Html.HiddenFor(m => m.FechaFinal)
@Html.HiddenFor(m => m.BodegaId)
@Html.HiddenFor(m => m.CategoriaHabitacionNombre)
@Html.HiddenFor(m => m.CodigoSeguro)

<input type="hidden" id="ResponsableNit" value="@(Model.Consulta?.Citas?.ResponsableNit ?? "")" />
<input type="hidden" id="ResponsableNombre" value="@(Model.Consulta?.Citas?.ResponsableNombre ?? "")" />
<input type="hidden" id="ResponsableDireccion" value="@(Model.Consulta?.Citas?.ResponsableDireccion ?? "")" />
<input type="hidden" id="ResponsableCorreo" value="@(Model.Consulta?.Citas?.ResponsableCorreo ?? "")" />
<input type="hidden" id="SeguroNombre" value="@(Model.CodigoSeguro ?? "")" />
<input type="hidden" id="PacienteNombreAdmision" value="@(Model.PacienteNombre ?? "")" />
<input type="hidden" id="PacienteDpi" value="@(Model.PacienteDpi ?? "")" />
<input type="hidden" id="MedicoAsignadoNombre" value="@(Model.MedicoAsignado ?? "")" />
<input type="hidden" id="PrimerMedicoSecundarioNombre" value="@(Model.MedicosSecundarios != null && Model.MedicosSecundarios.Any() ? Model.MedicosSecundarios.First().NombreCompleto : "")" />
<input type="hidden" id="CitaPrimerAyudante"  value="@(Model.CitaPrimerAyudante  ?? "")" />
<input type="hidden" id="CitaAnestesista"     value="@(Model.CitaAnestesista     ?? "")" />
<input type="hidden" id="CitaSegundoAyudante" value="@(Model.CitaSegundoAyudante ?? "")" />
<input type="hidden" id="CitaInstrumentista"  value="@(Model.CitaInstrumentista  ?? "")" />
<input type="hidden" id="CitaCirculante"      value="@(Model.CitaCirculante      ?? "")" />
<input type="hidden" id="CitaProcedimiento"    value="@(Model.CitaProcedimiento    ?? "")" />
<input type="hidden" id="FechaProcedimiento"    value="@(Model.FechaFinal)" />
<input type="hidden" id="AdmisionId" value="@Model.HospitalizacionId" />
<input type="hidden" id="PacienteFechaNacimiento" value="@(Model.FechaNacimientoPaciente ?? "")" />
<input type="hidden" id="PacienteEdad" value="@(Model.EdadPaciente)" />
<input type="hidden" id="PacientePeso" value="@(Model.PacientePeso ?? "")" />
<input type="hidden" id="PacienteTalla" value="@(Model.PacienteTalla ?? "")" />
<input type="hidden" id="PacienteTipoSangre" value="@(Model.PacienteTipoSangre ?? "")" />
<input type="hidden" id="CitaCirujanoId" value="@(Model.Consulta?.Citas?.EmpleadoId?.ToString() ?? "")" />
<input type="hidden" id="Cliente" value="@cliente" />
<input type="hidden" id="ConsultaIdHistoriaClinica" value="@(Model.Consulta?.Id ?? 0)" />
<input type="hidden" id="CitaIdPDF" value="@Model.CitaIdPDF" />

@{
    var usuarioAdmisiones = User.IsInRole("Admisiones");
    var usuarioEnfermeria = User.IsInRole("Enfermeria");
    var usuarioMedicoGeneral = User.IsInRole("Medico General");
    var usuarioRecepcionDiurno = User.IsInRole("Recepcion Diurno");
    var idHospi = @Model.HospitalizacionId.ToString();
}
<input type="hidden" id="NotaMedicaPuedeEditar" value="@((!usuarioAdmisiones && !Model.HospitalizacionFinalizada && !User.IsInRole("Enfermeria") && !User.IsInRole("Coordinador Laboratorio") && !User.IsInRole("Tecnico laboratorio")) ? "1" : "0")" />
<input type="hidden" id="ChequeoPuedeEditar" value="@(!User.IsInRole("Medico Externo") ? "1" : "0")" />
<input type="hidden" id="KitPuedeReutilizar" value="@(!User.IsInRole("Medico Externo") ? "1" : "0")" />
<script src="~/js/voicetotext/voicetotext.js"></script>

 <link href="~/css/quill.snow.css" rel="stylesheet" />
<style>

/* =====================================================
   VARIABLES DE ESTILO GLOBAL (CLÍNICO NEUTRO)
===================================================== */

:root {

    --nota-text: #2d3748;
    --nota-muted: #718096;
    --nota-border: #e2e8f0;
    --nota-bg: #f7f9fc;

    /* Color neutro clínico */
    --clinico-color: #6b7280;
    --clinico-light: #f3f4f6;
    --clinico-mid: #d1d5db;

    /* Secciones clínicas */
    --enfermeria-color: #2e7d9a;
    --operatoria-color: #5a6e8a;
    --evolucion-color: #3d7a5e;

}

/* =====================================================
   ACORDEON
===================================================== */

.accordion {
    cursor: pointer;
    background-color: #f4f5f7;
    color: #444;
    padding: 16px;
    width: 100%;
    border: none;
    text-align: left;
    font-size: 14px;
    transition: 0.25s;
}

.accordion:hover {
    background-color: #e5e7eb;
}

.panel {
    padding: 0 18px;
    background-color: white;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.2s ease-out;
}

/* =====================================================
   ESTILO UNIFICADO
   CHEQUEO · KIT · PREANESTESIA
===================================================== */

.nota-header-chequeo,
.nota-header-kit,
.nota-header-preanest {

    background: linear-gradient(135deg, var(--clinico-light) 0%, #e9eaee 100%);
    border-left: 4px solid var(--clinico-color) !important;

}

.nota-header-icon-chequeo,
.nota-header-icon-kit,
.nota-header-icon-preanest {

    background-color: var(--clinico-mid);
    color: var(--clinico-color);

}

.nota-badge-chequeo,
.nota-badge-kit,
.nota-badge-preanest {

    background-color: var(--clinico-light);
    color: var(--clinico-color);
    border: 1px solid var(--clinico-mid);
    font-size: 0.72rem;
    padding: 3px 9px;
    border-radius: 20px;
    font-weight: 600;

}

.nota-contenido-cell-chequeo,
.nota-contenido-cell-kit,
.nota-contenido-cell-preanest {

    border-left: 3px solid var(--clinico-color);

}

.nota-fecha-icon-chequeo,
.nota-fecha-icon-kit,
.nota-fecha-icon-preanest {

    background-color: var(--clinico-light);
    color: var(--clinico-color);

}


.btn-nota-accion {

    font-size: 0.78rem;
    padding: 4px 10px;
    border-radius: 6px;
    font-weight: 600;
    white-space: nowrap;
    transition: all .18s;

}


.btn-nota-operatoria {
    border: 1px solid var(--operatoria-color);
    color: var(--operatoria-color);
    background: transparent;
}
.btn-nota-operatoria:hover {
    background: var(--operatoria-color);
    color: #fff;
}

.btn-nota-evolucion {
    border: 1px solid var(--evolucion-color);
    color: var(--evolucion-color);
    background: transparent;
}
.btn-nota-evolucion:hover {
    background: var(--evolucion-color);
    color: #fff;
}

.btn-nota-enfermeria {
    border: 1px solid var(--enfermeria-color);
    color: var(--enfermeria-color);
    background: transparent;
}
.btn-nota-enfermeria:hover {
    background: var(--enfermeria-color);
    color: #fff;
}

/* Botón Firmar — dorado */
.btn-nota-firmar {
    border: 1px solid #e6a817;
    color: #e6a817;
    background: transparent;
}
.btn-nota-firmar:hover {
    background: #e6a817;
    color: #fff;
}

.btn-nota-primary {
    font-size: 0.82rem;
    font-weight: 600;
    border-radius: 7px;
    transition: all .18s;
}
.btn-nota-primary-operatoria {
    background: var(--operatoria-color);
    color: #fff;
    border: 0;
}
.btn-nota-primary-operatoria:hover {
    background: #47576e;
    color: #fff;
}
.btn-nota-primary-evolucion {
    background: var(--evolucion-color);
    color: #fff;
    border: 0;
}
.btn-nota-primary-evolucion:hover {
    background: #2e6047;
    color: #fff;
}
.btn-nota-primary-enfermeria {
    background: var(--enfermeria-color);
    color: #fff;
    border: 0;
}
.btn-nota-primary-enfermeria:hover {
    background: #235e76;
    color: #fff;
}


.btn-nota-chequeo,
.btn-nota-kit,
.btn-nota-preanest {

    border: 1px solid var(--clinico-color);
    color: var(--clinico-color);
    background: transparent;

}

.btn-nota-chequeo:hover,
.btn-nota-kit:hover,
.btn-nota-preanest:hover {

    background: var(--clinico-color);
    color: #fff;

}

.btn-nota-primary-chequeo,
.btn-nota-primary-kit,
.btn-nota-primary-preanest {

    background: var(--clinico-color);
    color: #fff;

}

.btn-nota-primary-chequeo:hover,
.btn-nota-primary-kit:hover,
.btn-nota-primary-preanest:hover {

    background: #4b5563;
    color: #fff;

}

/* =====================================================
   TABLA CHEQUEO QUIRURGICO
===================================================== */

.tabla-chequeo-seccion th {

    background: #f3f4f6;
    font-size: 0.78rem;
    text-transform: uppercase;
    color: #555;

}

.chequeo-si-no {

    display: flex;
    gap: 12px;
    align-items: center;

}

.chequeo-radio-label {

    font-size: 0.82rem;
    display: flex;
    align-items: center;
    gap: 4px;

}

/* =====================================================
   TARJETAS DE NOTAS CLÍNICAS
===================================================== */

.nota-clinica-card {

    border: 0 !important;
    border-radius: 14px !important;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    background: #ffffff;

}

/* =====================================================
   HEADER DE TARJETAS
===================================================== */

.nota-header {

    padding: 18px 24px;
    border-bottom: 1px solid var(--nota-border);
    display: flex;
    align-items: center;
    justify-content: space-between;

}

.nota-header-title {

    font-size: 1rem;
    font-weight: 700;
    color: var(--nota-text);

}

.nota-header-subtitle {

    font-size: 0.78rem;
    color: var(--nota-muted);

}

.nota-header-icon {

    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;

}

/* =====================================================
   BODY TARJETA
===================================================== */

.nota-card-body {

    padding: 20px 24px;
    background-color: var(--nota-bg);

}

/* =====================================================
   TABLA DE NOTAS
===================================================== */

.tabla-notas {

    border-collapse: separate;
    border-spacing: 0 6px;

}

.tabla-notas thead tr th {

    font-size: 0.72rem;
    text-transform: uppercase;
    color: var(--nota-muted);
    padding: 8px 12px;
    background: transparent;

}

.tabla-notas tbody tr {

    background: #ffffff;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    border-radius: 10px;
    transition: all .2s;

}

.tabla-notas tbody tr:hover {

    box-shadow: 0 4px 14px rgba(0,0,0,0.1);
    transform: translateY(-1px);

}

.tabla-notas tbody tr td {

    padding: 12px 14px;
    vertical-align: middle;
    color: var(--nota-text);
    font-size: 0.88rem;

}

/* =====================================================
   CELDA CONTENIDO
===================================================== */

.nota-contenido-cell {

    background-color: #f0f4f8;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.86rem;
    line-height: 1.6;
    white-space: pre-wrap;

}

/* =====================================================
   FECHAS
===================================================== */

.nota-fecha-wrapper {

    display: flex;
    align-items: center;
    gap: 10px;

}

.nota-fecha-icon {

    width: 34px;
    height: 34px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;

}

.nota-fecha-text {

    font-weight: 600;
    font-size: 0.86rem;

}

.nota-fecha-label {

    font-size: 0.72rem;
    color: var(--nota-muted);

}

/* =====================================================
   FOOTER
===================================================== */

.nota-footer {

    padding: 12px 24px;
    background: #ffffff;
    border-top: 1px solid var(--nota-border);
    font-size: 0.8rem;
    color: var(--nota-muted);

}

/* =====================================================
   ESTADO VACÍO
===================================================== */

.nota-empty-state {

    text-align: center;
    padding: 40px 20px;
    color: var(--nota-muted);

}

/* =====================================================
   FIX MODAL BACKDROP
===================================================== */

.modal {
    z-index: 1060 !important;
}

.modal-backdrop {
    z-index: 1050 !important;
}

.ui-widget-overlay {
    z-index: 1050 !important;
}

.ui-dialog {
    z-index: 1060 !important;
}

.select2-container--open {
    z-index: 1070 !important;
}

#div-loading {
    z-index: 1030 !important;
}

/* Elimina el box-shadow del tema que genera el rectángulo
   fantasma visible detrás del modal de firma */
#mdl-firma-nota-operatoria .modal-dialog {
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
}

/* Elimina el box-shadow fantasma en modales Bootstrap del kit */
#mdl-agregar-producto-kit .modal-dialog,
#mdl-detalle-kit-ingreso .modal-dialog {
    box-shadow: none !important;
    -webkit-box-shadow: none !important;
}





/* ============================================
   ESTILOS RESPONSIVOS PARA MODALES (jQuery UI + Bootstrap)
   Aplican en dispositivos con ancho ≤ 768px
============================================ */
@@media (max-width: 768px) {

    /* === MODALES JQUERY UI === */
    .ui-dialog {
        max-width: 95% !important;
        width: auto !important;
        left: 2.5% !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    .ui-dialog .ui-dialog-content {
        padding: 15px !important;
        overflow-x: auto !important;
    }

    .ui-dialog .ui-dialog-titlebar {
        padding: 8px 12px !important;
        font-size: 1rem !important;
    }

    .ui-dialog .ui-dialog-buttonpane {
        padding: 8px 12px !important;
    }

    /* === MODALES BOOTSTRAP === */
    .modal-dialog {
        margin: 1rem auto !important;
        max-width: 95% !important;
        width: auto !important;
    }

    .modal-body {
        padding: 1rem !important;
    }

    /* === ESTILOS COMUNES DENTRO DE MODALES === */

    /* Campos de formulario ocupan ancho completo */
    .modal-body input,
    .modal-body select,
    .modal-body textarea,
    .ui-dialog input,
    .ui-dialog select,
    .ui-dialog textarea,
    .modal-body .form-control,
    .ui-dialog .form-control {
        width: 100% !important;
        box-sizing: border-box;
    }

    /* Filas de formulario (form-row) en columna */
    .modal-body .form-row,
    .ui-dialog .form-row {
        flex-direction: column !important;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    .modal-body .form-row > [class*="col-"],
    .ui-dialog .form-row > [class*="col-"] {
        max-width: 100% !important;
        flex: 0 0 100% !important;
        padding-left: 0 !important;
        padding-right: 0 !important;
        margin-bottom: 0.75rem;
    }

    /* Tablas dentro de modales: scroll horizontal */
    .modal-body .table-responsive,
    .ui-dialog .table-responsive {
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch;
    }

    .modal-body table,
    .ui-dialog table {
        min-width: 600px; /* fuerza scroll si la tabla es ancha */
        width: 100%;
    }

    /* Botones: apilados en móvil */
    .modal-body .d-flex,
    .ui-dialog .d-flex {
        flex-wrap: wrap !important;
        gap: 0.5rem;
    }

    .modal-body .btn,
    .ui-dialog .btn {
        width: 100% !important;
        margin: 0.25rem 0 !important;
        white-space: normal !important;
    }

    /* Grupo de botones al final del modal */
    .modal-footer,
    .ui-dialog .ui-dialog-buttonpane {
        flex-direction: column !important;
        align-items: stretch !important;
    }

    .modal-footer .btn,
    .ui-dialog-buttonpane .btn {
        width: 100% !important;
        margin: 0.25rem 0 !important;
    }

    /* Ajustes para los "chequeo-si-no" y radios horizontales */
    .chequeo-si-no,
    .form-check-inline {
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .chequeo-radio-label {
        margin-right: 0.5rem;
    }

    /* Reduce el tamaño de fuente en modales para móvil */
    .modal-body,
    .ui-dialog {
        font-size: 0.9rem;
    }

    /* Tarjetas dentro de modales */
    .modal-body .card,
    .ui-dialog .card {
        margin-bottom: 1rem !important;
    }

    /* Ajusta el espaciado en modales de kit de ingreso y preanestésico */
    #mdl-agregar-kit-ingreso .form-row,
    #mdl-agregar-preanestesico .form-row {
        flex-direction: column !important;
    }

    #mdl-agregar-kit-ingreso .col-md-2,
    #mdl-agregar-kit-ingreso .col-md-3,
    #mdl-agregar-kit-ingreso .col-md-4,
    #mdl-agregar-preanestesico .col-md-2,
    #mdl-agregar-preanestesico .col-md-3,
    #mdl-agregar-preanestesico .col-md-4 {
        flex: 0 0 100% !important;
        max-width: 100% !important;
        margin-bottom: 0.75rem;
    }
}

.tab-content > .tab-pane:not(.active) {
    display: none !important;
}
.tab-content > .tab-pane.active {
    display: block !important;
}

@@media (max-width: 768px) {
    #editor {
        height: 200px !important;
    }
    .ql-toolbar.ql-snow {
        flex-wrap: wrap;
        padding: 4px;
    }
    .ql-toolbar.ql-snow .ql-formats {
        margin-right: 6px;
        margin-bottom: 4px;
    }
    /* Reduce tamaño de íconos en móvil */
    .ql-snow .ql-picker-label,
    .ql-snow .ql-stroke {
        font-size: 12px;
    }
    .ql-snow .ql-picker-options {
        max-width: 200px;
    }
}
</style>
@* HospitalizacionId ya está en @Html.HiddenFor(m => m.HospitalizacionId) al inicio de la vista *@



<div id="hospitalizacion-ko-root">
<div id="mensajeAccion" class="alert d-none" role="alert"></div>
@await Html.PartialAsync("_CabeceraHospitalizacion", Model)

@* #Region Pestañas Hospitalización *@
@await Html.PartialAsync("_Tabs", Model)


@* #EndRegion Pestañas Hospitalización *@
<div class="form-row">
    <div class="col-md-12">
        <div class="tab-content">
            
            @* #Region TAB CARGOS ENFERMERIA *@
            @await Html.PartialAsync("_CargosEnfermeria", Model)
            @* #EndRegion TAB CARGOS ENFERMERIA *@

            @* #Region TAB Signos Vitales *@
            @await Html.PartialAsync("_SignosVitales", Model)
            @* #EndRegion TAB Signos Vitales *@

            @* #Region TAB INGESTA / EXCRETA*@
            @await Html.PartialAsync("_IngestaExcreta", Model)
            @* #EndRegion TAB INGESTA / EXCRETA*@

            @* #Region TAB CONTROL GLUCOMETRIA *@
            @await Html.PartialAsync("_ControlGlucometria", Model)
            @* #EndRegion TAB CONTROL GLUCOMETRIA *@

            @*  #Region TAB EXAMENES COMPLEMENTARIOS *@
            @await Html.PartialAsync("_ExamenesComplementarios", Model)
            @*  #EndRegion TAB EXAMENES COMPLEMENTARIOS *@

            @* #Region TAB ORDEN MEDICA *@
            <div class="tab-pane tabs-animation fade" id="tab-content-orden-medica" role="tabpanel">
                @await Html.PartialAsync("Tabs/_OrdenMedica", Model)
            </div>
            @* #EndRegion TAB ORDEN MEDICA *@

            @* #Region TAB DEVOLUCION DE MEDICAMENTOS *@
            <div class="tab-pane tabs-animation fade" id="tab-content-devolucion-medicamentos" role="tabpanel">
                @await Html.PartialAsync("Tabs/_DevolucionMedicamentos", Model)
            </div>
            @* #EndRegion TAB DEVOLUCION DE MEDICAMENTOS *@

            @* #Region TAB CIRUGIA-PAQUERE *@
            @* #End TAB CIRUGIA-PAQUERE *@

            @* #Region TAB NOTA EVOLUCION *@
            @* #EndRegion TAB NOTA EVOLUCION *@

            @* #Region TAB NOTA OPERATORIOA *@
            @await Html.PartialAsync("_NotaOperatoria", Model)
            @* #EndRegion TAB NOTA OPERATORIOA *@

            @* #Region TAB NOTA ENFERMERIA *@
            @await Html.PartialAsync("_NotaEnfermeria", Model)
            @* #EndRegion TAB NOTA ENFERMERIA *@

            @* #Region TAB ACTUALIZAR ESTADIA *@
            <div class="tab-pane tabs-animation fade " id="tab-content-2" role="tabpanel">
                <div class="main-card mb-3 card">
                    <div class="card-body">
                        <label>Periodo de hospitalización:</label>
                        <input type="text" class="form-control" id="periodo-hospitalizacion" data-bind="value: periodo">
                        @if (!User.IsInRole("Enfermeria") && !User.IsInRole("Medico General") && !User.IsInRole("Coordinador Laboratorio") && !User.IsInRole("Tecnico laboratorio"))
                        {                            
                            <button class="btn btn-primary" data-bind="click:actualizarEstadia">
                                Actualizar
                            </button>
                        }
                    </div>
                </div>
            </div>
            @* #EndRegion TAB ACTUALIZAR ESTADIA *@

            @* #Region TAB ADELANTOS *@
            @await Html.PartialAsync("_Adelantos", Model)
            @* #EndRegion TAB ADELANTOS *@

            @* #Region TAB USUARIOS CON ACCESO *@
            @await Html.PartialAsync("_UsuariosAccesos", Model)
            @* #EndRegion TAB USUARIOS CON ACCESO *@

            @* #Region TAB PACIENTES - ARCHIVOS *@
