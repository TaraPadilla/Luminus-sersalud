<script>
/**
 * Inserta un mensaje visual de carga en el cuerpo de la tabla.
 */
function mostrarCargandoDataTable(selector) {
    const $tabla = $(selector);
    const numColumnas = $tabla.find('thead th').length;
    const $tbody = $tabla.find('tbody');

    // Evitar duplicar el mensaje de carga
    if ($tbody.find('.fila-cargando').length > 0) return;

    const filaCargando = `
        <tr class="fila-cargando">
            <td colspan="${numColumnas}" class="text-center p-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="ms-2">Cargando datos, por favor espere...</span>
            </td>
        </tr>`;
    
    // Si el tbody está vacío o solo tiene el mensaje de "No hay datos" de KO
    $tbody.html(filaCargando);
}

/**
 * Inicializa DataTables con validaciones de estructura y contenido.
 */
function inicializarDataTableGenerica(selector) {
    if (!selector || selector.trim() === "" || $(selector).length === 0) return;

    const $tabla = $(selector);

    // 1. FILTRADO DE FILAS REALES: Ignoramos totales, carga y mensajes de "vacío"
    const $filasReales = $tabla.find('tbody tr').filter(function() {
        const tieneColspan = $(this).find('td[colspan]').length > 0;
        const esFilaTotal = $(this).hasClass('fila-total');
        const esCargando = $(this).hasClass('fila-cargando');
        return !tieneColspan && !esFilaTotal && !esCargando;
    });

    // Si aún no hay registros reales, no inicializamos
    if ($filasReales.length === 0) return false;

    // 2. VALIDACIÓN DE CONSISTENCIA (TN18)
    const columnasHeader = $tabla.find('thead tr:first th').length;
    const columnasBody = $filasReales.first().find('td').length;

    if (columnasHeader !== columnasBody) {
        console.error(`Error TN18 en ${selector}: Header(${columnasHeader}) vs Body(${columnasBody})`);
        return false;
    }

    // 3. LIMPIEZA: Quitamos la fila de "Cargando" antes de inicializar
    $tabla.find('.fila-cargando').remove();

    // 4. INICIALIZACIÓN
    if ($.fn.DataTable.isDataTable(selector)) {
        $tabla.DataTable().destroy();
    }

    $tabla.DataTable({
        "pageLength": 10,
        "order": [[0, "desc"]],
        "language": {
            "search": "Buscar:",
            "lengthMenu": "Mostrar _MENU_ registros por página",
            "zeroRecords": "No se encontraron resultados",
            "info": "Mostrando página _PAGE_ de _PAGES_",
            "infoEmpty": "No hay registros disponibles",
            "infoFiltered": "(filtrado de _MAX_ registros totales)",
            "paginate": {
                "first": "Primero", "last": "Último", "next": "Siguiente", "previous": "Anterior"
            }
        }
    });
    return true; 
}

/**
 * Función que espera a que los datos estén listos con reintentos
 */
function esperarDatosEInicializar(selector, reintentos = 30) {
    // Ponemos el mensaje de carga inmediatamente
    mostrarCargandoDataTable(selector);

    const intervalo = setInterval(function() {
        const exito = inicializarDataTableGenerica(selector);
        
        if (exito || reintentos <= 0) {
            clearInterval(intervalo);
            // Si después de todos los reintentos no hubo éxito, quitamos el cargando
            if (!exito) {
                $(selector).find('.fila-cargando').remove();
            }
        }
        reintentos--;
    }, 200); 
}

