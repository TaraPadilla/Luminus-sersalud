                                    <option value="10">Mostrar 10</option>
                                    <option value="20">Mostrar 20</option>
                                    <option value="50">Mostrar 50</option>
                                </select>
                            </div>

                            <div class="alert alert-info py-2 mb-2"
                                 id="texto-cargando-paquetes-aplicados" style="display:none">
                                Cargando paquetes aplicados...
                            </div>
                            <div class="alert alert-danger py-2 mb-2"
                                 id="texto-error-consultar-paquetes-aplicados" style="display:none">
                                Error de conexión. <a href="#" data-paquete-accion="reintentar">Reintentar</a>
                            </div>

                            <table class="table table-hover" id="tablaPaquetesAplicados">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th>Código</th>
                                        <th>Nombre</th>
                                        <th>Descripción</th>
                                        <th>Cant. total</th>
                                        <th>Cant. aplicada</th>
                                        <th>Estado</th>
                                        <th>Fecha aplicación</th>
                                        <th>Persona</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody data-bind="foreach: $root.elementosPaginadosPaquetes">
                                    <tr>
                                        <td>
                                            <!-- ko if: Tipo() === 'Producto' -->
                                            <span class="badge badge-primary" data-bind="text: Tipo"></span>
                                            <!-- /ko -->
                                            <!-- ko if: Tipo() === 'Servicio' -->
                                            <span class="badge badge-danger" data-bind="text: Tipo"></span>
                                            <!-- /ko -->
                                            <!-- ko if: Tipo() === 'Laboratorio' -->
                                            <span class="badge badge-warning text-dark" data-bind="text: Tipo"></span>
                                            <!-- /ko -->
                                        </td>
                                        <td data-bind="text: Codigo"></td>
                                        <td data-bind="text: Nombre"></td>
                                        <td data-bind="text: Descripcion"></td>
                                        <td data-bind="text: Cantidad"></td>
                                        <td data-bind="text: CantidadAplicados"></td>

                                        <td>
                                            <!-- ko if: Aplicado() -->
                                            <span class="badge badge-success"><i class="fas fa-check-circle"></i> Aplicado</span>
                                            <!-- /ko -->
                                            <!-- ko ifnot: Aplicado() -->
                                                <!-- ko if: CantidadAplicados() > 0 -->
                                                <span class="badge badge-warning text-dark">
                                                    <i class="fas fa-clock"></i> Parcial
                                                    (<span data-bind="text: CantidadAplicados"></span>/<span data-bind="text: Cantidad"></span>)
                                                </span>
                                                <!-- /ko -->
                                                <!-- ko if: CantidadAplicados() === 0 -->
                                                <span class="badge badge-secondary"><i class="fas fa-hourglass-half"></i> Pendiente</span>
                                                <!-- /ko -->
                                            <!-- /ko -->
                                        </td>

                                        <td data-bind="text: FechaHoraAplicacion"></td>
                                        <td data-bind="text: Persona"></td>

                                        <td>
                                            <div style="display:flex;align-items:center;gap:5px;flex-wrap:wrap">

                                                <!-- ko if: Cantidad() > CantidadAplicados() -->
                                                <input type="number" class="form-control form-control-sm"
                                                       style="width:60px"
                                                       data-bind="value: CantidadAplicar,
                                                                  attr: { min: 1, max: Cantidad() - CantidadAplicados() }">
                                                <button type="button" class="btn btn-primary btn-sm"
                                                        data-paquete-accion="aplicar"
                                                        data-bind="attr: { 'data-paquete-id': Id }"
                                                        title="Aplicar">
                                                    <i class="fas fa-syringe"></i> Aplicar
                                                </button>
                                                <!-- /ko -->

                                                <!-- ko if: CantidadAplicados() === 0 -->
                                                <button type="button" class="btn btn-danger btn-sm"
                                                        data-paquete-accion="eliminar"
                                                        data-bind="attr: { 'data-paquete-id': Id }"
                                                        title="Eliminar (no aplicado)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                                <!-- /ko -->

                                                <!-- ko if: CantidadAplicados() > 0 -->
                                                <button type="button" class="btn btn-warning btn-sm text-dark"
                                                        data-paquete-accion="devolver"
                                                        data-bind="attr: { 'data-paquete-id': Id }"
                                                        title="Devolver a Pendiente">
                                                    <i class="fas fa-undo-alt mr-1"></i> Devolver
                                                </button>
                                                <!-- /ko -->

                                                <!-- ko if: Aplicado() -->
                                                <span class="text-muted small"><i class="fas fa-lock"></i> Completo</span>
                                                <!-- /ko -->

                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="text-center mt-3" data-bind="visible: listaProductosAplicacion().length > 0">
                                <button type="button" class="btn btn-outline-primary btn-sm"
                                        data-paquete-accion="pagina-anterior"
                                        data-bind="enable: paginaActualPaquetes() > 1">
                                    &#9665; Anterior
