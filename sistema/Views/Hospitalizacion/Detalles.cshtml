    }

    function obtenerMensajeRespuesta(data) {
        return (data && (data.Mensaje || data.mensaje)) || 'Operación no completada.';
    }

    function obtenerValorSelect(selectId) {
        var el = document.getElementById(selectId);
        if (!el) {
            return '';
        }
        if (window.jQuery && jQuery(el).data('select2')) {
