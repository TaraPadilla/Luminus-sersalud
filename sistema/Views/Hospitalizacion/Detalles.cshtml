                                                                           optionsText: function(item) { return item.ProductoCodigo + ' - ' + item.ProductoNombre; },
                                                                           optionsCaption: '-- Seleccione --',
                                                                           value: kit_productoSeleccionado"></select>
                    <small id="texto-cargando-kit-productos" style="display:none;color:#64748b;"><i class="fas fa-spinner fa-spin mr-1"></i>Cargando...</small>
                </div>
                <div class="col-md-3">
                    <label style="font-size:0.78rem;color:#374151;margin-bottom:3px;">Cantidad</label>
                    <input type="number" class="form-control form-control-sm" min="1" value="1" data-bind="value: kit_cantidad" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-sm btn-success w-100" data-bind="click: agregarProductoAlKit">
                        <i class="fas fa-plus mr-1"></i> Agregar
                    </button>
                </div>
            </div>
        </div>

        @* ── TABLA DE PRODUCTOS DEL KIT (sin precios) ── *@
        <div class="table-responsive">
            <table class="table table-bordered table-sm mb-2">
                <thead>
                    <tr style="background:var(--kit-light);">
                        <th>CÓDIGO</th>
                        <th>PRODUCTO</th>
                        <th class="text-center">CANTIDAD</th>
                        <th class="text-center">QUITAR</th>
                    </tr>
                </thead>
                <tbody data-bind="foreach: kit_productosAgregados">
                    <!-- ko ifnot: Eliminado() -->
                    <tr>
                        <td data-bind="text: ProductoCodigo"></td>
                        <td data-bind="text: ProductoNombre"></td>
                        <td class="text-center">
                            <input type="number" class="form-control form-control-sm text-center" min="1" style="width:80px;margin:auto;"
                                   data-bind="value: Cantidad, event: { change: $root.actualizarTotalesKit }" />
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-danger" data-bind="click: $root.quitarProductoKit">
                                <i class="fas fa-times"></i>
                            </button>
                        </td>
                    </tr>
                    <!-- /ko -->
                </tbody>
            </table>
            <!-- ko if: kit_productosAgregados().filter(function(p){ return !p.Eliminado(); }).length === 0 -->
            <div class="text-center text-muted py-3" style="font-size:0.85rem;">
                <i class="fas fa-box-open mr-1"></i> Agregue productos al kit usando el formulario de arriba
            </div>
            <!-- /ko -->
        </div>

        <div style="display:flex; justify-content:flex-end; gap:8px; margin-top:16px;">
            <button type="button" class="btn btn-secondary" onclick='$("#mdl-agregar-kit-ingreso").dialog("close")'><i class="fas fa-times mr-1"></i> Cancelar</button>
            <button type="button" class="btn btn-nota-primary-kit font-weight-bold" data-bind="click: guardarKitIngreso">
                <i class="fas fa-save mr-1"></i> Guardar Kit de Ingreso
            </button>
        </div>
    </div>
</div>

