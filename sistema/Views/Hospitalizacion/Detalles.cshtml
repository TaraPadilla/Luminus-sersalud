     * @@function agregarMedicoSecundarioAlDOM
     * @@description Inserta de forma dinámica un elemento en la lista visual de médicos secundarios.
     * @@param {number} citaId - ID de la cita para el evento del botón quitar.
     * @@param {string} nombre - Nombre descriptivo del médico.
     * @@param {number} medicoId - ID del empleado/médico.
     */
    function agregarMedicoSecundarioAlDOM(citaId, nombre, medicoId) {
        // --- TRAZABILIDAD: OBTENCIÓN DE DATA (CONTENEDOR DOM) ---
        const contenedor = document.getElementById("listaMedicosSecundarios");
        if (!contenedor) {
            mostrarMensaje("No se pudo actualizar la lista de médicos secundarios (contenedor no encontrado).", "danger");
            location.reload();
            return;
        }

        // Lógica de validación: Control de duplicados en el cliente
        if (document.getElementById(`medico-secundario-${medicoId}`)) {
            mostrarMensaje(`ℹ️ ${nombre} ya está agregado como médico secundario.`, "warning");
            return;
        }

        // Construcción de componentes UI (Estructura de trazabilidad visual)
        const item = document.createElement("div");
        item.className = "d-flex justify-content-between align-items-center";
        item.id = `medico-secundario-${medicoId}`;

        const span = document.createElement("span");
        span.className = "h5 font-weight-bold mb-0 text-muted";
        span.style.maxWidth = "85%";
        span.title = nombre;
        span.innerHTML = `<i class="fas fa-user-plus mr-2 text-warning"></i>${nombre}`;

        const botonQuitar = document.createElement("button");
        botonQuitar.className = "btn btn-link text-danger p-0 ml-2";
        botonQuitar.innerHTML = `<i class="fas fa-times-circle fa-lg hover-scale"></i>`;
        
        // Asignación de evento de eliminación con inyección de parámetros de trazabilidad
        botonQuitar.onclick = function() {
            quitarMedicoSecundario(citaId, medicoId, botonQuitar);
        };

        item.appendChild(span);
        item.appendChild(botonQuitar);
        contenedor.appendChild(item);
    }

    /**
     * @@function quitarMedicoSecundario
     * @@description Elimina la relación de un médico secundario con la hospitalización.
     * @@param {number} citaId - Identificador de la cita médica.
     * @@param {number} medicoId - Identificador del médico a desvincular.
     * @@param {HTMLElement} boton - Referencia al elemento del DOM que disparó la acción.
     */
    function quitarMedicoSecundario(citaId, medicoId, boton) {
        const confirmacion = confirm(`¿Deseas quitar al médico secundario con ID ${medicoId}?`);
        if (!confirmacion) {
            alert("Operación cancelada por el usuario.");
            return;
        }

        // --- TRAZABILIDAD: ENTREGA DE DATA (API FETCH) ---
        fetch('/Hospitalizacion/QuitarMedicoSecundario', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    citaId: citaId,
                    empleadoId: medicoId
                }),
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status} - ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                if (esRespuestaExitosa(data)) {
                    const item = document.getElementById(`medico-secundario-${medicoId}`);
                    if (item) item.remove();
                    mostrarMensaje(`✅ Médico secundario eliminado correctamente.`, "success");
                    location.reload();
                } else {
                    mostrarMensaje(`Error: ${obtenerMensajeRespuesta(data)}`, "danger");
                }
            })
            .catch(error => {
                console.error('Error inesperado:', error);
                alert(`Error inesperado: Ocurrió un problema al comunicarse con el servidor. Detalles: ${error.message}`);
            });
    } 
