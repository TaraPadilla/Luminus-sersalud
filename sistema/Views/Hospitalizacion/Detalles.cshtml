                body: JSON.stringify({
                    citaId: citaId,
                    hospitalizacionId: hospitalizacionId,
                    nuevoCodigoSeguro: seguroSeleccionado
                }),
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status} - ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                if (esRespuestaExitosa(data)) {
