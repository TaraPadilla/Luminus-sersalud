@model sistema.Models.HospitalizacionDetallesViewModel
@{
    var usuarioAdmisiones = User.IsInRole("Admisiones");
} 
<div class="tab-pane tabs-animation fade " id="tab-content-nota-enfermeria" role="tabpanel">
    <div class="form-row">
        <div class="col-md-12">
            <div class="main-card mb-3 nota-clinica-card">

                <!-- Header Enfermería -->
                <div class="nota-header nota-header-enfermeria">
                    <div class="d-flex align-items-center">
                        <div class="nota-header-icon nota-header-icon-enfermeria">
                            <i class="fas fa-heartbeat"></i>
                        </div>
                        <div>
                            <h5 class="nota-header-title">Notas de Enfermer&iacute;a</h5>
                            <p class="nota-header-subtitle">Registro de turnos y seguimiento de enfermer&iacute;a</p>
                        </div>
                    </div>
                    <div class="d-flex" style="gap: 8px;">
                        @if (!usuarioAdmisiones)
                        {
                            @if (!Model.HospitalizacionFinalizada && !User.IsInRole("Medico General") && !User.IsInRole("Coordinador Laboratorio") && !User.IsInRole("Tecnico laboratorio") && !User.IsInRole("Medico Externo"))
                            {
                                <button class="btn btn-nota-primary btn-nota-primary-enfermeria"
                                        data-bind="click:agregarTurnoEnfermeria">
                                    <i class="fas fa-plus mr-1"></i> Agregar Turno
                                </button>
                            }
                        }

                        <button class="btn btn-sm btn-info" data-bind="click: function() { window.open('/CrearPDF/NotasEnfermeriaAllPDF?hospitalizacionId=' + $root.hospitalizacionId(), '_blank'); }">
    <i class="fas fa-print"></i> Imprimir todas
</button>
                    </div>
                </div>

                <!-- Cuerpo -->
                <div class="nota-card-body">
                    <div class="table-responsive">
                        <table class="table tabla-notas">
                            <thead>
                                <tr>
                                    <th>Fecha de registro</th>
                                    <th>N&deg; Turno</th>
                                    <th>Profesional</th>
                                    <th>Nombre del Turno</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!--ko foreach: turnosEnfermeria-->
                                <tr>
                                    <td>
                                        <div class="nota-fecha-wrapper">
                                            <div class="nota-fecha-icon nota-fecha-icon-enfermeria">
                                                <i class="fas fa-calendar-check"></i>
                                            </div>
                                            <div>
                                                <div class="nota-fecha-text" data-bind="text:FechaRegistro"></div>
                                                <div class="nota-fecha-label">Registro de turno</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge badge-light border" data-bind="text: NumeroTurno || '—'"></span>
                                    </td>
                                    <td>
                                        <span class="nota-badge-enfermeria" data-bind="text:Profesional"></span>
                                    </td>
                                    <td>
                                        <div class="nota-contenido-cell nota-contenido-cell-enfermeria" data-bind="text:NombreTurno"></div>
                                    </td>
                                    <td class="text-center">
    <div class="d-flex justify-content-center" style="gap: 6px;">
        <button class="btn btn-nota-accion btn-nota-enfermeria"
                data-bind="click: function() { $root.verModalAgregarNotaEnfermeria(Id) }">
            <i class="fas fa-eye mr-1"></i> Ver Notas
        </button>

<!-- ko if: Firmado -->
        <span class="badge badge-success px-2 py-1" style="font-size:0.75rem;border-radius:8px;">
            <i class="fas fa-check-circle mr-1"></i> Firmado
        </span>
        <!-- /ko -->

        @if(!User.IsInRole("Medico Externo")){ 
<!-- ko ifnot: Firmado -->
        <button class="btn btn-nota-accion btn-nota-firmar"
                data-bind="click: function() { $root.abrirModalFirmaTurnoEnfermeria($data) }">
            <i class="fas fa-signature mr-1"></i> Firmar
        </button>
        <!-- /ko -->
        }
    </div>
</td>

                                </tr>
                                <!--/ko-->
                                <!-- ko if: turnosEnfermeria().length === 0 -->
                                <tr>
                                    <td colspan="5">
                                        <div class="nota-empty-state">
                                            <i class="fas fa-heartbeat d-block"></i>
                                            <p>No hay turnos de enfermer&iacute;a registrados</p>
                                        </div>
                                    </td>
                                </tr>
                                <!-- /ko -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Footer -->
                <div class="nota-footer">
                    <span><i class="fas fa-list-ul mr-1" style="color:var(--enfermeria-color)"></i> Turnos registrados: <strong data-bind="text: turnosEnfermeria().length"></strong></span>
                </div>

            </div>
        </div>
    </div>
</div>
