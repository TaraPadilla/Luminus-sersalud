    <link href="~/css/daterangepicker.css" rel="stylesheet">

    <script>
        var acc = document.getElementsByClassName("accordion");
        var i;

        for (i = 0; i < acc.length; i++) {
            acc[i].addEventListener("click", function () {
                this.classList.toggle("active");
                var panel = this.nextElementSibling;
                if (panel.style.maxHeight) {
                    panel.style.maxHeight = null;
                } else {
                    panel.style.maxHeight = panel.scrollHeight + "px";
                }
            });
        }
    </script>

    <script>
            function abrirVentanaEditarConsultaHistoriaClinica(consultaId) {
            var url = '/Consultas/EditarConsultaHistoriaClinica/' + consultaId;

            // Tamaño de la ventana emergente
            var width = 900;
            var height = 600;

            // Cálculo de la posición centrada
            var left = (screen.width / 2) - (width / 2);
            var top = (screen.height / 2) - (height / 2);

            // Especificaciones de la ventana, incluyendo las posiciones calculadas
            var windowFeatures = "width=" + width + ",height=" + height + ",top=" + top + ",left=" + left + ",scrollbars=yes,resizable=yes";

            // Abrir la ventana en la posición calculada
            window.open(url, "EditarConsultaHistoriaClinica", windowFeatures);
        }
    </script>
}