@model sistema.Models.HospitalizacionDetallesViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    // Leer el valor del appsettings.json. 
    string sufijoLayout = Configuration["Cliente"]; 
    
    // Concatenar para formar el nombre del Layout (ejemplo: "_Layout" + "SS")
    // Si la clave trae el nombre completo (ej. "_LayoutSS"), simplemente asignalo directo.
    Layout = $"_Layout{sufijoLayout}"; 
    ViewData["Title"] = "Hospitalizacion - Detalles";
}

@await Html.PartialAsync("_MensajeExito")

@Html.HiddenFor(m => m.HospitalizacionId)


@Html.HiddenFor(m => m.CuentaId)
@Html.HiddenFor(m => m.HabitacionId)
@Html.HiddenFor(m => m.PacienteId)
@Html.HiddenFor(m => m.FechaInicial)
@Html.HiddenFor(m => m.FechaFinal)

<style>
    .accordion {
        cursor: pointer;
        background-color: #eee;
        color: #444;
        cursor: pointer;
        padding: 18px;
        width: 100%;
        border: none;
        text-align: left;
        outline: none;
        font-size: 15px;
        transition: 0.4s;
    }

        .accordion:hover {
            background-color: #ccc;
        }

    .panel {
        padding: 0 18px;
        background-color: white;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.2s ease-out;
    }
</style>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="col-md-12">
            <center><h4><b>Hospitalizaci&oacute;n - Informaci&oacute;n</b></h4></center>
            <hr />
            @if (!Model.Pagada)
            {
                <button class="btn btn-success mr-2"
                        data-bind="click:pagarCuenta">
                    <i class="fas fa-dollar-sign"></i>&nbsp;
                    Pagar Q <span data-bind="text:totalPagar"></span>
                </button>
                <button class="btn btn-primary" data-bind="click:verModalCambioHabitacion">
                    Cambiar de habitaci&oacute;n
                </button>
            }
            <button class="btn btn-danger" data-bind="click:verInformeGeneral">
                <i class="fas fa-file-pdf"></i>&nbsp;Informe general
            </button>
            <button class="btn btn-danger" data-bind="click:verInformeDetallado">
                <i class="fas fa-file-pdf"></i>&nbsp;Informe detallado
            </button>
        </div>
    </div>
</div>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-11">
                <h5><b>Paciente</b></h5>
                <hr />
            </div>
            <div class="col-md-1">
                <button class="btn btn-primary" onclick="irADetallesPaciente(@Model.PacienteId)">
                    <i class="fas fa-external-link-alt"></i>&nbsp;
                    Ver
                </button>
            </div>
        </div>
        <div class="form-row">
            <div class="col-md-4">
                <label><b>Nombre</b></label><br />
                @Model.PacienteNombre
            </div>
            <div class="col-md-4">
                <label><b>Tipo</b></label><br />
                @Model.TipoPaciente
            </div>
            <div class="col-md-4">
                <label><b>Sexo</b></label><br />
                @Model.PacienteSexo
            </div>
            <div class="col-md-4">
                <label><b>Tipo de sangre</b></label><br />
                @Model.PacienteTipoSangre
            </div>
            <div class="col-md-4">
                <label><b>Tel&eacute;fono</b></label><br />
                @Model.PacienteTelefono
            </div>
            <div class="col-md-4">
                <label><b>Celular</b></label><br />
                @Model.PacienteCelular
            </div>
            <div class="col-md-4">
                <label><b>Especialidad</b></label><br />
                @Model.EspecialidadNombre
            </div>
        </div>
    </div>
</div>

<ul class="body-tabs body-tabs-layout tabs-animated body-tabs-animated nav">
    <li class="nav-item">
        <a role="tab" class="nav-link active" id="tab-0" data-toggle="tab" href="#tab-content-0">
            <span>Gabinete y Laboratorios</span>
        </a>
    </li>
    <li class="nav-item">
        <a role="tab" class="nav-link" id="tab-historia-clinica" data-toggle="tab" href="#tab-content-historia-clinica">
            <span>Historica Clinica</span>
        </a>
    </li>
    <li class="nav-item">
        <a role="tab" class="nav-link" id="tab-historia-clinica-pediatria" data-toggle="tab" href="#tab-content-historia-clinica-pediatria">
            <span>Historica Clinica Pediatria</span>
        </a>
    </li>
    <li class="nav-item">
