@model sistema.Models.HospitalizacionDetallesViewModel
<input type="hidden" id="PreanestPuedeEditar" value="@(!User.IsInRole("Medico Externo") ? "1" : "0")" />
<div class="tab-pane tabs-animation fade" id="tab-content-preanestesico" role="tabpanel">
    <div class="form-row">
        <div class="col-md-12">
            <div class="main-card mb-3 nota-clinica-card">

                <div class="nota-header nota-header-preanest">
                    <div class="d-flex align-items-center">
                        <div class="nota-header-icon nota-header-icon-preanest">
                            <i class="fas fa-notes-medical"></i>
                        </div>
                        <div>
                            <h5 class="nota-header-title">Cuestionario Pre-Anest&eacute;sico</h5>
                            <p class="nota-header-subtitle">Evaluaci&oacute;n del estado de salud previo a la anestesia</p>
                        </div>
                    </div>
                    
                    @if(!User.IsInRole("Medico Externo")){

                    <div>
                        <button type="button" class="btn btn-nota-primary btn-nota-primary-preanest" data-preanest-accion="nuevo">
                            <i class="fas fa-plus mr-1"></i> Nuevo Cuestionario
                        </button>
                    </div>
                    }
                </div>

                <div class="nota-card-body">
                    <div class="table-responsive">
                        <table class="table tabla-notas">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Paciente</th>
                                    <th>Procedimiento programado</th>
                                    <th>Cirujano</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-cuestionarios-preanest"></tbody>
                        </table>
                    </div>
                </div>

                <div class="nota-footer">
                    <span><i class="fas fa-notes-medical mr-1" style="color:var(--preanest-color)"></i> Cuestionarios registrados: <strong id="preanest-total-count">0</strong></span>
                </div>
            </div>
        </div>
    </div>
</div>
