}



@section css {
    <style>
        .app-main {
            @* background-image: url("/assets/images/cubbas.png"); *@ background-size: cover;
        }

        .logoprincipal img {
            width: 350px;
            display: block;
            margin: auto;
        }

        .logoprincipal {
            width: 100%;
        }

        @@media screen and (max-width: 620px) {
            .logoprincipal img {
                width: 250px;
                display: block;
                margin: auto;
            }
        }
    </style>
}

@await Html.PartialAsync("_MensajeExito")


