@using System;
@using System.Globalization;
@model IEnumerable<Database.Shared.Models.Producto>;

@{ Layout = "_HojaLayout"; }

<div class="header center" style="width: 100%; background-color: #1D50BD; color: white; padding: 5px; font-family: Georgia, serif ">
    <strong><b><span style="font-size: 18PX;  ">FALTANTES CLINICA ELOIM</span></b></strong>
    <br>

    <br>
    <strong>Los Cruces, Peten, zona 2</strong>
    <br>
</div>
<br>
<br>
<div>
    <span class="font-weight-bold">FECHA DE EMISI&#211;N </span>
    <span> @DateTime.Now.ToString("D", CultureInfo.CreateSpecificCulture("Es-GT")).ToUpperInvariant()</span>
</div>

<div>
    <span class="font-weight-bold"> Lugar </span>
    <span> Clínica </span>
</div>
<br>

<style>
    .seccion-expediente {
        background-color: black;
        color: white;
        padding: 10px;
    }

    .lgon {
        width: 300px;
        height: 100px;
        background-image: url("logo");
    }

    thead {
        background-color: black;
        color: white;
    }

    .color {
        background-color: red;
        width: 100%;
        height: 5px;
    }

    .textoTipo {
        font-family: Georgia, serif;
    }

    .fondo {
        background-color: #1D50BD;
    }

    .custom-table td, .custom-table th {
        padding: 1px; /* Ajusta este valor según sea necesario */
    }

    footer {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 10px; /* Puedes ajustar la altura según tus necesidades */
        padding: 15px;
        height: 14%; /* Ajusta la altura según tus necesidades */
    }
</style>

<table class="table table-bordered">
    <thead>
        <tr>
            <th style="background: #1D50BD !important; color: white;"><span contenteditable>Producto</span></th>
            <th style="background: #1D50BD !important; color: white;"><span contenteditable>Presentación</span></th>
            <th style="background: #1D50BD !important; color: white;"><span contenteditable>Stock</span></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var producto in Model)
        {
            var presentacion = producto.PresentacionProducto == null ? "// sin asignar" : producto.PresentacionProducto.PresentProducto;

<tr>
    <td><span contenteditable>@producto.NombreProducto</span></td>
    <td><span data-prefix>@presentacion</span></td>
    <td><span>@producto.Stock</span> </td>
</tr>}
    </tbody>
</table>







