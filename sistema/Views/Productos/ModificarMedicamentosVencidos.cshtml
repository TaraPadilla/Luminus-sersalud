@{
}
@using sistema.Models
@model InventarioProductoViewModel
@{
     ViewData["Title"] = Model.TipoBodegaNombre + " - " + Model.TipoProductoNombre;
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>@(Model.TipoBodegaNombre + " - Modificar " + Model.TipoProductoNombre+" "+"Vencidos")</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_InventarioProdctosVencidosFrom")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div>
            <button class="btn btn-danger" data-bind="click: cancelarEdicionProducto">
                Cancelar
            </button>
            <button class="btn btn-primary" data-bind="click: editarProductoVencido">
                Guardar nueva Fecha
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="text/javascript" src="~/ViewModelKo/InventarioProductoVM.js"></script>
}