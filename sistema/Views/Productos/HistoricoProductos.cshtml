@using sistema.Models
@using Microsoft.AspNetCore.Mvc.Rendering
@model sistema.Models.MovimientoProductoViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    // Leer el valor del appsettings.json. 
    string sufijoLayout = Configuration["Cliente"]; 
    
    // Concatenar para formar el nombre del Layout (ejemplo: "_Layout" + "SS")
    // Si la clave trae el nombre completo (ej. "_LayoutSS"), simplemente asignalo directo.
    Layout = $"_Layout{sufijoLayout}";
    ViewData["Title"] = "Histórico de Productos";
}

@await Html.PartialAsync("_MensajeExito")

<div class="container-fluid px-0 px-md-2">

    <!-- Header -->
    <div class="d-flex align-items-start align-items-md-center justify-content-between flex-wrap mb-3">
        <div class="mb-2 mb-md-0">
            <h4 class="mb-1 font-weight-bold">Histórico de Productos</h4>
            <div class="text-muted small">Kardex / Movimientos</div>
        </div>
    </div>

    <!-- Filtros / Acciones (reordenado) -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">

            <!-- 1) Fecha -->
            <div class="row">
                <div class="col-12">
                    <label class="text-muted small mb-1">Rango de fechas</label>

                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white">
                                <i class="fa fa-calendar"></i>
                            </span>
                        </div>

                        <input type="text"
                               class="form-control"
                               id="reservationtime"
                               name="fecha"
                               placeholder="Sin filtro (consultar todo)">

                        <div class="input-group-append">
                            <button type="button"
                                    class="btn btn-outline-secondary"
                                    data-bind="click: limpiarFecha"
                                    title="Limpiar rango">
                                <i class="fa fa-times"></i>
                            </button>
                        </div>
                    </div>

                    <small class="form-text text-muted mb-0">
                        Si no eliges fechas, se consulta todo el histórico.
                    </small>
                </div>
            </div>

            <hr class="my-3" />

            <!-- 2) Filtros (debajo de fecha) -->
            <div class="row">
                <div class="col-12">
                    <label class="text-muted small mb-1">Filtros</label>

                    <div class="d-flex flex-wrap align-items-center">
                        <button type="button" class="btn btn-outline-primary btn-sm mr-2 mb-2"
                                data-bind="click: showModalFiltrarTipoProducto">
                            <i class="fa fa-tags mr-1"></i>
                            Tipo producto
                            <span class="badge badge-primary ml-1" data-bind="text: selectedTiposProducto().length"></span>
                        </button>

                        <button type="button" class="btn btn-outline-primary btn-sm mr-2 mb-2"
                                data-bind="click: showModalFiltrarAmbientes">
                            <i class="fa fa-map-marker mr-1"></i>
                            Ambientes
                            <span class="badge badge-primary ml-1" data-bind="text: selectedAmbientes().length"></span>
                        </button>

                        <button type="button" class="btn btn-outline-primary btn-sm mr-2 mb-2"
                                data-bind="click: showModalFiltrarBodegas">
                            <i class="fa fa-archive mr-1"></i>
                            Bodegas
                            <span class="badge badge-primary ml-1" data-bind="text: selectedBodegas().length"></span>
                        </button>

                        <button type="button" class="btn btn-outline-primary btn-sm mr-2 mb-2"
                                data-bind="click: showModalFiltrarProductos">
                            <i class="fa fa-box mr-1"></i>
                            Productos
                            <span class="badge badge-primary ml-1" data-bind="text: selectedProductos().length"></span>
                        </button>

                        <button type="button" class="btn btn-outline-secondary btn-sm mr-2 mb-2" disabled title="Obviado por ahora">
                            <i class="fa fa-receipt mr-1"></i> Facturado
                            <span class="badge badge-secondary ml-1">0</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 3) Acciones (debajo de filtros) -->
            <div class="row">
                <div class="col-12">
                    <div class="d-flex flex-wrap align-items-center mt-1">
                        <button type="button" class="btn btn-primary mr-2 mb-2"
                                data-bind="click: consultarHistorico">
                            <i class="fa fa-search mr-1"></i> Consultar histórico
                        </button>

                        <button type="button" class="btn btn-outline-secondary mr-2 mb-2"
                                data-bind="click: limpiarFiltros">
                            <i class="fa fa-eraser mr-1"></i> Limpiar
                        </button>

                        <div class="btn-group mb-2 ml-auto" role="group" aria-label="Exportar">
                            <button type="button" class="btn btn-outline-danger"
                                    data-bind="click: generarReportePDF">
                                <i class="fa fa-file-pdf mr-1"></i> PDF
                            </button>
                            <button type="button" class="btn btn-outline-success"
                                    data-bind="click: generarReporteExcel">
                                <i class="fa fa-file-excel mr-1"></i> Excel
                            </button>
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

    <!-- Tabla -->
    <div class="card border-0 shadow-sm p-3">
        <div class="card-body p-0">

            <div class="px-3 pt-3 d-flex align-items-center justify-content-between flex-wrap">
                <div class="mb-2 mb-md-0">
                    <span class="font-weight-bold">Listado</span>
                    @* <span class="text-muted small ml-2" data-bind="text: movimientosFiltrados().length + ' registros'"></span> *@
                    <span class="text-muted small ml-2" data-bind="text: totalRegistros"></span>

                </div>
            </div>

            <div class="table-responsive mt-2">
                <table id="tabla-historico" class="table table-hover table-sm mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th class="text-nowrap">Fecha</th>
                            <th class="text-nowrap">Ambiente</th>
                            <th class="text-nowrap">Bodega</th>
                            <th class="text-nowrap">Tipo mov.</th>
                            <th>Descripción</th>
                            <th class="text-nowrap">Tipo producto</th>
                            <th>Producto</th>
                            <th class="text-nowrap">Lote</th>
                            <th class="text-nowrap">Unidad</th>
                            <th class="text-right text-nowrap">Cantidad</th>
                            <th class="text-right text-nowrap">Saldo final</th>
                            <th class="text-nowrap">Facturado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- ko foreach: movimientosFiltrados -->
                        @* <tr>
                            <td class="text-nowrap" data-bind="text: moment(Fecha).format('DD-MM-YYYY HH:mm')"></td>
                            <td class="text-nowrap" data-bind="text: AmbienteNombre"></td>
                            <td class="text-nowrap" data-bind="text: BodegaNombre"></td>
                            <td class="text-nowrap" data-bind="text: TipoMovimientoNombre"></td>
                            <td data-bind="text: DescripcionMovimiento"></td>
                            <td class="text-nowrap" data-bind="text: TipoProductoNombre"></td>
                            <td data-bind="text: Medicamento"></td>
                            <td class="text-nowrap" data-bind="text: Lote"></td>
                            <td class="text-nowrap" data-bind="text: UnidadNombre"></td>
                            <td class="text-right text-nowrap" data-bind="text: Cantidad"></td>
                            <td class="text-right text-nowrap" data-bind="text: SaldoActual"></td>
                            <td class="text-muted text-nowrap">-</td>
                        </tr> *@
                        <!-- /ko -->
                    </tbody>
                </table>
            </div>

            <div class="p-3" data-bind="visible: movimientosFiltrados().length === 0">
                <div class="alert alert-light border mb-0">
                    <i class="fa fa-info-circle mr-1"></i>
                    <small class="text-muted">No hay resultados con los filtros seleccionados.</small>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Modal genérico de filtros -->
<div id="mdl-filtro-generico" style="display:none;">
    <div class="mb-2 d-flex justify-content-between align-items-center">
        <div>
            <strong data-bind="text: modalFiltroTitulo"></strong>
            <div class="text-muted" style="font-size: 12px;">Selecciona los valores a mostrar</div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover mb-2" id="tabla-filtro-generico">
            <thead class="thead-light">
                <tr>
                    <th style="width:90px;">
                        <div class="custom-control custom-checkbox m-0">
                            <input class="custom-control-input" type="checkbox" id="chkModalSelectAll" data-bind="checked: modalSelectAll">
                            <label class="custom-control-label" for="chkModalSelectAll">Todos</label>
                        </div>
                    </th>
                    <th data-bind="text: modalFiltroColumnaNombre"></th>
                </tr>
            </thead>
            <tbody data-bind="foreach: modalFiltroOpciones">
                <tr>
                    <td>
                        <div class="custom-control custom-checkbox m-0">
                            <input class="custom-control-input"
                                   type="checkbox"
                                   data-bind="attr: { id: 'opt_' + $index() }, checked: selected" />
                            <label class="custom-control-label" data-bind="attr: { for: 'opt_' + $index() }"></label>
                        </div>
                    </td>
                    <td data-bind="text: name"></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-end">
        <button type="button" class="btn btn-outline-secondary mr-2" data-bind="click: limpiarFiltroModal">Limpiar</button>
        <button type="button" class="btn btn-primary" data-bind="click: aplicarFiltroModal">Aplicar</button>
    </div>
</div>

@section Scripts
{
    <script type="text/javascript" src="~/js/moment.min.js"></script>
    <script type="text/javascript" src="~/js/daterangepicker.js"></script>

    @* DataTables: si no está global, incluye aquí *@
    @* <script src="~/lib/datatables/jquery.dataTables.min.js"></script>
       <script src="~/lib/datatables/dataTables.bootstrap4.min.js"></script> *@

    <script type="text/javascript" src="~/ViewModelKo/HistoricoProductosVM.js"></script>

    <script>
        $(function () {
            $('#reservationtime').daterangepicker({
                timePicker: true,
                timePickerIncrement: 30,
                autoUpdateInput: false,
                locale: {
                    format: 'MM/DD/YYYY hh:mm A',
                    applyLabel: 'Aplicar',
                    cancelLabel: 'Limpiar',
                    fromLabel: 'Desde',
                    toLabel: 'Hasta',
                    customRangeLabel: 'Personalizado',
                    weekLabel: 'S',
                    daysOfWeek: ['Do', 'Lu', 'Ma', 'Mi', 'Ju', 'Vi', 'Sa'],
                    monthNames: ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'],
                    firstDay: 1
                }
            });

            $('#reservationtime').on('apply.daterangepicker', function (ev, picker) {
                $(this).val(
                    picker.startDate.format('MM/DD/YYYY hh:mm A') +
                    ' - ' +
                    picker.endDate.format('MM/DD/YYYY hh:mm A')
                );
            });

            $('#reservationtime').on('cancel.daterangepicker', function () {
                $(this).val('');
            });
        });
    </script>
}

@section css
{
    <link href="~/css/daterangepicker.css" rel="stylesheet" />

    <style>
        #tabla-historico thead th { border-top: 0; }
        .card { border-radius: .5rem; }
        .badge { font-weight: 600; }
        .table-responsive { border-top: 1px solid rgba(0,0,0,.05); }
    </style>
}
