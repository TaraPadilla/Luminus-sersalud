<div class="col-md-6">
    @if (registroInventario.ProductosInventarioPrecios != null)
    {
        // Filtrar solo el precio con nombre "Precio Costo"
        var precioCosto = registroInventario.ProductosInventarioPrecios.FirstOrDefault(p => p.Precio.NombrePrecio == "Precio Costo");

        if (precioCosto != null)
        {
            <span id="precio_@(registroInventario.Id)_@(precioCosto.Id)">
                Precio Costo: @precioCosto.Valor
            </span>
            <br/><br/>
        }
        else
        {}
    }
    else
    {}
    @if (registroInventario.ProductosInventarioPrecios != null)
    {
        <label for="precioSelector_@(registroInventario.Id)">Selecciona un precio:</label>


        <select id="precioSelector_@(registroInventario.Id)" class="form-select precio-select2" onchange="mostrarPrecioSeleccionado(@registroInventario.Id)">
            <option value="" disabled selected>Selecciona un precio</option>
            @if (Model.SeguroId != null && Model.SeguroId != 0)
            {
                // Obtener el nombre del seguro basado en SeguroId
                var seguroNombre = Model.SegurosSelectList.FirstOrDefault(s => s.Value == Model.SeguroId.ToString())?.Text;

                if (!string.IsNullOrEmpty(seguroNombre))
                {
                    // Filtrar precios basados en el nombre del seguro
                    var precioSeguro = Model.Precios.FirstOrDefault(p => p.NombrePrecio == seguroNombre);
                    if (precioSeguro != null)
                    {
                        <option value="@precioSeguro.Id">@precioSeguro.NombrePrecio</option>
                    }
                }
            }
            else
            {
                // Mostrar todos los precios si no hay SeguroId
                foreach (var p in Model.Precios)
                {
                    // Mostrar "Precio Costo" solo si el usuario es Administrador
                    if (p.NombrePrecio == "Precio Costo" && !usuarioAdministrador)
                    {
                        continue;
                    }
                    <option value="@p.Id">@p.NombrePrecio</option>
                }
            }
        </select>



        <div id="precioDetalle_@(registroInventario.Id)" class="mt-3" style="display: none;">
            <span id="precioNombre_@(registroInventario.Id)"></span>: 
            <span id="precioValor_@(registroInventario.Id)" style="font-weight: bold;"></span>
            <button class="btn btn-primary btn-sm" id="editarBtn_@(registroInventario.Id)" style="display: none;">
                <i class="fas fa-edit"></i> Editar
            </button>
        </div>

        <!-- Inputs ocultos para manejar valores -->
        @foreach (var p in Model.Precios)
        {
            var precio = registroInventario.ProductosInventarioPrecios.FirstOrDefault(x => x.PrecioId == p.Id);
            var valor = precio?.Valor ?? 0;
