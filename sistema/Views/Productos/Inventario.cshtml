<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>

<script>
    function generarCodigosBarras() {
        console.log("Generando códigos de barras...");
        
        var elementos = document.querySelectorAll('.barcode-main-table');
        console.log("Elementos encontrados:", elementos.length);
        
        if (elementos.length === 0) {
            console.log("No se encontraron elementos .barcode-main-table");
            return;
        }
        
        elementos.forEach(function(img) {
            var serial = img.getAttribute('data-serial');
            
            if (serial && serial !== "" && typeof JsBarcode !== 'undefined') {
                try {
                    serial = serial.replace(/[^a-zA-Z0-9]/g, '-');
                    
                    JsBarcode(img, serial, {
                        format: "CODE128",
                        displayValue: true,
                        fontSize: 14,
                        width: 2.5,
                        height: 50,
                        margin: 8,
                        background: "#ffffff",
                        lineColor: "#000000"
                    });
                    console.log("Código generado para:", serial);
                } catch (error) {
                    console.error("Error:", error);
                }
            }
        });
    }

    function manejarZoom() {
        console.log("Inicializando sistema de zoom para escaneo...");
        
        $(document).off('click', '.barcode-main-table');
        $(document).off('click', 'body');
        
        $(document).on('click', '.barcode-main-table', function(e) {
            e.stopPropagation();
            
            console.log("Click en código de barras - preparando para escaneo");
            
            $('.barcode-zoom-active').each(function() {
                $(this).removeClass('barcode-zoom-active')
                       .removeAttr('style');
            });
            
            var serial = $(this).attr('data-serial');
            
            var $this = $(this);
            var $wrapper = $this.closest('.barcode-wrapper-container');
            var nombreProducto = $wrapper.find('small').text();
            
            $this.addClass('barcode-zoom-active')
                   .css({
                       'position': 'fixed',
                       'top': '50%',
                       'left': '50%',
                       'transform': 'translate(-50%, -50%)',
                       'z-index': '10000',
                       'box-shadow': '0 0 0 9999px rgba(0,0,0,0.8), 0 0 50px rgba(0,0,0,0.9)',
                       'border': '4px solid #007bff',
                       'padding': '40px',
                       'background': 'white',
                       'width': 'auto',
                       'height': 'auto',
                       'max-width': '95vw',
                       'max-height': '90vh',
                       'object-fit': 'contain'
                   });
            
            if ($('.zoom-instructions').length === 0) {
                $('body').append(`
                    <div class="zoom-instructions" style="
                        position: fixed;
                        bottom: 30px;
                        left: 50%;
                        transform: translateX(-50%);
                        z-index: 10001;
                        background: #28a745;
                        color: white;
                        padding: 15px 30px;
                        border-radius: 50px;
                        font-size: 18px;
                        font-weight: bold;
                        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
                        text-align: center;
                        pointer-events: none;
                    ">
                        
                        <div style="font-size: 14px; margin-top: 5px;">Haga clic fuera para cerrar</div>
                    </div>
                `);
            }
        });
        
        $(document).on('click', 'body', function(e) {
            if (!$(e.target).hasClass('barcode-zoom-active') && !$(e.target).hasClass('zoom-instructions')) {
                $('.barcode-zoom-active').removeClass('barcode-zoom-active')
                                         .removeAttr('style');
                $('.zoom-instructions').remove();
            }
        });
        
        $(document).on('click', '.barcode-zoom-active', function(e) {
            e.stopPropagation();
        });
    }

    $(document).ready(function() {
        if (!$('#barcode-styles').length) {
            $('head').append(`
                <style id="barcode-styles">
                    /* Estilo base en tabla */
                    .barcode-main-table {
                        width: 250px !important;
                        height: 70px !important;
                        min-width: 250px !important;
                        min-height: 70px !important;
                        max-width: 250px !important;
                        max-height: 70px !important;
                        cursor: zoom-in;
                        transition: all 0.3s ease;
                        display: block !important;
                        margin: 0 auto !important;
                        background: white;
                        padding: 5px;
                        border: 1px solid #ccc;
                        border-radius: 6px;
                        object-fit: contain;
                    }
                    
                    .barcode-wrapper-container {
                        width: 280px !important;
                        height: 100px !important;
                        margin: 10px auto !important;
                        padding: 8px !important;
                        display: flex !important;
                        flex-direction: column !important;
                        align-items: center !important;
                        justify-content: center !important;
                        background: #f8f9fa;
                        border-radius: 8px;
                        border: 1px solid #dee2e6;
                    }
                    
                    .barcode-wrapper-container small {
                        max-width: 260px !important;
                        white-space: nowrap !important;
                        overflow: hidden !important;
                        text-overflow: ellipsis !important;
                        font-size: 12px !important;
                        font-weight: 500 !important;
                        margin-bottom: 5px !important;
                        color: #333;
                    }
                    
                    .barcode-wrapper-container::before {
                        display: block;
                        font-size: 11px;
                        font-weight: bold;
                        color: #dc3545;  /* Rojo para destacar */
                        margin-bottom: 3px;
                        text-transform: uppercase;
                        letter-spacing: 0.5px;
                    }
                    
                    /* ZOOM OPTIMIZADO PARA ESCANEO - TAMAÑO MUY GRANDE */
                    .barcode-zoom-active {
                        position: fixed !important;
                        top: 50% !important;
                        left: 50% !important;
                        transform: translate(-50%, -50%) scale(1) !important;
                        z-index: 10000 !important;
                        box-shadow: 0 0 0 9999px rgba(0,0,0,0.8), 0 0 60px rgba(0,0,0,0.9) !important;
                        border: 4px solid #007bff !important;
                        padding: 40px !important;
                        background: white !important;
                        cursor: zoom-out !important;
                        width: auto !important;
                        height: auto !important;
                        max-width: 1200px !important;      /* Aumentado para escaneo */
                        max-height: 800px !important;      /* Aumentado para escaneo */
                        min-width: 600px !important;       /* Mínimo más grande */
                        min-height: 200px !important;
                        object-fit: contain !important;
                        border-radius: 16px;
                    }
                    
                    /* Asegurar que las barras se vean nítidas en zoom */
                    .barcode-zoom-active canvas {
                        width: 100% !important;
                        height: auto !important;
                        display: block !important;
                    }
                    
                    /* Responsive para diferentes pantallas */
                    @@media (min-width: 1400px) {
                        .barcode-zoom-active {
                            max-width: 1400px !important;
                            max-height: 900px !important;
                            min-width: 800px !important;
                        }
                    }
                    
                    @@media (max-width: 1200px) {
                        .barcode-main-table {
                            width: 220px !important;
                            height: 60px !important;
                        }
                        
                        .barcode-wrapper-container {
                            width: 250px !important;
                            height: 90px !important;
                        }
                        
                        .barcode-zoom-active {
                            max-width: 95vw !important;
                            max-height: 85vh !important;
                            min-width: 500px !important;
                            padding: 30px !important;
                        }
                    }
                    
                    @@media (max-width: 768px) {
                        .barcode-main-table {
                            width: 180px !important;
                            height: 50px !important;
                        }
                        
                        .barcode-wrapper-container {
                            width: 200px !important;
                            height: 80px !important;
                        }
                        
                        .barcode-zoom-active {
                            max-width: 98vw !important;
                            max-height: 90vh !important;
                            min-width: 350px !important;
                            padding: 20px !important;
                        }
                    }
                </style>
            `);
        }
        
        manejarZoom();
        
        setTimeout(function() {
            if (!$.fn.DataTable.isDataTable('#tabla-clinica-medicamentos')) {
                var table = $('#tabla-clinica-medicamentos').DataTable({
                    "paging": true,
                    "lengthChange": true,
                    "searching": true,
                    "ordering": true,
                    "info": true,
                    "autoWidth": false,
                    "responsive": true,
                    "language": {
                        "search": "Buscar:",
                        "lengthMenu": "Mostrar _MENU_ registros",
                        "zeroRecords": "No se encontraron resultados",
                        "info": "Mostrando _START_ a _END_ de _TOTAL_ registros",
                        "infoEmpty": "Mostrando 0 a 0 de 0 registros",
                        "infoFiltered": "(filtrado de _MAX_ registros totales)",
                        "paginate": {
                            "first": "Primero",
                            "last": "Último",
                            "next": "Siguiente",
                            "previous": "Anterior"
                        }
                    },
                    "drawCallback": function(settings) {
                        setTimeout(generarCodigosBarras, 100);
                    }
                });
            }
            
            setTimeout(generarCodigosBarras, 500);
        }, 500);
    });

    $(document).on('shown.bs.collapse', function() {
        setTimeout(generarCodigosBarras, 200);
    });

    $('#exampleModal').on('shown.bs.modal', function() {
        setTimeout(generarCodigosBarras, 500);
    });
</script>

    <script>
        $(function () {
            $('[data-toggle="tooltip"]').tooltip();
        });
    </script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>

    <!-- Inicialización de Select2 -->
    <script>
        $(document).ready(function () {

            $('#exampleModal').appendTo("body");

            $('.precio-select2').select2({
                placeholder: "Selecciona un tipo de precio",
                allowClear: true  // Permitir limpiar la selección
            });

        });

        function mostrarPrecioSeleccionado(registroId) {
            const selector = $(`#precioSelector_${registroId}`).val();  // Obtener el valor con Select2
            const detalleDiv = document.getElementById(`precioDetalle_${registroId}`);
            const nombreSpan = document.getElementById(`precioNombre_${registroId}`);
            const valorSpan = document.getElementById(`precioValor_${registroId}`);
            const editarBtn = document.getElementById(`editarBtn_${registroId}`);

            const precioId = selector;
            const precioInput = document.getElementById(`hiddenPrecio_${registroId}_${precioId}`);

            if (precioInput) {
                const nombre = precioInput.getAttribute("data-nombre");
                const valor = precioInput.value;

                nombreSpan.textContent = nombre;
                valorSpan.textContent = valor;

                editarBtn.style.display = "inline-block";
                editarBtn.onclick = function () {
                    editarPrecioProducto(precioId, valor, precioId, registroId);
                };

                detalleDiv.style.display = "block";
            } else {
                detalleDiv.style.display = "none";
            }
        }

        function abrirModalGeneral() {
            const contenedor = $('#divReplicaTabla');
            contenedor.empty();

            const loaderHtml = `
                <div class="loading-container" id="loader-conexion">
                    <div class="spinner-border text-primary" role="status">
                        <span class="sr-only">Cargando...</span>
                    </div>
                    <div class="loading-text pulse-text">BUSCANDO CONEXIÓN...</div>
                </div>
            `;
            contenedor.append(loaderHtml);

            $('#exampleModal').modal('show');

            setTimeout(function() {
                $('#loader-conexion').remove();

                const tablaNueva = $(`
                    <table id="tabla-modal-final" class="table table-striped table-bordered" style="width:100%">
                        <thead>
                            <tr>
                                <th style="width: 80px;">Detalles</th>
                                <th>Producto</th>
                                <th>Ubicación</th>
                                <th>Stock</th>
                                <th>Unidad</th>
                                <th>Tipo</th>
                                <th style="width: 50px;">RFID</th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                `);

                const tableOriginal = $('#tabla-clinica-medicamentos').DataTable();

                tableOriginal.rows().nodes().to$().each(function() {
                    const fila = $(this);
                    const nombreProd = fila.find('td:first b').text().trim();

                    if (nombreProd && nombreProd !== "" && nombreProd !== "-") {

                        const ubicacion = fila.find('td:nth-child(2) label.font-weight-bold:first').text().trim();

                        const stockSpan = fila.find('span[id^="stockProducto_"]').first().text().trim();
                        const stockPartes = stockSpan.split(/\s+/);
                        const valorStock = stockPartes[0] || "0";
                        const nombreUnidad = stockPartes.slice(1).join(" ") || "UN";

                        const lote = fila.find('input[id^="lote_"]').val() || "N/A";
                        const fRecep = fila.find('input[id^="fechaRecepcionLote_"]').val() || "-";
                        const fVence = fila.find('input[id^="fechaVencimiento_"]').val() || "-";

                        let presentaciones = "No especificadas";
                        const labelPres = fila.find('label:contains("Presentaciones")').next('label.font-weight-bold');
                        if(labelPres.length > 0) presentaciones = labelPres.text().trim();

                        const nuevaFila = $(`
                            <tr data-lote="${lote}" data-frecep="${fRecep}" data-fvence="${fVence}" data-pres="${presentaciones}">
                                <td class="details-control text-center">
                                    <button class="btn btn-xs btn-primary shadow-sm" style="font-size: 11px;">
                                        <i class="fa fa-plus"></i> Detalles
                                    </button>
                                </td>
                                <td><strong>${nombreProd}</strong></td>
                                <td>${ubicacion}</td>
                                <td class="text-right"><strong>${valorStock}</strong></td>
                                <td>${nombreUnidad}</td>
                                <td><span class="badge badge-secondary">Venta</span></td>
                                <td class="text-center">
                                    <button class="pulse-icon" onclick="ejecutarAccion('${nombreProd}')">
                                        <i class="fa fa-rss"></i>
                                    </button>
                                </td>
                            </tr>
                        `);

                        tablaNueva.find('tbody').append(nuevaFila);
                    }
                });

                contenedor.append(tablaNueva);

                const dtModal = $('#tabla-modal-final').DataTable({
                    destroy: true,
                    responsive: true,
                    language: {
                        search: "Buscar:",
                        paginate: { next: "Sig.", previous: "Ant." }
                    }
                });

                $('#tabla-modal-final tbody').on('click', 'td.details-control', function () {
                    const tr = $(this).closest('tr');
                    const row = dtModal.row(tr);
                    const btn = $(this).find('button');
                    const icon = $(this).find('i');

                    if (row.child.isShown()) {
                        row.child.hide();
                        btn.removeClass('btn-danger').addClass('btn-primary');
                        icon.attr('class', 'fa fa-plus');
                    } else {
                        const d = tr.data();
                        row.child(formatearDetalles(d)).show();
                        btn.removeClass('btn-primary').addClass('btn-danger');
                        icon.attr('class', 'fa fa-minus');
                    }
                });

            }, 1500); 
        }

        function formatearDetalles(d) {
            return `
                <div class="p-3 bg-light border-left-primary" style="border-left: 4px solid #4e73df;">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-1"><strong>Presentaciones:</strong></p>
                            <p class="text-muted small">${d.pres}</p>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-unstyled mb-0" style="font-size: 0.9rem;">
                                <li><strong>Lote:</strong> <span class="badge badge-warning">${d.lote}</span></li>
                                <li><strong>Recepción:</strong> ${d.frecep}</li>
                                <li><strong>Vencimiento:</strong> <span class="text-danger font-weight-bold">${d.fvence}</span></li>
                            </ul>
                        </div>
                    </div>
                </div>
            `;
        }

function ejecutarAccion(nombre) {
    console.log("Acción iniciada para: " + nombre);
}

function regenerarCodigosEnModal() {
    if (typeof JsBarcode === 'undefined') {
        console.error("JsBarcode no está cargado");
        return;
    }
    
    $('.barcode-modal-item').each(function() {
        const img = this;
        const serial = $(img).attr('data-serial');
        
        if (serial && serial !== 'SIN-CODIGO') {
            try {
                JsBarcode(img, serial, {
                    format: "CODE128",
                    displayValue: true, 
                    fontSize: 14,        
                    width: 3,            
                    height: 70,          
                    margin: 8,          
                    background: "#ffffff",
                    lineColor: "#000000",
                    textMargin: 5,      
                    font: "monospace",   
                    fontOptions: "bold" 
                });
                console.log("Código grande generado para:", serial);
            } catch (error) {
                console.error("Error generando código:", error);
            }
        }
    });
}

function abrirModalEscaneo() {
    const contenedor = $('#contenedorEscaneo');
    contenedor.empty().html(`
        <div class="col-12 text-center p-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 font-weight-bold">Cargando todos los productos...</p>
            <p class="text-muted small">Preparando códigos de barras para escaneo</p>
        </div>
    `);
    
    $('#modalEscaneo').appendTo("body").modal('show');
    
    setTimeout(function() {
        contenedor.empty();
        
        const table = $('#tabla-clinica-medicamentos').DataTable();
        const allNodes = table.rows().nodes();
        
        if (allNodes.length === 0) {
            contenedor.append('<div class="col-12 text-center p-5"><h4>No hay productos para mostrar</h4></div>');
            return;
        }
        
        let productos = [];
        
        $(allNodes).each(function(index) {
            const filaOriginal = $(this);
            
            const nombreElement = filaOriginal.find('td:first-child b').first();
            let nombreHtml = nombreElement.length ? nombreElement.text().trim() : 'Producto sin nombre';
            
            if (nombreHtml.length > 40) {
                nombreHtml = nombreHtml.substring(0, 40) + '...';
            }
            
            const barcodeWrapper = filaOriginal.find('.barcode-wrapper-container').first();
            const barcodeImg = barcodeWrapper.find('.barcode-main-table');
            const serial = barcodeImg.attr('data-serial') || 'SIN-CODIGO';
            
            const lote = filaOriginal.find('input[id^="lote_"]').first().val() || 'N/A';
            let fechaVence = filaOriginal.find('input[id^="fechaVencimiento_"]').first().val() || '-';
            
            let stock = '0';
            const stockSpan = filaOriginal.find('span[id^="stockProducto_"]').first();
            if (stockSpan.length) {
                stock = stockSpan.text().trim().split(' ')[0];
            } else {
                const totalStockLabel = filaOriginal.find('label:contains("Total Stock:")').first();
                if (totalStockLabel.length) {
                    stock = totalStockLabel.text().replace('Total Stock:', '').trim();
                }
            }
            
            let fechaFormateada = '-';
            if (fechaVence && fechaVence !== '-' && fechaVence.length > 0) {
                const partes = fechaVence.split('-');
                if (partes.length === 3) {
                    fechaFormateada = `${partes[2]}/${partes[1]}/${partes[0]}`;
                }
            }
            
            productos.push({
                id: index,
                nombre: nombreHtml,
                serial: serial,
                lote: lote,
                fechaVence: fechaFormateada,
                stock: stock
            });
        });
        
        if (productos.length === 0) {
            contenedor.append('<div class="col-12 text-center p-5"><h4>No se encontraron códigos de barras</h4></div>');
            return;
        }
        
        const totalProductos = productos.length;
        contenedor.append(`
            <div class="col-12 mb-3">
                <div class="alert alert-info d-flex justify-content-between align-items-center">
                    <span><strong>Total productos:</strong> ${totalProductos} códigos de barras</span>
                    <span class="badge badge-primary" id="pagination-info">Página 1 de ${Math.ceil(totalProductos/8)}</span>
                </div>
            </div>
        `);
        
        const cardsContainer = $('<div class="row" id="cards-container" style="padding:1%"></div>');
        contenedor.append(cardsContainer);
        
        function renderPage(page) {
            const itemsPerPage = 8; 
            const start = (page - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const pageItems = productos.slice(start, end);
            const totalPages = Math.ceil(productos.length / itemsPerPage);
            
            let cardsHtml = '';
            pageItems.forEach(p => {
                cardsHtml += `
                    <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6 mb-4">
                        <div class="card shadow-sm border-0 " style="border-radius: 12px; overflow: hidden;">
                            <div class="card-header bg-primary text-white py-3 px-3">
                                <small class="font-weight-bold d-block text-truncate" title="${p.nombre}" style="font-size: 0.9rem;">${p.nombre}</small>
                            </div>
                            <div class="card-body p-3 text-center">
                                <div class="barcode-container-modal bg-white p-3 rounded" style="min-height: 120px; display: flex; align-items: center; justify-content: center;">
                                    <img class="barcode-modal-item w-100" 
                                         data-serial="${p.serial}" 
                                         style="max-width: 100%; height: 90px; width: auto; object-fit: contain;"
                                         alt="Código de Barras" />
                                </div>
                                <div class="mt-3 text-left">
                                    <div class="row">
                                        <div class="col-6">
                                            <span class="text-muted small">Lote:</span><br>
                                            <span class="badge badge-warning px-2 py-1" style="font-size: 0.85rem;">${p.lote}</span>
                                        </div>
                                        <div class="col-6">
                                            <span class="text-muted small">Stock:</span><br>
                                            <span class="font-weight-bold text-primary" style="font-size: 1.1rem;">${p.stock}</span>
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <span class="text-muted small">Vence:</span><br>
                                        <span class="text-danger font-weight-bold" style="font-size: 0.95rem;">${p.fechaVence}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            cardsContainer.html(cardsHtml);
            $('#pagination-info').text(`Página ${page} de ${totalPages}`);
            
            setTimeout(function() {
                regenerarCodigosEnModal();
            }, 100);
            
            return totalPages;
        }
        
        const totalPages = Math.ceil(productos.length / 8);
        let currentPage = 1;
        
        const paginationHtml = `
            <div class="col-12 mt-4">
                <nav aria-label="Navegación de productos">
                    <ul class="pagination justify-content-center" id="pagination">
                        <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                            <a class="page-link" href="#" data-page="prev">Anterior</a>
                        </li>
                        ${generatePageNumbers(currentPage, totalPages)}
                        <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                            <a class="page-link" href="#" data-page="next">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            </div>
        `;
        
        contenedor.append(paginationHtml);
        
        renderPage(1);
        
        $('#pagination').on('click', 'a.page-link', function(e) {
            e.preventDefault();
            const page = $(this).data('page');
            
            if (page === 'prev' && currentPage > 1) {
                currentPage--;
            } else if (page === 'next' && currentPage < totalPages) {
                currentPage++;
            } else if (typeof page === 'number') {
                currentPage = page;
            } else {
                return;
            }
            
            renderPage(currentPage);
            
            updatePagination(currentPage, totalPages);
        });
        
        function generatePageNumbers(current, total) {
            let html = '';
            for (let i = 1; i <= total; i++) {
                if (i === 1 || i === total || (i >= current - 2 && i <= current + 2)) {
                    html += `<li class="page-item ${i === current ? 'active' : ''}">
                        <a class="page-link" href="#" data-page="${i}">${i}</a>
                    </li>`;
                } else if (i === current - 3 || i === current + 3) {
                    html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
                }
            }
            return html;
        }
        
        function updatePagination(current, total) {
            $('#pagination').html(`
                <li class="page-item ${current === 1 ? 'disabled' : ''}">
                    <a class="page-link" href="#" data-page="prev">Anterior</a>
                </li>
                ${generatePageNumbers(current, total)}
                <li class="page-item ${current === total ? 'disabled' : ''}">
                    <a class="page-link" href="#" data-page="next">Siguiente</a>
                </li>
            `);
            $('#pagination-info').text(`Página ${current} de ${total}`);
        }
        
    }, 300);
}
    </script>
}


