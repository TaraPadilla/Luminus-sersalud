@model sistema.Models.TrasladoViewModel
@{
    ViewData["Title"] = "Nuevo traslado";
}

@await Html.PartialAsync("_MensajeExito")

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="text-center">
            <h4><b>Nuevo traslado</b></h4>
        </div>
    </div>
</div>

@await Html.PartialAsync("_TrasladoForm", Model)

<div class="main-card mb-3 card">
    <div class="card-body">
        <div>
            <button class="btn btn-danger" data-bind="click: cancelarRegistroTraslado">
                Cancelar
            </button>
            <button class="btn btn-primary" data-bind="click: guardarTraslado">
                Registrar
            </button>
        </div>
    </div>
</div>

@section Scripts{

<script type="text/javascript" src="~/ViewModelKo/TrasladoVM.js"></script>

}