<form asp-action="Lista" method="get">
    @* <div class="col-md-6">
        <a href="@Url.Action("ClientesPdf","CrearPDF")" class="btn btn-primary">
        Generar Pdf
        </a>
        </div> *@
    <br />
    <div class="col-md-12">
        <div class="input-group">
            <div class="input-group-prepend">
                <input type="submit" value="Buscar" class="btn btn-success"></input>
            </div>
            <input type="text" name="buscar" value="@ViewData["CurrentFilter"]" class="form-control"
                   placeholder="Buscar por código o por responsable...">
        </div>
    </div>
</form>


<br />

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="mb-0 table table-hover ">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Fecha</th>
                        <th>Origen<br />Destino</th>
                        <th>Fecha</th>
                        <th>Usuario Envío</th>
                        <th>Resp. última operación</th>
                        <th>Estado</th>
                        <th># Productos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var personaEnviado = item.ResponsableEnviado == null ? "" : item.ResponsableEnviadoText;
                        var personaRecibido = item.ResponsableRecibido == null ? "" : item.ResponsableRecibidoText;

                        <tr>
                            <td>@item.Id</td>
                            <td>@item.FechaTraslado</td>
                            <td>
                                <label class="badge badge-warning">
                                    @(item.BodegaOrigen!=null
                                ?item.BodegaOrigen.NombreBodega
                                :"N/A")
                                </label><br>
                                <label class="badge badge-success">
                                    @(item.BodegaDestino!=null
                                ?item.BodegaDestino.NombreBodega
                                :"N/A")
                                </label>
                            </td>
                            <td>@item.FechaTraslado</td>
                            <td>@personaEnviado</td>
                            <td>@personaRecibido</td>
                            <td>@item.EstadoTraslados.DescripcionEstado</td>
                            <td>@item.DetalleTrasladoProductos.Count(d => !d.Eliminado)</td>
                            <td>
                                <a href="@Url.Action("Editar","Traslados", new {id = @item.Id})"
                               class="btn btn-warning btn-sm">
                                    Información
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@await Html.PartialAsync("_TrasladosPaginacion", Model)