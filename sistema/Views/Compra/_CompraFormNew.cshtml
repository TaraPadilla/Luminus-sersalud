<script type="text/javascript">
    function habilitarDeshabilitarInput(valorSeleccionado) {
        //var input = document.getElementById('DiasCredito');
        var input = document.getElementsByClassName('DiasCredito');
        // Aquí, implementa la lógica para determinar si el input debe ser habilitado o deshabilitado.
        // Por ejemplo, si el valor seleccionado es "3", deshabilita el input.
        if (valorSeleccionado == "2") {
            input.disabled = false;
        } else {
            input.disabled = true;
        }
    }
</script>

<script type="text/javascript">
    $(document).ready(function () {
        // Función para actualizar sucursal según el ambiente
        function actualizarSucursalPorAmbiente() {
            var ambienteId = parseInt($("#EncabezadoAmbienteId").val());
            var globalId = @((int)Database.Shared.Enumeraciones.AmbienteEnum.Global);
            var $sucursalSelect = $("#EncabezadoSucursalId");

            if (ambienteId === globalId) {
                // Buscar la opción que tenga texto "Central" (insensible a mayúsculas)
                var optionCentral = $sucursalSelect.find('option').filter(function () {
                    return $(this).text().trim().toLowerCase() === "central";
                });

                if (optionCentral.length) {
                    $sucursalSelect.val(optionCentral.val()).trigger('change');
                } else {
                    console.warn("No se encontró una sucursal llamada 'Central'");
                }
                // Opcional: deshabilitar el combo de sucursal para forzar Central
                $sucursalSelect.prop('disabled', true);
            } else {
                // Habilitar el combo de sucursal para otros ambientes
                $sucursalSelect.prop('disabled', false);
            }
        }

        // Escuchar cambios en el ambiente
        $("#EncabezadoAmbienteId").on('change', actualizarSucursalPorAmbiente);

        // Ejecutar al cargar la página por si ya venía con Global seleccionado
        actualizarSucursalPorAmbiente();
    });
</script>