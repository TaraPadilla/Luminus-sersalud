@model sistema.Models.ModCategoriaListados
@{
    ViewData["Title"] = "Nueva Categoria";
}

@await Html.PartialAsync("_MensajeExito")

<form asp-controller="LaboratorioClinico" asp-action="NuevaCategoria" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
    @await Html.PartialAsync("_CategoriaForm", Model)
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script type="text/javascript" src="~/js/moment.min.js"></script>
    <script type="text/javascript" src="~/js/daterangepicker.js"></script>
    <script type="text/javascript" src="~/js/tempusdominus-bootstrap-4.min.js"></script>
}

@section css {
    <link href="~/css/daterangepicker.css" rel="stylesheet">
}
