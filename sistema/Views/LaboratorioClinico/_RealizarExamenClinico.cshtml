<script>
    document.addEventListener('DOMContentLoaded', function() {
        const currentUrl = window.location.href.toLowerCase();
        const containscategoriaLabClinico = currentUrl.includes('radiologia');
        
        if (containscategoriaLabClinico) {
            const editLinks = document.querySelectorAll('a[href*="ModificarTodosResultadosExamen"]');
            
            
            editLinks.forEach(function(link, index) {
                const currentHref = link.getAttribute('href');
                
                if (!currentHref.includes('radiologia=')) {
                    const separator = currentHref.includes('?') ? '&' : '?';
                    
                    const newHref = currentHref + separator + 'radiologia=true';
                    
                    link.setAttribute('href', newHref);
                    
                } else {
                    console.log(`Enlace ${index + 1} ya contiene parámetro radiologia:`, currentHref);
                }
            });
            
        } else {
            console.log('ℹ️ No se detectó "radiologia" en la URL, no se modificaron enlaces');
        }
    });
</script>