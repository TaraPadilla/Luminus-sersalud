@using Database.Shared.Paginacion;
@model sistema.Models.RealizarExamenLabClinicoViewModel

@{
    decimal subtotal = 0.00m;
    decimal total = 0.00m;
    decimal descuento = 0.00m;
    var todayDate = DateTime.Now;

    //Roles y permisos
    var usuarioDesarrollador = User.IsInRole("Desarrollador");
    var usuarioRadiologia = User.IsInRole("Radiologia");
    var usuarioAdministrador = User.IsInRole("Administrador");
    var usuarioSupervisorLaboratorio = User.IsInRole("Supervisor Laboratorio");
    var usuarioTecnicoLaboratorio = User.IsInRole("Tecnico laboratorio");
    var usuarioCoordinadorLaboratorio = User.IsInRole("Coordinador Laboratorio");
}

@{
    // Asignar objeto paciente para simplificar el acceso
    var pacienteObj = Model.Examen.Paciente;
    // Paciente
    var pacienteNombre = pacienteObj?.Nombre ?? "Sin Asignar";
    var pacienteDPI = pacienteObj?.Dpi ?? "Sin DPI";
    var fechaNacimiento = pacienteObj?.FechaNacimiento;
    var pacienteFechaNacimiento = fechaNacimiento.HasValue ? fechaNacimiento.Value.ToString("dd/MM/yyyy") : "No registrada";
    
    // Calcular la edad en base a la fecha de nacimiento, si existe
    var edad = 0;
    if (fechaNacimiento.HasValue)
    {
        edad = todayDate.Year - fechaNacimiento.Value.Year;
        if (todayDate.Month < fechaNacimiento.Value.Month || 
           (todayDate.Month == fechaNacimiento.Value.Month && todayDate.Day < fechaNacimiento.Value.Day))
        {
            edad--;
        }
    }
    
    // Médico: se toma el nombre desde la propiedad del viewmodel (si fue asignada) o de la entidad relacionada
    var medico = !string.IsNullOrEmpty(Model.NombreMedico)
                    ? Model.NombreMedico 
                    : (Model.Examen.Empleado != null ? Model.Examen.Empleado.Nombre : "// sin referencia");
    
    // Clínica Referida
    var clinicaReferida = !string.IsNullOrEmpty(Model.Examen.ClinicaReferida) ? Model.Examen.ClinicaReferida : "Sin Clínica Asignada";
    
    // Nombre de la Habitación (proveniente de la propiedad del viewmodel)
    var nombreHabitacion = !string.IsNullOrEmpty(Model.NombreHabitacion) ? Model.NombreHabitacion : "Sin Habitación";
    
    // Nombre del Seguro (proveniente de la propiedad del viewmodel)
    var nombreSeguro = !string.IsNullOrEmpty(Model.NombreSeguro) ? Model.NombreSeguro : "Sin Seguro";
}

