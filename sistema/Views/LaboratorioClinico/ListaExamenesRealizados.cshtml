<script>
    document.getElementById('reportePDF').addEventListener('click', function (event) {
        event.preventDefault(); // Previene el comportamiento predeterminado del enlace

        // Función para obtener el valor de un elemento de manera segura
        function obtenerValorElemento(nombreElemento) {
            var elemento = document.getElementsByName(nombreElemento)[0];
            return elemento ? elemento.value : ''; // Retorna el valor si existe, si no, una cadena vacía
        }

        // Capturar los valores del formulario usando la función de comprobación
        var fechaInicial = obtenerValorElemento('fechaInicial');
        var fechaFinal = obtenerValorElemento('fechaFinal');
        var estado = obtenerValorElemento('estado');
        var medicoReferido = obtenerValorElemento('medicoReferido');
        var usuarioSolicitaRequest = obtenerValorElemento('usuarioSolicitaRequest');
        var usuarioIngresoRequest = obtenerValorElemento('usuarioIngresoRequest');

        // Construir la URL con los parámetros
        var url = '@Url.Action("GenerarPdfLaboratorioClinicoExamenesClinicos", "CrearPDF")' +
            '?fechaInicial=' + encodeURIComponent(fechaInicial) +
            '&fechaFinal=' + encodeURIComponent(fechaFinal) +
            '&estado=' + encodeURIComponent(estado) +
            '&medicoReferido=' + encodeURIComponent(medicoReferido) +
            '&usuarioSolicitaRequest=' + encodeURIComponent(usuarioSolicitaRequest) +
            '&usuarioIngresoRequest=' + encodeURIComponent(usuarioIngresoRequest);

        // Redireccionar al controlador con los parámetros del formulario
        window.location.href = url;
    });

    document.getElementById('reporteExcel').addEventListener('click', function (event) {
        event.preventDefault(); // Previene el comportamiento predeterminado del enlace

        // Función para obtener el valor de un elemento de manera segura
        function obtenerValorElemento(nombreElemento) {
            var elemento = document.getElementsByName(nombreElemento)[0];
            return elemento ? elemento.value : ''; // Retorna el valor si existe, si no, una cadena vacía
        }

        // Capturar los valores del formulario usando la función de comprobación
        var fechaInicial = obtenerValorElemento('fechaInicial');
        var fechaFinal = obtenerValorElemento('fechaFinal');
        var estado = obtenerValorElemento('estado');
        var medicoReferido = obtenerValorElemento('medicoReferido');
        var usuarioSolicitaRequest = obtenerValorElemento('usuarioSolicitaRequest');
        var usuarioIngresoRequest = obtenerValorElemento('usuarioIngresoRequest');

        // Construir la URL con los parámetros
        var url = '@Url.Action("CrearExcelListaExamenesRealizados", "CrearExcel")' +
            '?fechaInicial=' + encodeURIComponent(fechaInicial) +
            '&fechaFinal=' + encodeURIComponent(fechaFinal) +
            '&estado=' + encodeURIComponent(estado) +
            '&medicoReferido=' + encodeURIComponent(medicoReferido) +
            '&usuarioSolicitaRequest=' + encodeURIComponent(usuarioSolicitaRequest) +
            '&usuarioIngresoRequest=' + encodeURIComponent(usuarioIngresoRequest);

        // Redireccionar al controlador con los parámetros del formulario
        window.location.href = url;
    });
</script>

<script>
    document.getElementById("busquedaTabla").addEventListener("keyup", function () {
        var filtro = this.value.toLowerCase();
        var filas = document.querySelectorAll("table tbody tr");

        filas.forEach(function (fila) {
            var texto = fila.textContent.toLowerCase();
            fila.style.display = texto.includes(filtro) ? "" : "none";
        });
    });
</script>

