@model sistema.Models.ExamenLabClinicoViewModel

@Html.HiddenFor(m => m.IdExamen)

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="main-card mb-3 card">
            <div class="card-body">
                <div class="form-row">
                    <div class="col-md-12">
                        <h5><b>Informaci&oacute;n general</b></h5>
                        <hr />
                    </div>
                    <div class="col-md-3">
                        <label>C&oacute;digo</label>
                        @Html.TextBoxFor(a => a.CodigoInterno, new
                            {
                                @class = "form-control",
                                @placeholder = "Codigo del examen"
                            })
                    </div>
                    <div class="col-md-3">
                        <label>Nombre del examen</label>
                        @Html.TextBoxFor(a => a.NombreExamen, new
                            {
                                @class = "form-control",
                                @placeholder = "Nombre del examen"
                            })
                    </div>
                    <div class="col-md-3">
                        <label>Tipo de examen</label>
                        @Html.TextBoxFor(a => a.TipoExamen, new
                            {
                                @class = "form-control",
                                @placeholder = "Tipo de examen"
                            })
                    </div>
                    <div class="col-md-3">
                        <label>Categoría</label>
                        <select class="form-control select2bs4"
                                asp-for="CategoriaLabClinicoId"
                                asp-items="Model.ListCategorias"></select>
                    </div>
                    <div class="col-md-12 table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Indicaciones</td>
                                    <td>
                                        @Html.TextAreaFor(a => a.Indicaciones, 5, 500, htmlAttributes: new
                                            {
                                                @class = "form-control ",
                                                @placeholder = "Indicaciones",
                                                @style = "max-width:100% !important;height:80px"
                                            })
                                    </td>
                                </tr>
                                <tr>
                                    <td>Instrucciones</td>
                                    <td>
                                        @Html.TextAreaFor(a => a.Instrucciones, 5, 500, htmlAttributes: new
                                            {
                                                @class = "form-control ",
                                                @placeholder = "Instrucciones",
                                                @style = "max-width:100% !important;height:80px"
                                            })
                                    </td>
                                </tr>
                                <tr>
                                    <td>Advertencia</td>
                                    <td>
                                        @Html.TextAreaFor(a => a.Advertencias, 5, 500, htmlAttributes: new
                                            {
                                                @class = "form-control ",
                                                @placeholder = "Advertencia",
                                                @style = "max-width:100% !important;height:80px"
                                            })
                                    </td>
                                </tr>
                                <tr>
                                    <td>Declaracion de consentimiento</td>
                                    <td>
                                        @Html.TextAreaFor(a => a.DeclaracionConsentimiento, 5, 500, htmlAttributes: new
                                            {
                                                @class = "form-control ",
                                                @placeholder = "Declaracion de Consentimiento",
                                                @style = "max-width:100% !important;height:80px"
                                            })
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

