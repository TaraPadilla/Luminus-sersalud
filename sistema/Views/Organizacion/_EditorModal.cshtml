@model TuProyecto.Models.ViewModels.OrganizacionVM

<form asp-action="Guardar" method="post" id="form-organizacion" onsubmit="return submitForm(this);">
    <input type="hidden" asp-for="Id" />

    <div class="modal-header bg-dark text-white">
        <h5 class="modal-title font-weight-bold">
            <i class="fas fa-sitemap mr-2"></i> @(Model.Id == 0 ? "Nuevo Departamento" : "Editar Departamento")
        </h5>
        <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>

    <div class="modal-body pb-0">
        <div class="form-group mb-4">
            <label class="font-weight-bold text-muted text-uppercase" style="font-size:0.8rem">Nombre del
                Departamento</label>
                <input asp-for="Nombre" class="form-control form-control-lg border-secondary"
                       placeholder="Ej. Tecnología, Recursos Humanos..." required />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="font-weight-bold mb-0">Unidades Asociadas</h6>
                <button type="button" id="btn-agregar-unidad" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                    <i class="fas fa-plus mr-1"></i> Nueva Unidad
                </button>
            </div>
            <hr class="mt-0 mb-3" />

            <div id="unidades-container" style="max-height: 45vh; overflow-y: auto; padding-right: 5px;">
                @for (int i = 0; i < Model.Unidades.Count; i++)
                {
                    <div class="card mb-3 border-0 shadow-sm unidad-item bg-light" data-index="@i">
                        <div class="card-body p-3">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <input type="hidden" name="Unidades[@i].Id" value="@Model.Unidades[i].Id" />
                                <input type="text" name="Unidades[@i].Nombre" value="@Model.Unidades[i].Nombre"
                                       class="form-control font-weight-bold" placeholder="Nombre de la Unidad" required />
                                <button type="button" class="btn btn-outline-danger btn-sm ml-2"
                                        onclick="this.closest('.unidad-item').remove()" title="Quitar Unidad">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>

                            <div class="ml-4 pl-3 border-left border-primary pt-2">
                                <label class="text-muted small font-weight-bold mb-1">Secciones de la Unidad</label>

                                <div class="secciones-lista d-flex flex-wrap gap-2 mb-2">
                                    @for (int j = 0; j < Model.Unidades[i].Secciones.Count; j++)
                                    {
                                        <div class="input-group input-group-sm mb-1 mr-2 seccion-item" style="width: 200px;">
                                            <input type="hidden" name="Unidades[@i].Secciones[@j].Id"
                                                   value="@Model.Unidades[i].Secciones[j].Id" />
                                            <input type="text" name="Unidades[@i].Secciones[@j].Nombre"
                                                   value="@Model.Unidades[i].Secciones[j].Nombre" class="form-control bg-white"
                                                   placeholder="Sección" required />
                                            <div class="input-group-append">
                                                <button type="button" class="btn btn-outline-secondary"
                                                        onclick="this.closest('.seccion-item').remove()">×</button>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 btn-agregar-seccion">
                                    <i class="fas fa-plus-circle mr-1"></i> Agregar Sección
                                </button>
                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="modal-footer bg-light mt-3 border-top-0">
            <button type="button" class="btn btn-secondary rounded-pill px-4" data-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-primary rounded-pill px-4 font-weight-bold shadow-sm">
                <i class="fas fa-save mr-1"></i> Guardar Cambios
            </button>
        </div>
    </form>

    <script>
        // Inicializamos contadores para IDs dinámicos
        var unidadCounter = @Model.Unidades.Count;

        // Lógica dinámica para Agregar Unidad
        $('#btn-agregar-unidad').off('click').on('click', function () {
            const container = $('#unidades-container');
            const index = unidadCounter++;

            const html = `
                <div class="card mb-3 border-0 shadow-sm unidad-item bg-light" data-index="${index}">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <input type="hidden" name="Unidades[${index}].Id" value="0" />
                            <input type="text" name="Unidades[${index}].Nombre" class="form-control font-weight-bold border-primary" placeholder="Nueva Unidad" required />
                            <button type="button" class="btn btn-outline-danger btn-sm ml-2" onclick="this.closest('.unidad-item').remove()"><i class="fas fa-trash"></i></button>
                        </div>
                        <div class="ml-4 pl-3 border-left border-primary pt-2">
                            <label class="text-muted small font-weight-bold mb-1">Secciones de la Unidad</label>
                            <div class="secciones-lista d-flex flex-wrap gap-2 mb-2"></div>
                            <button type="button" class="btn btn-link btn-sm text-decoration-none p-0 btn-agregar-seccion"><i class="fas fa-plus-circle mr-1"></i> Agregar Sección</button>
                        </div>
                    </div>
                </div>`;
            container.append(html);
            container.scrollTop(container[0].scrollHeight);
        });

        // Lógica dinámica para Agregar Sección (Delegación de eventos)
        $(document).off('click', '.btn-agregar-seccion').on('click', '.btn-agregar-seccion', function () {
            const unidadItem = $(this).closest('.unidad-item');
            const unidadIndex = unidadItem.attr('data-index');
            const seccionesLista = unidadItem.find('.secciones-lista');

            // Usamos un contador único basado en la hora para evitar choques al eliminar/agregar rápido
            // MVC model binder asume los índices como una lista, pero es suficientemente inteligente 
            // para ordenarlos en el POST siempre que sigan el patrón [unidadIndex].Secciones[indexUnico]
            const seccionIndex = Date.now();

            const html = `
                <div class="input-group input-group-sm mb-1 mr-2 seccion-item" style="width: 200px;">
                    <input type="hidden" name="Unidades[${unidadIndex}].Secciones[${seccionIndex}].Id" value="0" />
                    <input type="text" name="Unidades[${unidadIndex}].Secciones[${seccionIndex}].Nombre" class="form-control border-info shadow-sm" placeholder="Nueva Sección" required />
                    <div class="input-group-append">
                        <button type="button" class="btn btn-outline-danger shadow-sm" onclick="this.closest('.seccion-item').remove()">×</button>
                    </div>
                </div>`;
            seccionesLista.append(html);

            // Hacer focus en el nuevo input creado
            seccionesLista.find('input[type="text"]').last().focus();
        });
    </script>