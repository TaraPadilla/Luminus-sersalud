@{
    ViewData["Title"] = "Registrar Huella";
    @* Layout = "~/Views/Shared/_LoginLayout.cshtml"; *@
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    <div class="d-flex align-items-center mb-3">
                        <div class="mr-3">
                            <span class="badge badge-success p-3">
                                <i class="bi bi-fingerprint" style="font-size: 1.5rem;"></i>
                            </span>
                        </div>
                        <div>
                            <h4 class="mb-1">Registrar biometría</h4>
                        </div>
                    </div>

                    <button id="btnRegistrar" type="button" class="btn btn-success btn-block btn-lg">
                        <i class="bi bi-fingerprint mr-2"></i> Registrar
                    </button>

                    <div class="mt-3">
                        <div id="mensaje" class="alert d-none mb-0" role="alert"></div>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const btn = document.getElementById("btnRegistrar");
    const alertBox = document.getElementById("mensaje");

    function setAlert(type, text, details) {
        alertBox.className = "alert alert-" + type;
        alertBox.classList.remove("d-none");

        const safeDetails = details ? String(details) : "";
        alertBox.innerHTML = safeDetails
            ? `<div>${text}</div><pre class="small text-monospace mb-0 mt-2">${safeDetails}</pre>`
            : `<div>${text}</div>`;
    }

    function clearAlert() {
        alertBox.className = "alert d-none";
        alertBox.innerHTML = "";
    }

    function setBusy(isBusy) {
        btn.disabled = isBusy;
        btn.classList.toggle("disabled", isBusy);
        btn.innerHTML = isBusy
            ? `<span class="spinner-border spinner-border-sm mr-2" role="status" aria-hidden="true"></span> Procesando...`
            : `<i class="bi bi-fingerprint mr-2"></i> Registrar`;
    }

    function arrayBufferToBase64(buffer) {
        const bytes = new Uint8Array(buffer);
        let binary = "";
        for (let i = 0; i < bytes.byteLength; i++) {
            binary += String.fromCharCode(bytes[i]);
        }
        return btoa(binary);
    }

    function normalizeBase64(base64) {
        if (!base64) return base64;

        // Soporta base64url si llega desde backend
        let s = String(base64).replace(/-/g, "+").replace(/_/g, "/");
        const pad = s.length % 4;
        if (pad === 2) s += "==";
        else if (pad === 3) s += "=";

        return s;
    }

    function base64ToUint8Array(base64) {
        const normalized = normalizeBase64(base64);
        return Uint8Array.from(atob(normalized), c => c.charCodeAt(0));
    }

    async function safeReadText(response) {
        try { return await response.text(); }
        catch { return ""; }
    }

    btn.addEventListener("click", async () => {
        clearAlert();

        // 1. CAPTURAR EL ID DEL USUARIO DESDE LA URL
        const urlParams = new URLSearchParams(window.location.search);
        const userId = urlParams.get('userId');

        if (!userId) {
            setAlert("warning", "Falta información.", "No se encontró el ID del usuario seleccionado en la URL.");
            return;
        }

        if (!window.PublicKeyCredential) {
            setAlert("warning", "Navegador no compatible.", "Este navegador no soporta WebAuthn/FIDO2.");
            return;
        }

        if (!window.isSecureContext) {
            setAlert("danger", "Se requiere HTTPS.", "WebAuthn necesita un contexto seguro (HTTPS).");
            return;
        }

        setBusy(true);

        try {
            // 2. ENVIAR EL userId AL SERVIDOR EN LA URL (QueryString)
            const res1 = await fetch(`/api/WebAuthn/BeginRegister?userId=${userId}`, {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" }
            });

            if (!res1.ok) {
                const errorText = await safeReadText(res1);
                setAlert("danger", "Error al iniciar el registro.", `HTTP ${res1.status}\n${errorText}`);
                return;
            }

            const optionsFromServer = await res1.json();
            console.log("Opciones recibidas del servidor:", optionsFromServer);

            const excludeCreds = Array.isArray(optionsFromServer.excludeCredentials)
                ? optionsFromServer.excludeCredentials.map(cred => {
                    let transports = cred.transports;

                    if (transports && !Array.isArray(transports)) {
                        if (typeof transports === "string") {
                            transports = transports.split(",").map(t => t.trim()).filter(Boolean);
                        } else {
                            transports = null;
                        }
                    }

                    const item = {
                        id: base64ToUint8Array(cred.id),
                        type: "public-key"
                    };

                    if (Array.isArray(transports) && transports.length > 0) {
                        item.transports = transports;
                    }

                    return item;
                })
                : [];

            const authenticatorSelectionFromServer = optionsFromServer.authenticatorSelection || {};

            const publicKeyOptions = {
                challenge: base64ToUint8Array(optionsFromServer.challenge),
                rp: optionsFromServer.rp,
                user: {
                    id: base64ToUint8Array(optionsFromServer.user.id),
                    name: optionsFromServer.user.name,
                    displayName: optionsFromServer.user.displayName
                },
                pubKeyCredParams: (optionsFromServer.pubKeyCredParams || []).map(p => ({
                    type: "public-key",
                    alg: p.alg
                })),
                timeout: optionsFromServer.timeout,
                excludeCredentials: excludeCreds,
                authenticatorSelection: {
                    authenticatorAttachment: authenticatorSelectionFromServer.authenticatorAttachment,
                    requireResidentKey: authenticatorSelectionFromServer.requireResidentKey,
                    userVerification: authenticatorSelectionFromServer.userVerification
                },
                attestation: optionsFromServer.attestation
            };

            console.log("Opciones formateadas para WebAuthn:", publicKeyOptions);

            let credential;
            try {
                credential = await navigator.credentials.create({ publicKey: publicKeyOptions });
            } catch (error) {
                console.error("Error creando credencial:", error);

                if (error && error.name === "NotAllowedError") {
                    setAlert("warning", "Registro cancelado.", "Se canceló o no se completó la verificación.");
                    return;
                }
                if (error && error.name === "SecurityError") {
                    setAlert("danger", "Bloqueado por seguridad.", "Verifica HTTPS y el origen del sitio.");
                    return;
                }

                setAlert("danger", "No se pudo crear la credencial.", error && error.message ? error.message : "Error desconocido.");
                return;
            }

            const attestationResponse = {
                id: arrayBufferToBase64(credential.rawId),
                rawId: arrayBufferToBase64(credential.rawId),
                type: credential.type,
                response: {
                    clientDataJSON: arrayBufferToBase64(credential.response.clientDataJSON),
                    attestationObject: arrayBufferToBase64(credential.response.attestationObject)
                },
                extensions: {}
            };

            console.log("Respuesta para enviar al servidor:", attestationResponse);

            const res2 = await fetch("/api/WebAuthn/CompleteRegister", {
                method: "POST",
                credentials: "include",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(attestationResponse)
            });

            if (res2.ok) {
                setAlert("success", "✅ Huella registrada correctamente.");
                return;
            }

            const errorText2 = await safeReadText(res2);
            console.error("Error del servidor:", errorText2);
            setAlert("danger", "❌ Error al registrar.", `HTTP ${res2.status}\n${errorText2}`);
        } catch (error) {
            console.error("Error en el proceso de registro WebAuthn:", error);
            setAlert("danger", "❌ Error inesperado.", error && error.message ? error.message : "Error desconocido.");
        } finally {
            setBusy(false);
        }
    });
})();
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
}
