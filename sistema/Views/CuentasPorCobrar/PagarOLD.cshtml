            const enviarDatosAlServidor = async (jsonString, hospitalizacionId) => {
            const url = hospitalizacionId 
                ? `/CrearPDF/ProcesarEstadoCuenta?id=${hospitalizacionId}`
                : '/CrearPDF/ProcesarEstadoCuenta';
            const response = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: jsonString
                });
                const blob = await response.blob();
                const urlBlob = window.URL.createObjectURL(blob);
                window.open(urlBlob, '_blank');
            };

            // Función para validar y actualizar los datos del paciente
            function validarDatosPaciente(paciente) {
                // Recorrer todas las propiedades del objeto paciente
                for (let propiedad in paciente) {
                    // Validar si el valor de la propiedad es uno de los valores predeterminados
                    if (paciente[propiedad] === "No disponible" ||
                        paciente[propiedad] === "No registrada" ||
                        paciente[propiedad] === "No definido" ||
                        paciente[propiedad] === "0" ||
                        paciente[propiedad] === "") {

                        // Mostrar un prompt al usuario para que ingrese el valor faltante
                        let nuevoValor = prompt(`Por favor, ingrese el valor para: ${propiedad}`, paciente[propiedad]);

                        // Si el usuario ingresa un valor (no está vacío), actualizar la propiedad
                        if (nuevoValor && nuevoValor.trim() !== "") {
                            paciente[propiedad] = nuevoValor.trim();
                            @* alert(`Valor de ${propiedad} actualizado a: ${nuevoValor.trim()}`); *@
                                                                    } else {
                            // Si no se ingresa un valor, mantén el valor original
                            alert(`El valor de ${propiedad} no ha sido actualizado.`);
                        }
                    }
                }

                // Retornar el objeto paciente actualizado
                return paciente;
            }

            // Modificar el evento click del botón
            document.getElementById("btnEstadoCuenta").addEventListener("click", async (e) => {
                e.preventDefault();

                // Recopilar los datos completos del estado de cuenta (esto ya es un objeto JavaScript)
                const datos = recopilarDatosEstadoCuenta();

                // Convertir los datos a JSON para la visualización si es necesario
                const jsonString = JSON.stringify(datos, null, 4);

                // Primero, parsear el JSON para convertirlo a un objeto de JavaScript
                const datosObjeto = JSON.parse(jsonString);

                // Pasar el objeto Paciente para validarlo y actualizarlo
                const nuevoDatosPaciente = validarDatosPaciente(datosObjeto.Paciente);

                // Reemplazar el subobjeto Paciente con el actualizado
                datosObjeto.Paciente = nuevoDatosPaciente;

                // Convertir el objeto completo actualizado nuevamente a JSON
                const jsonStringActualizado = JSON.stringify(datosObjeto, null, 4);

                @* console.log(jsonStringActualizado); *@

                    // Enviar los datos al servidor con el objeto actualizado
                    const hospitalizacionId = datos.Hospitalizacion?.HospitalizacionId || 0;
                    await enviarDatosAlServidor(jsonString, hospitalizacionId);
                    //await enviarDatosAlServidor(jsonStringActualizado);
            });
        });

