    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let exclusiones = [];
            let productos = [];

            // IDs de exámenes inyectados desde el servidor
            const idsExamenes = window._idsExamenes || [];

            function esFilaExamen(row) {
                // Un item es examen si su índice de producto corresponde a un id de examen
                // Lo detectamos por el dataset.esexamen="true" que ponemos en el Razor,
                // o si el tipo del row no está en los tipos conocidos de no-examen
                const tipo = (row.dataset.tipo || "").toLowerCase();
                const noExamenTypes = ["medicamentos","insumos médicos","equipos médicos","servicio","dietas","depósitos (resta)","emergencia","paquete de hospitalización","ambulancia"];
                if (noExamenTypes.some(t => tipo.includes(t))) return false;
                // Si tiene data-tipo y NO es un tipo conocido de producto/servicio, es examen
                if (row.dataset.tipo) return true;
                return false;
            }

 const SALDO_BASE_BD = parseFloat($("#Valor").val()) || 0;

let TOTAL_BRUTO_ORIGINAL = 0;

function cargarProductosIniciales() {
    productos = Array.from(document.querySelectorAll("#productos-body tr")).map((row, idx) => {
        if (row.children.length >= 6) {
            const rubro = row.children[0].textContent.trim();
            const item = row.children[1].textContent.trim();
            const cantidad = parseInt(row.children[2].textContent.trim(), 10) || 0;
            const precioTexto = row.children[3].textContent.trim().replace("Q", "").replace(",", ".");
            const precioUnitario = parseFloat(precioTexto) || 0;
            const esExamen = esFilaExamen(row);
            const descuentoPct = esExamen ? 100 : 0;
            const cargoAdicional = 0;

            return {
                tipo: rubro,
                nombre: item,
                cantidad: cantidad,
                precioUnitario: precioUnitario,
                precioOriginal: precioUnitario,
                esExamen: esExamen,
                descuentoPct: descuentoPct,
                cargoAdicional: cargoAdicional
            };
        }
        return null;
    }).filter(x => x !== null);

    TOTAL_BRUTO_ORIGINAL = productos.reduce((sum, p) => {
        return sum + (p.cantidad * p.precioOriginal);
    }, 0);

    document.querySelectorAll("#productos-body tr").forEach(row => {
        const btn = row.querySelector("button");
        if (btn && btn.textContent.trim() === "No excluible") {
            const precioTexto = row.children[3]?.textContent.trim().replace("Q","").replace(",",".");
            TOTAL_BRUTO_ORIGINAL += parseFloat(precioTexto) || 0;
        }
    });

    console.log("[INIT] SALDO_BASE_BD:", SALDO_BASE_BD, "| TOTAL_BRUTO_ORIGINAL:", TOTAL_BRUTO_ORIGINAL);

    actualizarTablaProductos();
}

            function calcularSubtotalProducto(p) {
                const bruto = p.cantidad * p.precioUnitario;
                const descuento = bruto * (p.descuentoPct || 0) / 100;
                const cargo = parseFloat(p.cargoAdicional) || 0;
                return Math.max(bruto - descuento + cargo, 0);
            }

            function actualizarTablaProductos() {
                let tbody = document.getElementById("productos-body");
                tbody.innerHTML = "";

                productos.forEach((producto, index) => {
                    let row = document.createElement("tr");
                    let tipoLower = (producto.tipo || "").toLowerCase();
                    const noExcluible = tipoLower.includes("paquete") || tipoLower === "ambulancia";

                    let accionHtml = noExcluible
                        ? `<button class="btn btn-secondary btn-sm" disabled>No excluible</button>`
                        : `<button class="btn btn-warning btn-sm excluir-producto" data-index="${index}">Excluir</button>`;

                    const subtotal = calcularSubtotalProducto(producto);
                    const descPct = producto.descuentoPct || 0;
                    const cargo = producto.cargoAdicional || 0;

                    // Badge de tipo de item para la columna
                    let badgeDesc = '';
                    if (descPct > 0) badgeDesc += `<span class="badge badge-warning mr-1">-${descPct}%</span>`;
                    if (cargo > 0)   badgeDesc += `<span class="badge badge-info">+Q${parseFloat(cargo).toFixed(2)}</span>`;

                    row.innerHTML = `
                        <td>${producto.tipo}</td>
                        <td>${producto.nombre}</td>
                        <td>${producto.cantidad}</td>
                        <td>Q ${producto.precioUnitario.toFixed(2)}</td>
                        <td class="celda-subtotal font-weight-bold">Q ${subtotal.toFixed(2)}</td>
                        <td>
                            <div class="d-flex align-items-center" style="gap:4px; min-width:200px;">
                                <div class="input-group input-group-sm" style="width:90px;" title="Descuento %">
                                    <input type="number" class="form-control form-control-sm input-desc-pct"
                                           min="0" max="100" step="0.01" value="${descPct}"
                                           data-index="${index}" placeholder="0"
                                           style="padding:2px 4px;">
                                    <div class="input-group-append"><span class="input-group-text" style="padding:2px 6px;">%</span></div>
                                </div>
                                <div class="input-group input-group-sm" style="width:95px;" title="Cargo adicional">
                                    <div class="input-group-prepend"><span class="input-group-text" style="padding:2px 6px;">+Q</span></div>
                                    <input type="number" class="form-control form-control-sm input-cargo"
                                           min="0" step="0.01" value="${cargo > 0 ? cargo : ''}"
                                           data-index="${index}" placeholder="0"
                                           style="padding:2px 4px;">
                                </div>
                            </div>
                        </td>
                        <td>${accionHtml}</td>
                    `;

                    tbody.appendChild(row);
                });

                // Eventos para los inputs de desc% y cargo
                tbody.querySelectorAll(".input-desc-pct").forEach(input => {
                    input.addEventListener("input", function() {
                        const idx = parseInt(this.dataset.index);
                        productos[idx].descuentoPct = parseFloat(this.value) || 0;
                        actualizarFilaSubtotal(idx);
                        actualizarTotalCuenta();
                    });
                });
                tbody.querySelectorAll(".input-cargo").forEach(input => {
                    input.addEventListener("input", function() {
                        const idx = parseInt(this.dataset.index);
                        productos[idx].cargoAdicional = parseFloat(this.value) || 0;
                        actualizarFilaSubtotal(idx);
                        actualizarTotalCuenta();
                    });
                });

                actualizarTotalCuenta();
            }

            function actualizarFilaSubtotal(idx) {
                const filas = document.querySelectorAll("#productos-body tr");
                if (!filas[idx]) return;
                const celda = filas[idx].querySelector(".celda-subtotal");
                if (celda) {
                    const subtotal = calcularSubtotalProducto(productos[idx]);
                    celda.textContent = "Q " + subtotal.toFixed(2);
                }
            }


            @* function actualizarTotalCuenta() {
                let totalProductos = productos.reduce((total, producto) => {
                    return total + (producto.cantidad * producto.precioUnitario);
                }, 0);

                let totalHonorarios = Array.from(document.querySelectorAll(".honorario-medico"))
                    .map(input => parseFloat(input.value) || 0)
                    .reduce((total, valor) => total + valor, 0);
                let tarifaHabitacion = parseFloat($("#TarifaHabitacion").val()) || 0;
                let totalCuenta = totalProductos + totalHonorarios + tarifaHabitacion;
                document.getElementById("totalDeLaCuenta").value = totalCuenta.toFixed(2);
                actualizarTotalAseguradora(); // Se actualiza el total aseguradora
