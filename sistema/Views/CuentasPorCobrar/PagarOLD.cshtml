    <script>
        document.getElementById("btnMostrarFila").addEventListener("click", function () {
            // Recorremos las filas de la tabla de la 1 a la 25
            for (var i = 1; i <= 25; i++) {
                var fila = document.getElementById("fila" + i);
                // Si se encuentra la primera fila oculta, se muestra y se sale del bucle
                if (fila && fila.style.display === "none") {
                    fila.style.display = "table-row";
                    break;
                }
            }

            // Verificar si aún quedan filas ocultas
            var quedanOcultas = false;
            for (var i = 1; i <= 25; i++) {
                var fila = document.getElementById("fila" + i);
                if (fila && fila.style.display === "none") {
                    quedanOcultas = true;
                    break;
                }
            }
            // Si ya no quedan filas ocultas, se oculta el botón
            if (!quedanOcultas) {
                this.style.display = "none";
            }
        });
    </script>

