                    let row = event.target.closest("tr");
                    let rubro = row.children[0].textContent.trim(); // Rubro
                    let nombreProducto = row.children[1].textContent.trim(); // Item
                    let cantidad = parseInt(row.children[2].textContent.trim(), 10) || 0;

                    let precioUnitario = parseFloat(
                        row.children[3].textContent.trim().replace("Q", "").replace(",", ".")
                    ) || 0;

                    let tipoProducto = rubro; // mantengo "tipo" como rubro (igual que en cargarProductosIniciales)

                    if (productoIndex !== -1) {
                        let producto = productos[productoIndex];

                        // console.log(`Tipo detectado: ${tipoProducto}`);

                        let seguroNombre = "SIN SEGURO";

                        // Obtener precio por seguro
                        let precioSeguro = await obtenerPrecioPorSeguro(tipoProducto, producto.nombre, seguroNombre);

                        if (precioSeguro === null) {
                            return;
                        }

                        // Actualizar el precio unitario con el del seguro
                        producto.precioUnitario = precioSeguro;

