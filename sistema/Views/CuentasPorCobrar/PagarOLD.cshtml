window.actualizarDescuento = function (origen) {
    const totalCuenta = parseFloat($("#totalDeLaCuenta").val()) || 0;

    if (origen === 'monto') {
        const montoDesc = parseFloat($("#montoDescuento").val()) || 0;
        const pct = totalCuenta > 0 ? (montoDesc / totalCuenta) * 100 : 0;
        $("#porcentajeDescuento").val(pct > 0 ? pct.toFixed(2) : "");
    } else {
        const pct = parseFloat($("#porcentajeDescuento").val()) || 0;
        const montoDesc = (totalCuenta * pct) / 100;
        $("#montoDescuento").val(montoDesc > 0 ? montoDesc.toFixed(2) : "");
    }

    const montoDescFinal = parseFloat($("#montoDescuento").val()) || 0;
    const totalConDesc = Math.max(totalCuenta - montoDescFinal, 0);
    $("#totalConDescuento").val(totalConDesc.toFixed(2));

    window.recalcularPagoPacienteConDescuento();
};

window.limpiarDescuento = function () {
    $("#porcentajeDescuento").val("");
    $("#montoDescuento").val("");
    $("#totalConDescuento").val("");
    window.recalcularPagoPacienteConDescuento();
};

window.recalcularPagoPacienteConDescuento = function () {
    const totalCuenta = parseFloat($("#totalDeLaCuenta").val()) || 0;
    const montoDesc = parseFloat($("#montoDescuento").val()) || 0;

    const totalConDescuento = Math.max(totalCuenta - montoDesc, 0);

    const pagoPaciente = totalConDescuento;

    $("#pagoPaciente").val(pagoPaciente.toFixed(2));

    if (typeof cuentaPagarVm !== "undefined") {
        cuentaPagarVm.actualizarTotales();
    }
};



