            function inicializarTotales() {
    const saldoRealBD = parseFloat($("#Valor").val()) || 0;
    
    document.getElementById("totalDeLaCuenta").value = saldoRealBD.toFixed(2);
    
    actualizarTotalAseguradora();
    cuentaPagarVm.actualizarTotales();
}

function actualizarTotalCuenta() {

    let totalBrutoActual = productos.reduce((total, producto) => {
        return total + calcularSubtotalProducto(producto);
    }, 0);

    // Sumar honorarios (siempre van al total)
    let totalHonorarios = 0;
    if (typeof cuentaPagarVm !== 'undefined' && cuentaPagarVm.honorariosLista) {
        totalHonorarios = cuentaPagarVm.honorariosLista().reduce((total, item) => {
            return total + (parseFloat(item.Monto) || 0);
        }, 0);
    }

    // Sumar paquetes y ambulancias (no excluibles, precio fijo)
    let totalNoExcluibles = 0;
    document.querySelectorAll("#productos-body tr").forEach(row => {
        const btn = row.querySelector("button.btn-secondary");
        if (btn && btn.disabled) {
            const celdaSubtotal = row.querySelector(".celda-subtotal");
            if (celdaSubtotal) {
                totalNoExcluibles += parseFloat(
                    celdaSubtotal.textContent.replace("Q","").trim()
                ) || 0;
            }
        }
    });

    totalBrutoActual += totalHonorarios;

    const diferencia = TOTAL_BRUTO_ORIGINAL - totalBrutoActual;

    const saldoAjustado = Math.max(SALDO_BASE_BD - diferencia, 0);

    console.log("[actualizarTotalCuenta]", {
        SALDO_BASE_BD,
        TOTAL_BRUTO_ORIGINAL,
        totalBrutoActual,
        totalHonorarios,
        diferencia,
        saldoAjustado
    });

    // 4. Actualizar el campo visible
    document.getElementById("totalDeLaCuenta").value = saldoAjustado.toFixed(2);

    actualizarTotalAseguradora();
}

            // [NUEVO]: Exponer la función al contexto global para que el ViewModel de Knockout pueda acceder a ella
            window.actualizarTotalCuenta = actualizarTotalCuenta;


           function actualizarTotalAseguradora() {
    const totalCuenta = parseFloat(document.getElementById("totalDeLaCuenta").value) || 0;
    const totalNoElegibles = parseFloat(document.getElementById("totalNoElegibles").value) || 0;

    // Aseguradora solo cubre hasta el saldo pendiente
    const totalAseguradora = Math.max(totalCuenta - totalNoElegibles, 0);
    document.getElementById("totalAseguradora").value = totalAseguradora.toFixed(2);

    actualizarCoaseguro();
}

            function actualizarCoaseguro() {
                let porcentajeCoaseguro = parseFloat(document.getElementById("porcentajeCoaseguro").value) || 0;
                let totalAseguradora = parseFloat(document.getElementById("totalAseguradora").value) || 0;

                let coaseguro = (porcentajeCoaseguro / 100) * totalAseguradora;
                document.getElementById("valorCoaseguro").value = coaseguro.toFixed(2);
                actualizarPagoPaciente(); // Se actualiza el pago del paciente después del coaseguro
                cuentaPagarVm.actualizarTotales();
            }

            function actualizarPagoSeguro() {
                let totalAseguradora = parseFloat(document.getElementById("totalAseguradora").value) || 0;
                let pagoPaciente = parseFloat(document.getElementById("pagoPaciente").value) || 0;

                let pagoSeguro = Math.max(totalAseguradora - pagoPaciente, 0);
                document.getElementById("pagoSeguro").value = pagoSeguro.toFixed(2);
                cuentaPagarVm.actualizarTotales();
            }

            document.getElementById("totalAseguradora").addEventListener("input", actualizarPagoSeguro);
            document.getElementById("pagoPaciente").addEventListener("input", actualizarPagoSeguro);

            document.getElementById("porcentajeCoaseguro").addEventListener("input", actualizarCoaseguro);
            document.getElementById("totalAseguradora").addEventListener("input", actualizarCoaseguro);

            function actualizarTablaExclusiones() {
                let tbody = document.getElementById("exclusiones-body");
                tbody.innerHTML = "";
                let totalExclusiones = 0;

                exclusiones.forEach((exclusion, index) => {
                    let subtotal = exclusion.cantidad * exclusion.precioUnitario;
                    totalExclusiones += subtotal;

                    let row = document.createElement("tr");
                    row.innerHTML = `
                                                                <td>${exclusion.nombre}</td>
                                                                <td>${exclusion.cantidad}</td>
                                                                <td>Q ${exclusion.precioUnitario.toFixed(2)}</td>
                                                                <td>Q ${subtotal.toFixed(2)}</td>
                                                                <td>
                                                                    <button class="btn btn-success btn-sm reintegrar-producto" data-index="${index}">
                                                                        Reintegrar
                                                                    </button>
                                                                </td>
                                                            `;
                    tbody.appendChild(row);
                });

                document.getElementById("totalNoElegibles").value = totalExclusiones.toFixed(2);
            }

            document.getElementById("totalNoElegibles").addEventListener("input", actualizarTotalAseguradora);
            document.getElementById("totalDeLaCuenta").addEventListener("input", actualizarTotalAseguradora);

function actualizarPagoPaciente() {
    const totalCuenta = parseFloat(document.getElementById("totalDeLaCuenta").value) || 0;
    const montoDesc = parseFloat($("#montoDescuento").val()) || 0;
    const totalConDesc = Math.max(totalCuenta - montoDesc, 0);

    const deducible = parseFloat(document.getElementById("totalDeducibles").value) || 0;
    const coaseguro = parseFloat(document.getElementById("valorCoaseguro").value) || 0;
    const copago = parseFloat(document.getElementById("valorCopago").value) || 0;
    const iva = parseFloat(document.getElementById("valorIVA").value) || 0;

    let pagoPaciente = totalConDesc + deducible + coaseguro + copago + iva;
    pagoPaciente = Math.max(pagoPaciente, 0);

    document.getElementById("pagoPaciente").value = pagoPaciente.toFixed(2);
    actualizarPagoSeguro();
}

            document.getElementById("totalNoElegibles").addEventListener("input", actualizarPagoPaciente);
            document.getElementById("totalDeducibles").addEventListener("input", actualizarPagoPaciente);
            document.getElementById("valorCoaseguro").addEventListener("input", actualizarPagoPaciente);
            document.getElementById("valorCopago").addEventListener("input", actualizarPagoPaciente);
