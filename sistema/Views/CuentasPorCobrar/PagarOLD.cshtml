@model sistema.Models.CuentasPorCobrarPagarViewModel;
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    // Leer el valor del appsettings.json. 
    string sufijoLayout = Configuration["Cliente"]; 
    
    // Concatenar para formar el nombre del Layout (ejemplo: "_Layout" + "SS")
    // Si la clave trae el nombre completo (ej. "_LayoutSS"), simplemente asignalo directo.
    Layout = $"_Layout{sufijoLayout}"; 
    
    ViewData["Title"] = "Pagar cuenta";
}
@Html.HiddenFor(c => c.CuentaId)
@Html.HiddenFor(c => c.PacienteId)
@Html.HiddenFor(c => c.ResponsableNit)
@Html.HiddenFor(c => c.ResponsableNombre)
@Html.HiddenFor(c => c.ResponsableDireccion)
@Html.HiddenFor(c => c.ResponsableCorreo)

@await Html.PartialAsync("_MensajeExito")





<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12 text-center">
                <h4><b>Pagar cuenta</b></h4>
            </div>
        </div>
    </div>
</div>

<div style="display: none" id="info-paciente-estado-cuenta">
    <h5><b>Información del Paciente</b></h5>
    <div class="datos-paciente">
        <p><strong>Nombre:</strong> <span data-paciente="nombre">@Model.PacienteNombre</span></p>
        <p><strong>Teléfono:</strong> <span data-paciente="telefono">@Model.PacienteTelefono</span></p>
        <p><strong>Celular:</strong> <span data-paciente="celular">@Model.PacienteCelular</span></p>
        <p><strong>Dirección:</strong> <span data-paciente="direccion">@Model.PacienteDireccion</span></p>
        <p><strong>NIT:</strong> <span data-paciente="nit">@Model.PacienteNit</span></p>
        <p><strong>DPI:</strong> <span data-paciente="dpi">@Model.PacienteDpi</span></p>
        <p><strong>Fecha Nacimiento:</strong> <span
                data-paciente="fechaNacimiento">@Model.PacienteFechaNacimiento</span></p>
        <p><strong>Edad:</strong> <span data-paciente="edad">@Model.PacienteEdad</span></p>
        <p><strong>Sexo:</strong> <span data-paciente="sexo">@Model.PacienteSexo</span></p>
    </div>

    <h5><b>Información de Hospitalización</b></h5>
    <div class="datos-hospitalizacion">
        <p><strong>Fecha de Inicio de Hospitalización:</strong> <span
                data-hospitalizacion="fechaInicio">@Model.FechaInicioHops</span></p>
        <p><strong>Médico Responsable:</strong> <span data-hospitalizacion="medicoResponsable">@Model.MedicoHops</span>
        </p>
        <p><strong>Nombre del Seguro:</strong> <span data-hospitalizacion="nombreSeguro">@Model.NombreDelSeguro</span>
        </p>
    </div>
</div>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <div id="tabs-datos-cuenta">
                    <ul>
                        <li><a href="#tab-paciente">General</a></li>
                        @* <li><a href="#tab-hospitalizaciones">Hospitalizaciones</a></li> *@
                        <li><a href="#tab-productos">Detalles</a></li> <!-- Se renombró a "Productos" -->
                        @* <li><a href="#tab-general">General</a></li> *@
                    </ul>
                    @* Toda esta info del paciente debe ir en Estado de Cuenta *@
                    <div id="tab-paciente">
                        <div class="form-row">
                            <div class="col-md-12">
                                <button class="btn btn-primary" data-bind="click:verInformacionPaciente">
                                    <i class="fas fa-external-link-alt"></i>&nbsp;
                                    Ver informaci&oacute;n del paciente
                                </button>
                                <br /><br />
                            </div>
                            <div class="col-md-3">
                                @Html.HiddenFor(m => m.PacienteNombre)
                                <b>Nombre del responsable</b><br />
                                @Model.ResponsableNombre
                            </div>
                            <div class="col-md-3">
                                @Html.HiddenFor(m => m.PacienteNit)
                                <b>Nit/Dpi del responsable</b><br />
                                @Model.ResponsableNit
                            </div>
                            <div class="col-md-3">
                                <b>Direcci&oacute;n del responsable</b><br />
                                @Model.ResponsableDireccion
                            </div>
                            <div class="col-md-3">
                                <b>Correo del responsable</b><br />
                                @Model.ResponsableCorreo
                            </div>
                        </div>
                    </div>
                    @* <div id="tab-hospitalizaciones">
                        <div class="form-row">
                            <div class="col-md-12">
                                Hospitalizaciones
                            </div>
                        </div>
                    </div> *@


                    <div id="tab-productos" class="container-fluid p-0">
                        @* Esta info de la habitacion debe ir dentro de estado de cuenta *@
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0 text-primary font-weight-bold">Datos de la Habitación</h5>
                            </div>
                            <div class="card-body">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <div class="row">
                                            <div class="col-md-3 mb-2">
                                                @* <p><b>ID:</b> @Model.Habitacion?.Id</p> *@
                                                <label class="font-weight-bolder mb-0">Número</label>
                                                <div class="font-weight-bold">@Model.Habitacion?.NombreHabitacion</div>
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label class="font-weight-bolder mb-0">Categoría</label>
                                                <div class="font-weight-bold">
                                                    @Model.Habitacion?.NombreCategoriaHabitacion</div>
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label class="font-weight-bolder mb-0">Tarifa</label>
                                                <div class="font-weight-bold text-success">Q
                                                    @Model.Habitacion?.CostoTotal</div>
                                            </div>
                                            <div class="col-md-3 mb-2">
                                                <label class="font-weight-bolder mb-0">Seguro</label>
                                                <div class="font-weight-bold">@Model.SeguroNombre</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <input type="hidden" id="NumeroHabitacion" value="@Model.Habitacion?.NombreHabitacion" />
                        <input type="hidden" id="CategoriaHabitacion"
                            value="@Model.Habitacion?.NombreCategoriaHabitacion" />
                        <input type="hidden" id="TarifaHabitacion" value="@Model.Habitacion?.CostoTotal" />

                        @* FIX: evitar ID duplicado con @Html.HiddenFor(m => m.PacienteNombre) *@
                        <input type="hidden" id="PacienteNombreAdmision" value="@Model.PacienteNombreAdmision" />

                        <input type="hidden" id="AdmisionId" value="@Model.AdmisionId" />
        @{
            // IDs de los productos que son exámenes (para marcarlos con 100% descuento por defecto)
            var idsExamenes = Model.Productos?
                .Where(p => {
                    var prop = p.GetType().GetProperty("EsExamen");
                    return prop != null && (bool)(prop.GetValue(p) ?? false);
                })
                .Select(p => p.Id)
                .ToList() ?? new System.Collections.Generic.List<int>();
        }
        <script>
            window._idsExamenes = [@Html.Raw(string.Join(",", idsExamenes))];
        </script>

                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-white">
                                <h5 class="mb-0 font-weight-bold">Detalle de Cargos</h5>
                            </div>
                            <div class="card-body p-0">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        @* Esta es la tabla que se usa para crear el Estado de Cuenta *@
                                        <table class="table table-hover" style="display: none;">
                                            <thead>
                                                <tr>
                                                    <th>Fecha</th>
                                                    <th>Item</th>
                                                    <th>Tipo de Item</th>
                                                    <th>Cantidad</th>
                                                    <th>Precio Unitario</th>
                                                    <th>Subtotal</th>
                                                    <th>Acción</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @if (Model.Productos?.Count > 0)
                                                {
                                                    @foreach (var producto in Model.Productos)
                                                    {
                                                        <tr>
                                                            <td>@producto.FechaAplicacion</td>
                                                            <td>@producto.Nombre</td>
                                                            <td>@producto.Tipo</td>
                                                            <td>@producto.Cantidad</td>
                                                            <td>Q @producto.PrecioUnitario</td>
                                                            <td>Q @producto.Subtotal</td>

                                                            <td>
                                                                <button class="btn btn-warning btn-sm excluir-producto"
                                                                    data-nombre="@producto.Nombre"
                                                                    data-cantidad="@producto.Cantidad"
                                                                    data-precio="@producto.PrecioUnitario">
                                                                    Excluir
                                                                </button>
                                                            </td>
                                                            <td style="display: none;">@producto.Tipo</td>

                                                        </tr>
                                                    }
                                                }
                                                else
                                                {
                                                    <tr>
                                                        <td colspan="5" class="text-center">No hay productos aplicados
                                                            registrados.
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>

                                        <div class="table-responsive">
                                            <table class="table table-hover table-bordered mb-0">
                                                <thead class="thead-light">
                                                    <tr>
                                                        <th>Rubro</th>
                                                        <th>Item</th>
                                                        <th>Cantidad</th>
                                                        <th>Precio Unitario</th>
                                                        <th>Subtotal</th>
                                                        <th style="min-width:180px">Desc% / Cargo</th>
                                                        <th>Acción</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="productos-body">
                                                    @if (Model.Paquetes?.Count > 0)
                                                    {
                                                        @foreach (var paquete in Model.Paquetes)
                                                        {
                                                            <tr data-esexamen="false" data-descpct="0">
                                                                <td>@paquete.Tipo</td>
                                                                <td>@paquete.Nombre</td>
                                                                <td>1</td>
                                                                <td>Q @paquete.Precio</td>
                                                                <td class="celda-subtotal">Q @paquete.Precio</td>
                                                                <td></td>
                                                                <td>
                                                                    <button class="btn btn-secondary btn-sm" disabled>
                                                                        No excluible
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                    @if (Model.Ambulancias?.Count > 0)
                                                    {
                                                        @foreach (var amb in Model.Ambulancias)
                                                        {
                                                            <tr data-esexamen="false" data-descpct="0">
                                                                <td>Ambulancia</td>
                                                                <td>Ambulancia - @amb.TipoTraslado</td>
                                                                <td>1</td>
                                                                <td>Q @amb.Precio</td>
                                                                <td class="celda-subtotal">Q @amb.Precio</td>
                                                                <td></td>
                                                                <td>
                                                                    <button class="btn btn-secondary btn-sm" disabled>
                                                                        No excluible
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }


                                                    @if (Model.Productos?.Count > 0)
                                                    {
                                                        @foreach (var producto in Model.Productos)
                                                        {
                                                            @* EsExamen se detecta en JS por data-tipo; aquí marcamos con data-tipo *@
                                                            <tr data-tipo="@producto.Tipo" data-descpct="0">
                                                                <td>@producto.Tipo</td>
                                                                <td>@producto.Nombre</td>
                                                                <td>@producto.Cantidad</td>
                                                                <td>Q @producto.PrecioUnitario</td>
                                                                <td class="celda-subtotal">Q @producto.Subtotal</td>
                                                                <td></td>
                                                                <td>
                                                                    <button class="btn btn-warning btn-sm excluir-producto"
                                                                        data-nombre="@producto.Nombre"
                                                                        data-cantidad="@producto.Cantidad"
                                                                        data-precio="@producto.PrecioUnitario">
                                                                        Excluir
                                                                    </button>
                                                                </td>
                                                            </tr>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <tr>
                                                            <td colspan="6" class="text-center py-3">No hay productos
                                                                aplicados registrados.
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                                @{
                                                    decimal totalPaquetes = Math.Round(Model.Paquetes?.Sum(p => p.Precio) ??
                                                    0m, 2);
                                                    decimal totalAmbulancias = Math.Round(Model.Ambulancias?.Sum(a =>
                                                    a.Precio) ?? 0m, 2);
                                                    decimal totalProductos = Math.Round(Model.Productos?.Sum(p =>
                                                    p.Subtotal) ?? 0m, 2);

                                                    decimal totalTabla = Math.Round(totalPaquetes + totalAmbulancias +
                                                    totalProductos, 2);
                                                }
                                                <tfoot>
                                                    <tr>
                                                        <th colspan="4" class="text-right">Total:</th>
                                                        <th colspan="3">Q @totalTabla.ToString("N2")</th>
                                                    </tr>
                                                </tfoot>
                                            </table>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mb-4 border-warning">
                            <div class="card-header bg-warning text-dark">
                                <h5 class="mb-0 font-weight-bold">Exclusiones</h5>
                            </div>
                            <div class="card-body p-0">
                                <div class="form-row">
                                    <div class="col-md-12">
                                        <div class="form-row">
                                            <div class="col-md-12">
                                                @* Esta data de los excluidos tambien debe ir en estado de cuenta *@
                                                <div class="table-responsive">
                                                    <table class="table table-hover mb-0" id="tabla-exclusiones">
                                                        <thead class="thead-light">
                                                            <tr>
                                                                <th>Item</th>
                                                                <th>Cantidad</th>
                                                                <th>Precio Unitario</th>
                                                                <th>Subtotal</th>
                                                                <th>Acción</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="exclusiones-body">
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                        @* <p><b>Total Exclusiones: </b><span id="total-exclusiones">Q 0.00</span></p> *@

                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-info text-white">
                                <h5 class="mb-0 font-weight-bold">Honorarios Médicos</h5>
                            </div>
                            <div class="card-body">
                                <div class="form-row align-items-end mb-3">
                                    <div class="col-md-6">
                                        <label>Médico</label>
                                        @Html.DropDownList("DoctorId", Model.DoctoresSelectListItem, "-- Seleccione médico --", 
                                            new { @class = "form-control", data_bind = "value: medicoSeleccionado" })
                                    </div>
                                    <div class="col-md-4">
                                        <label>Monto</label>
                                        <input type="number" class="form-control" data-bind="value: montoHonorarioNuevo" placeholder="0.00" />
                                    </div>
                                    <div class="col-md-2">
                                        <button type="button" class="btn btn-primary btn-block" data-bind="click: agregarHonorarioBD">
                                            <i class="fa fa-plus"></i> Agregar
                                        </button>
                                    </div>
                                </div>

                                <table class="table table-sm table-striped" id="tabla-honorarios">
                                    <thead>
                                        <tr>
                                            <th>Médico</th>
                                            <th class="text-right">Monto</th>
                                            <th class="text-center">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody data-bind="foreach: honorariosLista">
                                        <tr>
                                            <td data-bind="text: NombreMedico"></td>
                                            <td class="text-right">Q <span data-bind="text: Monto.toFixed(2)"></span></td>
                                            <td class="text-center">
                                                <button type="button" class="btn btn-danger btn-sm" data-bind="click: $parent.eliminarHonorarioBD">
                                                    <i class="fa fa-trash"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>


                    <div id="tab-general" style="display: none;">
                        <div class="form-row">
                            <div class="col-md-12">
                                @Html.HiddenFor(m => m.Valor)
                                <label><b>Valor</b></label><br />
                                @Model.Valor
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="col-md-12">
                                <label><b>Observaciones</b></label><br />
                                @Model.Observaciones
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

