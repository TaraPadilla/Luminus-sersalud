            @* document.getElementById("tabla-honorarios").addEventListener("input", function (event) {
                if (event.target.classList.contains("honorario-medico")) {
                    actualizarTotalCuenta();
                }
            }); *@

            cargarProductosIniciales();

            document.getElementById("exclusiones-body").addEventListener("click", function (event) {
                if (event.target.classList.contains("reintegrar-producto")) {
                    let index = event.target.getAttribute("data-index");
                    let producto = exclusiones.splice(index, 1)[0];

                    // Restaurar su precio unitario original
                    producto.precioUnitario = producto.precioOriginal;

                    productos.push(producto);
                    actualizarTablaProductos();
                    actualizarTablaExclusiones();
                    actualizarPagoPaciente();

                    cuentaPagarVm.actualizarTotales();
                }
            });

            cargarProductosIniciales();
        });

        // Función para obtener el precio del seguro desde el servidor
        async function obtenerPrecioPorSeguro(tipo, nombreProducto, seguroNombre) {
            try {
                let response = await fetch(`/Precios/ObtenerPrecioPorSeguro?tipo=${encodeURIComponent(tipo)}&nombre=${encodeURIComponent(nombreProducto)}&seguro=${encodeURIComponent(seguroNombre)}`);
                let data = await response.json();

                if (data.exitoso && data.precio) {
                    return parseFloat(data.precio);
                } else {
                    alert(`No se encontró precio para ${nombreProducto} con el seguro ${seguroNombre}. No se puede excluir.`);
                    return null; // No permite la exclusión
                }
            } catch (error) {
                console.error("Error al obtener el precio del seguro:", error);
                return null;
            }
        }
