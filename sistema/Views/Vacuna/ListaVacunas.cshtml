<div class="tab-pane tabs-animation fade show active" id="tab-content-0" role="tabpanel">
    <div class="main-card mb-3 card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="mb-0 table table-hover ">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Nombre</th>
                            <th>Preparación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.nombreVacunas)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Nombre</td>
                                <td>@item.Preparacion</td>
                                
                                <td>
                                     <a href="@Url.Action("ModificarVacuna","Vacuna", new {id = @item.Id})"
                                       class="btn btn-warning btn-sm">
                                        <i class="fa fa-edit"></i>
                                    </a> 
                                    <a asp-action="EliminarVacuna" asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm"
                                       onclick="return confirm('¿Está seguro/a que desea eliminar este registro?');">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </td>  

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

 @{
    var prevDisabled = !Model.nombreVacunas.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.nombreVacunas.HasNextPage ? "disabled" : "";
} 



<a asp-action="ListaExamenes" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@(Model.nombreVacunas.PageIndex - 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-danger btn-sm @prevDisabled">
    Anterior
</a>
<a asp-action="ListaExamenes" asp-route-sortOrder="@ViewData["CurrentSort"]" asp-route-pageNumber="@(Model.nombreVacunas.PageIndex + 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]" class="btn btn-danger btn-sm @nextDisabled" class="">
    Siguiente
</a>