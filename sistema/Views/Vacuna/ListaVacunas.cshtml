@{
    ViewData["Title"] = "Lista Vacunas";
    var todayDate = DateTime.Now;
}


@await Html.PartialAsync("_MensajeExito")

 <div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <center><h4><b>Vacunas</b></h4></center>
                <hr />
                <a class="btn btn-danger btn-sm" asp-action="CrearVacuna"
                   asp-controller="Vacuna">
                    <i class="fa fa-plus"></i>&nbsp;
                    Nueva Vacuna
                </a>
            </div>
        </div>
    </div>
</div>


