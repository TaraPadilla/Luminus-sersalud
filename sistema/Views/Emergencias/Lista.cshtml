@using sistema.Models
@model EmergenciasListaVM
@{
    ViewData["Title"] = "Emergencias - " + ViewData["Estado"];
    var urlGenerarVenta = Url.Action("GenerarVenta", "Consultas", new { id = 0 });
}

@Html.HiddenFor(a => a.Ingresadas)

<div class="main-card mb-card card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-8 col-md-10">
                <h4 class="mb-0"><b>Emergencias - @ViewData["Estado"]</b></h4>
            </div>
            <div class="col-4 col-md-2 text-right">
                <a href="/Emergencias/Nueva" class="btn btn-primary btn-sm btn-block-mobile">
                    <i class="fas fa-plus d-md-none"></i>
                    <span class="d-none d-md-inline">Nueva</span>
                </a>
            </div>
        </div>
    </div>
</div>

<br />

<div class="main-card mb-card card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12 text-primary" id="texto-cargando-emergencias" style="display:none">
                Cargando emergencias...
            </div>
            <div class="col-md-12 text-danger" id="texto-error-cargando-emergencias" style="display:none">
                Error al consultar emergencias.
                <a href="#" data-bind="click:consultarEmergencias">Reintentar</a>
            </div>
            <div class="col-md-12 table-responsive">
                <table class="table table-hover" id="tabla-emergencias">
                    <thead>
                        <tr>
                            <th style="width: 60px;">No.</th>
                            <th style="min-width: 120px;">Fecha</th>
                            <th style="min-width: 150px;">Paciente</th>
                            <th style="width: 100px;">Total</th>
                            @if(!Model.Ingresadas){
                                <th style="width: 90px;" class="text-center">Estado</th>
                            }
                            @if (!Model.Ingresadas)
                            {
                                <th style="min-width: 100px;" class="text-center">Acciones</th>
                            }
                            <th style="width: 60px;" class="text-center">Det</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!--ko foreach:emergencias-->
                        <tr>
                            <td class="font-weight-bold align-middle" data-bind="text:EmergenciaId"></td>
                            <td class="align-middle" data-bind="text:EmergenciasFechaRegistro"></td>
                            <td class="align-middle" data-bind="text:PacienteNombre"></td>
                            <td class="text-right align-middle">
                                Q <span data-bind="text:EmergenciaValorTotal"></span>
                            </td>
                            @if(!Model.Ingresadas){
                                <td class="text-center align-middle">
                                    <span class="badge badge-mobile" data-bind="text: Pagado ? 'PAG' : 'PEN', 
                                        css: { 'badge-success': Pagado, 'badge-danger': !Pagado }">
                                    </span>
                                    <span class="badge badge-full d-none d-sm-inline-block" data-bind="text: Pagado ? 'PAGADO' : 'PENDIENTE', 
                                        css: { 'badge-success': Pagado, 'badge-danger': !Pagado }">
                                    </span>
                                </td>
                            }
                            @if (!Model.Ingresadas)
                            {
                                <td class="text-center align-middle">
                                    <div class="btn-group btn-group-mobile" role="group">
                                        <a class="btn btn-warning btn-sm" 
                                               data-bind="attr:{href:'/Emergencias/Editar?emergenciaId='+EmergenciaId}, visible: !Pagado"
                                               title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>

                                        <a class="btn btn-primary btn-sm" 
                                               data-bind="attr:{href:'/Venta/NuevaVentaUnificada?isEmergencia=true&emergenciaId='+EmergenciaId}, 
                                            visible: !Pagado"
                                               title="Venta">
                                            <i class="fas fa-store"></i>
                                        </a>
                                    </div>
                                </td>
                            }
                            <td class="text-center align-middle">
                                <a class="btn btn-sm btn-info-mobile" 
                                       data-bind="attr:{href:'/Emergencias/Detalles?emergenciaId='+EmergenciaId}"
                                       title="Detalles">
                                    <i class="fas fa-eye"></i>
                                </a>
                            </td>
                        </tr>
                        <!--/ko-->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/ViewModelKo/EmergenciasListaVM.js"></script>
}

<style>
    /* Estilos base */
    #tabla-emergencias thead th {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
        font-size: 0.9rem;
        padding: 12px 8px;
        vertical-align: middle;
        white-space: nowrap;
    }
    
    #tabla-emergencias tbody td {
        padding: 8px 6px;
        vertical-align: middle;
    }
    
    /* Estilos para badges en móvil */
    .badge-mobile {
        display: inline-block;
        padding: 5px 8px;
        border-radius: 4px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .badge-full {
        display: none;
    }
    
    .badge-success {
        background-color: #28a745;
        color: white;
    }
    
    .badge-danger {
        background-color: #dc3545;
        color: white;
    }
    
    /* Grupo de botones responsive */
    .btn-group-mobile {
        display: inline-flex;
        gap: 3px;
    }
    
    .btn-group-mobile .btn {
        padding: 0.25rem 0.4rem;
        font-size: 0.75rem;
        line-height: 1.2;
        border-radius: 3px;
        min-width: 28px;
    }
    
    /* Botón de detalle responsive */
    .btn-info-mobile {
        background-color: #17a2b8;
        border-color: #17a2b8;
        color: white;
        padding: 0.25rem 0.4rem;
        font-size: 0.75rem;
        line-height: 1.2;
        border-radius: 3px;
        min-width: 28px;
    }
    
    .btn-info-mobile:hover {
        background-color: #138496;
        border-color: #117a8b;
        color: white;
    }
    
    /* Botón Nueva responsive */
    .btn-block-mobile {
        width: auto;
    }
    
    /* Mensajes de carga y error */
    #texto-cargando-emergencias, #texto-error-cargando-emergencias {
        padding: 10px;
        margin-bottom: 10px;
        border-radius: 4px;
        text-align: center;
    }
    
    #texto-cargando-emergencias {
        background-color: #e7f3ff;
        border: 1px solid #b8daff;
    }
    
    #texto-error-cargando-emergencias {
        background-color: #f8d7da;
        border: 1px solid #f5c6cb;
    }
    
    /* Media queries para responsive */
    @@media (max-width: 576px) {
        #tabla-emergencias thead th {
            font-size: 0.8rem;
            padding: 8px 4px;
        }
        
        #tabla-emergencias tbody td {
            padding: 6px 4px;
            font-size: 0.85rem;
        }
        
        .badge-mobile {
            display: inline-block;
            font-size: 0.7rem;
            padding: 3px 6px;
        }
        
        .badge-full {
            display: none;
        }
        
        .btn-group-mobile .btn {
            padding: 0.2rem 0.3rem;
            font-size: 0.7rem;
            min-width: 24px;
        }
        
        .btn-info-mobile {
            padding: 0.2rem 0.3rem;
            font-size: 0.7rem;
            min-width: 24px;
        }
        
        .btn-block-mobile {
            width: 100%;
            padding: 0.25rem 0.5rem;
            font-size: 0.85rem;
        }
    }
    
    @@media (min-width: 577px) {
        .badge-mobile {
            display: none;
        }
        
        .badge-full {
            display: inline-block;
            padding: 5px 10px;
            border-radius: 4px;
            font-size: 0.85rem;
        }
    }
    
    /* Para pantallas muy pequeñas */
    @@media (max-width: 400px) {
        .btn-group-mobile .btn {
            padding: 0.15rem 0.25rem;
            font-size: 0.65rem;
            min-width: 22px;
        }
        
        .btn-info-mobile {
            padding: 0.15rem 0.25rem;
            font-size: 0.65rem;
            min-width: 22px;
        }
        
        #tabla-emergencias thead th {
            font-size: 0.7rem;
            white-space: nowrap;
        }
        
        #tabla-emergencias tbody td {
            font-size: 0.75rem;
        }
    }
</style>