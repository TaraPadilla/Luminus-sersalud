<div title="Registrar nuevo paciente" style="display:none" id="mdl-nuevo-paciente">
    <div class="form-row mt-2">
        <div class="col-md-12 mb-2">
            <div class="alert alert-info">
                <i class="fas fa-info-circle"></i>
                El paciente ingresado no existe en el sistema. Complete los datos para registrarlo.
            </div>
        </div>
        <div class="col-md-6">
            <label><b>Nombre completo <span class="text-danger">*</span></b></label>
            <input type="text" class="form-control" id="nuevo-paciente-nombre" placeholder="Nombre completo" />
        </div>
        <div class="col-md-6">
            <label><b>NIT</b></label>
            <input type="text" class="form-control" id="nuevo-paciente-nit" placeholder="NIT" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Dirección</b></label>
            <input type="text" class="form-control" id="nuevo-paciente-direccion" placeholder="Dirección" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Teléfono</b></label>
            <input type="text" class="form-control" id="nuevo-paciente-telefono" placeholder="Teléfono" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Fecha de nacimiento</b></label>
            <input type="date" class="form-control" id="nuevo-paciente-fecha-nacimiento" />
        </div>
        <div class="col-md-6 mt-2">
            <label><b>Género</b></label>
            <select class="form-control" id="nuevo-paciente-genero">
                <option value="">-- Seleccione --</option>
                <option value="M">Masculino</option>
                <option value="F">Femenino</option>
            </select>
        </div>
        <div class="col-md-12 mt-2" id="mdl-nuevo-paciente-error" style="display:none">
            <div class="alert alert-danger" id="mdl-nuevo-paciente-error-msg"></div>
        </div>
    </div>
</div>

