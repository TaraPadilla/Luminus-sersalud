<script src="~/js/voicetotext/voicetotext.js"></script>
<script>
    window.voiceToTextFields = ['Observaciones'];
</script>

<div class="main-card mb-3 card">
    <div class="card-body">
        <div class="form-row">
            <div class="col-md-12">
                <div id="tabs-venta">
                    <ul>
                        <li><a href="#tab-encabezado">Encabezado</a></li>
                        <li><a href="#tab-detalles"><i class="fas fa-file-invoice"></i> Detalles</a></li>
                        <li><a href="#tab-hospitalizacion"><i class="fas fa-hospital"></i> Hospitalizaci&oacute;n</a></li>
                        <li><a href="#tab-observaciones"> Observaciones</a></li>
                    </ul>
                    <div id="tab-encabezado">
                        <div class="main-card mb-3 card">
                            <div class="card-body">
                                <div class="main-card mb-3 card">
                                    <div class="card-body">
                                        <div class="form-row">
                                            <div class="col-md-4">
                                                <b>Sucursal</b>
                                                <select class="form-control select-emergencia" readonly
                                                        asp-for="SucursalId"
                                                        asp-items="Model.ListaSucursales">
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <b>C&oacute;digo de empleado</b>
                                                @Html.TextBoxFor(m => m.CodigoVendedor,
                                                         new
                                                         {
                                                             @class = "form-control dato-emergencia",
                                                             @placeholder = "Codigo de empleado",
                                                             @readonly = "readonly"
                                                         })
                                            </div>

                                            <div class="col-md-4">
                                                <b>Responsable</b>
                                                @Html.TextBoxFor(m => m.Responsable,
                                                         new { @class = "form-control dato-emergencia", @placeholder = "Responsable" })
                                            </div>
                                            <div class="col-md-4">
                                                <b>Paciente</b>
                                                <select class="form-control select2bs4 select-emergencia" style="width: 100%;"
                                                        data-bind="options:pacientesExistentes
                                                            ,optionsText:'Nombre'
                                                            ,value:pacienteSeleccionado">
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <b>NIT</b>
                                                @Html.TextBoxFor(m => m.PacienteNit,
                                                         new { @class = "form-control dato-emergencia", @placeholder = "NIT" })
                                            </div>
                                            <div class="col-md-4">
                                                <b>Direccion</b>
                                                @Html.TextBoxFor(m => m.PacienteDireccion,
                                                         new { @class = "form-control dato-emergencia", @placeholder = "Direccion" })
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="tab-detalles">
                        <!--Productos-->
                        @if (Model.HabilitarEdicion)
                        {
                            <div class="form-row">
                                <div class="col-md-12 seccion-header" id="productos-header">
                                    <b>AGREGAR PRODUCTOS</b>
                                </div>
                                <div class="col-md-12 form-row seccion-body" id="productos-body">
                                    <div class="col-md-12 text-primary" id="texto-cargando-productos-existentes" style="display:none">
                                        Cargando productos...
                                    </div>
                                    <div class="col-md-12 text-danger" id="texto-error-cargando-productos-existentes" style="display:none">
                                        Error al consultar productos.
                                        <a href="#" data-bind="click:consultarProductosExistentes">Reintentar</a>
                                    </div>
                                    <div class="col-md-12 form-row">
                                        <div class="col-md-12 form-row">
                                            <div class="col-md-12">
                                                <br />
                                            </div>
                                            <div class="col-md-1">
                                                <label class="text-white">Refresh</label>
                                                <button class="btn btn-primary" data-bind="click: consultarProductosExistentes">
                                                    <i class="fas fa-redo-alt"></i>
                                                </button>
                                            </div>
                                            <div class="col-md-6">
                                                <label>Seleccionar producto:</label>
                                                <select class="form-control select2bs4 " data-bind="options:productosExistentes,
                                                                                                                        optionsText: 'ProductoNombreMostrar',
                                                                                                            value: productoSeleccionado" style="width: 100%;">
                                                </select>
                                            </div>
                                            <div class="col-md-2">
                                                <label>Seleccionar unidad:</label>
                                                <select class="form-control"
                                                        data-bind="options: unidadesVentaProducto,
                                                                                            optionsText: 'UnidadMedidaVentaNombre',
                                                                                                    value: unidadVentaSeleccionadaProducto"></select>
                                            </div>
                                            <div class="col-md-2">
                                                <label>Seleccionar precio:</label>
                                                <select class="form-control"
                                                        data-bind="options: preciosProducto,
                                                                            optionsText: 'Precio',
                                                                                value: precioSeleccionadoProducto"></select>
                                            </div>
                                            <div class="col-md-1">
                                                <label class="text-white">Agregar</label>
                                                <button class="btn btn-primary" data-bind="click: agregarProducto">
                                                    <i class="fas fa-plus"></i>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <hr />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }



