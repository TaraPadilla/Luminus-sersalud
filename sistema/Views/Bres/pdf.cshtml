@{
    Layout = "";
    ViewData["Title"] = "BRES PDF";
}

<style>
    .bres-pdf {
        font-family: Arial, sans-serif;
        color: #000;
        box-sizing: border-box;
    }

    .bres-header {
        text-align: center;
        margin-bottom: 6px;
        line-height: 1.2;
    }

    .bres-header .title {
        font-weight: bold;
        font-size: 12px;
        text-transform: uppercase;
    }

    .bres-header .subtitle {
        font-weight: bold;
        font-size: 11px;
        text-transform: uppercase;
    }

    .bres-meta {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 6px;
        table-layout: fixed;
        font-size: 9px;
    }

    .bres-meta td {
        padding: 2px 4px;
        vertical-align: top;
    }

    .bres-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .bres-table th,
    .bres-table td {
        border: 1px solid #000;
        padding: 2px 2px;
        font-size: 6.5px;
        vertical-align: middle;
        word-wrap: break-word;
        overflow-wrap: break-word;
    }

    .bres-table th {
        font-weight: bold;
        text-align: center;
        background: #e6e6e6;
    }

    .text-right { text-align: right; }
    .text-center { text-align: center; }
    .nowrap { white-space: nowrap; }

    /* Anchos aproximados (afinamos luego 1:1) */
    .w-no { width: 18px; }
    .w-fin { width: 42px; }
    .w-min { width: 58px; }
    .w-ind { width: 36px; }
    .w-act { width: 44px; }
    .w-desc { width: 170px; }
    .w-descm { width: 100px; }
    .w-med { width: 46px; }
    .w-num { width: 44px; }
    .w-pre { width: 52px; }
    .w-tot { width: 55px; }
    .w-obs { width: 90px; }
</style>

